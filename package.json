{
  "name": "achi-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "backend:dev": "npm run start:dev --prefix backend",
    "backend:build": "npm run build --prefix backend",
    "db:generate": "npm run db:generate --prefix backend",
    "db:migrate": "npm run db:migrate --prefix backend",
    "db:studio": "npm run db:studio --prefix backend",
    "frontend:dev": "npm run dev --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "gen:api": "npm run gen:api --prefix frontend",
    "lint": "npm run lint --prefix frontend && npm run lint --prefix backend",
    "check": "npm run check --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
