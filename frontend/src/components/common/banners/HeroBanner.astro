---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  imageUrl: string;
  ctaText: string;
  ctaLink: string;
}

const { title, subtitle, description, imageUrl, ctaText, ctaLink } = Astro.props;
---
<section class="w-full relative h-[100vh] bg-[#1A1A1A] flex items-center text-white overflow-hidden">
  <div class="hero-banner-image absolute inset-0 bg-cover bg-center opacity-70" style={`background-image: url('${imageUrl}');`}></div>
  <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
  
  <div class="hero-banner-content relative w-full max-w-[1440px] mx-auto px-6 pt-24 flex flex-col justify-center items-start h-full">
    <span class="hero-subtitle text-xs uppercase tracking-[0.3em] text-gray-300 font-light mb-4 block">{subtitle}</span>
    <h1 class="hero-title font-serif text-5xl sm:text-8xl tracking-tight leading-none mb-4 uppercase" set:html={title} />
    <p class="hero-description font-sans text-xs sm:text-sm max-w-[500px] tracking-widest font-light mb-10 text-gray-300 uppercase leading-relaxed">
      {description}
    </p>
    
    <a href={ctaLink} class="hero-cta border border-white hover:bg-white hover:text-brand-charcoal text-white px-10 py-3.5 text-xs uppercase tracking-widest font-medium transition-all duration-300 rounded-sm">
      {ctaText}
    </a>
  </div>
</section>
