---
import Layout from '../layouts/Layout.astro';
---

<Layout title="TERMS & CONDITIONS | ACHI Studio" description="ACHI's website usage terms and order cancellation conditions.">
  <div class="max-w-[800px] mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h1 class="font-serif text-4xl tracking-widest uppercase text-brand-charcoal">TERMS & CONDITIONS</h1>
      <p class="text-[10px] tracking-[0.2em] uppercase text-gray-400 mt-2 font-light">Terms of service and purchasing rules</p>
    </div>

    <div class="space-y-6 text-sm font-light text-gray-600 leading-relaxed">
      <p>
        Welcome to the ACHI e-commerce store. By accessing our site and purchasing our clothing collections, you agree to comply with the terms below.
      </p>

      <h3 class="font-serif text-base uppercase tracking-wider text-brand-charcoal font-medium mt-8 mb-4">Orders & Stock</h3>
      <p>
        Stock quantities are updated dynamically. If an item becomes unavailable after payment validation due to a system lag, we will contact you immediately to process a full refund or swap items.
      </p>

      <h3 class="font-serif text-base uppercase tracking-wider text-brand-charcoal font-medium mt-8 mb-4">Intellectual Property</h3>
      <p>
        All site templates, typography layout, campaign photography assets, and logos are properties of ACHI Studio.
      </p>
    </div>
  </div>
</Layout>
