---
import Layout from '../layouts/Layout.astro';
---

<Layout title="RETURN & REFUNDS | ACHI Studio" description="Steps to initiate returns and process refunds.">
  <div class="max-w-[800px] mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h1 class="font-serif text-4xl tracking-widest uppercase text-brand-charcoal">REFUNDS</h1>
      <p class="text-[10px] tracking-[0.2em] uppercase text-gray-400 mt-2 font-light">Return and Refund Operations</p>
    </div>

    <div class="space-y-8 text-sm font-light text-gray-600 leading-relaxed">
      <p>
        Refunds are processed promptly after our quality control team receives and inspects the returned merchandise.
      </p>

      <h3 class="font-serif text-base uppercase tracking-wider text-brand-charcoal font-medium mt-8 mb-4">Refund Methods</h3>
      <p>
        Refunds will be processed back to your original payment method:
      </p>
      <ul class="list-disc list-inside space-y-2 text-xs text-gray-500 pl-4">
        <li><strong>Credit Card:</strong> 7-15 billing days (depending on your bank card issuer).</li>
        <li><strong>Bank Transfer / PromptPay:</strong> 2-3 business days.</li>
      </ul>
    </div>
  </div>
</Layout>
