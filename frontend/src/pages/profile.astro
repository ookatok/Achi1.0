---
import Layout from '../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';
import { useTranslations } from '../lib/translations';

const session = await getSession(Astro.request);
const token = (session as any)?.accessToken;

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

if (!token) {
  return Astro.redirect(`/${lang}/auth/signin?callbackUrl=${encodeURIComponent(`/${lang}/profile`)}`);
}

const t = useTranslations(lang);

const role = (session?.user as any)?.role || 'customer';
let orders = [] as any[];
let errorMsg = null;

if (role === 'customer') {
  try {
    const res = await fetch('http://localhost:3001/api/orders', {
      headers: {
        'Authorization': `Bearer ${token}`
      }
    });

    if (res.ok) {
      orders = await res.json();
    }
  } catch (err) {
    console.error('[NestJS API Error] Fetching orders failed.', err);
    errorMsg = lang === 'en' ? 'Could not load orders history. Backend server may be offline.' : 'ไม่สามารถโหลดประวัติการสั่งซื้อได้ เนื่องจากเซิร์ฟเวอร์ออฟไลน์';
  }
}
---

<Layout 
  title={lang === 'en' ? "Your Account | ACHI Studio" : "บัญชีของคุณ | ACHI Studio"} 
  description={lang === 'en' ? "Manage your ACHI customer profile and track orders." : "จัดการประวัติข้อมูลโปรไฟล์ลูกค้าของ ACHI และติดตามคำสั่งซื้อสินค้า"}
>
  <!-- Top Minimalist Banner -->
  <section class="bg-stone-50 border-b border-stone-200/60 py-16">
    <div class="max-w-[1200px] mx-auto px-6 flex flex-col sm:flex-row justify-between items-center gap-6">
      <div>
        <h1 class="font-serif text-3xl tracking-widest text-brand-charcoal uppercase leading-tight">
          {lang === 'en' ? "Welcome" : "ยินดีต้อนรับ"}, {session?.user?.name}
        </h1>
        <p class="text-[10px] tracking-[0.2em] uppercase text-stone-400 mt-1 font-light">
          ACHI Premium {role === 'admin' ? (lang === 'en' ? 'Administrator' : 'ผู้ดูแลระบบ') : (lang === 'en' ? 'Member' : 'สมาชิก')}
        </p>
      </div>
      <div>
        <a href="/products" class="border border-brand-charcoal text-brand-charcoal hover:bg-brand-charcoal hover:text-white px-8 py-3 rounded-full text-[10px] uppercase tracking-widest font-semibold transition-all duration-300">
          {lang === 'en' ? "Continue Shopping" : "ช้อปปิ้งต่อ"}
        </a>
      </div>
    </div>
  </section>

  <div id="profile-container" data-token={token} class="max-w-[1200px] mx-auto px-6 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16 items-start">
      
      <!-- Left Column: Member Card -->
      <div class="lg:col-span-1 bg-white border border-stone-200/80 p-8 rounded-sm shadow-sm relative overflow-hidden flex flex-col justify-between aspect-[1.586/1] md:aspect-auto">
        <!-- Background Pattern -->
        <div class="absolute -right-12 -top-12 w-36 h-36 rounded-full bg-stone-50 pointer-events-none select-none opacity-50 border border-stone-200/50"></div>
        
        <div class="space-y-6 relative z-10">
          <div class="flex items-center justify-between">
            <div class="w-10 h-10 rounded-full bg-brand-charcoal text-white font-serif flex items-center justify-center text-sm font-semibold select-none">
              {session?.user?.name ? session.user.name.substring(0, 2).toUpperCase() : 'AC'}
            </div>
            <span class="text-[9px] tracking-[0.3em] font-medium text-brand-gold uppercase bg-amber-50/50 border border-brand-gold/20 px-2.5 py-0.5 rounded-full">
              {role === 'admin' ? (lang === 'en' ? 'Admin' : 'แอดมิน') : (lang === 'en' ? 'Member' : 'สมาชิก')}
            </span>
          </div>

          <div class="space-y-4">
            <div>
              <span class="block text-[9px] uppercase tracking-widest text-stone-400 font-semibold mb-1">
                {lang === 'en' ? "Name" : "ชื่อ"}
              </span>
              <span class="text-sm font-serif font-semibold text-brand-charcoal">{session?.user?.name}</span>
            </div>
            
            <div>
              <span class="block text-[9px] uppercase tracking-widest text-stone-400 font-semibold mb-1">
                {lang === 'en' ? "Email Account" : "บัญชีอีเมล"}
              </span>
              <span class="text-xs font-light text-stone-500">{session?.user?.email}</span>
            </div>
          </div>
        </div>

        <div class="border-t border-stone-100 pt-6 mt-8 relative z-10">
          <button
            id="signout-btn"
            class="w-full border border-stone-300 text-stone-600 hover:border-brand-charcoal hover:text-brand-charcoal py-3 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer"
          >
            {t('nav.signout')}
          </button>
        </div>
      </div>

      <!-- Right Column: Profile Form and Details -->
      <div class="lg:col-span-2 space-y-12">
        <!-- Profile Update Form -->
        <div class="bg-white border border-stone-200/80 p-8 rounded-sm shadow-sm space-y-6">
          <div class="pb-2 border-b border-stone-100">
            <h2 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium">
              {lang === 'en' ? "Manage Profile Settings" : "การจัดการข้อมูลโปรไฟล์"}
            </h2>
          </div>

          <form id="profile-edit-form" class="space-y-6">
            <div>
              <label class="block text-[10px] uppercase tracking-widest text-stone-400 font-semibold mb-1">
                {lang === 'en' ? "Full Name" : "ชื่อ-นามสกุล"}
              </label>
              <input 
                type="text" 
                id="profile-name" 
                value={session?.user?.name || ''} 
                required 
                class="w-full border border-stone-200 px-3 py-2.5 text-xs focus:outline-none focus:border-brand-charcoal rounded-sm bg-white" 
              />
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-[10px] uppercase tracking-widest text-stone-400 font-semibold mb-1">
                  {lang === 'en' ? "New Password (leave blank to keep current)" : "รหัสผ่านใหม่ (ปล่อยว่างหากต้องการใช้รหัสผ่านเดิม)"}
                </label>
                <input 
                  type="password" 
                  id="profile-password" 
                  class="w-full border border-stone-200 px-3 py-2.5 text-xs focus:outline-none focus:border-brand-charcoal rounded-sm bg-white" 
                />
              </div>
              <div>
                <label class="block text-[10px] uppercase tracking-widest text-stone-400 font-semibold mb-1">
                  {lang === 'en' ? "Confirm New Password" : "ยืนยันรหัสผ่านใหม่"}
                </label>
                <input 
                  type="password" 
                  id="profile-confirm-password" 
                  class="w-full border border-stone-200 px-3 py-2.5 text-xs focus:outline-none focus:border-brand-charcoal rounded-sm bg-white" 
                />
              </div>
            </div>

            <button 
              type="submit" 
              class="bg-brand-charcoal text-white hover:bg-stone-800 px-8 py-3 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer"
            >
              {lang === 'en' ? "Save Profile Changes" : "บันทึกการเปลี่ยนแปลงโปรไฟล์"}
            </button>
          </form>
        </div>

        {role === 'admin' ? (
          <div class="bg-stone-50 border border-stone-200/80 p-8 rounded-sm shadow-sm space-y-4">
            <h3 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium pb-2 border-b border-stone-200">
              {lang === 'en' ? "Admin Dashboard Access" : "การเข้าถึงแดชบอร์ดแอดมิน"}
            </h3>
            <p class="text-[11px] text-stone-500 font-light leading-relaxed">
              {lang === 'en'
                ? "As an Administrator, you have full access to management tools including catalog additions, order tracking, categories configuration, and blogging engine."
                : "ในฐานะผู้ดูแลระบบ คุณมีสิทธิ์เข้าถึงเครื่องมือการจัดการอย่างเต็มรูปแบบ รวมถึงการเพิ่มรายการสินค้า การติดตามสินค้า คอนฟิกหมวดหมู่ และเครื่องมือบล็อกโพสต์"
              }
            </p>
            <div class="pt-2">
              <a href="/admin" class="inline-block bg-brand-charcoal text-white hover:bg-stone-800 px-8 py-3 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300">
                {lang === 'en' ? "Go to Admin Panel" : "ไปยังระบบควบคุมผู้ดูแลระบบ"}
              </a>
            </div>
          </div>
        ) : (
          <div class="space-y-8">
            <div class="flex items-center justify-between pb-4 border-b border-stone-200/80">
              <h2 class="font-serif text-lg uppercase tracking-wider text-brand-charcoal font-semibold">
                {lang === 'en' ? "Order History Logs" : "ประวัติรายการสั่งซื้อสินค้า"}
              </h2>
              <span class="text-[10px] uppercase tracking-widest text-stone-400 font-light font-sans">
                {lang === 'en' ? `${orders.length} Orders Total` : `คำสั่งซื้อทั้งหมด ${orders.length} รายการ`}
              </span>
            </div>

            {errorMsg && (
              <div class="text-xs text-red-500 font-light bg-red-50 p-4 border-l-2 border-red-500 rounded-sm">
                {errorMsg}
              </div>
            )}

            {orders.length === 0 ? (
              <div class="text-center py-20 border border-dashed border-stone-200 text-stone-400 text-xs font-light rounded-sm bg-stone-50/30">
                {lang === 'en' ? "No orders found under this account." : "ไม่พบประวัติคำสั่งซื้อภายใต้บัญชีใช้งานนี้"}
              </div>
            ) : (
              <div class="space-y-6">
                {orders.map((order: any) => (
                  <div class="border border-stone-200/80 p-6 rounded-sm bg-white hover:border-brand-gold transition-colors duration-300 space-y-6">
                    <!-- Order Card Header -->
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                      <div>
                        <span class="font-mono text-xs font-semibold tracking-wider text-brand-charcoal block uppercase">
                          ACHI-ORD-{String(order.id).padStart(5, '0')}
                        </span>
                        <span class="text-[9px] text-stone-400 font-light block uppercase mt-1 tracking-wider">
                          {lang === 'en' ? "Placed:" : "สั่งซื้อเมื่อ:"} {new Date(order.createdAt).toLocaleDateString(lang === 'en' ? 'en-US' : 'th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}
                        </span>
                      </div>
                      
                      <div class="flex items-center gap-4">
                        <div class="text-right">
                          <span class="text-xs text-stone-400 uppercase tracking-widest font-light block">
                            {lang === 'en' ? "Total" : "ยอดเงินรวมทั้งสิ้น"}
                          </span>
                          <span class="font-semibold text-brand-charcoal text-sm">${Number(order.totalPrice).toLocaleString(undefined, { minimumFractionDigits: 2 })}</span>
                        </div>
                        
                        <span class={`text-[9px] uppercase tracking-widest px-3 py-1 rounded-full border font-semibold inline-block ${
                          order.status === 'pending' 
                            ? 'text-amber-600 bg-amber-50/50 border-amber-200/60' 
                            : 'text-green-600 bg-green-50/50 border-green-200/60'
                        }`}>
                          {order.status === 'pending' 
                            ? (lang === 'en' ? 'pending' : 'รอดำเนินการ') 
                            : (lang === 'en' ? 'completed' : 'เสร็จสมบูรณ์')
                          }
                        </span>
                      </div>
                    </div>

                    <!-- Order Shipping Details -->
                    <div class="bg-stone-50 p-4 rounded-sm border border-stone-100 flex flex-col sm:flex-row justify-between gap-4 text-xs font-light text-stone-500">
                      <div>
                        <span class="block text-[9px] uppercase tracking-widest text-stone-400 font-semibold mb-1">
                          {lang === 'en' ? "Shipping Address" : "ที่อยู่สำหรับจัดส่งพัสดุ"}
                        </span>
                        <span class="text-xs text-stone-600 leading-relaxed block">{order.shippingAddress}</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        )}
      </div>

    </div>
  </div>

  <script>
    import { signOut } from 'auth-astro/client';
    
    // Sign out logic
    const signoutBtn = document.getElementById('signout-btn');
    if (signoutBtn) {
      signoutBtn.addEventListener('click', () => {
        signOut({ callbackUrl: '/' } as any);
      });
    }

    // Profile update form logic
    const profileForm = document.getElementById('profile-edit-form');
    
    if (profileForm) {
      profileForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const isEn = document.documentElement.lang === 'en';
        
        const nameInput = document.getElementById('profile-name') as HTMLInputElement | null;
        const passwordInput = document.getElementById('profile-password') as HTMLInputElement | null;
        const confirmPasswordInput = document.getElementById('profile-confirm-password') as HTMLInputElement | null;
        
        const name = nameInput?.value;
        const password = passwordInput?.value;
        const confirmPassword = confirmPasswordInput?.value;
        
        if (password && password !== confirmPassword) {
          window.showStatusAlert(
            400,
            isEn ? 'Passwords do not match.' : 'รหัสผ่านไม่ตรงกัน',
            null,
            false
          );
          return;
        }
        
        const container = document.getElementById('profile-container');
        const token = container?.getAttribute('data-token');
        
        try {
          const res = await fetch('http://localhost:3001/api/users/profile', {
            method: 'PATCH',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
              name,
              ...(password ? { password } : {})
            })
          });
          
          if (res.ok) {
            window.showStatusAlert(
              200,
              isEn 
                ? 'Profile updated successfully. Please re-sign in for changes to reflect in your header name.'
                : 'อัปเดตข้อมูลบัญชีเสร็จสมบูรณ์ กรุณาเข้าสู่ระบบใหม่อีกครั้งเพื่อให้ชื่อแสดงผลถูกต้องที่แถบเมนูด้านบน',
              null,
              true
            );
            if (passwordInput) passwordInput.value = '';
            if (confirmPasswordInput) confirmPasswordInput.value = '';
          } else {
            const err = await res.json();
            window.showStatusAlert(
              res.status,
              null,
              err ? err.message : (isEn ? 'Failed to update profile.' : 'อัปเดตโปรไฟล์ล้มเหลว')
            );
          }
        } catch (err) {
          console.error(err);
          window.showStatusAlert(
            0,
            null,
            isEn ? 'Backend server error or network issue.' : 'ระบบเกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์'
          );
        }
      });
    }
  </script>
</Layout>
