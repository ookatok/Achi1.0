---
import Layout from '../../../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

const session = await getSession(Astro.request);
const token = (session as any)?.accessToken;

if (!token) {
  return Astro.redirect(`/${lang}/auth/signin?callbackUrl=/${lang}/admin`);
}

if ((session?.user as any)?.role !== 'admin') {
  return new Response('Forbidden: Admin access only.', { status: 403 });
}

const id = Astro.url.searchParams.get('id');
if (!id) {
  return Astro.redirect(`/${lang}/admin?tab=products&subtab=new-arrivals`);
}

let pendingOrdersCount = 0;
let products = [] as any[];
let activeCollection = null as any;

try {
  // Fetch orders count
  const ordRes = await fetch('http://localhost:3001/api/orders', {
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });
  if (ordRes.ok) {
    const orders = await ordRes.json();
    pendingOrdersCount = orders.filter((o: any) => o.status === 'pending').length;
  }

  // Fetch active products
  const prodRes = await fetch('http://localhost:3001/api/products');
  if (prodRes.ok) {
    products = await prodRes.json();
  }

  // Fetch specific collection
  const colRes = await fetch(`http://localhost:3001/api/collections/${id}`);
  if (colRes.ok) {
    activeCollection = await colRes.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching admin data failed.', err);
}

if (!activeCollection) {
  return Astro.redirect(`/${lang}/admin?tab=products&subtab=new-arrivals`);
}

const activeProducts = products.filter((p: any) => p.status !== 'inactive');
const associatedProductIds = activeCollection.products ? activeCollection.products.map((p: any) => p.id) : [];

const resolveImage = (url: string) => {
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http') || url.startsWith('data:')) return url;
  if (url.startsWith('/')) return url;
  if (url.startsWith('assets/')) return '/' + url;
  return url;
};

const resolveAdminImage = (url: string) => {
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http') || url.startsWith('data:')) return url;
  if (url.startsWith('/')) return `http://localhost:3001${url}`;
  return url;
};

let secondModelImageUrl = '';
let thirdModelImageUrl = '';
if (activeCollection && activeCollection.galleryImages) {
  try {
    const gallery = JSON.parse(activeCollection.galleryImages);
    if (Array.isArray(gallery)) {
      if (gallery.length > 0) secondModelImageUrl = gallery[0];
      if (gallery.length > 1) thirdModelImageUrl = gallery[1];
    }
  } catch (e) {
    secondModelImageUrl = activeCollection.galleryImages;
  }
}
