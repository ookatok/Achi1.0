  <script>
    const form = document.getElementById('edit-arrival-set-form');
    const container = document.getElementById('set-editor-container');
    const token = container?.getAttribute('data-token');
    const lang = container?.getAttribute('data-lang') || 'en';
    const id = container?.getAttribute('data-id');

    // Setup file upload handlers for 4 slots (cover, 1, 2, 3)
    const uploadStatus = document.getElementById('new-arrival-upload-status');
    const isEn = lang === 'en';

    const setupUploader = (index: string | number) => {
      const fileInput = document.getElementById(`new-arrival-file-${index}`) as HTMLInputElement | null;
      const btn = document.getElementById(`new-arrival-upload-btn-${index}`);
      const preview = document.getElementById(`new-arrival-preview-${index}`) as HTMLImageElement | null;
      const urlInput = document.getElementById(`new-arrival-url-${index}`) as HTMLInputElement | null;

      if (btn && fileInput) {
        btn.addEventListener('click', () => {
          fileInput.click();
        });

        const uploadArea = document.getElementById(`new-arrival-upload-area-${index}`);
        if (uploadArea) {
          uploadArea.addEventListener('click', () => {
            fileInput.click();
          });
        }

        fileInput.addEventListener('change', async (e: any) => {
          const file = e.target.files[0];
          if (!file) return;

          const label = index === 'cover' ? (isEn ? 'Cover Image' : 'รูปปก') : (isEn ? `Model Image ${index}` : `รูปนายแบบที่ ${index}`);

          if (uploadStatus) {
            uploadStatus.textContent = isEn ? `Uploading ${label}...` : `กำลังอัปโหลด${label}...`;
            uploadStatus.classList.remove('hidden');
          }

          const formData = new FormData();
          formData.append('file', file);

          try {
            const res = await fetch('http://localhost:3001/api/collections/upload', {
              method: 'POST',
              headers: {
                'Authorization': `Bearer ${token}`
              },
              body: formData
            });

            if (res.ok) {
              const data = await res.json();
              if (preview) {
                preview.src = `http://localhost:3001${data.imageUrl}`;
              }
              if (urlInput) {
                urlInput.value = data.imageUrl;
              }
              if (uploadStatus) {
                uploadStatus.textContent = isEn ? `${label} uploaded successfully!` : `อัปโหลด${label}สำเร็จ!`;
              }
            } else {
              if (uploadStatus) {
                uploadStatus.textContent = isEn ? `Upload failed for ${label}.` : `อัปโหลด${label}ล้มเหลว`;
              }
            }
          } catch (err) {
            console.error(err);
            if (uploadStatus) {
              uploadStatus.textContent = isEn ? 'Network error.' : 'เกิดข้อผิดพลาดในการเชื่อมต่อ';
            }
          }
        });
      }
    };

    ['cover', 1, 2, 3].forEach(setupUploader);

    // Form Submission
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const title = (document.getElementById('set-title-input') as HTMLInputElement).value.trim();
      const discountPercent = parseInt((document.getElementById('set-discount-input') as HTMLInputElement).value, 10) || 0;
      const coverUrl = (document.getElementById('new-arrival-url-cover') as HTMLInputElement)?.value || '';
      const url1 = (document.getElementById('new-arrival-url-1') as HTMLInputElement)?.value || '';
      const url2 = (document.getElementById('new-arrival-url-2') as HTMLInputElement)?.value || '';
      const url3 = (document.getElementById('new-arrival-url-3') as HTMLInputElement)?.value || '';

      const checkedCheckboxes = document.querySelectorAll('input[name="new-arrival-products"]:checked') as NodeListOf<HTMLInputElement>;
      const productIds = Array.from(checkedCheckboxes).map((cb) => parseInt(cb.value, 10));

      if (!coverUrl) {
        window.showStatusAlert(400, null, isEn ? 'Please upload a cover image.' : 'กรุณาอัปโหลดภาพปกของเซ็ต');
        return;
      }

      const saveSetBtn = document.getElementById('save-set-btn') as HTMLButtonElement | null;
      if (saveSetBtn) {
        saveSetBtn.disabled = true;
        saveSetBtn.textContent = isEn ? 'Saving...' : 'กำลังบันทึก...';
      }

      const isVisible = (document.getElementById('set-visibility-input') as HTMLInputElement).checked;
      const showOnHome = (document.getElementById('set-show-on-home-input') as HTMLInputElement).checked;

      const galleryArray = [url2, url3].filter(Boolean);
      const galleryImages = galleryArray.length > 0 ? JSON.stringify(galleryArray) : null;

      const payload = {
        title,
        discountPercent,
        imageUrl: coverUrl,
        storyImageUrl: url1 || null,
        galleryImages,
        productIds,
        isVisible,
        showOnHome
      };

      try {
        const res = await fetch(`http://localhost:3001/api/collections/${id}`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        });

        if (res.ok) {
          window.showStatusAlert(
            200,
            isEn ? 'New Arrival Set updated successfully!' : 'แก้ไขเซ็ตสินค้ามาใหม่เรียบร้อยแล้ว!',
            null,
            true,
            () => {
              window.location.href = `/${lang}/admin?tab=products&subtab=new-arrivals`;
            }
          );
        } else {
          const data = await res.json();
          window.showStatusAlert(res.status, null, data ? data.message : (isEn ? 'Failed to update set.' : 'แก้ไขเซ็ตไม่สำเร็จ'));
          if (saveSetBtn) {
            saveSetBtn.disabled = false;
            saveSetBtn.textContent = isEn ? 'Save Changes' : 'บันทึกการแก้ไข';
          }
        }
      } catch (err) {
        console.error(err);
        window.showStatusAlert(0, isEn ? 'Connection error.' : 'เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์');
        if (saveSetBtn) {
          saveSetBtn.disabled = false;
          saveSetBtn.textContent = isEn ? 'Save Changes' : 'บันทึกการแก้ไข';
        }
      }
    });
  </script>
</Layout>
