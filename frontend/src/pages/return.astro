---
import Layout from '../layouts/Layout.astro';
---

<Layout title="UNCONDITIONAL RETURN | ACHI Studio" description="14 days unconditional return policy details.">
  <div class="max-w-[800px] mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h1 class="font-serif text-4xl tracking-widest uppercase text-brand-charcoal">RETURNS</h1>
      <p class="text-[10px] tracking-[0.2em] uppercase text-gray-400 mt-2 font-light">14-Days Unconditional Return Policy</p>
    </div>

    <div class="space-y-8 text-sm font-light text-gray-600 leading-relaxed">
      <p>
        At ACHI, we stand by the quality of our clothing. If you are not completely satisfied with your purchase, you may return the items unconditionally within 14 days of delivery.
      </p>

      <h3 class="font-serif text-base uppercase tracking-wider text-brand-charcoal font-medium mt-8 mb-4">Return Conditions</h3>
      <ul class="list-disc list-inside space-y-2 text-xs text-gray-500 pl-4">
        <li>Items must be unworn, unwashed, and undamaged.</li>
        <li>Original hangtags, packaging, and invoices must be returned together.</li>
        <li>Return shipping must be booked via our official courier partners.</li>
      </ul>
    </div>
  </div>
</Layout>
