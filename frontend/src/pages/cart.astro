---
import Layout from '../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';
import { useTranslations, translateProductName } from '../lib/translations';

// Fetch user session for token authorization
const session = await getSession(Astro.request);
const token = (session as any)?.accessToken;
const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';
const t = useTranslations(lang);

let cartData = { id: 0, items: [] as any[] };
let errorMsg = null;

if (token) {
  try {
    const res = await fetch('http://localhost:3001/api/cart', {
      headers: {
        'Authorization': `Bearer ${token}`
      }
    });
    
    if (res.ok) {
      cartData = await res.json();
    } else {
      errorMsg = lang === 'en' ? 'Could not load cart details. Please try again.' : 'ไม่สามารถโหลดข้อมูลตะกร้าสินค้าได้ กรุณาลองใหม่อีกครั้ง';
    }
  } catch (err) {
    console.error(err);
    errorMsg = lang === 'en' ? 'Network error: Backend server is not running.' : 'เกิดข้อผิดพลาดในการเชื่อมต่อเครือข่าย: เซิร์ฟเวอร์แบ็คเอนด์ไม่ได้ทำงานอยู่';
  }
}

// Compute cart totals
const subtotal = cartData.items.reduce((sum: number, item: any) => sum + (Number(item.productPrice) * item.quantity), 0);
const cartTotal = subtotal; // Modify if taxes/shipping applies
---

<Layout 
  title={lang === 'en' ? "Cart | ACHI Studio" : "ตะกร้าสินค้า | ACHI Studio"} 
  description={lang === 'en' ? "Review your selected items and checkout." : "ตรวจสอบสินค้าที่คุณเลือกและดำเนินการชำระเงิน"}
>
  <div class="max-w-[1440px] mx-auto px-6 py-16">
    {/* Page Title */}
    <div class="text-center mb-16">
      <h1 class="font-serif text-3xl tracking-widest font-bold uppercase text-brand-charcoal">
        {lang === 'en' ? "Your Cart" : "ตะกร้าสินค้าของคุณ"}
      </h1>
      <p class="text-[10px] tracking-[0.2em] uppercase text-gray-400 mt-2 font-light">
        {lang === 'en' ? "Confirm selected clothing configurations" : "ยืนยันรายละเอียดเสื้อผ้าที่คุณเลือกช็อปปิ้ง"}
      </p>
    </div>

    {!token ? (
      <div class="text-center py-20 border border-dashed border-gray-200 max-w-xl mx-auto rounded-sm">
        <p class="text-gray-500 mb-6 font-light">
          {lang === 'en' ? "Please sign in to view and manage your shopping cart." : "กรุณาเข้าสู่ระบบเพื่อดูและจัดการตะกร้าสินค้าของคุณ"}
        </p>
        <a href="/auth/signin?callbackUrl=/cart" class="bg-brand-charcoal text-white hover:bg-brand-gold hover:text-brand-charcoal px-8 py-3 rounded-sm text-xs uppercase tracking-wider font-semibold transition-all">
          {t('nav.signin')}
        </a>
      </div>
    ) : errorMsg ? (
      <div class="text-center py-16 max-w-xl mx-auto text-red-500 font-light">
        {errorMsg}
      </div>
    ) : cartData.items.length === 0 ? (
      <div class="text-center py-20 border border-dashed border-gray-200 max-w-xl mx-auto rounded-sm">
        <p class="text-gray-500 mb-6 font-light">
          {lang === 'en' ? "Your shopping cart is currently empty." : "ตะกร้าสินค้าของคุณไม่มีสินค้าในขณะนี้"}
        </p>
        <a href="/products" class="bg-brand-charcoal text-white hover:bg-brand-gold hover:text-brand-charcoal px-8 py-3 rounded-sm text-xs uppercase tracking-wider font-semibold transition-all">
          {lang === 'en' ? "Go Shop" : "ไปช้อปเลย"}
        </a>
      </div>
    ) : (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        {/* Left Side: Cart Items List */}
        <div class="lg:col-span-2 space-y-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {cartData.items.map((item: any) => (
              <div class="border border-gray-200 p-6 relative flex flex-col justify-between aspect-[1/1] rounded-sm bg-white product-card-hover" id={`cart-item-${item.id}`}>
                {/* Remove button at top right of the card */}
                <button
                  class="absolute top-4 right-4 text-gray-400 hover:text-brand-charcoal focus:outline-none cursor-pointer remove-item-btn"
                  data-item-id={item.id}
                  aria-label="Remove item"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                  </svg>
                </button>

                {/* Card Top: Title */}
                <div class="text-center">
                  <h3 class="font-serif text-base font-medium text-brand-charcoal uppercase tracking-wider">
                    {translateProductName(item.productName, lang)} {item.size ? `(${item.size})` : ''}
                  </h3>
                  {item.color && (
                    <span class="text-[10px] tracking-widest text-gray-400 uppercase font-light mt-1 block">
                      {lang === 'en' ? 'Color' : 'สี'}: {item.color}
                    </span>
                  )}
                </div>

                {/* Card Center: Product Image */}
                <div class="flex-grow flex items-center justify-center my-4 overflow-hidden aspect-[4/3] relative">
                  <img
                    src={item.productImageUrl || '/assets/images/placeholder-product.png'}
                    alt={translateProductName(item.productName, lang)}
                    class="h-full object-contain mix-blend-multiply"
                  />
                </div>

                {/* Card Bottom: Quantity and Subtotal */}
                <div class="border-t border-gray-100 pt-4 flex items-center justify-between text-xs tracking-wider font-light text-gray-500 uppercase">
                  <div class="flex items-center border border-gray-200 rounded-sm bg-white overflow-hidden shadow-sm">
                    <button 
                      type="button" 
                      class="w-8 h-8 flex items-center justify-center text-gray-500 hover:text-brand-charcoal hover:bg-stone-50 transition-all cursor-pointer font-bold focus:outline-none cart-qty-minus-btn"
                      data-item-id={item.id}
                      data-current-qty={item.quantity}
                    >
                      &minus;
                    </button>
                    <input 
                      type="number" 
                      value={item.quantity} 
                      min="1" 
                      max="99" 
                      class="w-10 h-8 text-center text-xs font-semibold text-brand-charcoal focus:outline-none bg-transparent border-none outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none cart-qty-input"
                      data-item-id={item.id}
                      data-current-qty={item.quantity}
                    />
                    <button 
                      type="button" 
                      class="w-8 h-8 flex items-center justify-center text-gray-500 hover:text-brand-charcoal hover:bg-stone-50 transition-all cursor-pointer font-bold focus:outline-none cart-qty-plus-btn"
                      data-item-id={item.id}
                      data-current-qty={item.quantity}
                    >
                      &#43;
                    </button>
                  </div>
                  <div class="flex items-center gap-4">
                    <span class="text-brand-charcoal font-medium">{lang === 'en' ? 'Subtotal' : 'ยอดรวมย่อย'}</span>
                    <span class="text-brand-charcoal font-semibold">${Number(item.productPrice) * item.quantity}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Right Side: Order Summary & Checkout */}
        <div class="space-y-8">
          {/* Order Summary Block */}
          <div class="border border-gray-200 p-6 rounded-sm bg-white">
            <h2 class="font-serif text-sm uppercase tracking-widest text-center border-b border-gray-100 pb-4 mb-6 font-medium text-brand-charcoal">
              {lang === 'en' ? "Order Summary" : "สรุปใบสั่งซื้อ"}
            </h2>
            <div class="space-y-4 text-xs tracking-widest font-light text-gray-500 uppercase">
              <div class="flex justify-between">
                <span>{lang === 'en' ? "Subtotal" : "ยอดรวมย่อย"}</span>
                <span class="text-brand-charcoal font-medium">${subtotal}</span>
              </div>
              <hr class="border-gray-100" />
              <div class="flex justify-between text-sm font-medium text-brand-charcoal">
                <span>{lang === 'en' ? "Cart total" : "ยอดรวมทั้งหมด"}</span>
                <span>${cartTotal}</span>
              </div>
            </div>
          </div>

          {/* Gift Message Block */}
          <div class="border border-gray-200 p-6 rounded-sm bg-white">
            <label for="gift-message" class="block text-[11px] uppercase tracking-wider font-medium text-brand-charcoal mb-4">
              {lang === 'en' ? "Add gift message" : "เพิ่มข้อความบนการ์ดของขวัญ"}
            </label>
            <textarea
              id="gift-message"
              rows="4"
              placeholder={lang === 'en' ? "Write your custom gift message here..." : "ระบุข้อความอวยพรของคุณตรงนี้..."}
              class="w-full p-4 border border-gray-200 rounded-sm focus:border-brand-gold outline-none text-xs font-light resize-none bg-gray-50 focus:bg-white transition-all"
            ></textarea>
          </div>

          {/* Go to Checkout Button */}
          <button
            id="checkout-btn"
            class="w-full bg-brand-charcoal text-white hover:bg-brand-gold hover:text-brand-charcoal py-4 rounded-sm text-xs uppercase tracking-[0.2em] font-semibold transition-all cursor-pointer"
          >
            {lang === 'en' ? "Go to Checkout" : "ไปหน้าชำระเงิน"}
          </button>
        </div>
      </div>
    )}
  </div>

  {/* Client-side script to handle item deletion and checkout redirects */}
  <script is:inline define:vars={{ token, lang }}>
    // Setup listeners for remove buttons
    document.querySelectorAll('.remove-item-btn').forEach(button => {
      button.addEventListener('click', async () => {
        const itemId = button.getAttribute('data-item-id');
        if (!itemId || !token) return;

        const isEn = lang === 'en';
        const confirmMsg = isEn 
          ? 'Are you sure you want to remove this item from your cart?' 
          : 'คุณแน่ใจหรือไม่ว่าต้องการลบสินค้านี้ออกจากตะกร้าของคุณ?';

        if (confirm(confirmMsg)) {
          try {
            const res = await fetch(`http://localhost:3001/api/cart/item/${itemId}`, {
              method: 'DELETE',
              headers: {
                'Authorization': `Bearer ${token}`
              }
            });

            if (res.ok) {
              window.location.reload();
            } else {
              alert(isEn ? 'Failed to remove item. Please try again.' : 'ลบสินค้าล้มเหลว กรุณาลองใหม่อีกครั้ง');
            }
          } catch (err) {
            console.error(err);
            alert(isEn ? 'A network error occurred.' : 'เกิดข้อผิดพลาดในการเชื่อมต่อเครือข่าย');
          }
        }
      });
    });

    // Update quantity function helper
    const updateCartItemQuantity = async (itemId, newQty) => {
      if (!itemId || !token) return;
      const isEn = lang === 'en';
      try {
        const res = await fetch(`http://localhost:3001/api/cart/item/${itemId}`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ quantity: newQty })
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          alert(data && data.message ? data.message : (isEn ? 'Failed to update quantity.' : 'ปรับปรุงจำนวนสินค้าล้มเหลว'));
        }
      } catch (err) {
        console.error(err);
        alert(isEn ? 'A network error occurred.' : 'เกิดข้อผิดพลาดในการเชื่อมต่อเครือข่าย');
      }
    };

    // Setup listeners for cart quantity adjustment buttons
    document.querySelectorAll('.cart-qty-minus-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const itemId = btn.getAttribute('data-item-id');
        const currentQty = parseInt(btn.getAttribute('data-current-qty'), 10) || 1;
        if (currentQty > 1) {
          await updateCartItemQuantity(itemId, currentQty - 1);
        }
      });
    });

    document.querySelectorAll('.cart-qty-plus-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const itemId = btn.getAttribute('data-item-id');
        const currentQty = parseInt(btn.getAttribute('data-current-qty'), 10) || 1;
        await updateCartItemQuantity(itemId, currentQty + 1);
      });
    });

    document.querySelectorAll('.cart-qty-input').forEach(input => {
      input.addEventListener('change', async () => {
        const itemId = input.getAttribute('data-item-id');
        const originalQty = parseInt(input.getAttribute('data-current-qty'), 10) || 1;
        let newQty = parseInt(input.value, 10);
        if (isNaN(newQty) || newQty < 1) {
          input.value = originalQty;
          return;
        }
        if (newQty !== originalQty) {
          await updateCartItemQuantity(itemId, newQty);
        }
      });
    });

    // Handle checkout button click
    const checkoutBtn = document.getElementById('checkout-btn');
    if (checkoutBtn) {
      checkoutBtn.addEventListener('click', () => {
        window.location.href = '/checkout';
      });
    }
  </script>
</Layout>
