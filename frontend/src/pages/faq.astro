---
import Layout from '../layouts/Layout.astro';
const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

let faqs = [] as any[];
try {
  const res = await fetch('http://localhost:3001/api/faqs');
  if (res.ok) {
    faqs = await res.json();
    faqs.sort((a: any, b: any) => (a.order || 0) - (b.order || 0));
  }
} catch (e) {
  console.error('[NestJS API Error] Fetching public FAQs failed.', e);
}
---

<Layout 
  title={lang === 'en' ? "FAQ | ACHI Studio" : "คำถามที่พบบ่อย | ACHI Studio"} 
  description={lang === 'en' ? "Frequently Asked Questions about orders, shipping, and returns." : "คำถามที่พบบ่อยเกี่ยวกับการสั่งซื้อ การจัดส่ง และการคืนสินค้า"}
>
  <div class="max-w-[800px] mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h1 class="font-serif text-4xl tracking-widest uppercase text-brand-charcoal">FAQ</h1>
      <p class="text-[10px] tracking-[0.2em] uppercase text-gray-400 mt-2 font-light">
        {lang === 'en' ? "Frequently Asked Questions" : "คำถามที่พบบ่อย"}
      </p>
    </div>

    <div class="space-y-6 divide-y divide-gray-200 text-xs tracking-wider uppercase font-light text-gray-600">
      {faqs.length === 0 ? (
        <div class="text-center py-24 text-stone-400 font-light italic text-sm border border-dashed border-stone-200 rounded-sm">
          {lang === 'en' ? "Frequently Asked Questions are being prepared. Check back soon!" : "ขออภัย ขณะนี้กำลังจัดเตรียมข้อมูลคำถามที่พบบ่อย โปรดติดตามเร็วๆ นี้!"}
        </div>
      ) : (
        faqs.map((faq, index) => (
          <div class={`py-6 ${index === 0 ? 'first:pt-0' : ''}`}>
            <details class="group cursor-pointer">
              <summary class="flex justify-between items-center focus:outline-none select-none text-left">
                <span>
                  {lang === 'en' ? faq.questionEn : faq.questionTh}
                </span>
                <span class="transition-transform duration-300 group-open:rotate-180">▼</span>
              </summary>
              <div class="mt-4 text-gray-500 font-light normal-case tracking-normal leading-relaxed pl-2 whitespace-pre-line">
                {lang === 'en' ? faq.answerEn : faq.answerTh}
              </div>
            </details>
          </div>
        ))
      )}
    </div>
  </div>
</Layout>

