---
import Layout from '../layouts/Layout.astro';
---

<Layout title="DELIVERY INFORMATION | ACHI Studio" description="Standard and express shipping rates and delivery times.">
  <div class="max-w-[800px] mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h1 class="font-serif text-4xl tracking-widest uppercase text-brand-charcoal">DELIVERY</h1>
      <p class="text-[10px] tracking-[0.2em] uppercase text-gray-400 mt-2 font-light">Shipping Policy and Delivery Information</p>
    </div>

    <div class="space-y-8 text-sm font-light text-gray-600 leading-relaxed">
      <p>
        ACHI provides shipping services all across Thailand. Orders are shipped from our Bangkok distribution center within 24 hours of payment validation.
      </p>

      <h3 class="font-serif text-base uppercase tracking-wider text-brand-charcoal font-medium mt-8 mb-4">Standard Delivery</h3>
      <ul class="list-disc list-inside space-y-2 text-xs text-gray-500 pl-4">
        <li><strong>Cost:</strong> Free on all orders.</li>
        <li><strong>Bangkok & Perimeter:</strong> 2 - 4 business days.</li>
        <li><strong>Other Provinces:</strong> 3 - 5 business days.</li>
      </ul>

      <h3 class="font-serif text-base uppercase tracking-wider text-brand-charcoal font-medium mt-8 mb-4">Tracking Your Order</h3>
      <p>
        Once your order has been dispatched, you will receive a tracking link via email or SMS. You can also view the dispatch status in your <a href="/profile" class="underline hover:text-brand-gold">user profile</a>.
      </p>
    </div>
  </div>
</Layout>
