---
import Layout from '../layouts/Layout.astro';
---

<Layout title="COOKIE SETTINGS | ACHI Studio" description="Manage cookie preferences for standard shopping carts and user sessions.">
  <div class="max-w-[800px] mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h1 class="font-serif text-4xl tracking-widest uppercase text-brand-charcoal">COOKIES</h1>
      <p class="text-[10px] tracking-[0.2em] uppercase text-gray-400 mt-2 font-light">Cookie Preferences & Settings</p>
    </div>

    <div class="space-y-6 text-sm font-light text-gray-600 leading-relaxed">
      <p>
        We use essential cookies to maintain user authentication sessions (Auth.js) and shopping cart records.
      </p>

      <h3 class="font-serif text-base uppercase tracking-wider text-brand-charcoal font-medium mt-8 mb-4">Essential Cookies</h3>
      <p>
        These cookies are strictly necessary to allow pages (like the Checkout page or Cart page) to function. They cannot be disabled.
      </p>
    </div>
  </div>
</Layout>
