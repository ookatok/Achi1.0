---
import Layout from '../layouts/Layout.astro';
const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';
---

<Layout 
  title={lang === 'en' ? "ABOUT US | ACHI Studio" : "เกี่ยวกับเรา | ACHI Studio"} 
  description={lang === 'en' ? "Discover the minimalist design philosophy and sustainable sourcing values of ACHI." : "สำรวจปรัชญาการออกแบบมินิมอลและคุณค่าการสรรหาวัสดุที่ยั่งยืนของ ACHI"}
>
  <!-- Top Banner / Editorial Quote -->
  <section class="bg-stone-50 border-b border-stone-200/60 py-24 text-center">
    <div class="max-w-[800px] mx-auto px-6">
      <span class="text-[9px] uppercase tracking-[0.3em] text-brand-gold font-semibold mb-3 block">Est. 2026</span>
      <h1 class="motion-title font-serif text-4xl sm:text-5xl tracking-widest text-brand-charcoal uppercase leading-tight mb-6">
        {lang === 'en' ? "CHIC MINIMALISM" : "ความเรียบง่ายที่มีสไตล์"}
      </h1>
      <p class="motion-desc font-sans text-xs sm:text-sm max-w-[600px] mx-auto tracking-widest font-light text-stone-500 uppercase leading-relaxed">
        {lang === 'en' ? "Stripping away the excess to reveal the essence of premium materials and timeless silhouettes." : "การละทิ้งส่วนเกินเพื่อเผยให้เห็นความโดดเด่นของเนื้อผ้าระดับพรีเมียมและรูปทรงที่อยู่เหนือกาลเวลา"}
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <div class="max-w-[1000px] mx-auto px-6 py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <!-- Left Column: Manifesto -->
      <div class="motion-item space-y-6">
        <h2 class="font-serif text-xl uppercase tracking-wider text-brand-charcoal font-medium pb-2 border-b border-stone-200/80">
          {lang === 'en' ? "THE MANIFESTO" : "แถลงการณ์ของเรา"}
        </h2>
        <p class="text-xs text-stone-500 font-light leading-relaxed">
          {lang === 'en' 
            ? "At ACHI, we believe that true style does not shout; it whispers. We do not design for seasons; we design for longevity. Our garments are constructed to stand the test of time, both in durability and aesthetic relevance."
            : "ที่ ACHI เราเชื่อว่าสไตล์ที่แท้จริงไม่จำเป็นต้องส่งเสียงดัง แต่มันคือการกระซิบที่เรียบง่าย เราไม่ได้ออกแบบตามฤดูกาล แต่เราออกแบบมาเพื่อความยั่งยืน เสื้อผ้าของเราถูกตัดเย็บขึ้นมาเพื่อให้ยืนหยัดผ่านการทดสอบของกาลเวลา ทั้งในแง่ของความทนทานและความงดงามอย่างลงตัว"
          }
        </p>
        <p class="text-xs text-stone-500 font-light leading-relaxed">
          {lang === 'en'
            ? "We reject the hyper-cycles of fast fashion. Instead, we advocate for a curated capsule wardrobe—pieces that integrate seamlessly, wear beautifully, and bring calm functionality to everyday life."
            : "เราปฏิเสธวงจรอันรวดเร็วของฟาสต์แฟชั่น และสนับสนุนตู้เสื้อผ้าที่ได้รับการดูแลอย่างพิถีพิถัน — ชิ้นงานที่ผสมผสานกันอย่างลงตัว สวมใส่ได้อย่างสวยงาม และนำความเรียบง่ายมาสู่ชีวิตประจำวัน"
          }
        </p>
      </div>

      <!-- Right Column: Sourcing & Slogan -->
      <div class="motion-item space-y-8">
        <h2 class="font-serif text-xl uppercase tracking-wider text-brand-charcoal font-medium pb-2 border-b border-stone-200/80">
          {lang === 'en' ? "SUSTAINABLE SOURCING" : "การใช้วัสดุที่ยั่งยืน"}
        </h2>
        <p class="text-xs text-stone-500 font-light leading-relaxed">
          {lang === 'en'
            ? "Every fabric is audits for environmental trace. We source organic cotton, certified European linen, and recycled polyester blends. Our partnerships are restricted to suppliers who share our dedication to fair labor and minimal waste."
            : "ผ้าทุกผืนได้รับการตรวจสอบผลกระทบต่อสิ่งแวดล้อม เราเลือกใช้ฝ้ายออร์แกนิก ลินินยุโรปที่ได้รับการรับรอง และวัสดุโพลีเอสเตอร์รีไซเคิล โดยร่วมมือกับคู่ค้าที่คำนึงถึงความเป็นธรรมของแรงงานและลดการสร้างขยะให้เหลือน้อยที่สุด"
          }
        </p>

        <div class="border-l-2 border-brand-gold pl-6 py-1 italic font-serif text-brand-charcoal text-base">
          {lang === 'en' ? '"Minimalist High-Quality - That\'s the Way We Do Business."' : '"ความเรียบง่ายที่มีคุณภาพสูง คือวิถีการทำธุรกิจของเรา"'}
        </div>
      </div>
    </div>
  </div>
</Layout>
