---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SIZE GUIDE | ACHI Studio" description="Detailed size measurement chart for shirts, outerwear, and trousers.">
  <!-- Top Header -->
  <section class="bg-stone-50 border-b border-stone-200/60 py-16 text-center">
    <div class="max-w-[800px] mx-auto px-6">
      <h1 class="font-serif text-3xl tracking-widest text-brand-charcoal uppercase leading-tight">SIZE GUIDE</h1>
      <p class="text-[10px] tracking-[0.2em] uppercase text-stone-400 mt-1 font-light">Find your perfect fit</p>
    </div>
  </section>

  <div class="max-w-[800px] mx-auto px-6 py-20 space-y-12">
    
    <!-- Shirts Table -->
    <div class="space-y-4">
      <h2 class="font-serif text-sm uppercase tracking-widest text-brand-charcoal font-semibold border-b border-stone-200 pb-2">
        T-SHIRTS & SHIRTS (INCHES)
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-xs text-gray-500 border-collapse border border-gray-100">
          <thead>
            <tr class="bg-gray-50 text-brand-charcoal uppercase font-semibold">
              <th class="p-3 border border-gray-100">Size</th>
              <th class="p-3 border border-gray-100">Chest</th>
              <th class="p-3 border border-gray-100">Length</th>
              <th class="p-3 border border-gray-100">Shoulder</th>
            </tr>
          </thead>
          <tbody>
            <tr class="hover:bg-stone-50/50 transition-colors">
              <td class="p-3 border border-gray-100 font-medium text-brand-charcoal">S</td>
              <td class="p-3 border border-gray-100">38</td>
              <td class="p-3 border border-gray-100">26.5</td>
              <td class="p-3 border border-gray-100">16.5</td>
            </tr>
            <tr class="bg-stone-50/30 hover:bg-stone-50/50 transition-colors">
              <td class="p-3 border border-gray-100 font-medium text-brand-charcoal">M</td>
              <td class="p-3 border border-gray-100">40</td>
              <td class="p-3 border border-gray-100">27.5</td>
              <td class="p-3 border border-gray-100">17.5</td>
            </tr>
            <tr class="hover:bg-stone-50/50 transition-colors">
              <td class="p-3 border border-gray-100 font-medium text-brand-charcoal">L</td>
              <td class="p-3 border border-gray-100">42</td>
              <td class="p-3 border border-gray-100">28.5</td>
              <td class="p-3 border border-gray-100">18.5</td>
            </tr>
            <tr class="bg-stone-50/30 hover:bg-stone-50/50 transition-colors">
              <td class="p-3 border border-gray-100 font-medium text-brand-charcoal">XL</td>
              <td class="p-3 border border-gray-100">44</td>
              <td class="p-3 border border-gray-100">29.5</td>
              <td class="p-3 border border-gray-100">19.5</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pants Table -->
    <div class="space-y-4">
      <h2 class="font-serif text-sm uppercase tracking-widest text-brand-charcoal font-semibold border-b border-stone-200 pb-2">
        TROUSERS & PANTS (INCHES)
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-xs text-gray-500 border-collapse border border-gray-100">
          <thead>
            <tr class="bg-gray-50 text-brand-charcoal uppercase font-semibold">
              <th class="p-3 border border-gray-100">Size</th>
              <th class="p-3 border border-gray-100">Waist</th>
              <th class="p-3 border border-gray-100">Hip</th>
              <th class="p-3 border border-gray-100">Inseam</th>
            </tr>
          </thead>
          <tbody>
            <tr class="hover:bg-stone-50/50 transition-colors">
              <td class="p-3 border border-gray-100 font-medium text-brand-charcoal">28 (S)</td>
              <td class="p-3 border border-gray-100">28 - 29</td>
              <td class="p-3 border border-gray-100">36</td>
              <td class="p-3 border border-gray-100">30</td>
            </tr>
            <tr class="bg-stone-50/30 hover:bg-stone-50/50 transition-colors">
              <td class="p-3 border border-gray-100 font-medium text-brand-charcoal">30 (M)</td>
              <td class="p-3 border border-gray-100">30 - 31</td>
              <td class="p-3 border border-gray-100">38</td>
              <td class="p-3 border border-gray-100">30</td>
            </tr>
            <tr class="hover:bg-stone-50/50 transition-colors">
              <td class="p-3 border border-gray-100 font-medium text-brand-charcoal">32 (L)</td>
              <td class="p-3 border border-gray-100">32 - 33</td>
              <td class="p-3 border border-gray-100">40</td>
              <td class="p-3 border border-gray-100">31</td>
            </tr>
            <tr class="bg-stone-50/30 hover:bg-stone-50/50 transition-colors">
              <td class="p-3 border border-gray-100 font-medium text-brand-charcoal">34 (XL)</td>
              <td class="p-3 border border-gray-100">34 - 35</td>
              <td class="p-3 border border-gray-100">42</td>
              <td class="p-3 border border-gray-100">31</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Measurement Advice Card -->
    <div class="bg-stone-50 p-6 rounded-sm border border-stone-200/60 text-xs font-light text-stone-500 space-y-2">
      <h3 class="font-serif font-semibold text-brand-charcoal uppercase tracking-wider mb-2">How to Measure</h3>
      <p class="leading-relaxed">
        <strong>Chest:</strong> Measure around the fullest part of your chest, keeping the tape horizontal.
      </p>
      <p class="leading-relaxed">
        <strong>Waist:</strong> Measure around your natural waistline, keeping the tape slightly loose.
      </p>
    </div>
  </div>
</Layout>
