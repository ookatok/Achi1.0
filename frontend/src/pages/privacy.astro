---
import Layout from '../layouts/Layout.astro';
---

<Layout title="PRIVACY POLICY | ACHI Studio" description="ACHI's privacy policies and customer data protection rules.">
  <div class="max-w-[800px] mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h1 class="font-serif text-4xl tracking-widest uppercase text-brand-charcoal">PRIVACY POLICY</h1>
      <p class="text-[10px] tracking-[0.2em] uppercase text-gray-400 mt-2 font-light">Data protection and privacy guidelines</p>
    </div>

    <div class="space-y-6 text-sm font-light text-gray-600 leading-relaxed">
      <p>
        ACHI is committed to protecting your privacy. This policy explains what information we collect, how we protect it, and your data rights.
      </p>

      <h3 class="font-serif text-base uppercase tracking-wider text-brand-charcoal font-medium mt-8 mb-4">Information We Collect</h3>
      <p>
        When you register a customer profile, place an order, or contact us, we collect your name, email, shipping address, phone number, and transaction logs.
      </p>

      <h3 class="font-serif text-base uppercase tracking-wider text-brand-charcoal font-medium mt-8 mb-4">Data Protection</h3>
      <p>
        All connection credentials and personal logs are encrypted. We never sell or share your personal data with third-party advertising networks.
      </p>
    </div>
  </div>
</Layout>
