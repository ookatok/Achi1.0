      imagesArr.forEach((item, index) => {
        const itemEl = document.createElement('div');
        itemEl.className = 'flex items-center justify-between gap-3 p-2 bg-stone-50 border border-stone-200 rounded-sm';

        // Left side: image and filename
        const leftEl = document.createElement('div');
        leftEl.className = 'flex items-center gap-2 min-w-0 flex-1';

        const imgEl = document.createElement('img');
        imgEl.className = 'w-8 h-10 object-cover rounded-sm border border-stone-200';
        imgEl.src = item.imageUrl.startsWith('http') ? item.imageUrl : `http://localhost:3001${item.imageUrl}`;

        const urlTextEl = document.createElement('span');
        urlTextEl.className = 'text-[9px] text-stone-500 truncate font-mono flex-1';
        urlTextEl.textContent = item.imageUrl.split('/').pop() || item.imageUrl;

        leftEl.appendChild(imgEl);
        leftEl.appendChild(urlTextEl);

        // Right side: color selector and remove button
        const rightEl = document.createElement('div');
        rightEl.className = 'flex items-center gap-2 shrink-0';

        const selectEl = document.createElement('select');
        selectEl.className = `${formType}-multi-image-color-select border border-stone-200 px-2 py-1 text-[10px] focus:outline-none rounded-sm bg-white`;
        selectEl.addEventListener('change', () => {
          item.color = selectEl.value;
        });

        // Add options to select
        const defOpt = document.createElement('option');
        defOpt.value = '';
        defOpt.textContent = lang === 'en' ? 'Default' : 'รูปเริ่มต้น/ไม่มีสี';
        selectEl.appendChild(defOpt);

        colors.forEach(col => {
          const opt = document.createElement('option');
          opt.value = col;
          opt.textContent = col;
          if (col === item.color) {
            opt.selected = true;
          }
          selectEl.appendChild(opt);
        });

        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'text-red-500 hover:text-red-700 text-xs font-bold px-1.5 py-0.5 border border-transparent hover:border-red-200 hover:bg-red-50 rounded-sm cursor-pointer';
        removeBtn.textContent = '×';
        removeBtn.addEventListener('click', () => {
          imagesArr.splice(index, 1);
          renderMultiImagesList(formType);
        });

        rightEl.appendChild(selectEl);
        rightEl.appendChild(removeBtn);

        itemEl.appendChild(leftEl);
        itemEl.appendChild(rightEl);

        listEl.appendChild(itemEl);
