---
import Layout from '../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';
import { useTranslations } from '../lib/translations';

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';
const t = useTranslations(lang);



const session = await getSession(Astro.request);
const token = (session as any)?.accessToken;

if (!token) {
  return Astro.redirect(`/${lang}/auth/signin?callbackUrl=/${lang}/admin`);
}

// Security double check (just in case middleware is bypassed)
if ((session?.user as any)?.role !== 'admin') {
  return new Response('Forbidden: Admin access only.', { status: 403 });
}

let productsCount = 0;
let orders = [] as any[];
let products = [] as any[];
let blogs = [] as any[];
let blogCategories = [] as any[];
let productCategories = [] as any[];
let productTagsList = [] as any[];
let contacts = [] as any[];
let collections = [] as any[];
let faqs = [] as any[];
let errorMsg = null;

try {
  // 1. Fetch products list
  const prodRes = await fetch('http://localhost:3001/api/products?limit=100');
  if (prodRes.ok) {
    products = await prodRes.json();
    productsCount = products.length;
  }

  // 2. Fetch all orders (since we are admin, we can fetch all orders or look up our own)
  const ordRes = await fetch('http://localhost:3001/api/orders', {
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });
  if (ordRes.ok) {
    orders = await ordRes.json();
  }

  // 3. Fetch all blogs
  const blogRes = await fetch('http://localhost:3001/api/blogs');
  if (blogRes.ok) {
    blogs = await blogRes.json();
  }

  // 4. Fetch all blog categories
  const catRes = await fetch('http://localhost:3001/api/blogs/categories');
  if (catRes.ok) {
    blogCategories = await catRes.json();
  }

  // 5. Fetch all product categories
  const prodCatRes = await fetch('http://localhost:3001/api/products/categories');
  if (prodCatRes.ok) {
    productCategories = await prodCatRes.json();
  }

  // 6. Fetch all product tags
  const prodTagRes = await fetch('http://localhost:3001/api/products/tags');
  if (prodTagRes.ok) {
    productTagsList = await prodTagRes.json();
  }

  // 7. Fetch all contact requests
  const contactRes = await fetch('http://localhost:3001/api/contacts', {
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });
  if (contactRes.ok) {
    contacts = await contactRes.json();
  }

  // 8. Fetch all collections
  const colRes = await fetch('http://localhost:3001/api/collections');
  if (colRes.ok) {
    collections = await colRes.json();
  }

  // 9. Fetch all FAQs
  const faqRes = await fetch('http://localhost:3001/api/faqs');
  if (faqRes.ok) {
    faqs = await faqRes.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Admin page fetch failed.', err);
  errorMsg = 'Could not load admin panel data. Backend server may be offline.';
}

const activeProducts = products.filter((p: any) => p.status !== 'inactive');
const inactiveProducts = products.filter((p: any) => p.status === 'inactive');
const newArrivalSets = collections.filter((c: any) => c.slug === 'new-arrivals' || c.slug.startsWith('new-arrivals-'));
const normalCollections = collections.filter((c: any) => c.slug !== 'new-arrivals' && !c.slug.startsWith('new-arrivals-'));

const normalOrders = orders.filter((o: any) => !o.isPreOrder);
const preOrders = orders.filter((o: any) => o.isPreOrder);

const parseArray = (val: any) => {
  try {
    const parsed = typeof val === 'string' ? JSON.parse(val) : val;
    return Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    return [];
  }
};
const resolveImage = (url: string) => {
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http') || url.startsWith('data:')) return url;
  if (url.startsWith('/')) return url;
  if (url.startsWith('assets/')) return '/' + url;
  return url;
};
---

<Layout title={`${t('admin.title')} | ACHI Studio`} description={t('admin.console')} isAdminPanel={true} pendingOrdersCount={orders.filter((o: any) => o.status === 'pending').length}>
  <div id="admin-container" data-token={token} data-lang={lang} class="max-w-[1440px] mx-auto px-6 py-24">
    {/* Page Header */}
    <div class="flex flex-col md:flex-row justify-between items-center mb-16 gap-4 border-b border-stone-100 pb-8">
      <div class="text-center md:text-left">
        <h1 class="font-serif text-3xl tracking-widest font-bold uppercase text-brand-charcoal">{t('admin.title')}</h1>
        <p class="text-[10px] tracking-[0.2em] uppercase text-gray-400 mt-2 font-light">{t('admin.console')}</p>
      </div>
      <div>
        <button
          id="signout-btn"
          class="border border-stone-300 text-stone-600 hover:border-brand-charcoal hover:text-brand-charcoal px-6 py-2.5 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer"
        >
          {t('admin.signout')}
        </button>
      </div>
    </div>

    {errorMsg && (
      <div class="text-xs text-red-500 font-light bg-red-50 p-4 border-l-2 border-red-500 rounded-sm mb-8">
        {errorMsg}
      </div>
    )}

    <!-- Section: Dashboard Overview -->
    <div id="dashboard-section" class="bg-white border border-stone-200 p-8 rounded-sm space-y-8 mb-8">
      <div class="pb-2 border-b border-stone-100">
        <h2 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium">
          {t('admin.overview')}
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
        <!-- Card 1: Products Count -->
        <div class="bg-gray-50 border border-gray-100 p-6 rounded-sm text-center">
          <span class="block text-[10px] uppercase tracking-wider font-semibold text-gray-400 mb-2">{t('admin.total_products')}</span>
          <span class="text-3xl font-serif font-bold text-brand-charcoal">{productsCount}</span>
          <div class="flex justify-center gap-3 mt-2.5 text-[9px] uppercase tracking-wider font-semibold border-t border-stone-200/50 pt-2.5">
            <span class="text-green-600">{lang === 'en' ? 'Active' : 'เปิดขาย'}: {activeProducts.length}</span>
            <span class="text-stone-300">|</span>
            <span class="text-red-500">{lang === 'en' ? 'Inactive' : 'ปิดขาย'}: {inactiveProducts.length}</span>
          </div>
        </div>

        <!-- Card 2: Orders Count -->
        <div class="bg-gray-50 border border-gray-100 p-6 rounded-sm text-center">
          <span class="block text-[10px] uppercase tracking-wider font-semibold text-gray-400 mb-2">{t('admin.total_orders')}</span>
          <span id="admin-total-orders-count" class="text-3xl font-serif font-bold text-brand-charcoal">{orders.length}</span>
          <div class="flex justify-center gap-3 mt-2.5 text-[9px] uppercase tracking-wider font-semibold border-t border-stone-200/50 pt-2.5">
            <span id="admin-normal-orders-count" class="text-stone-600">{lang === 'en' ? 'Normal' : 'สั่งซื้อปกติ'}: {orders.filter((o: any) => !o.isPreOrder).length}</span>
            <span class="text-stone-300">|</span>
            <span id="admin-pre-orders-count" class="text-amber-600">{lang === 'en' ? 'Pre-Order' : 'สั่งจองพรี'}: {orders.filter((o: any) => o.isPreOrder).length}</span>
          </div>
        </div>

        <!-- Card 3: Blogs Count -->
        <div class="bg-gray-50 border border-gray-100 p-6 rounded-sm text-center">
          <span class="block text-[10px] uppercase tracking-wider font-semibold text-gray-400 mb-2">{t('admin.total_blogs')}</span>
          <span class="text-3xl font-serif font-bold text-brand-charcoal">{blogs.length}</span>
        </div>

        <!-- Card 4: Collections Count -->
        <div class="bg-gray-50 border border-gray-100 p-6 rounded-sm text-center">
          <span class="block text-[10px] uppercase tracking-wider font-semibold text-gray-400 mb-2">{t('nav.collections')}</span>
          <span class="text-3xl font-serif font-bold text-brand-charcoal">{normalCollections.length}</span>
        </div>

        <!-- Card 5: Server Status -->
        <div class="bg-gray-50 border border-gray-100 p-6 rounded-sm text-center">
          <span class="block text-[10px] uppercase tracking-wider font-semibold text-gray-400 mb-2">{t('admin.server_status')}</span>
          <span class="text-xs font-semibold text-green-600 uppercase tracking-widest bg-green-50 px-2.5 py-1.5 rounded-full border border-green-100 inline-block mt-1">
            {t('admin.status_online')}
          </span>
        </div>
      </div>

      <!-- Welcome Note -->
      <div class="p-6 bg-stone-50 border border-stone-100 rounded-sm">
        <h3 class="font-serif text-xs tracking-widest uppercase text-brand-charcoal font-semibold mb-2">{t('admin.welcome_title')}</h3>
        <p class="text-[11px] text-stone-500 font-light leading-relaxed">
          {t('admin.welcome_desc')}
        </p>
      </div>
    </div>

    <!-- Section: Orders Management -->
    <div id="orders-section" class="bg-white border border-stone-200 p-8 rounded-sm space-y-6 hidden">
      <h2 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium pb-2 border-b border-stone-100">
        {t('admin.orders_title')}
      </h2>

      {orders.length === 0 ? (
        <div class="text-center py-12 text-gray-400 text-xs font-light">
          {t('admin.no_orders')}
        </div>
      ) : (
        <>
          <!-- Sub-tabs for Orders -->
          <div class="flex gap-6 border-b border-stone-200 pb-px mb-6">
            <button
              id="tab-normal-orders"
              class="border-b-2 border-brand-charcoal text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300"
            >
              {lang === 'en' ? 'Normal Orders' : 'ออเดอร์ปกติ'} (<span id="tab-normal-orders-count-span">{normalOrders.length}</span>)
            </button>
            <button
              id="tab-pre-orders"
              class="border-b-2 border-transparent text-stone-400 hover:text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300"
            >
              {lang === 'en' ? 'Pre-Orders' : 'สั่งจองล่วงหน้า (Pre-Order)'} (<span id="tab-pre-orders-count-span">{preOrders.length}</span>)
            </button>
          </div>

          <!-- Normal Orders Table -->
          <div id="normal-orders-container" class="overflow-x-auto">
            {normalOrders.length === 0 ? (
              <div class="text-center py-12 text-gray-400 text-xs font-light bg-stone-50 border border-dashed border-stone-200 rounded-sm">
                {lang === 'en' ? 'No normal orders found.' : 'ไม่พบรายการสั่งซื้อปกติในระบบ'}
              </div>
            ) : (
              <table class="w-full text-left text-xs text-stone-500 border-collapse border border-stone-100">
                <thead>
                  <tr class="bg-stone-50 text-brand-charcoal uppercase font-semibold text-[10px] tracking-wider">
                    <th class="p-3 border border-stone-100 w-24">{t('admin.order_id')}</th>
                    <th class="p-3 border border-stone-100 w-32">{t('admin.date')}</th>
                    <th class="p-3 border border-stone-100">{t('admin.shipping_address')}</th>
                    <th class="p-3 border border-stone-100 text-right w-32">Amount</th>
                    <th class="p-3 border border-stone-100 text-center w-32">Status</th>
                  </tr>
                </thead>
                <tbody>
                  {normalOrders.map((order: any) => (
                    <tr class="hover:bg-stone-50/50 transition-colors">
                      <td class="p-3 border border-stone-100 font-medium text-brand-charcoal">#{order.id}</td>
                      <td class="p-3 border border-stone-100">{new Date(order.createdAt).toLocaleDateString()}</td>
                      <td class="p-3 border border-stone-100 max-w-[250px] truncate">{order.shippingAddress}</td>
                      <td class="p-3 border border-stone-100 text-right font-semibold text-brand-charcoal">
                        ${Number(order.totalPrice).toLocaleString()}
                      </td>
                      <td class="p-3 border border-stone-100 text-center">
                        <span class="text-[9px] uppercase tracking-widest text-amber-600 bg-amber-50 px-2.5 py-0.5 rounded-full border border-amber-100 font-semibold inline-block">
                          {order.status}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )}
          </div>

          <!-- Pre-Orders Table -->
          <div id="pre-orders-container" class="overflow-x-auto hidden">
            {preOrders.length === 0 ? (
              <div class="text-center py-12 text-gray-400 text-xs font-light bg-stone-50 border border-dashed border-stone-200 rounded-sm">
                {lang === 'en' ? 'No pre-orders found.' : 'ไม่พบรายการสั่งจองล่วงหน้าในระบบ'}
              </div>
            ) : (
              <table class="w-full text-left text-xs text-stone-500 border-collapse border border-stone-100">
                <thead>
                  <tr class="bg-stone-50 text-brand-charcoal uppercase font-semibold text-[10px] tracking-wider">
                    <th class="p-3 border border-stone-100 w-24">{t('admin.order_id')}</th>
                    <th class="p-3 border border-stone-100 w-32">{t('admin.date')}</th>
                    <th class="p-3 border border-stone-100">{t('admin.shipping_address')}</th>
                    <th class="p-3 border border-stone-100 text-right w-32">Amount</th>
                    <th class="p-3 border border-stone-100 text-center w-32">Status</th>
                  </tr>
                </thead>
                <tbody>
                  {preOrders.map((order: any) => (
                    <tr class="hover:bg-stone-50/50 transition-colors">
                      <td class="p-3 border border-stone-100 font-medium text-brand-charcoal">#{order.id}</td>
                      <td class="p-3 border border-stone-100">{new Date(order.createdAt).toLocaleDateString()}</td>
                      <td class="p-3 border border-stone-100 max-w-[250px] truncate">{order.shippingAddress}</td>
                      <td class="p-3 border border-stone-100 text-right font-semibold text-brand-charcoal">
                        ${Number(order.totalPrice).toLocaleString()}
                      </td>
                      <td class="p-3 border border-stone-100 text-center">
                        <span class="text-[9px] uppercase tracking-widest text-amber-600 bg-amber-50 px-2.5 py-0.5 rounded-full border border-amber-100 font-semibold inline-block">
                          {order.status}
                        </span>
                        <span class="block text-[8px] bg-amber-100 text-amber-800 rounded px-1.5 py-0.5 mt-1 font-semibold uppercase text-center w-20 mx-auto">Pre-Order</span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )}
          </div>
        </>
      )}
    </div>

    <!-- Section: Products Management -->
    <div id="products-section" class="bg-white border border-stone-200 p-8 rounded-sm space-y-6 hidden">
      <!-- Main Products Sub-Navigation Tabs -->
      <div class="flex gap-6 border-b border-stone-200 pb-px mb-2">
        <button
          id="main-tab-products"
          class="border-b-2 border-brand-charcoal text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300"
        >
          {lang === 'en' ? 'Products Catalog' : 'แค็ตตาล็อกสินค้า'}
        </button>
        <button
          id="main-tab-new-arrivals"
          class="border-b-2 border-transparent text-stone-400 hover:text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300"
        >
          {lang === 'en' ? 'New Arrival Set' : 'เซ็ตสินค้ามาใหม่ (New Arrival Set)'}
        </button>
      </div>

      <!-- Container: Products Catalog Content -->
      <div id="products-catalog-tab-content" class="space-y-6">
        <div class="flex justify-between items-center pb-2 border-b border-stone-100">
          <h2 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium">
            {t('admin.products_title')}
          </h2>
          <a
            href={`/${lang}/admin/products/new`}
            class="bg-brand-charcoal text-white hover:bg-stone-800 px-4 py-2 rounded-sm text-[10px] uppercase tracking-widest font-semibold cursor-pointer transition-colors block text-center"
          >
            {t('admin.add_product')}
          </a>
        </div>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Products List (Col 1-3) -->
        <div class="lg:col-span-3 space-y-6">
          <!-- Filters Bar -->
          <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 p-4 bg-stone-50 border border-stone-100 rounded-sm">
            <div>
              <label class="block text-[8px] uppercase tracking-widest text-stone-400 font-semibold mb-1">{t('nav.search')}</label>
              <input
                type="text"
                id="admin-product-search"
                placeholder={t('admin.search_placeholder')}
                class="w-full border border-stone-200 px-3 py-2 text-xs rounded-sm focus:outline-none focus:border-brand-charcoal bg-white"
              />
            </div>
            <div>
              <label class="block text-[8px] uppercase tracking-widest text-stone-400 font-semibold mb-1">{t('admin.th_category')}</label>
              <select
                id="admin-product-category-filter"
                class="w-full border border-stone-200 px-3 py-2 text-xs rounded-sm focus:outline-none focus:border-brand-charcoal bg-white"
              >
                <option value="">{t('admin.filter_category')}</option>
                {productCategories.map((cat: any) => (
                  <option value={cat.id}>{cat.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-[8px] uppercase tracking-widest text-stone-400 font-semibold mb-1">{t('admin.th_tags')}</label>
              <select
                id="admin-product-tag-filter"
                class="w-full border border-stone-200 px-3 py-2 text-xs rounded-sm focus:outline-none focus:border-brand-charcoal bg-white"
              >
                <option value="">{t('admin.filter_tag')}</option>
                {productTagsList.map((tag: any) => (
                  <option value={tag.name.toLowerCase()}>{tag.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-[8px] uppercase tracking-widest text-stone-400 font-semibold mb-1">{t('admin.filter_stock')}</label>
              <select
                id="admin-product-stock-filter"
                class="w-full border border-stone-200 px-3 py-2 text-xs rounded-sm focus:outline-none focus:border-brand-charcoal bg-white"
              >
                <option value="">{t('admin.filter_stock')}</option>
                <option value="out">{t('admin.stock_outofstock')}</option>
                <option value="low">{t('admin.stock_lowstock')}</option>
                <option value="in">{t('admin.stock_instock')}</option>
              </select>
            </div>
          </div>

          <!-- Sub-tabs for Product Status -->
          <div class="flex gap-6 border-b border-stone-200 pb-px mb-6">
            <button
              id="tab-active-products"
              class="border-b-2 border-brand-charcoal text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300"
            >
              {lang === 'en' ? 'Open for Sale' : 'เปิดขาย'} ({activeProducts.length})
            </button>
            <button
              id="tab-inactive-products"
              class="border-b-2 border-transparent text-stone-400 hover:text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300"
            >
              {lang === 'en' ? 'Not for Sale' : 'ไม่เปิดขายแล้ว'} ({inactiveProducts.length})
            </button>
          </div>

          <!-- Active Products Container -->
          <div id="active-products-container" class="space-y-6">
            {activeProducts.length === 0 ? (
              <div class="text-center py-12 text-gray-400 text-xs font-light bg-stone-50 border border-dashed border-stone-200 rounded-sm">
                {lang === 'en' ? 'No active products found.' : 'ไม่พบสินค้าที่เปิดขายในระบบ'}
              </div>
            ) : (
              <div class="overflow-x-auto">
                <table class="w-full text-left text-xs text-stone-500 border-collapse border border-stone-100">
                  <thead>
                    <tr class="bg-stone-50 text-brand-charcoal uppercase font-semibold text-[10px] tracking-wider">
                      <th class="p-4 border border-stone-100 w-16">{t('admin.th_image')}</th>
                      <th class="p-4 border border-stone-100">{lang === 'en' ? 'Product Info' : 'ข้อมูลสินค้า'}</th>
                      <th class="p-4 border border-stone-100 w-24">{t('admin.th_price')}</th>
                      <th class="p-4 border border-stone-100 w-20">{lang === 'en' ? 'Stock (On-Hand)' : 'ในคลัง (On-Hand)'}</th>
                      <th class="p-4 border border-stone-100 w-20">{lang === 'en' ? 'On-Order (Booked)' : 'สั่งจอง (On-Order)'}</th>
                      <th class="p-4 border border-stone-100 w-20">{lang === 'en' ? 'Sales' : 'ยอดขาย'}</th>
                      <th class="p-4 border border-stone-100">{lang === 'en' ? 'Sizes & Colors' : 'ไซส์และสี'}</th>
                      <th class="p-4 border border-stone-100 text-left w-24">{t('admin.product_status')}</th>
                      <th class="p-4 border border-stone-100 text-center w-32">{t('admin.th_actions')}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {activeProducts.map((product) => {
                      const prodSizes = parseArray(product.sizes);
                      const prodColors = parseArray(product.colors);
                      const prodTags = parseArray(product.tags);
                      return (
                        <tr class="product-row hover:bg-stone-50/50 transition-colors"
                            data-name={product.name.toLowerCase()}
                            data-desc={(product.description || '').toLowerCase()}
                            data-category-name={(product.categoryName || '').toLowerCase()}
                            data-category-id={product.categoryId ? String(product.categoryId) : ''}
                            data-tags={JSON.stringify(prodTags.map((t: any) => typeof t === 'object' ? t.name.toLowerCase() : t.toLowerCase()))}
                            data-stock={product.stockQuantity}>
                          <td class="p-4 border border-stone-100">
                            {product.imageUrl ? (
                              <img src={resolveImage(product.imageUrl)} alt={product.name} class="w-12 h-14 object-cover rounded-sm border border-stone-100" />
                            ) : (
                              <div class="w-12 h-14 bg-stone-100 flex items-center justify-center text-[10px] text-stone-400 rounded-sm">{lang === 'en' ? 'No img' : 'ไม่มีรูป'}</div>
                            )}
                          </td>
                          <td class="p-4 border border-stone-100">
                            <div class="font-medium text-brand-charcoal text-sm">{product.name}</div>
                            <div class="text-[10px] text-stone-400 mt-0.5 tracking-wider">slug: {product.slug}</div>
                            <div class="text-[9px] uppercase tracking-widest text-stone-400 mt-1 font-semibold">{product.categoryName || (lang === 'en' ? 'Clothing' : 'เสื้อผ้า')}</div>
                          </td>
                          <td class="p-4 border border-stone-100 font-medium text-brand-charcoal">
                            ${Number(product.price).toLocaleString()}
                          </td>
                          <td class="p-4 border border-stone-100">
                            <span class={`font-medium ${product.stockQuantity === 0 ? 'text-red-500 font-semibold' : 'text-stone-700'}`}>
                              {product.stockQuantity}
                            </span>
                          </td>
                          <td class="p-4 border border-stone-100 font-medium">
