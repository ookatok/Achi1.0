      margin-bottom: 0.75rem;
    }
  </style>

  <script>
    import { signOut } from 'auth-astro/client';

    // Auth setup
    try {
      const signoutBtn = document.getElementById('signout-btn');
      if (signoutBtn) {
        signoutBtn.addEventListener('click', () => {
          signOut({ callbackUrl: '/' } as any);
        });
      }
    } catch (e) {
      console.error('Error setting up signout button:', e);
    }

    // Token retrieval
    const container = document.getElementById('admin-container');
    const token = container ? container.dataset.token : '';

    // Browser-side translation helper
    const lang = container ? (container.dataset.lang || 'th') : 'th';
    const msgs: Record<string, Record<string, string>> = {
      en: {
        confirmDeleteProduct: 'Are you sure you want to delete product "{name}"?',
        failedDeleteProduct: 'Failed to delete product.',
        failedConnectBackend: 'Could not connect to the backend server.',
        confirmDeleteBlog: 'Are you sure you want to delete blog post "{title}"?',
        failedDeleteBlog: 'Failed to delete blog post.',
        confirmDeleteBlogCat: 'Are you sure you want to delete blog category "{name}"? Blogs in this category will be uncategorized.',
        failedCreateCategory: 'Failed to create category.',
        failedDeleteCategory: 'Failed to delete category.',
        failedConnectServer: 'Could not connect to server.',
        confirmDeleteProductCat: 'Are you sure you want to delete product category "{name}"? Products in this category will be uncategorized.',
        confirmDeleteProductTag: 'Are you sure you want to delete product tag "{name}"? This will untag all associated products.',
        failedCreateTag: 'Failed to create tag.',
        failedDeleteTag: 'Failed to delete tag.',
        failedCreateProduct: 'Failed to create product.',
        failedUpdateProduct: 'Failed to update product.',
        failedCreateBlogPost: 'Failed to create blog post.',
        failedUpdateBlogPost: 'Failed to update blog post.',
        categoryNameRequired: 'Category name is required',
        tagNameRequired: 'Tag name is required',
        uploadingImage: 'Uploading image...',
        uploadSuccess: 'Upload successful!',
        uploadFailed: 'Upload failed.',
        networkErrorUpload: 'Network error during upload.'
      },
      th: {
        confirmDeleteProduct: 'คุณแน่ใจหรือไม่ที่จะลบสินค้า "{name}"?',
        failedDeleteProduct: 'ลบสินค้าไม่สำเร็จ',
        failedConnectBackend: 'ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์แบ็คเอนด์ได้',
        confirmDeleteBlog: 'คุณแน่ใจหรือไม่ที่จะลบบล็อก "{title}"?',
        failedDeleteBlog: 'ลบบล็อกไม่สำเร็จ',
        confirmDeleteBlogCat: 'คุณแน่ใจหรือไม่ที่จะลบหมวดหมู่บล็อก "{name}"? บล็อกในหมวดหมู่นี้จะกลายเป็นไม่มีหมวดหมู่',
        failedCreateCategory: 'สร้างหมวดหมู่ไม่สำเร็จ',
        failedDeleteCategory: 'ลบหมวดหมู่ไม่สำเร็จ',
        failedConnectServer: 'ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์ได้',
        confirmDeleteProductCat: 'คุณแน่ใจหรือไม่ที่จะลบหมวดหมู่สินค้า "{name}"? สินค้าในหมวดหมู่นี้จะกลายเป็นไม่มีหมวดหมู่',
        confirmDeleteProductTag: 'คุณแน่ใจหรือไม่ที่จะลบป้ายแท็กสินค้า "{name}"? การลบป้ายแท็กนี้จะลบป้ายแท็กออกจากสินค้าที่เกี่ยวข้องทั้งหมด',
        failedCreateTag: 'สร้างป้ายแท็กไม่สำเร็จ',
        failedDeleteTag: 'ลบป้ายแท็กไม่สำเร็จ',
        failedCreateProduct: 'สร้างสินค้าไม่สำเร็จ',
        failedUpdateProduct: 'อัปเดตสินค้าไม่สำเร็จ',
        failedCreateBlogPost: 'สร้างบล็อกไม่สำเร็จ',
        failedUpdateBlogPost: 'อัปเดตบล็อกไม่สำเร็จ',
        categoryNameRequired: 'กรุณากรอกชื่อหมวดหมู่',
        tagNameRequired: 'กรุณากรอกชื่อป้ายแท็ก',
        uploadingImage: 'กำลังอัปโหลดรูปภาพ...',
        uploadSuccess: 'อัปโหลดสำเร็จ!',
        uploadFailed: 'อัปโหลดล้มเหลว',
        networkErrorUpload: 'เกิดข้อผิดพลาดในการเชื่อมต่อเครือข่ายระหว่างอัปโหลด'
      }
    };

    const getMsg = (key: string, replacements: Record<string, string> = {}) => {
      let msg = msgs[lang]?.[key] || msgs.en[key] || '';
      for (const [k, v] of Object.entries(replacements)) {
        msg = msg.replace(`{${k}}`, v);
      }
      return msg;
    };

    // Real-time pending orders count polling
    const updatePendingOrdersBadge = async () => {
      if (!token) return;
      try {
        const res = await fetch('/api/orders', {
          headers: {
            'Authorization': `Bearer ${token}`
          }
        });
        if (res.ok) {
          const ordersList = await res.json();
          const pendingCount = ordersList.filter((o: any) => o.status === 'pending').length;
          
          // Update navigation tab badge
          const badge = document.getElementById('nav-orders-badge');
          if (badge) {
            badge.textContent = String(pendingCount);
            if (pendingCount > 0) {
              badge.classList.remove('hidden');
            } else {
              badge.classList.add('hidden');
            }
          }

          // Update Dashboard Overview "Total Orders" Card
          const totalOrdersCard = document.getElementById('admin-total-orders-count');
          if (totalOrdersCard) {
            totalOrdersCard.textContent = String(ordersList.length);
          }

          const normalOrdersCard = document.getElementById('admin-normal-orders-count');
          if (normalOrdersCard) {
            const normalCount = ordersList.filter((o: any) => !o.isPreOrder).length;
            normalOrdersCard.textContent = (lang === 'en' ? 'Normal' : 'สั่งซื้อปกติ') + ': ' + normalCount;
          }

          const preOrdersCard = document.getElementById('admin-pre-orders-count');
          if (preOrdersCard) {
            const preCount = ordersList.filter((o: any) => o.isPreOrder).length;
            preOrdersCard.textContent = (lang === 'en' ? 'Pre-Order' : 'สั่งจองพรี') + ': ' + preCount;
          }

          const normalOrdersSpan = document.getElementById('tab-normal-orders-count-span');
          if (normalOrdersSpan) {
            const normalCount = ordersList.filter((o: any) => !o.isPreOrder).length;
            normalOrdersSpan.textContent = String(normalCount);
          }

          const preOrdersSpan = document.getElementById('tab-pre-orders-count-span');
          if (preOrdersSpan) {
            const preCount = ordersList.filter((o: any) => o.isPreOrder).length;
            preOrdersSpan.textContent = String(preCount);
          }
        }
      } catch (err) {
        console.error('Error polling pending orders count:', err);
      }
    };

    try {
      // Poll every 10 seconds
      setInterval(updatePendingOrdersBadge, 10000);
      // Initial fetch to ensure up-to-date
      updatePendingOrdersBadge();
    } catch (e) {
      console.error('Error running pending orders badge polling:', e);
    }

    // Tab switcher using top navigation
    try {
      console.log('[Admin Tabs] Initializing tab switcher...');
      const navDashboard = document.getElementById('nav-tab-dashboard');
      const navOrders = document.getElementById('nav-tab-orders');
      const navProducts = document.getElementById('nav-tab-products');
      const navCollections = document.getElementById('nav-tab-collections');
      const navBlogs = document.getElementById('nav-tab-blogs');
      const navContacts = document.getElementById('nav-tab-contacts');
      const navFaqs = document.getElementById('nav-tab-faqs');
 
      const dashboardSection = document.getElementById('dashboard-section');
      const ordersSection = document.getElementById('orders-section');
      const productsSection = document.getElementById('products-section');
      const collectionsSection = document.getElementById('collections-section');
      const blogsSection = document.getElementById('blogs-section');
      const contactsSection = document.getElementById('contacts-section');
      const faqsSection = document.getElementById('faqs-section');
 
      console.log('[Admin Tabs] Elements found:', {
        navDashboard: !!navDashboard,
        navOrders: !!navOrders,
        navProducts: !!navProducts,
        navCollections: !!navCollections,
        navBlogs: !!navBlogs,
        navContacts: !!navContacts,
        navFaqs: !!navFaqs,
        dashboardSection: !!dashboardSection,
        ordersSection: !!ordersSection,
        productsSection: !!productsSection,
        collectionsSection: !!collectionsSection,
        blogsSection: !!blogsSection,
        contactsSection: !!contactsSection,
        faqsSection: !!faqsSection
      });
 
      const switchTab = (activeNavBtn: any, activeSection: any) => {
        console.log('[Admin Tabs] Switching tab to:', activeSection?.id);
        [navDashboard, navOrders, navProducts, navCollections, navBlogs, navContacts, navFaqs].forEach(btn => {
          if (btn) {
            if (btn === activeNavBtn) {
              btn.classList.add('active');
              btn.classList.add('border-brand-charcoal', 'text-brand-charcoal', 'font-semibold');
              btn.classList.remove('border-transparent', 'text-gray-400', 'font-light');
            } else {
              btn.classList.remove('active');
              btn.classList.remove('border-brand-charcoal', 'text-brand-charcoal', 'font-semibold');
              btn.classList.add('border-transparent', 'text-gray-400', 'font-light');
            }
          }
        });
 
        [dashboardSection, ordersSection, productsSection, collectionsSection, blogsSection, contactsSection, faqsSection].forEach(section => {
          if (section) {
            if (section === activeSection) {
              section.classList.remove('hidden');
            } else {
              section.classList.add('hidden');
            }
          }
        });
      };
 
      navDashboard?.addEventListener('click', (e) => { e.preventDefault(); switchTab(navDashboard, dashboardSection); });
      navOrders?.addEventListener('click', (e) => { e.preventDefault(); switchTab(navOrders, ordersSection); });
      navProducts?.addEventListener('click', (e) => { e.preventDefault(); switchTab(navProducts, productsSection); });
      navCollections?.addEventListener('click', (e) => { e.preventDefault(); switchTab(navCollections, collectionsSection); });
      navBlogs?.addEventListener('click', (e) => { e.preventDefault(); switchTab(navBlogs, blogsSection); });
      navContacts?.addEventListener('click', (e) => { e.preventDefault(); switchTab(navContacts, contactsSection); });
      navFaqs?.addEventListener('click', (e) => { e.preventDefault(); switchTab(navFaqs, faqsSection); });
 
      // Initialize the default tab based on URL search query
      const urlParams = new URLSearchParams(window.location.search);
      const tabParam = urlParams.get('tab');
      if (tabParam === 'orders' && navOrders && ordersSection) {
        switchTab(navOrders, ordersSection);
      } else if (tabParam === 'products' && navProducts && productsSection) {
        switchTab(navProducts, productsSection);
      } else if (tabParam === 'collections' && navCollections && collectionsSection) {
        switchTab(navCollections, collectionsSection);
      } else if (tabParam === 'blogs' && navBlogs && blogsSection) {
        switchTab(navBlogs, blogsSection);
      } else if (tabParam === 'contacts' && navContacts && contactsSection) {
        switchTab(navContacts, contactsSection);
      } else if (tabParam === 'faqs' && navFaqs && faqsSection) {
        switchTab(navFaqs, faqsSection);
      } else {
        switchTab(navDashboard, dashboardSection);
      }
    } catch (e) {
      console.error('[Admin Tabs] Error initializing tab switcher:', e);
    }

    // Product sub-tabs (Active vs Inactive) switcher
    try {
      const tabActiveProducts = document.getElementById('tab-active-products');
      const tabInactiveProducts = document.getElementById('tab-inactive-products');
      const activeProductsContainer = document.getElementById('active-products-container');
      const inactiveProductsContainer = document.getElementById('inactive-products-container');

      if (tabActiveProducts && tabInactiveProducts && activeProductsContainer && inactiveProductsContainer) {
        tabActiveProducts.addEventListener('click', () => {
          activeProductsContainer.classList.remove('hidden');
          inactiveProductsContainer.classList.add('hidden');
          tabActiveProducts.className = "border-b-2 border-brand-charcoal text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
          tabInactiveProducts.className = "border-b-2 border-transparent text-stone-400 hover:text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
        });

        tabInactiveProducts.addEventListener('click', () => {
          inactiveProductsContainer.classList.remove('hidden');
          activeProductsContainer.classList.add('hidden');
          tabInactiveProducts.className = "border-b-2 border-brand-charcoal text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
          tabActiveProducts.className = "border-b-2 border-transparent text-stone-400 hover:text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
        });
      }
    } catch (e) {
      console.error('[Admin Sub-tabs] Error initializing sub-tabs switcher:', e);
    }

    // Products main tabs switcher (General Catalog vs New Arrival Set)
    try {
      const mainTabProducts = document.getElementById('main-tab-products');
      const mainTabNewArrivals = document.getElementById('main-tab-new-arrivals');
      const productsCatalogTabContent = document.getElementById('products-catalog-tab-content');
      const newArrivalSetTabContent = document.getElementById('new-arrival-set-tab-content');

      if (mainTabProducts && mainTabNewArrivals && productsCatalogTabContent && newArrivalSetTabContent) {
        mainTabProducts.addEventListener('click', () => {
          productsCatalogTabContent.classList.remove('hidden');
          newArrivalSetTabContent.classList.add('hidden');
          mainTabProducts.className = "border-b-2 border-brand-charcoal text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
          mainTabNewArrivals.className = "border-b-2 border-transparent text-stone-400 hover:text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
        });

        mainTabNewArrivals.addEventListener('click', () => {
          newArrivalSetTabContent.classList.remove('hidden');
          productsCatalogTabContent.classList.add('hidden');
          mainTabNewArrivals.className = "border-b-2 border-brand-charcoal text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
          mainTabProducts.className = "border-b-2 border-transparent text-stone-400 hover:text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
        });

        // Activating sub-tab based on URL search query
        const urlParams = new URLSearchParams(window.location.search);
        const subtabParam = urlParams.get('subtab');
        if (subtabParam === 'new-arrivals') {
          newArrivalSetTabContent.classList.remove('hidden');
          productsCatalogTabContent.classList.add('hidden');
          mainTabNewArrivals.className = "border-b-2 border-brand-charcoal text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
          mainTabProducts.className = "border-b-2 border-transparent text-stone-400 hover:text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
        }
      }
    } catch (e) {
      console.error('[Admin Products Main Tabs] Error:', e);
    }

    // New Arrival Sets Management (Delete only)
    try {
      const isEn = lang === 'en';
      document.querySelectorAll('.delete-set-btn').forEach((btn: any) => {
        btn.addEventListener('click', async () => {
          const id = btn.getAttribute('data-id');
          const title = btn.getAttribute('data-title') || '';
          if (!id) return;

          const confirmMsg = isEn 
            ? `Are you sure you want to delete set "${title}"?` 
            : `คุณแน่ใจหรือไม่ที่จะลบเซ็ตสินค้า "${title}"?`;

          if (confirm(confirmMsg)) {
            try {
              const res = await fetch(`http://localhost:3001/api/collections/${id}`, {
                method: 'DELETE',
                headers: {
                  'Authorization': `Bearer ${token}`
                }
              });

              if (res.ok) {
                (window as any).showStatusAlert(200, isEn ? 'Set deleted successfully.' : 'ลบเซ็ตเสร็จสมบูรณ์', null, true);
                window.location.reload();
              } else {
                const data = await res.json();
                (window as any).showStatusAlert(res.status, null, data ? data.message : (isEn ? 'Failed to delete set.' : 'ลบเซ็ตไม่สำเร็จ'));
              }
            } catch (err) {
              console.error(err);
              (window as any).showStatusAlert(0, isEn ? 'Connection error.' : 'เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์');
            }
          }
        });
      });
    } catch (e) {
      console.error('[New Arrival Set Delete] Error:', e);
    }

    // New Arrival Sets Visibility Toggle
    try {
      const isEn = lang === 'en';
      document.querySelectorAll('.visibility-toggle-checkbox').forEach((checkbox: any) => {
        checkbox.addEventListener('change', async () => {
          const id = checkbox.getAttribute('data-id');
          const isVisible = checkbox.checked;
          if (!id) return;

          try {
            const res = await fetch(`http://localhost:3001/api/collections/${id}`, {
              method: 'PATCH',
              headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
              },
              body: JSON.stringify({ isVisible })
            });

            if (res.ok) {
              (window as any).showStatusAlert(200, isEn ? 'Visibility updated successfully.' : 'อัปเดตการแสดงผลสำเร็จ', null, true);
            } else {
              const data = await res.json();
              (window as any).showStatusAlert(res.status, null, data ? data.message : (isEn ? 'Failed to update visibility.' : 'อัปเดตการแสดงผลไม่สำเร็จ'));
              checkbox.checked = !isVisible;
            }
          } catch (err) {
            console.error(err);
            (window as any).showStatusAlert(0, isEn ? 'Connection error.' : 'เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์');
            checkbox.checked = !isVisible;
          }
        });
      });
    } catch (e) {
      console.error('[New Arrival Set Visibility Toggle] Error:', e);
    }

    // New Arrival Sets Show on Home Toggle
    try {
      const isEn = lang === 'en';
      document.querySelectorAll('.show-on-home-toggle-checkbox').forEach((checkbox: any) => {
        checkbox.addEventListener('change', async () => {
          const id = checkbox.getAttribute('data-id');
          const showOnHome = checkbox.checked;
          if (!id) return;

          try {
            const res = await fetch(`http://localhost:3001/api/collections/${id}`, {
              method: 'PATCH',
              headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
              },
              body: JSON.stringify({ showOnHome })
            });

            if (res.ok) {
              (window as any).showStatusAlert(200, isEn ? 'Show on Home updated successfully.' : 'อัปเดตการแสดงผลหน้าแรกสำเร็จ', null, true);
            } else {
              const data = await res.json();
              (window as any).showStatusAlert(res.status, null, data ? data.message : (isEn ? 'Failed to update show on home.' : 'อัปเดตการแสดงผลหน้าแรกไม่สำเร็จ'));
              checkbox.checked = !showOnHome;
            }
          } catch (err) {
            console.error(err);
            (window as any).showStatusAlert(0, isEn ? 'Connection error.' : 'เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์');
            checkbox.checked = !showOnHome;
          }
        });
      });
    } catch (e) {
      console.error('[New Arrival Set Show on Home Toggle] Error:', e);
    }

    // Orders sub-tabs (Normal vs Pre-Order) switcher
    try {
      const tabNormalOrders = document.getElementById('tab-normal-orders');
      const tabPreOrders = document.getElementById('tab-pre-orders');
      const normalOrdersContainer = document.getElementById('normal-orders-container');
      const preOrdersContainer = document.getElementById('pre-orders-container');

      if (tabNormalOrders && tabPreOrders && normalOrdersContainer && preOrdersContainer) {
        tabNormalOrders.addEventListener('click', () => {
          normalOrdersContainer.classList.remove('hidden');
          preOrdersContainer.classList.add('hidden');
          tabNormalOrders.className = "border-b-2 border-brand-charcoal text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
          tabPreOrders.className = "border-b-2 border-transparent text-stone-400 hover:text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
        });

        tabPreOrders.addEventListener('click', () => {
          preOrdersContainer.classList.remove('hidden');
          normalOrdersContainer.classList.add('hidden');
          tabPreOrders.className = "border-b-2 border-brand-charcoal text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
          tabNormalOrders.className = "border-b-2 border-transparent text-stone-400 hover:text-brand-charcoal font-semibold text-xs pb-3 tracking-widest uppercase cursor-pointer transition-all duration-300";
        });
      }
    } catch (e) {
      console.error('[Admin Orders Sub-tabs] Error initializing orders sub-tabs switcher:', e);
    }

    // Products table filtering and pagination logic
    let activeProductsPage = 1;
    let inactiveProductsPage = 1;
    let setsPage = 1;
    const itemsPerPage = 10;

    const prodSearch = document.getElementById('admin-product-search') as HTMLInputElement | null;
    const prodCategoryFilter = document.getElementById('admin-product-category-filter') as HTMLSelectElement | null;
    const prodTagFilter = document.getElementById('admin-product-tag-filter') as HTMLSelectElement | null;
    const prodStockFilter = document.getElementById('admin-product-stock-filter') as HTMLSelectElement | null;

    const paginateProducts = (type: 'active' | 'inactive') => {
      const containerId = type === 'active' ? 'active-products-container' : 'inactive-products-container';
      const paginationId = type === 'active' ? 'active-products-pagination' : 'inactive-products-pagination';
      const rows = document.querySelectorAll(`#${containerId} .product-row`) as NodeListOf<HTMLTableRowElement>;
      
      const matchingRows: HTMLTableRowElement[] = [];
      rows.forEach(row => {
        if (row.dataset.match === 'true') {
          matchingRows.push(row);
        } else {
          row.classList.add('hidden');
        }
      });

      const totalMatching = matchingRows.length;
      const totalPages = Math.ceil(totalMatching / itemsPerPage) || 1;

      let currentPage = type === 'active' ? activeProductsPage : inactiveProductsPage;
      if (currentPage > totalPages) {
        currentPage = totalPages;
        if (type === 'active') activeProductsPage = totalPages;
        else inactiveProductsPage = totalPages;
      }
      if (currentPage < 1) {
        currentPage = 1;
        if (type === 'active') activeProductsPage = 1;
        else inactiveProductsPage = 1;
      }

      // Show/hide matching rows based on pagination window
      const startIndex = (currentPage - 1) * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;

      matchingRows.forEach((row, index) => {
        if (index >= startIndex && index < endIndex) {
          row.classList.remove('hidden');
        } else {
          row.classList.add('hidden');
        }
      });

      // Render pagination UI
      const paginationContainer = document.getElementById(paginationId);
      if (paginationContainer) {
        paginationContainer.innerHTML = '';
        if (totalPages <= 1) {
          return;
        }

        // Prev Button
        const prevBtn = document.createElement('button');
        prevBtn.className = `border border-stone-200 px-3 py-1 rounded text-[10px] uppercase font-bold tracking-widest text-stone-600 transition-colors ${currentPage === 1 ? 'opacity-40 cursor-not-allowed' : 'hover:bg-stone-50 cursor-pointer'}`;
        prevBtn.innerText = lang === 'en' ? 'Prev' : 'ก่อนหน้า';
        if (currentPage > 1) {
          prevBtn.addEventListener('click', () => {
            if (type === 'active') activeProductsPage--;
            else inactiveProductsPage--;
            paginateProducts(type);
          });
        }
        paginationContainer.appendChild(prevBtn);

        // Page Numbers
        for (let i = 1; i <= totalPages; i++) {
          const pageBtn = document.createElement('button');
          pageBtn.className = `border px-2.5 py-1 rounded text-[10px] font-bold transition-colors cursor-pointer ${
            i === currentPage 
              ? 'border-brand-charcoal bg-brand-charcoal text-white' 
              : 'border-stone-200 text-stone-600 hover:bg-stone-50'
          }`;
          pageBtn.innerText = String(i);
          pageBtn.addEventListener('click', () => {
            if (type === 'active') activeProductsPage = i;
            else inactiveProductsPage = i;
            paginateProducts(type);
          });
          paginationContainer.appendChild(pageBtn);
        }

        // Next Button
        const nextBtn = document.createElement('button');
        nextBtn.className = `border border-stone-200 px-3 py-1 rounded text-[10px] uppercase font-bold tracking-widest text-stone-600 transition-colors ${currentPage === totalPages ? 'opacity-40 cursor-not-allowed' : 'hover:bg-stone-50 cursor-pointer'}`;
        nextBtn.innerText = lang === 'en' ? 'Next' : 'ถัดไป';
        if (currentPage < totalPages) {
          nextBtn.addEventListener('click', () => {
            if (type === 'active') activeProductsPage++;
            else inactiveProductsPage++;
            paginateProducts(type);
          });
        }
        paginationContainer.appendChild(nextBtn);
      }
    };

    const paginateSets = () => {
      const rows = document.querySelectorAll('.set-row') as NodeListOf<HTMLTableRowElement>;
      const totalMatching = rows.length;
      const totalPages = Math.ceil(totalMatching / itemsPerPage) || 1;

      if (setsPage > totalPages) {
        setsPage = totalPages;
      }
      if (setsPage < 1) {
        setsPage = 1;
      }

      const startIndex = (setsPage - 1) * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;

      rows.forEach((row, index) => {
        if (index >= startIndex && index < endIndex) {
          row.classList.remove('hidden');
        } else {
          row.classList.add('hidden');
        }
      });

      const paginationContainer = document.getElementById('sets-pagination');
      if (paginationContainer) {
        paginationContainer.innerHTML = '';
        if (totalPages <= 1) {
          return;
        }

        // Prev Button
        const prevBtn = document.createElement('button');
        prevBtn.className = `border border-stone-200 px-3 py-1 rounded text-[10px] uppercase font-bold tracking-widest text-stone-600 transition-colors ${setsPage === 1 ? 'opacity-40 cursor-not-allowed' : 'hover:bg-stone-50 cursor-pointer'}`;
        prevBtn.innerText = lang === 'en' ? 'Prev' : 'ก่อนหน้า';
        if (setsPage > 1) {
          prevBtn.addEventListener('click', () => {
            setsPage--;
            paginateSets();
          });
        }
        paginationContainer.appendChild(prevBtn);

        // Page Numbers
        for (let i = 1; i <= totalPages; i++) {
          const pageBtn = document.createElement('button');
          pageBtn.className = `border px-2.5 py-1 rounded text-[10px] font-bold transition-colors cursor-pointer ${
            i === setsPage 
              ? 'border-brand-charcoal bg-brand-charcoal text-white' 
              : 'border-stone-200 text-stone-600 hover:bg-stone-50'
          }`;
          pageBtn.innerText = String(i);
          pageBtn.addEventListener('click', () => {
            setsPage = i;
            paginateSets();
          });
          paginationContainer.appendChild(pageBtn);
        }

        // Next Button
        const nextBtn = document.createElement('button');
        nextBtn.className = `border border-stone-200 px-3 py-1 rounded text-[10px] uppercase font-bold tracking-widest text-stone-600 transition-colors ${setsPage === totalPages ? 'opacity-40 cursor-not-allowed' : 'hover:bg-stone-50 cursor-pointer'}`;
        nextBtn.innerText = lang === 'en' ? 'Next' : 'ถัดไป';
        if (setsPage < totalPages) {
          nextBtn.addEventListener('click', () => {
            setsPage++;
            paginateSets();
          });
        }
        paginationContainer.appendChild(nextBtn);
      }
    };

    const filterProducts = () => {
      const productRows = document.querySelectorAll('.product-row') as NodeListOf<HTMLTableRowElement>;
      const searchVal = prodSearch?.value.toLowerCase().trim() || '';
      const catVal = prodCategoryFilter?.value || '';
      const tagVal = prodTagFilter?.value || '';
      const stockVal = prodStockFilter?.value || '';

      productRows.forEach(row => {
        const name = row.getAttribute('data-name') || '';
        const desc = row.getAttribute('data-desc') || '';
        const categoryId = row.getAttribute('data-category-id') || '';
        const categoryName = row.getAttribute('data-category-name') || '';
        const tags = JSON.parse(row.getAttribute('data-tags') || '[]');
        const stock = parseInt(row.getAttribute('data-stock') || '0', 10);

        const matchText = !searchVal || 
                          name.includes(searchVal) || 
                          desc.includes(searchVal) || 
                          categoryName.includes(searchVal) || 
                          tags.some((t: string) => t.includes(searchVal));
        const matchCategory = !catVal || categoryId === catVal;
        const matchTag = !tagVal || tags.includes(tagVal);

        let matchStock = true;
        if (stockVal === 'out') {
          matchStock = stock === 0;
        } else if (stockVal === 'low') {
          matchStock = stock > 0 && stock <= 10;
        } else if (stockVal === 'in') {
          matchStock = stock > 10;
        }

        if (matchText && matchCategory && matchTag && matchStock) {
          row.dataset.match = 'true';
        } else {
          row.dataset.match = 'false';
        }
      });

      // Reset to page 1 on filter
      activeProductsPage = 1;
      inactiveProductsPage = 1;
      paginateProducts('active');
      paginateProducts('inactive');
    };

    prodSearch?.addEventListener('input', filterProducts);
    prodCategoryFilter?.addEventListener('change', filterProducts);
    prodTagFilter?.addEventListener('change', filterProducts);
    prodStockFilter?.addEventListener('change', filterProducts);

