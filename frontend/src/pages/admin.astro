      }
      const colorsInput = document.getElementById(`${formType}-colors`) as HTMLInputElement | null;
      const colors = colorsInput ? colorsInput.value.split(',').map(c => c.trim()).filter(Boolean) : [];

      if (imagesArr.length === 0) {
        listEl.innerHTML = `<div class="text-stone-400 text-[10px] italic py-1">${lang === 'en' ? 'No multi-images uploaded yet.' : 'ยังไม่มีรูปภาพเพิ่มเติม'}</div>`;
        return;
