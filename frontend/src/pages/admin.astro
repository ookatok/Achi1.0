      border-left: 2px solid #e7e5e4;
      padding-left: 1rem;
      color: #78716c;
      font-style: italic;
      margin-bottom: 0.75rem;
    }
  </style>

  <script>
    import { signOut } from 'auth-astro/client';
    import { Editor } from '@tiptap/core';
    import StarterKit from '@tiptap/starter-kit';

    // Auth setup
    try {
      const signoutBtn = document.getElementById('signout-btn');
      if (signoutBtn) {
        signoutBtn.addEventListener('click', () => {
          signOut({ callbackUrl: '/' } as any);
        });
      }
    } catch (e) {
      console.error('Error setting up signout button:', e);
    }

    // Token retrieval
    const container = document.getElementById('admin-container');
    const token = container ? container.dataset.token : '';

    // Browser-side translation helper
    const lang = container ? (container.dataset.lang || 'th') : 'th';
    const msgs: Record<string, Record<string, string>> = {
      en: {
        confirmDeleteProduct: 'Are you sure you want to delete product "{name}"?',
        failedDeleteProduct: 'Failed to delete product.',
        failedConnectBackend: 'Could not connect to the backend server.',
        confirmDeleteBlog: 'Are you sure you want to delete blog post "{title}"?',
        failedDeleteBlog: 'Failed to delete blog post.',
        confirmDeleteBlogCat: 'Are you sure you want to delete blog category "{name}"? Blogs in this category will be uncategorized.',
        failedCreateCategory: 'Failed to create category.',
        failedDeleteCategory: 'Failed to delete category.',
        failedConnectServer: 'Could not connect to server.',
        confirmDeleteProductCat: 'Are you sure you want to delete product category "{name}"? Products in this category will be uncategorized.',
        confirmDeleteProductTag: 'Are you sure you want to delete product tag "{name}"? This will untag all associated products.',
        failedCreateTag: 'Failed to create tag.',
        failedDeleteTag: 'Failed to delete tag.',
        failedCreateProduct: 'Failed to create product.',
        failedUpdateProduct: 'Failed to update product.',
        failedCreateBlogPost: 'Failed to create blog post.',
        failedUpdateBlogPost: 'Failed to update blog post.',
        categoryNameRequired: 'Category name is required',
        tagNameRequired: 'Tag name is required',
        uploadingImage: 'Uploading image...',
        uploadSuccess: 'Upload successful!',
        uploadFailed: 'Upload failed.',
        networkErrorUpload: 'Network error during upload.'
      },
      th: {
        confirmDeleteProduct: 'คุณแน่ใจหรือไม่ที่จะลบสินค้า "{name}"?',
        failedDeleteProduct: 'ลบสินค้าไม่สำเร็จ',
        failedConnectBackend: 'ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์แบ็คเอนด์ได้',
        confirmDeleteBlog: 'คุณแน่ใจหรือไม่ที่จะลบบล็อก "{title}"?',
        failedDeleteBlog: 'ลบบล็อกไม่สำเร็จ',
        confirmDeleteBlogCat: 'คุณแน่ใจหรือไม่ที่จะลบหมวดหมู่บล็อก "{name}"? บล็อกในหมวดหมู่นี้จะกลายเป็นไม่มีหมวดหมู่',
        failedCreateCategory: 'สร้างหมวดหมู่ไม่สำเร็จ',
        failedDeleteCategory: 'ลบหมวดหมู่ไม่สำเร็จ',
        failedConnectServer: 'ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์ได้',
        confirmDeleteProductCat: 'คุณแน่ใจหรือไม่ที่จะลบหมวดหมู่สินค้า "{name}"? สินค้าในหมวดหมู่นี้จะกลายเป็นไม่มีหมวดหมู่',
        confirmDeleteProductTag: 'คุณแน่ใจหรือไม่ที่จะลบป้ายแท็กสินค้า "{name}"? การลบป้ายแท็กนี้จะลบป้ายแท็กออกจากสินค้าที่เกี่ยวข้องทั้งหมด',
        failedCreateTag: 'สร้างป้ายแท็กไม่สำเร็จ',
        failedDeleteTag: 'ลบป้ายแท็กไม่สำเร็จ',
        failedCreateProduct: 'สร้างสินค้าไม่สำเร็จ',
        failedUpdateProduct: 'อัปเดตสินค้าไม่สำเร็จ',
        failedCreateBlogPost: 'สร้างบล็อกไม่สำเร็จ',
        failedUpdateBlogPost: 'อัปเดตบล็อกไม่สำเร็จ',
        categoryNameRequired: 'กรุณากรอกชื่อหมวดหมู่',
        tagNameRequired: 'กรุณากรอกชื่อป้ายแท็ก',
        uploadingImage: 'กำลังอัปโหลดรูปภาพ...',
        uploadSuccess: 'อัปโหลดสำเร็จ!',
        uploadFailed: 'อัปโหลดล้มเหลว',
        networkErrorUpload: 'เกิดข้อผิดพลาดในการเชื่อมต่อเครือข่ายระหว่างอัปโหลด'
      }
    };

    const getMsg = (key: string, replacements: Record<string, string> = {}) => {
      let msg = msgs[lang]?.[key] || msgs.en[key] || '';
      for (const [k, v] of Object.entries(replacements)) {
        msg = msg.replace(`{${k}}`, v);
      }
      return msg;
    };

    // Real-time pending orders count polling
    const updatePendingOrdersBadge = async () => {
      if (!token) return;
      try {
        const res = await fetch('http://localhost:3001/api/orders', {
          headers: {
            'Authorization': `Bearer ${token}`
          }
        });
        if (res.ok) {
          const ordersList = await res.json();
          const pendingCount = ordersList.filter((o: any) => o.status === 'pending').length;
          
          // Update navigation tab badge
          const badge = document.getElementById('nav-orders-badge');
          if (badge) {
            badge.textContent = String(pendingCount);
            if (pendingCount > 0) {
              badge.classList.remove('hidden');
            } else {
              badge.classList.add('hidden');
            }
          }

          // Update Dashboard Overview "Total Orders" Card
          const totalOrdersCard = document.getElementById('admin-total-orders-count');
          if (totalOrdersCard) {
            totalOrdersCard.textContent = String(ordersList.length);
          }
        }
      } catch (err) {
        console.error('Error polling pending orders count:', err);
      }
    };

    try {
      // Poll every 10 seconds
      setInterval(updatePendingOrdersBadge, 10000);
      // Initial fetch to ensure up-to-date
      updatePendingOrdersBadge();
    } catch (e) {
      console.error('Error running pending orders badge polling:', e);
    }

    // Tab switcher using top navigation
    try {
      console.log('[Admin Tabs] Initializing tab switcher...');
      const navDashboard = document.getElementById('nav-tab-dashboard');
      const navOrders = document.getElementById('nav-tab-orders');
      const navProducts = document.getElementById('nav-tab-products');
      const navCollections = document.getElementById('nav-tab-collections');
      const navBlogs = document.getElementById('nav-tab-blogs');
      const navContacts = document.getElementById('nav-tab-contacts');
 
      const dashboardSection = document.getElementById('dashboard-section');
      const ordersSection = document.getElementById('orders-section');
      const productsSection = document.getElementById('products-section');
      const collectionsSection = document.getElementById('collections-section');
      const blogsSection = document.getElementById('blogs-section');
      const contactsSection = document.getElementById('contacts-section');
 
      console.log('[Admin Tabs] Elements found:', {
        navDashboard: !!navDashboard,
        navOrders: !!navOrders,
        navProducts: !!navProducts,
        navCollections: !!navCollections,
        navBlogs: !!navBlogs,
        navContacts: !!navContacts,
        dashboardSection: !!dashboardSection,
        ordersSection: !!ordersSection,
        productsSection: !!productsSection,
        collectionsSection: !!collectionsSection,
        blogsSection: !!blogsSection,
        contactsSection: !!contactsSection
      });
 
      const switchTab = (activeNavBtn: any, activeSection: any) => {
        console.log('[Admin Tabs] Switching tab to:', activeSection?.id);
        [navDashboard, navOrders, navProducts, navCollections, navBlogs, navContacts].forEach(btn => {
          if (btn) {
            if (btn === activeNavBtn) {
              btn.classList.add('active');
              btn.classList.add('border-brand-charcoal', 'text-brand-charcoal', 'font-semibold');
              btn.classList.remove('border-transparent', 'text-gray-400', 'font-light');
            } else {
              btn.classList.remove('active');
              btn.classList.remove('border-brand-charcoal', 'text-brand-charcoal', 'font-semibold');
              btn.classList.add('border-transparent', 'text-gray-400', 'font-light');
            }
          }
        });
 
        [dashboardSection, ordersSection, productsSection, collectionsSection, blogsSection, contactsSection].forEach(section => {
          if (section) {
            if (section === activeSection) {
              section.classList.remove('hidden');
            } else {
              section.classList.add('hidden');
            }
          }
        });
      };
 
      navDashboard?.addEventListener('click', () => switchTab(navDashboard, dashboardSection));
      navOrders?.addEventListener('click', () => switchTab(navOrders, ordersSection));
      navProducts?.addEventListener('click', () => switchTab(navProducts, productsSection));
      navCollections?.addEventListener('click', () => switchTab(navCollections, collectionsSection));
      navBlogs?.addEventListener('click', () => switchTab(navBlogs, blogsSection));
      navContacts?.addEventListener('click', () => switchTab(navContacts, contactsSection));
 
      // Initialize the default tab
      switchTab(navDashboard, dashboardSection);
    } catch (e) {
      console.error('[Admin Tabs] Error initializing tab switcher:', e);
    }

    // Products table filtering logic
    const prodSearch = document.getElementById('admin-product-search') as HTMLInputElement | null;
    const prodCategoryFilter = document.getElementById('admin-product-category-filter') as HTMLSelectElement | null;
    const prodTagFilter = document.getElementById('admin-product-tag-filter') as HTMLSelectElement | null;
    const prodStockFilter = document.getElementById('admin-product-stock-filter') as HTMLSelectElement | null;

    const filterProducts = () => {
      const productRows = document.querySelectorAll('.product-row') as NodeListOf<HTMLTableRowElement>;
      const searchVal = prodSearch?.value.toLowerCase().trim() || '';
      const catVal = prodCategoryFilter?.value || '';
      const tagVal = prodTagFilter?.value || '';
      const stockVal = prodStockFilter?.value || '';

      productRows.forEach(row => {
        const name = row.getAttribute('data-name') || '';
        const desc = row.getAttribute('data-desc') || '';
        const categoryId = row.getAttribute('data-category-id') || '';
        const categoryName = row.getAttribute('data-category-name') || '';
        const tags = JSON.parse(row.getAttribute('data-tags') || '[]');
        const stock = parseInt(row.getAttribute('data-stock') || '0', 10);

        const matchText = !searchVal || 
                          name.includes(searchVal) || 
                          desc.includes(searchVal) || 
                          categoryName.includes(searchVal) || 
                          tags.some((t: string) => t.includes(searchVal));
        const matchCategory = !catVal || categoryId === catVal;
        const matchTag = !tagVal || tags.includes(tagVal);

        let matchStock = true;
        if (stockVal === 'out') {
          matchStock = stock === 0;
        } else if (stockVal === 'low') {
          matchStock = stock > 0 && stock <= 10;
        } else if (stockVal === 'in') {
          matchStock = stock > 10;
        }

        if (matchText && matchCategory && matchTag && matchStock) {
          row.classList.remove('hidden');
        } else {
          row.classList.add('hidden');
        }
      });
    };

    prodSearch?.addEventListener('input', filterProducts);
    prodCategoryFilter?.addEventListener('change', filterProducts);
    prodTagFilter?.addEventListener('change', filterProducts);
    prodStockFilter?.addEventListener('change', filterProducts);

    // Modal Setup helper
    const setupDialog = (dialogId: string, openBtnId?: string | null, onOpen: (() => void) | null = null) => {
      const dialog = document.getElementById(dialogId) as HTMLDialogElement | null;
      if (!dialog) return;

      if (openBtnId) {
        const openBtn = document.getElementById(openBtnId);
        openBtn?.addEventListener('click', () => {
          const errorDiv = dialog.querySelector('.text-red-500');
          if (errorDiv) errorDiv.classList.add('hidden');
          if (onOpen) onOpen();
          dialog.showModal();
        });
      }

      dialog.querySelectorAll('.close-dialog-btn').forEach(btn => {
        btn.addEventListener('click', () => dialog.close());
      });
    };

    // Helper for generating slugs
    const slugify = (text: string) => {
      return text
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/[\s_]+/g, '-')
        .replace(/^-+|-+$/g, '');
    };

    // Initialize Tiptap Editors
    let addEditor: any = null;
    let editEditor: any = null;

    try {
      const addEditorEl = document.getElementById('add-blog-editor');
      if (addEditorEl) {
        addEditor = new Editor({
          element: addEditorEl,
          extensions: [StarterKit],
          content: '',
        });
      }
    } catch (e) {
      console.error('Failed to initialize add-blog TipTap editor:', e);
    }

    try {
      const editEditorEl = document.getElementById('edit-blog-editor');
      if (editEditorEl) {
        editEditor = new Editor({
          element: editEditorEl,
          extensions: [StarterKit],
          content: '',
        });
      }
    } catch (e) {
      console.error('Failed to initialize edit-blog TipTap editor:', e);
    }

    // Toolbar logic helper
    const setupToolbar = (toolbarId: string, editorInstance: Editor | null) => {
      const toolbar = document.getElementById(toolbarId);
      if (!toolbar || !editorInstance) return;

      toolbar.querySelectorAll('button').forEach((btn: any) => {
        btn.addEventListener('click', (e: any) => {
          e.preventDefault();
          const cmd = btn.dataset.cmd;
          if (!cmd) return;

          if (cmd === 'h1') {
            editorInstance.chain().focus().toggleHeading({ level: 1 }).run();
          } else if (cmd === 'h2') {
            editorInstance.chain().focus().toggleHeading({ level: 2 }).run();
          } else if (cmd === 'h3') {
            editorInstance.chain().focus().toggleHeading({ level: 3 }).run();
          } else if (cmd === 'bold') {
            editorInstance.chain().focus().toggleBold().run();
          } else if (cmd === 'italic') {
            editorInstance.chain().focus().toggleItalic().run();
          } else if (cmd === 'bulletList') {
            editorInstance.chain().focus().toggleBulletList().run();
          } else if (cmd === 'orderedList') {
            editorInstance.chain().focus().toggleOrderedList().run();
          }
          
          updateButtonStates(toolbar, editorInstance);
        });
      });

      editorInstance.on('selectionUpdate', () => updateButtonStates(toolbar, editorInstance));
      editorInstance.on('transaction', () => updateButtonStates(toolbar, editorInstance));
    };

    const updateButtonStates = (toolbar: any, editorInstance: any) => {
      toolbar.querySelectorAll('button').forEach((btn: any) => {
        const cmd = btn.dataset.cmd;
        let isActive = false;

        if (cmd === 'h1') isActive = editorInstance.isActive('heading', { level: 1 });
        else if (cmd === 'h2') isActive = editorInstance.isActive('heading', { level: 2 });
        else if (cmd === 'h3') isActive = editorInstance.isActive('heading', { level: 3 });
        else if (cmd === 'bold') isActive = editorInstance.isActive('bold');
        else if (cmd === 'italic') isActive = editorInstance.isActive('italic');
