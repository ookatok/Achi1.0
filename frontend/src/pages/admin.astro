    // Draggable element helper
    function makeElementDraggable(el: HTMLElement, handle: HTMLElement) {
      let posX = 0, posY = 0, mouseX = 0, mouseY = 0;
      handle.onmousedown = dragMouseDown;

      function dragMouseDown(e: MouseEvent) {
        e.preventDefault();
        mouseX = e.clientX;
        mouseY = e.clientY;
        document.onmouseup = closeDragElement;
        document.onmousemove = elementDrag;
      }

      function elementDrag(e: MouseEvent) {
        e.preventDefault();
        posX = mouseX - e.clientX;
        posY = mouseY - e.clientY;
        mouseX = e.clientX;
        mouseY = e.clientY;
        
        const rect = el.getBoundingClientRect();
        let newTop = rect.top - posY;
        let newLeft = rect.left - posX;

        const maxLeft = window.innerWidth - el.offsetWidth;
        const maxTop = window.innerHeight - el.offsetHeight;
        if (newLeft < 0) newLeft = 0;
        if (newTop < 0) newTop = 0;
        if (newLeft > maxLeft) newLeft = maxLeft;
        if (newTop > maxTop) newTop = maxTop;

        el.style.top = newTop + 'px';
        el.style.left = newLeft + 'px';
      }

      function closeDragElement() {
        document.onmouseup = null;
        document.onmousemove = null;
      }

      // Touch events support
      handle.ontouchstart = dragTouchStart;
      function dragTouchStart(e: TouchEvent) {
        if (e.touches.length === 1) {
          const touch = e.touches[0];
          mouseX = touch.clientX;
          mouseY = touch.clientY;
          document.ontouchend = closeTouchDrag;
          document.ontouchmove = touchDrag;
        }
      }
      function touchDrag(e: TouchEvent) {
        if (e.touches.length === 1) {
          const touch = e.touches[0];
          posX = mouseX - touch.clientX;
          posY = mouseY - touch.clientY;
          mouseX = touch.clientX;
          mouseY = touch.clientY;

          const rect = el.getBoundingClientRect();
          let newTop = rect.top - posY;
          let newLeft = rect.left - posX;

          const maxLeft = window.innerWidth - el.offsetWidth;
          const maxTop = window.innerHeight - el.offsetHeight;
          if (newLeft < 0) newLeft = 0;
          if (newTop < 0) newTop = 0;
          if (newLeft > maxLeft) newLeft = maxLeft;
          if (newTop > maxTop) newTop = maxTop;

          el.style.top = newTop + 'px';
          el.style.left = newLeft + 'px';
        }
      }
      function closeTouchDrag() {
        document.ontouchend = null;
        document.ontouchmove = null;
      }
    }

    // Color conversion helpers
    function hsvToHex(h: number, s: number, v: number): string {
      s /= 100;
      v /= 100;
      const k = (n: number) => (n + h / 60) % 6;
      const f = (n: number) => v - v * s * Math.max(0, Math.min(k(n), 4 - k(n), 1));
      const decToHex = (x: number) => {
        const hex = Math.round(x * 255).toString(16);
        return hex.length === 1 ? '0' + hex : hex;
      };
      return `#${decToHex(f(5))}${decToHex(f(3))}${decToHex(f(1))}`;
    }

    function hexToHsv(hex: string) {
      let c = hex.replace(/^#/, '');
      if (c.length === 3) {
        c = c[0] + c[0] + c[1] + c[1] + c[2] + c[2];
      }
      if (c.length !== 6) return null;
      const r = parseInt(c.substring(0, 2), 16) / 255;
      const g = parseInt(c.substring(2, 4), 16) / 255;
      const b = parseInt(c.substring(4, 6), 16) / 255;

      const max = Math.max(r, g, b);
      const min = Math.min(r, g, b);
      const d = max - min;
      
      let h = 0;
      const s = max === 0 ? 0 : (d / max) * 100;
      const v = max * 100;

      if (max !== min) {
        switch (max) {
          case r: h = (g - b) / d + (g < b ? 6 : 0); break;
          case g: h = (b - r) / d + 2; break;
          case b: h = (r - g) / d + 4; break;
        }
        h /= 6;
      }
      return { h: Math.round(h * 360), s: Math.round(s), v: Math.round(v) };
    }

    // Color Palette Setup with Draggable Picker
    function setupColorPalette(
      inputId: string,
      buttonClass: string,
      customContainerId: string,
      draggablePickerId: string,
      draggableHandleId: string,
      pickerBtnId: string
    ) {
      const inputEl = document.getElementById(inputId) as HTMLInputElement | null;
      if (!inputEl) return;

      const presets = document.querySelectorAll(buttonClass) as NodeListOf<HTMLButtonElement>;
      const customContainer = document.getElementById(customContainerId);
      const draggablePicker = document.getElementById(draggablePickerId) as HTMLDialogElement | null;
      const handle = document.getElementById(draggableHandleId);
      const pickerBtn = document.getElementById(pickerBtnId);

      const getSelectedColors = () => {
        return inputEl.value
          .split(',')
          .map(c => c.trim())
          .filter(c => /^#[0-9A-F]{3,6}$/i.test(c));
      };

      const updateButtonStates = () => {
        const selectedColors = getSelectedColors();
        const lowerSelected = selectedColors.map(c => c.toLowerCase());

        // 1. Update presets
        const presetHexs: string[] = [];
        presets.forEach(btn => {
          const hex = (btn.dataset.color || '').toLowerCase();
          presetHexs.push(hex);
          const isActive = lowerSelected.includes(hex);
          const checkIcon = btn.querySelector('.check-icon');
          if (isActive) {
            btn.classList.add('ring-2', 'ring-stone-800', 'ring-offset-1', 'scale-110');
            if (checkIcon) checkIcon.classList.remove('hidden');
          } else {
            btn.classList.remove('ring-2', 'ring-stone-800', 'ring-offset-1', 'scale-110');
            if (checkIcon) checkIcon.classList.add('hidden');
          }
        });

        // 2. Render dynamic custom color badges
        if (customContainer) {
          customContainer.innerHTML = '';
          const customColors = selectedColors.filter(c => !presetHexs.includes(c.toLowerCase()));
          
          customColors.forEach(hex => {
            const badge = document.createElement('button');
            badge.type = 'button';
            badge.className = 'w-6 h-6 rounded-full cursor-pointer border border-stone-300 shadow-xs flex items-center justify-center text-[10px] font-bold transition-all hover:scale-110 active:scale-95 shrink-0';
            badge.style.backgroundColor = hex;
            
            // Calculate text contrast
            const isLightColor = (hexStr: string) => {
              let c = hexStr.substring(1);
              if (c.length === 3) {
                c = c[0] + c[0] + c[1] + c[1] + c[2] + c[2];
              }
              const rgb = parseInt(c, 16);
              const r = (rgb >> 16) & 0xff;
              const g = (rgb >> 8) & 0xff;
              const b = (rgb >> 0) & 0xff;
              const luma = 0.2126 * r + 0.7152 * g + 0.0722 * b;
              return luma > 180;
            };
            badge.style.color = isLightColor(hex) ? '#1a1a1a' : '#ffffff';
            badge.title = `${hex} (Click to remove)`;
            badge.innerHTML = '✕';

            badge.addEventListener('click', () => {
              const current = getSelectedColors();
              const filtered = current.filter(c => c.toLowerCase() !== hex.toLowerCase());
              inputEl.value = filtered.join(', ');
              updateButtonStates();
              inputEl.dispatchEvent(new Event('input'));
            });

            customContainer.appendChild(badge);
          });
        }
      };

      presets.forEach(btn => {
        btn.addEventListener('click', () => {
          const hex = btn.dataset.color || '';
          const current = getSelectedColors();
          const lowerColors = current.map(c => c.toLowerCase());
          const index = lowerColors.indexOf(hex.toLowerCase());

          if (index > -1) {
            current.splice(index, 1);
          } else {
            current.push(hex);
          }

          inputEl.value = current.join(', ');
          updateButtonStates();
          inputEl.dispatchEvent(new Event('input'));
        });
      });

      // Draggable color picker event mapping
      if (draggablePicker && handle && pickerBtn) {
        makeElementDraggable(draggablePicker, handle);

        const closeBtn = draggablePicker.querySelector('.close-picker-btn');
        const svBox = draggablePicker.querySelector('.color-picker-sv-box') as HTMLElement;
        const svCursor = draggablePicker.querySelector('.color-picker-sv-cursor') as HTMLElement;
        const hueSlider = draggablePicker.querySelector('.color-picker-hue') as HTMLInputElement;
        const preview = draggablePicker.querySelector('.color-picker-preview') as HTMLElement;
        const hexInput = draggablePicker.querySelector('.color-picker-hex-input') as HTMLInputElement;
        const selectBtn = draggablePicker.querySelector('.color-picker-select-btn');
        const dropperBtn = draggablePicker.querySelector('.color-picker-dropper-btn') as HTMLButtonElement | null;

        let currentH = 0;
        let currentS = 100;
        let currentV = 100;

        const updatePickerUi = (hexVal: string) => {
          preview.style.backgroundColor = hexVal;
          hexInput.value = hexVal.toUpperCase();
          svBox.style.backgroundColor = `hsl(${currentH}, 100%, 50%)`;
          svCursor.style.left = `${currentS}%`;
          svCursor.style.top = `${100 - currentV}%`;
          hueSlider.value = String(currentH);
        };

        const updateFromHsv = () => {
          const hex = hsvToHex(currentH, currentS, currentV);
          updatePickerUi(hex);
        };

        if (dropperBtn && 'EyeDropper' in window) {
          dropperBtn.classList.remove('hidden');
          dropperBtn.addEventListener('click', async () => {
            try {
              const eyeDropper = new (window as any).EyeDropper();
              const result = await eyeDropper.open();
              const hex = result.sRGBHex;
              const hsv = hexToHsv(hex);
              if (hsv) {
                currentH = hsv.h;
                currentS = hsv.s;
                currentV = hsv.v;
                updatePickerUi(hex);
              }
            } catch (err) {
              console.error('EyeDropper failed:', err);
            }
          });
        }

        pickerBtn.addEventListener('click', () => {
          if (draggablePicker) draggablePicker.showModal();
          const topVal = Math.max(20, (window.innerHeight - draggablePicker.offsetHeight) / 2);
          const leftVal = Math.max(20, (window.innerWidth - draggablePicker.offsetWidth) / 2);
          draggablePicker.style.top = `${topVal}px`;
          draggablePicker.style.left = `${leftVal}px`;
          draggablePicker.style.transform = 'none';
          
          const currentVal = hexInput.value;
          const hsv = hexToHsv(currentVal);
          if (hsv) {
            currentH = hsv.h;
            currentS = hsv.s;
            currentV = hsv.v;
          }
          updateFromHsv();
        });

        if (closeBtn) {
          closeBtn.addEventListener('click', () => {
            if (draggablePicker) draggablePicker.close();
          });
        }

        hueSlider.addEventListener('input', () => {
          currentH = parseInt(hueSlider.value, 10);
          updateFromHsv();
        });

        let isMouseDownOnSv = false;
        const handleSvEvent = (e: MouseEvent | TouchEvent) => {
          const rect = svBox.getBoundingClientRect();
          let clientX = 0;
          let clientY = 0;
          
          if ('touches' in e) {
            if (e.touches.length === 0) return;
            clientX = e.touches[0].clientX;
            clientY = e.touches[0].clientY;
          } else {
            clientX = e.clientX;
            clientY = e.clientY;
          }
          
          let x = clientX - rect.left;
          let y = clientY - rect.top;
          
          if (x < 0) x = 0;
          if (x > rect.width) x = rect.width;
          if (y < 0) y = 0;
          if (y > rect.height) y = rect.height;
          
          currentS = Math.round((x / rect.width) * 100);
          currentV = Math.round((1 - y / rect.height) * 100);
          updateFromHsv();
        };

        svBox.addEventListener('mousedown', (e) => {
          isMouseDownOnSv = true;
          handleSvEvent(e);
        });
        document.addEventListener('mousemove', (e) => {
          if (isMouseDownOnSv) handleSvEvent(e);
        });
        document.addEventListener('mouseup', () => {
          isMouseDownOnSv = false;
        });

        svBox.addEventListener('touchstart', (e) => {
          handleSvEvent(e);
        }, { passive: true });
        svBox.addEventListener('touchmove', (e) => {
          handleSvEvent(e);
        }, { passive: true });

        hexInput.addEventListener('change', () => {
          const hsv = hexToHsv(hexInput.value);
          if (hsv) {
            currentH = hsv.h;
            currentS = hsv.s;
            currentV = hsv.v;
            updatePickerUi(hexInput.value);
          }
        });

        if (selectBtn) {
          selectBtn.addEventListener('click', () => {
            const hex = hsvToHex(currentH, currentS, currentV);
            const current = getSelectedColors();
            if (!current.map(c => c.toLowerCase()).includes(hex.toLowerCase())) {
              current.push(hex);
              inputEl.value = current.join(', ');
              updateButtonStates();
              inputEl.dispatchEvent(new Event('input'));
            }
            if (draggablePicker) draggablePicker.close();
          });
        }
      }

      inputEl.addEventListener('input', updateButtonStates);
      updateButtonStates();
    }

    // Initialize palettes
    setupColorPalette(
      'add-colors',
      '.color-palette-btn-add',
      'add-custom-colors-container',
      'add-draggable-color-picker',
      'add-draggable-color-picker-handle',
      'add-custom-color-btn'
    );
    setupColorPalette(
      'edit-colors',
      '.color-palette-btn-edit',
      'edit-custom-colors-container',
      'edit-draggable-color-picker',
      'edit-draggable-color-picker-handle',
      'edit-custom-color-btn'
    );

    const addColorsInput = document.getElementById('add-colors') as HTMLInputElement | null;
    if (addColorsInput) {
      addColorsInput.addEventListener('input', () => {
        updateMultiImageColorSelectors('add');
        renderMultiImagesList('add');
      });
    }
    const editColorsInput = document.getElementById('edit-colors') as HTMLInputElement | null;
    if (editColorsInput) {
      editColorsInput.addEventListener('input', () => {
        updateMultiImageColorSelectors('edit');
        renderMultiImagesList('edit');
      });
    }

    // Collections CRUD Scripting
    const addColDialog = document.getElementById('add-collection-dialog') as HTMLDialogElement | null;
    const addColForm = document.getElementById('add-collection-form');
    const addColError = document.getElementById('add-col-error');

    setupDialog('add-collection-dialog', 'open-add-collection-btn', () => {
      if (addColForm) (addColForm as HTMLFormElement).reset();
      const previewContainer = document.getElementById('add-collection-image-preview-container');
      if (previewContainer) previewContainer.classList.add('hidden');
      const uploadStatus = document.getElementById('add-collection-upload-status');
      if (uploadStatus) uploadStatus.classList.add('hidden');
      if (addColError) addColError.classList.add('hidden');
    });

    addColForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (addColError) addColError.classList.add('hidden');

      const title = (document.getElementById('add-col-title') as HTMLInputElement).value;
      const slug = (document.getElementById('add-col-slug') as HTMLInputElement).value;
      const imageUrl = (document.getElementById('add-col-image') as HTMLInputElement).value;
      const description = (document.getElementById('add-col-desc') as HTMLInputElement).value;
      const publishDateStr = (document.getElementById('add-col-publish') as HTMLInputElement).value;
      const publishDate = publishDateStr ? new Date(publishDateStr).toISOString() : null;

      const productIds: number[] = [];
      document.querySelectorAll('#add-col-products-container input[type="checkbox"]:checked').forEach((cb) => {
        productIds.push(parseInt((cb as HTMLInputElement).value, 10));
      });

      const payload = { title, slug, description, imageUrl, publishDate, productIds };

      try {
        const res = await fetch('http://localhost:3001/api/collections', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          if (addColError) {
            addColError.textContent = Array.isArray(data.message) ? data.message.join(', ') : (data.message || 'Failed to create collection.');
            addColError.classList.remove('hidden');
          }
        }
      } catch (err) {
        console.error(err);
        if (addColError) {
          addColError.textContent = getMsg('failedConnectBackend');
          addColError.classList.remove('hidden');
        }
      }
    });

    const editColDialog = document.getElementById('edit-collection-dialog') as HTMLDialogElement | null;
    const editColForm = document.getElementById('edit-collection-form');
    const editColError = document.getElementById('edit-col-error');

    setupDialog('edit-collection-dialog');

    document.querySelectorAll('.edit-col-btn').forEach((btn: any) => {
      btn.addEventListener('click', () => {
        if (editColError) editColError.classList.add('hidden');

        const id = btn.dataset.id || '';
        const title = btn.dataset.title || '';
        const slug = btn.dataset.slug || '';
        const image = btn.dataset.image || '';
        const desc = btn.dataset.desc || '';
        const publish = btn.dataset.publish || '';
        const productIds = JSON.parse(btn.dataset.products || '[]');

        (document.getElementById('edit-col-id') as HTMLInputElement).value = id;
        (document.getElementById('edit-col-title') as HTMLInputElement).value = title;
        (document.getElementById('edit-col-slug') as HTMLInputElement).value = slug;
        (document.getElementById('edit-col-desc') as HTMLInputElement).value = desc;
        (document.getElementById('edit-col-image') as HTMLInputElement).value = image;
        (document.getElementById('edit-col-publish') as HTMLInputElement).value = publish;

        // Reset file input & upload status
        const fileInput = document.getElementById('edit-collection-image-file') as HTMLInputElement | null;
        if (fileInput) fileInput.value = '';
        const uploadStatus = document.getElementById('edit-collection-upload-status');
        if (uploadStatus) uploadStatus.classList.add('hidden');

        // Set preview image if exists
        const previewContainer = document.getElementById('edit-collection-image-preview-container');
        const preview = document.getElementById('edit-collection-image-preview') as HTMLImageElement | null;
        if (image) {
          let src = image;
          if (!src.startsWith('http') && src.startsWith('/')) {
            src = `http://localhost:3001${src}`;
          }
          if (preview && previewContainer) {
            preview.src = src;
            previewContainer.classList.remove('hidden');
          }
        } else {
          if (previewContainer) previewContainer.classList.add('hidden');
        }

        // Set checkboxes
        document.querySelectorAll('#edit-col-products-container input[type="checkbox"]').forEach((cb) => {
          const checkbox = cb as HTMLInputElement;
          checkbox.checked = productIds.includes(parseInt(checkbox.value, 10));
        });

        editColDialog?.showModal();
      });
    });

    editColForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (editColError) editColError.classList.add('hidden');

      const id = (document.getElementById('edit-col-id') as HTMLInputElement).value;
      const title = (document.getElementById('edit-col-title') as HTMLInputElement).value;
      const slug = (document.getElementById('edit-col-slug') as HTMLInputElement).value;
      const imageUrl = (document.getElementById('edit-col-image') as HTMLInputElement).value;
      const description = (document.getElementById('edit-col-desc') as HTMLInputElement).value;
      const publishDateStr = (document.getElementById('edit-col-publish') as HTMLInputElement).value;
      const publishDate = publishDateStr ? new Date(publishDateStr).toISOString() : null;

      const productIds: number[] = [];
      document.querySelectorAll('#edit-col-products-container input[type="checkbox"]:checked').forEach((cb) => {
        productIds.push(parseInt((cb as HTMLInputElement).value, 10));
      });

      const payload = { title, slug, description, imageUrl, publishDate, productIds };

      try {
        const res = await fetch(`http://localhost:3001/api/collections/${id}`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          if (editColError) {
            editColError.textContent = Array.isArray(data.message) ? data.message.join(', ') : (data.message || 'Failed to update collection.');
            editColError.classList.remove('hidden');
          }
        }
      } catch (err) {
        console.error(err);
        if (editColError) {
          editColError.textContent = getMsg('failedConnectBackend');
          editColError.classList.remove('hidden');
        }
      }
    });

    document.querySelectorAll('.delete-col-btn').forEach((btn: any) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        if (!id) return;
        if (!confirm(lang === 'en' ? 'Are you sure you want to delete this collection?' : 'คุณแน่ใจหรือไม่ที่จะลบคอลเลกชันนี้?')) return;

        try {
          const res = await fetch(`http://localhost:3001/api/collections/${id}`, {
            method: 'DELETE',
            headers: {
              'Authorization': `Bearer ${token}`
            }
          });

          if (res.ok) {
            window.location.reload();
          } else {
            alert(lang === 'en' ? 'Failed to delete collection.' : 'ลบคอลเลกชันไม่สำเร็จ');
          }
        } catch (err) {
          console.error(err);
          alert(lang === 'en' ? 'Network error occurred.' : 'เกิดข้อผิดพลาดในการเชื่อมต่อ');
        }
      });
    });
  </script>
</Layout>
