                      </td>
                      <td class="p-4 border border-stone-100 max-w-[250px] truncate">
                        {blog.summary || (lang === 'en' ? 'No summary' : 'ไม่มีสรุปเนื้อหา')}
                      </td>
                      <td class="p-4 border border-stone-100 text-stone-400">
                        {new Date(blog.createdAt).toLocaleDateString()}
                      </td>
                      <td class="p-4 border border-stone-100 text-center">
                        <div class="flex items-center justify-center gap-2">
                          <button
                            class="edit-blog-btn border border-stone-200 text-stone-600 hover:border-brand-charcoal hover:text-brand-charcoal px-3 py-1.5 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer"
                            data-id={blog.id}
                            data-title={blog.title}
                            data-slug={blog.slug}
                            data-summary={blog.summary}
                            data-content={blog.content}
                            data-image={blog.imageUrl}
                            data-category={blog.categoryId || ''}
                          >
                            {t('admin.btn_edit')}
                          </button>
                          <button
                            class="delete-blog-btn border border-red-200 text-red-500 hover:bg-red-50 hover:border-red-500 px-3 py-1.5 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer"
                            data-id={blog.id}
                            data-title={blog.title}
                          >
                            {t('admin.btn_delete')}
                          </button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>

        <!-- Blog Categories Sidebar (Col 4) -->
        <div class="border border-stone-200 p-6 rounded-sm bg-stone-50/50 space-y-6 self-start shadow-sm">
          <div>
            <h3 class="font-serif text-xs tracking-widest uppercase text-brand-charcoal font-semibold mb-3 pb-2 border-b border-stone-200">
              {lang === 'en' ? 'Blog Categories' : 'หมวดหมู่บล็อก'}
            </h3>
            
            {blogCategories.length === 0 ? (
              <p class="text-[10px] text-stone-400 font-light">{lang === 'en' ? 'No categories created yet.' : 'ยังไม่มีหมวดหมู่บล็อกในระบบ'}</p>
            ) : (
              <ul class="space-y-2 max-h-[200px] overflow-y-auto pr-1">
                {blogCategories.map((cat: any) => (
                  <li class="flex items-center justify-between text-xs py-1.5 border-b border-stone-100">
                    <span class="font-medium text-brand-charcoal font-mono text-[11px]">{cat.name}</span>
                    <button 
                      type="button" 
                      class="delete-blog-cat-btn text-red-500 hover:text-red-700 text-[9px] uppercase tracking-widest font-semibold cursor-pointer transition-colors"
                      data-id={cat.id}
                      data-name={cat.name}
                    >
                      {t('admin.btn_delete')}
                    </button>
                  </li>
                ))}
              </ul>
            )}
          </div>

          <div class="pt-4 border-t border-stone-200">
            <h4 class="font-serif text-[10px] tracking-widest uppercase text-stone-400 font-semibold mb-2">
              {lang === 'en' ? 'Create New Category' : 'สร้างหมวดหมู่ใหม่'}
            </h4>
            <form id="create-blog-cat-form" class="space-y-3">
              <div>
                <label class="block text-[8px] uppercase tracking-widest text-stone-400 font-semibold mb-0.5">{lang === 'en' ? 'Category Name' : 'ชื่อหมวดหมู่'}</label>
                <input 
                  type="text" 
                  id="new-blog-cat-name" 
                  placeholder="e.g. Styling Guide" 
                  required 
                  class="w-full border border-stone-200 px-2.5 py-1.5 text-xs focus:outline-none focus:border-brand-charcoal rounded-sm bg-white" 
                />
              </div>
              <div>
                <label class="block text-[8px] uppercase tracking-widest text-stone-400 font-semibold mb-0.5">{lang === 'en' ? 'Slug' : 'สลัก (Slug)'}</label>
                <input 
                  type="text" 
                  id="new-blog-cat-slug" 
                  placeholder="e.g. styling-guide" 
                  required 
                  class="w-full border border-stone-200 px-2.5 py-1.5 text-xs focus:outline-none focus:border-brand-charcoal rounded-sm bg-white" 
                />
              </div>
              <button 
                type="submit" 
                class="w-full bg-brand-charcoal text-white hover:bg-stone-800 py-2 rounded-sm text-[9px] uppercase tracking-widest font-semibold transition-all cursor-pointer shadow-sm"
              >
                {lang === 'en' ? 'Add Category' : 'เพิ่มหมวดหมู่'}
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: Contact Requests Management -->
    <div id="contacts-section" class="bg-white border border-stone-200 p-8 rounded-sm space-y-6 hidden">
      <div class="flex justify-between items-center pb-2 border-b border-stone-100">
        <h2 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium">
          {t('admin.contacts_title')}
        </h2>
      </div>

      <div class="space-y-6">
        {contacts.length === 0 ? (
          <div class="text-center py-12 text-gray-400 text-xs font-light bg-stone-50 border border-dashed border-stone-200 rounded-sm">
            {t('admin.no_contacts')}
          </div>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-left text-xs text-stone-500 border-collapse border border-stone-100">
              <thead>
                <tr class="bg-stone-50 text-brand-charcoal uppercase font-semibold text-[10px] tracking-wider">
                  <th class="p-4 border border-stone-100">{t('admin.date')}</th>
                  <th class="p-4 border border-stone-100">{lang === 'en' ? 'Customer Info' : 'ข้อมูลลูกค้า'}</th>
                  <th class="p-4 border border-stone-100">{lang === 'en' ? 'Topic' : 'หัวเรื่อง'}</th>
                  <th class="p-4 border border-stone-100">{lang === 'en' ? 'Description' : 'รายละเอียดข้อความ'}</th>
                </tr>
              </thead>
              <tbody>
                {contacts.map((req: any) => (
                  <tr class="hover:bg-stone-50/50 transition-colors">
                    <td class="p-4 border border-stone-100 w-40 font-mono text-[10px]">
                      {new Date(req.createdAt).toLocaleString()}
                    </td>
                    <td class="p-4 border border-stone-100 w-52">
                      <div class="font-semibold text-brand-charcoal">{req.name}</div>
                      <div class="text-[10px] text-stone-400 mt-0.5">{req.email}</div>
                      {req.phone && <div class="text-[10px] text-stone-400 mt-0.5">tel: {req.phone}</div>}
                    </td>
                    <td class="p-4 border border-stone-100 w-44 font-medium uppercase tracking-wider text-brand-charcoal animate-pulse">
                      <span class="px-2.5 py-0.5 bg-stone-100 rounded text-[9px]">
                        {req.topic}
                      </span>
                    </td>
                    <td class="p-4 border border-stone-100 normal-case leading-relaxed text-stone-600 font-light max-w-md">
                      <details class="group cursor-pointer focus:outline-none select-none">
                        <summary class="flex justify-between items-center gap-4 text-stone-700 hover:text-brand-charcoal transition-colors">
                          <span class="truncate max-w-[240px] block">
                            {req.description}
                          </span>
                          <span class="text-[9px] text-stone-400 font-semibold uppercase tracking-widest shrink-0 border border-stone-200 px-1.5 py-0.5 rounded-sm hover:border-brand-charcoal hover:text-brand-charcoal group-open:hidden transition-colors">
                            {lang === 'en' ? 'Read' : 'อ่านเพิ่มเติม'}
                          </span>
                          <span class="text-[9px] text-stone-400 font-semibold uppercase tracking-widest shrink-0 border border-stone-200 px-1.5 py-0.5 rounded-sm hover:border-brand-charcoal hover:text-brand-charcoal hidden group-open:inline-block transition-colors">
                            {lang === 'en' ? 'Close' : 'ปิด'}
                          </span>
                        </summary>
                        <div class="mt-2.5 p-3.5 bg-stone-50 border border-stone-200 rounded-sm text-stone-600 font-light leading-relaxed normal-case tracking-normal whitespace-pre-wrap text-[11px] break-words">
                          {req.description}
                        </div>
                      </details>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>

    <!-- Section: Collections Management -->
    <div id="collections-section" class="bg-white border border-stone-200 p-8 rounded-sm space-y-6 hidden">
      <div class="flex justify-between items-center pb-2 border-b border-stone-100">
        <h2 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium">
          {t('admin.collections_title')}
        </h2>
        <button
          id="open-add-collection-btn"
          type="button"
          class="bg-brand-charcoal text-white hover:bg-stone-800 px-4 py-2 rounded-sm text-[10px] uppercase tracking-widest font-semibold cursor-pointer transition-colors"
        >
          {t('admin.add_collection')}
        </button>
      </div>

      <div class="space-y-6">
        {collections.length === 0 ? (
          <div class="text-center py-12 text-gray-400 text-xs font-light bg-stone-50 border border-dashed border-stone-200 rounded-sm">
            {lang === 'en' ? 'No collections found.' : 'ไม่พบคอลเลกชันในระบบ'}
          </div>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-left text-xs text-stone-500 border-collapse border border-stone-100">
              <thead>
                <tr class="bg-stone-50 text-brand-charcoal uppercase font-semibold text-[10px] tracking-wider">
                  <th class="p-4 border border-stone-100 w-16">{t('admin.th_image')}</th>
                  <th class="p-4 border border-stone-100 text-left">{t('admin.collection_title')}</th>
                  <th class="p-4 border border-stone-100 text-left w-36">{t('admin.publish_date')}</th>
                  <th class="p-4 border border-stone-100 text-left w-32">{lang === 'en' ? 'Publish Status' : 'สถานะการโพสต์'}</th>
                  <th class="p-4 border border-stone-100 text-left w-36">{lang === 'en' ? 'Associated Products' : 'สินค้าที่เชื่อมโยง'}</th>
                  <th class="p-4 border border-stone-100 text-center w-32">{t('admin.th_actions')}</th>
                </tr>
              </thead>
              <tbody>
                {collections.map((col: any) => {
                  const publishDate = col.publishDate ? new Date(col.publishDate) : null;
                  const isScheduled = publishDate && publishDate > new Date();
                  const statusText = isScheduled 
                    ? (lang === 'en' ? 'Scheduled' : 'ตั้งเวลาเผยแพร่') 
                    : (lang === 'en' ? 'Active' : 'เผยแพร่แล้ว');
                  const statusClass = isScheduled 
                    ? 'bg-blue-50 text-blue-600 border-blue-100' 
                    : 'bg-green-50 text-green-600 border-green-100';

                  return (
                    <tr class="hover:bg-stone-50/50 transition-colors">
                      <td class="p-4 border border-stone-100 w-16">
                        {col.imageUrl ? (
                          <img src={resolveImage(col.imageUrl)} alt={col.title} class="w-12 h-14 object-cover rounded-sm border border-stone-100" />
                        ) : (
                          <div class="w-12 h-14 bg-stone-100 rounded-sm border border-stone-200 flex items-center justify-center text-[9px] uppercase text-stone-400 font-light font-mono">No Pic</div>
                        )}
                      </td>
                      <td class="p-4 border border-stone-100">
                        <div class="font-semibold text-brand-charcoal">{col.title}</div>
                        <div class="text-[9px] text-stone-400 font-mono mt-0.5">slug: {col.slug}</div>
                      </td>
                      <td class="p-4 border border-stone-100 text-[10px] font-mono">
                        {publishDate ? publishDate.toLocaleString() : '-'}
                      </td>
                      <td class="p-4 border border-stone-100">
                        <span class={`inline-block px-2.5 py-0.5 text-[9px] font-bold uppercase tracking-wider rounded border ${statusClass}`}>
                          {statusText}
                        </span>
                      </td>
                      <td class="p-4 border border-stone-100 text-[10px] leading-relaxed">
                        {col.products && col.products.length > 0 ? (
                          <div class="space-y-1">
                            {col.products.map((p: any) => (
                              <div class="flex items-center gap-1.5 flex-wrap">
                                <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${p.status === 'inactive' ? 'bg-red-500' : 'bg-green-500'}`} title={p.status === 'inactive' ? t('admin.status_inactive') : t('admin.status_active')}></span>
                                <span class="truncate max-w-[120px]">{p.name}</span>
                                <span class={`text-[8px] px-1 rounded-sm ${p.status === 'inactive' ? 'bg-red-50 text-red-600 border border-red-100/50' : 'bg-green-50 text-green-600 border border-green-100/50'}`}>
                                  {p.status === 'inactive' ? t('admin.status_inactive') : t('admin.status_active')}
                                </span>
                              </div>
                            ))}
                          </div>
                        ) : (
                          <span class="text-stone-400 font-light italic">{lang === 'en' ? 'No products' : 'ไม่มีสินค้า'}</span>
                        )}
                      </td>
                      <td class="p-4 border border-stone-100 text-center">
                        <div class="flex justify-center gap-1.5">
                          <button
                            type="button"
                            class="edit-col-btn border border-stone-200 hover:border-brand-charcoal text-stone-600 hover:text-brand-charcoal px-2.5 py-1.5 rounded-sm text-[9px] uppercase tracking-wider font-semibold cursor-pointer transition-colors"
                            data-id={col.id}
                            data-title={col.title}
                            data-slug={col.slug}
                            data-image={col.imageUrl || ''}
                            data-desc={col.description || ''}
                            data-publish={col.publishDate ? col.publishDate.substring(0, 16) : ''}
                            data-products={JSON.stringify((col.products || []).map((p: any) => p.id))}
                          >
                            {t('admin.btn_edit')}
                          </button>
                          <button
                            type="button"
                            class="delete-col-btn border border-stone-200 hover:border-red-500 text-stone-600 hover:text-red-500 px-2.5 py-1.5 rounded-sm text-[9px] uppercase tracking-wider font-semibold cursor-pointer transition-colors"
                            data-id={col.id}
                          >
                            {t('admin.btn_delete')}
                          </button>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Add Product Dialog -->
  <dialog id="add-product-dialog" class="bg-white border border-stone-200 p-8 rounded-sm max-w-lg w-full">
    <div class="flex items-center justify-between pb-4 border-b border-stone-100 mb-6">
      <h3 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium">{t('admin.add_product')}</h3>
      <button class="close-dialog-btn text-stone-400 hover:text-brand-charcoal text-lg font-light cursor-pointer">&times;</button>
    </div>
    <div id="add-error" class="hidden text-[10px] text-red-500 bg-red-50 p-2.5 border-l-2 border-red-500 mb-4 rounded-sm font-light"></div>
    <form id="add-product-form" class="space-y-4">
      <div>
        <label class="block text-[10px] uppercase tracking-widest text-stone-400 font-semibold mb-1">{t('admin.product_name')}</label>
        <input type="text" id="add-name" required class="w-full border border-stone-200 px-3 py-2 text-xs focus:outline-none focus:border-brand-charcoal rounded-sm" />
      </div>
      <div>
        <label class="block text-[10px] uppercase tracking-widest text-stone-400 font-semibold mb-1">{t('admin.slug')}</label>
        <input type="text" id="add-slug" required class="w-full border border-stone-200 px-3 py-2 text-xs focus:outline-none focus:border-brand-charcoal rounded-sm" />
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-[10px] uppercase tracking-widest text-stone-400 font-semibold mb-1">{t('admin.price_usd')}</label>
          <input type="number" id="add-price" step="0.01" required class="w-full border border-stone-200 px-3 py-2 text-xs focus:outline-none focus:border-brand-charcoal rounded-sm" />
