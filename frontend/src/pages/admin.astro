      font-size: 1.35rem;
      font-weight: 600;
      margin-top: 1rem;
      margin-bottom: 0.4rem;
      color: #1c1917;
      text-transform: uppercase;
      font-family: inherit;
    }
    .ProseMirror h3 {
      font-size: 1.15rem;
      font-weight: 600;
      margin-top: 0.75rem;
      margin-bottom: 0.3rem;
      color: #1c1917;
      text-transform: uppercase;
      font-family: inherit;
    }
