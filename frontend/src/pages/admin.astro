---
import Layout from '../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';

const session = await getSession(Astro.request);
const token = (session as any)?.accessToken;

if (!token) {
  return Astro.redirect('/auth/signin?callbackUrl=/admin');
}

// Security double check (just in case middleware is bypassed)
if ((session?.user as any)?.role !== 'admin') {
  return new Response('Forbidden: Admin access only.', { status: 403 });
}

let productsCount = 0;
let orders = [] as any[];
let products = [] as any[];
let blogs = [] as any[];
let blogCategories = [] as any[];
let productCategories = [] as any[];
let errorMsg = null;

try {
  // 1. Fetch products list
  const prodRes = await fetch('http://localhost:3001/api/products?limit=100');
  if (prodRes.ok) {
    products = await prodRes.json();
    productsCount = products.length;
  }

  // 2. Fetch all orders (since we are admin, we can fetch all orders or look up our own)
  const ordRes = await fetch('http://localhost:3001/api/orders', {
    headers: {
      'Authorization': `Bearer ${token}`
    }
  });
  if (ordRes.ok) {
    orders = await ordRes.json();
  }

  // 3. Fetch all blogs
  const blogRes = await fetch('http://localhost:3001/api/blogs');
  if (blogRes.ok) {
    blogs = await blogRes.json();
  }

  // 4. Fetch all blog categories
  const catRes = await fetch('http://localhost:3001/api/blogs/categories');
  if (catRes.ok) {
    blogCategories = await catRes.json();
  }

  // 5. Fetch all product categories
  const prodCatRes = await fetch('http://localhost:3001/api/products/categories');
  if (prodCatRes.ok) {
    productCategories = await prodCatRes.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Admin page fetch failed.', err);
  errorMsg = 'Could not load admin panel data. Backend server may be offline.';
}

const parseArray = (val: any) => {
  try {
    const parsed = typeof val === 'string' ? JSON.parse(val) : val;
    return Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    return [];
  }
};
---

<Layout title="Admin Panel | ACHI Studio" description="ACHI E-Commerce administrative console." isAdminPanel={true}>
  <div id="admin-container" data-token={token} class="max-w-[1000px] mx-auto px-6 py-24">
    {/* Page Header */}
    <div class="flex flex-col md:flex-row justify-between items-center mb-16 gap-4 border-b border-stone-100 pb-8">
      <div class="text-center md:text-left">
        <h1 class="font-serif text-3xl tracking-widest font-bold uppercase text-brand-charcoal">Admin Panel</h1>
        <p class="text-[10px] tracking-[0.2em] uppercase text-gray-400 mt-2 font-light">E-Commerce Management Console</p>
      </div>
      <div>
        <button
          id="signout-btn"
          class="border border-stone-300 text-stone-600 hover:border-brand-charcoal hover:text-brand-charcoal px-6 py-2.5 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer"
        >
          Sign Out
        </button>
      </div>
    </div>

    {errorMsg && (
      <div class="text-xs text-red-500 font-light bg-red-50 p-4 border-l-2 border-red-500 rounded-sm mb-8">
        {errorMsg}
      </div>
    )}

    <!-- Section: Dashboard Overview -->
    <div id="dashboard-section" class="bg-white border border-stone-200 p-8 rounded-sm space-y-8 mb-8">
      <div class="pb-2 border-b border-stone-100">
        <h2 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium">
          Dashboard Overview
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <!-- Card 1: Products Count -->
        <div class="bg-gray-50 border border-gray-100 p-6 rounded-sm text-center">
          <span class="block text-[10px] uppercase tracking-wider font-semibold text-gray-400 mb-2">Total Products</span>
          <span class="text-3xl font-serif font-bold text-brand-charcoal">{productsCount}</span>
        </div>

        <!-- Card 2: Orders Count -->
        <div class="bg-gray-50 border border-gray-100 p-6 rounded-sm text-center">
          <span class="block text-[10px] uppercase tracking-wider font-semibold text-gray-400 mb-2">Total Orders</span>
          <span class="text-3xl font-serif font-bold text-brand-charcoal">{orders.length}</span>
        </div>

        <!-- Card 3: Blogs Count -->
        <div class="bg-gray-50 border border-gray-100 p-6 rounded-sm text-center">
          <span class="block text-[10px] uppercase tracking-wider font-semibold text-gray-400 mb-2">Total Blogs</span>
          <span class="text-3xl font-serif font-bold text-brand-charcoal">{blogs.length}</span>
        </div>

        <!-- Card 4: Server Status -->
        <div class="bg-gray-50 border border-gray-100 p-6 rounded-sm text-center">
          <span class="block text-[10px] uppercase tracking-wider font-semibold text-gray-400 mb-2">Server Status</span>
          <span class="text-xs font-semibold text-green-600 uppercase tracking-widest bg-green-50 px-2.5 py-1.5 rounded-full border border-green-100 inline-block mt-1">
            Online
          </span>
        </div>
      </div>

      <!-- Welcome Note -->
      <div class="p-6 bg-stone-50 border border-stone-100 rounded-sm">
        <h3 class="font-serif text-xs tracking-widest uppercase text-brand-charcoal font-semibold mb-2">Welcome to ACHI Studio Console</h3>
        <p class="text-[11px] text-stone-500 font-light leading-relaxed">
          From this panel, you can manage orders, products, and categories, as well as create and edit blog posts. Use the navigation links at the top of the page to switch between modules.
        </p>
      </div>
    </div>

    <!-- Section: Orders Management -->
    <div id="orders-section" class="bg-white border border-stone-200 p-8 rounded-sm space-y-6 hidden">
      <h2 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium pb-2 border-b border-stone-100">
        System Orders List
      </h2>

      {orders.length === 0 ? (
        <div class="text-center py-12 text-gray-400 text-xs font-light">
          No orders found in the database.
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-left text-xs text-gray-500 border-collapse border border-gray-100">
            <thead>
              <tr class="bg-gray-50 text-brand-charcoal uppercase font-semibold">
                <th class="p-3 border border-gray-100">Order ID</th>
                <th class="p-3 border border-gray-100">Date</th>
                <th class="p-3 border border-gray-100">Shipping Address</th>
                <th class="p-3 border border-gray-100 text-right">Amount</th>
                <th class="p-3 border border-gray-100 text-center">Status</th>
              </tr>
            </thead>
            <tbody>
              {orders.map((order: any) => (
                <tr class="hover:bg-stone-50/50 transition-colors">
                  <td class="p-3 border border-gray-100 font-medium text-brand-charcoal">#{order.id}</td>
                  <td class="p-3 border border-gray-100">{new Date(order.createdAt).toLocaleDateString()}</td>
                  <td class="p-3 border border-gray-100 max-w-[250px] truncate">{order.shippingAddress}</td>
                  <td class="p-3 border border-gray-100 text-right font-semibold text-brand-charcoal">
                    ${Number(order.totalPrice).toLocaleString()}
                  </td>
                  <td class="p-3 border border-gray-100 text-center">
                    <span class="text-[9px] uppercase tracking-widest text-amber-600 bg-amber-50 px-2.5 py-0.5 rounded-full border border-amber-100 font-semibold inline-block">
                      {order.status}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <!-- Section: Products Management -->
    <div id="products-section" class="bg-white border border-stone-200 p-8 rounded-sm space-y-6 hidden">
      <div class="flex justify-between items-center pb-2 border-b border-stone-100">
        <h2 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium">
          Products Management
        </h2>
        <button
          id="open-add-dialog-btn"
          class="bg-brand-charcoal text-white hover:bg-stone-800 px-4 py-2 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer"
        >
          Add Product
        </button>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Products List (Col 1-3) -->
        <div class="lg:col-span-3 space-y-6">
          {products.length === 0 ? (
            <div class="text-center py-12 text-gray-400 text-xs font-light bg-stone-50 border border-dashed border-stone-200 rounded-sm">
              No products found in the database.
            </div>
          ) : (
            <div class="overflow-x-auto">
              <table class="w-full text-left text-xs text-stone-500 border-collapse border border-stone-100">
                <thead>
                  <tr class="bg-stone-50 text-brand-charcoal uppercase font-semibold text-[10px] tracking-wider">
                    <th class="p-4 border border-stone-100 w-16">Image</th>
                    <th class="p-4 border border-stone-100">Product Info</th>
                    <th class="p-4 border border-stone-100 w-24">Price</th>
                    <th class="p-4 border border-stone-100 w-20">Stock</th>
                    <th class="p-4 border border-stone-100">Sizes & Colors</th>
                    <th class="p-4 border border-stone-100 text-center w-32">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {products.map((product) => {
                    const prodSizes = parseArray(product.sizes);
                    const prodColors = parseArray(product.colors);
                    return (
                      <tr class="hover:bg-stone-50/50 transition-colors">
                        <td class="p-4 border border-stone-100">
                          {product.imageUrl ? (
                            <img src={product.imageUrl} alt={product.name} class="w-12 h-14 object-cover rounded-sm border border-stone-100" />
                          ) : (
                            <div class="w-12 h-14 bg-stone-100 flex items-center justify-center text-[10px] text-stone-400 rounded-sm">No img</div>
                          )}
                        </td>
                        <td class="p-4 border border-stone-100">
                          <div class="font-medium text-brand-charcoal text-sm">{product.name}</div>
                          <div class="text-[10px] text-stone-400 mt-0.5 tracking-wider">slug: {product.slug}</div>
                          <div class="text-[9px] uppercase tracking-widest text-stone-400 mt-1 font-semibold">{product.categoryName || 'Clothing'}</div>
                        </td>
                        <td class="p-4 border border-stone-100 font-medium text-brand-charcoal">
                          ${Number(product.price).toLocaleString()}
                        </td>
                        <td class="p-4 border border-stone-100">
                          <span class={`font-medium ${product.stockQuantity === 0 ? 'text-red-500 font-semibold' : 'text-stone-700'}`}>
                            {product.stockQuantity}
                          </span>
                        </td>
                        <td class="p-4 border border-stone-100 max-w-[200px]">
                          <div class="space-y-1">
                            {prodSizes.length > 0 && (
                              <div class="flex flex-wrap gap-1">
                                <span class="text-[9px] text-stone-400 uppercase tracking-widest mr-1 self-center">Sizes:</span>
                                {prodSizes.map((size: string) => (
                                  <span class="text-[9px] bg-stone-100 text-stone-600 px-1.5 py-0.5 rounded font-mono font-bold">{size}</span>
                                ))}
                              </div>
                            )}
                            {prodColors.length > 0 && (
                              <div class="flex flex-wrap gap-1">
                                <span class="text-[9px] text-stone-400 uppercase tracking-widest mr-1 self-center">Colors:</span>
                                {prodColors.map((color: string) => (
                                  <span class="text-[9px] bg-stone-50 border border-stone-200 text-stone-600 px-1.5 py-0.5 rounded font-sans">{color}</span>
                                ))}
                              </div>
                            )}
                          </div>
                        </td>
                        <td class="p-4 border border-stone-100 text-center">
                          <div class="flex items-center justify-center gap-2">
                            <button
                              class="edit-prod-btn border border-stone-200 text-stone-600 hover:border-brand-charcoal hover:text-brand-charcoal px-3 py-1.5 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer"
                              data-id={product.id}
                              data-name={product.name}
                              data-slug={product.slug}
                              data-price={product.price}
                              data-stock={product.stockQuantity}
                              data-image={product.imageUrl}
                              data-desc={product.description}
                              data-sizes={JSON.stringify(prodSizes)}
                              data-colors={JSON.stringify(prodColors)}
                              data-category={product.categoryId}
                            >
                              Edit
                            </button>
                            <button
                              class="delete-prod-btn border border-red-200 text-red-500 hover:bg-red-50 hover:border-red-500 px-3 py-1.5 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer"
                              data-id={product.id}
                              data-name={product.name}
                            >
                              Delete
                            </button>
                          </div>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )}
        </div>

        <!-- Product Categories Sidebar (Col 4) -->
        <div class="border border-stone-200 p-6 rounded-sm bg-stone-50/50 space-y-6 self-start shadow-sm">
          <div>
            <h3 class="font-serif text-xs tracking-widest uppercase text-brand-charcoal font-semibold mb-3 pb-2 border-b border-stone-200">
              Product Categories
            </h3>
            
            {productCategories.length === 0 ? (
              <p class="text-[10px] text-stone-400 font-light">No categories created yet.</p>
            ) : (
              <ul id="product-categories-list" class="space-y-2 max-h-[200px] overflow-y-auto pr-1">
                {productCategories.map((cat: any) => (
                  <li class="flex items-center justify-between text-xs py-1.5 border-b border-stone-100">
                    <div class="flex flex-col">
                      <span class="font-medium text-brand-charcoal font-mono text-[11px]">{cat.name}</span>
                      <span class="text-[9px] text-stone-400 font-light mt-0.5">{cat.productCount} product{cat.productCount !== 1 ? 's' : ''}</span>
                    </div>
                    <button 
                      type="button" 
                      class="delete-prod-cat-btn text-red-500 hover:text-red-700 text-[9px] uppercase tracking-widest font-semibold cursor-pointer transition-colors"
                      data-id={cat.id}
                      data-name={cat.name}
                    >
                      Delete
                    </button>
                  </li>
                ))}
              </ul>
            )}
          </div>

          <div class="pt-4 border-t border-stone-200">
            <h4 class="font-serif text-[10px] tracking-widest uppercase text-stone-400 font-semibold mb-2">
              Create New Category
            </h4>
            <form id="create-prod-cat-form" class="space-y-3">
              <div>
                <label class="block text-[8px] uppercase tracking-widest text-stone-400 font-semibold mb-0.5">Category Name</label>
                <input 
                  type="text" 
                  id="new-prod-cat-name" 
                  placeholder="e.g. Outerwear" 
                  required 
                  class="w-full border border-stone-200 px-2.5 py-1.5 text-xs focus:outline-none focus:border-brand-charcoal rounded-sm bg-white" 
                />
              </div>
              <div>
                <label class="block text-[8px] uppercase tracking-widest text-stone-400 font-semibold mb-0.5">Slug</label>
                <input 
                  type="text" 
                  id="new-prod-cat-slug" 
                  placeholder="e.g. outerwear" 
                  required 
                  class="w-full border border-stone-200 px-2.5 py-1.5 text-xs focus:outline-none focus:border-brand-charcoal rounded-sm bg-white" 
                />
              </div>
              <button 
                type="submit" 
                class="w-full bg-brand-charcoal text-white hover:bg-stone-800 py-2 rounded-sm text-[9px] uppercase tracking-widest font-semibold transition-all cursor-pointer shadow-sm"
              >
                Add Category
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Section: Blog Management -->
    <div id="blogs-section" class="bg-white border border-stone-200 p-8 rounded-sm space-y-6 hidden">
      <div class="flex justify-between items-center pb-2 border-b border-stone-100">
        <h2 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium">
          Blog Management
        </h2>
        <button
          id="open-add-blog-btn"
          class="bg-brand-charcoal text-white hover:bg-stone-800 px-4 py-2 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer"
        >
          Add Post
        </button>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Blog Posts List (Col 1-3) -->
        <div class="lg:col-span-3 space-y-6">
          {blogs.length === 0 ? (
            <div class="text-center py-12 text-gray-400 text-xs font-light bg-stone-50 border border-dashed border-stone-200 rounded-sm">
              No blog posts found in the database.
            </div>
          ) : (
            <div class="overflow-x-auto">
              <table class="w-full text-left text-xs text-stone-500 border-collapse border border-stone-100">
                <thead>
                  <tr class="bg-stone-50 text-brand-charcoal uppercase font-semibold text-[10px] tracking-wider">
                    <th class="p-4 border border-stone-100 w-16">Banner</th>
                    <th class="p-4 border border-stone-100 w-48">Article Info</th>
                    <th class="p-4 border border-stone-100">Summary</th>
                    <th class="p-4 border border-stone-100 w-24">Date</th>
                    <th class="p-4 border border-stone-100 text-center w-32">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {blogs.map((blog) => (
                    <tr class="hover:bg-stone-50/50 transition-colors">
                      <td class="p-4 border border-stone-100">
                        {blog.imageUrl ? (
                          <img src={blog.imageUrl.startsWith('http') ? blog.imageUrl : `http://localhost:3001${blog.imageUrl}`} alt={blog.title} class="w-12 h-12 object-cover rounded-sm border border-stone-100" />
                        ) : (
                          <div class="w-12 h-12 bg-stone-100 flex items-center justify-center text-[10px] text-stone-400 rounded-sm">No img</div>
                        )}
                      </td>
                      <td class="p-4 border border-stone-100">
                        <div class="font-medium text-brand-charcoal text-sm">{blog.title}</div>
                        <div class="text-[10px] text-stone-400 mt-0.5 tracking-wider">slug: {blog.slug}</div>
                        <div class="flex flex-wrap items-center gap-1.5 mt-1">
                          <span class="text-[9px] uppercase tracking-widest text-stone-400 font-semibold">Author: {blog.authorName || 'Admin'}</span>
                          {blog.categoryName && (
                            <>
                              <span class="text-stone-300 text-[9px]">•</span>
                              <span class="text-[9px] uppercase tracking-widest text-brand-gold font-bold bg-amber-50 border border-amber-100 px-1.5 py-0.5 rounded-sm">{blog.categoryName}</span>
                            </>
                          )}
                        </div>
                      </td>
                      <td class="p-4 border border-stone-100 max-w-[250px] truncate">
                        {blog.summary || 'No summary'}
                      </td>
                      <td class="p-4 border border-stone-100 text-stone-400">
                        {new Date(blog.createdAt).toLocaleDateString()}
                      </td>
                      <td class="p-4 border border-stone-100 text-center">
                        <div class="flex items-center justify-center gap-2">
                          <button
                            class="edit-blog-btn border border-stone-200 text-stone-600 hover:border-brand-charcoal hover:text-brand-charcoal px-3 py-1.5 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer"
                            data-id={blog.id}
                            data-title={blog.title}
                            data-slug={blog.slug}
                            data-summary={blog.summary}
                            data-content={blog.content}
                            data-image={blog.imageUrl}
                            data-category={blog.categoryId || ''}
                          >
                            Edit
                          </button>
                          <button
                            class="delete-blog-btn border border-red-200 text-red-500 hover:bg-red-50 hover:border-red-500 px-3 py-1.5 rounded-sm text-[10px] uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer"
                            data-id={blog.id}
                            data-title={blog.title}
                          >
                            Delete
                          </button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>

        <!-- Blog Categories Sidebar (Col 4) -->
        <div class="border border-stone-200 p-6 rounded-sm bg-stone-50/50 space-y-6 self-start shadow-sm">
          <div>
            <h3 class="font-serif text-xs tracking-widest uppercase text-brand-charcoal font-semibold mb-3 pb-2 border-b border-stone-200">
              Blog Categories
            </h3>
            
            {blogCategories.length === 0 ? (
              <p class="text-[10px] text-stone-400 font-light">No categories created yet.</p>
            ) : (
              <ul class="space-y-2 max-h-[200px] overflow-y-auto pr-1">
                {blogCategories.map((cat: any) => (
                  <li class="flex items-center justify-between text-xs py-1.5 border-b border-stone-100">
                    <span class="font-medium text-brand-charcoal font-mono text-[11px]">{cat.name}</span>
                    <button 
                      type="button" 
                      class="delete-blog-cat-btn text-red-500 hover:text-red-700 text-[9px] uppercase tracking-widest font-semibold cursor-pointer transition-colors"
                      data-id={cat.id}
                      data-name={cat.name}
                    >
                      Delete
                    </button>
                  </li>
                ))}
              </ul>
            )}
          </div>

          <div class="pt-4 border-t border-stone-200">
            <h4 class="font-serif text-[10px] tracking-widest uppercase text-stone-400 font-semibold mb-2">
              Create New Category
            </h4>
            <form id="create-blog-cat-form" class="space-y-3">
              <div>
                <label class="block text-[8px] uppercase tracking-widest text-stone-400 font-semibold mb-0.5">Category Name</label>
                <input 
                  type="text" 
                  id="new-blog-cat-name" 
                  placeholder="e.g. Styling Guide" 
                  required 
                  class="w-full border border-stone-200 px-2.5 py-1.5 text-xs focus:outline-none focus:border-brand-charcoal rounded-sm bg-white" 
                />
              </div>
              <div>
                <label class="block text-[8px] uppercase tracking-widest text-stone-400 font-semibold mb-0.5">Slug</label>
                <input 
                  type="text" 
                  id="new-blog-cat-slug" 
                  placeholder="e.g. styling-guide" 
                  required 
                  class="w-full border border-stone-200 px-2.5 py-1.5 text-xs focus:outline-none focus:border-brand-charcoal rounded-sm bg-white" 
                />
              </div>
              <button 
                type="submit" 
                class="w-full bg-brand-charcoal text-white hover:bg-stone-800 py-2 rounded-sm text-[9px] uppercase tracking-widest font-semibold transition-all cursor-pointer shadow-sm"
              >
                Add Category
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Add Product Dialog -->
  <dialog id="add-product-dialog" class="bg-white border border-stone-200 p-8 rounded-sm max-w-lg w-full">
    <div class="flex items-center justify-between pb-4 border-b border-stone-100 mb-6">
      <h3 class="font-serif text-lg tracking-widest uppercase text-brand-charcoal font-medium">Add Product</h3>
      <button class="close-dialog-btn text-stone-400 hover:text-brand-charcoal text-lg font-light cursor-pointer">&times;</button>
    </div>
    <div id="add-error" class="hidden text-[10px] text-red-500 bg-red-50 p-2.5 border-l-2 border-red-500 mb-4 rounded-sm font-light"></div>
    <form id="add-product-form" class="space-y-4">
      <div>
        <label class="block text-[10px] uppercase tracking-widest text-stone-400 font-semibold mb-1">Product Name</label>
