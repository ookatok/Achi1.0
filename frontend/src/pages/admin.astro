      font-weight: 600;
      margin-top: 0.75rem;
      margin-bottom: 0.3rem;
      color: #1c1917;
      text-transform: uppercase;
      font-family: inherit;
    }
    .ProseMirror p {
      margin-bottom: 0.75rem;
      line-height: 1.6;
    }
    .ProseMirror ul {
      list-style-type: disc;
      padding-left: 1.5rem;
      margin-bottom: 0.75rem;
    }
    .ProseMirror ol {
      list-style-type: decimal;
      padding-left: 1.5rem;
      margin-bottom: 0.75rem;
    }
    .ProseMirror blockquote {
      border-left: 2px solid #e7e5e4;
      padding-left: 1rem;
      color: #78716c;
      font-style: italic;
      margin-bottom: 0.75rem;
    }
  </style>

  <script>
    import { signOut } from 'auth-astro/client';
    import { Editor } from '@tiptap/core';
    import StarterKit from '@tiptap/starter-kit';

    // Auth setup
    const signoutBtn = document.getElementById('signout-btn');
    if (signoutBtn) {
      signoutBtn.addEventListener('click', () => {
        signOut({ callbackUrl: '/' });
      });
    }

    // Token retrieval
    const container = document.getElementById('admin-container');
    const token = container ? container.dataset.token : '';

    // Tab switcher using top navigation
    const navDashboard = document.getElementById('nav-tab-dashboard');
    const navOrders = document.getElementById('nav-tab-orders');
    const navProducts = document.getElementById('nav-tab-products');
    const navBlogs = document.getElementById('nav-tab-blogs');

    const dashboardSection = document.getElementById('dashboard-section');
    const ordersSection = document.getElementById('orders-section');
    const productsSection = document.getElementById('products-section');
    const blogsSection = document.getElementById('blogs-section');

    const switchTab = (activeNavBtn, activeSection) => {
      [navDashboard, navOrders, navProducts, navBlogs].forEach(btn => {
        if (btn) {
          if (btn === activeNavBtn) {
            btn.classList.add('border-brand-charcoal', 'text-brand-charcoal', 'font-semibold');
            btn.classList.remove('border-transparent', 'text-gray-400', 'font-light');
          } else {
            btn.classList.remove('border-brand-charcoal', 'text-brand-charcoal', 'font-semibold');
            btn.classList.add('border-transparent', 'text-gray-400', 'font-light');
          }
        }
      });

      [dashboardSection, ordersSection, productsSection, blogsSection].forEach(section => {
        if (section) {
          if (section === activeSection) {
            section.classList.remove('hidden');
          } else {
            section.classList.add('hidden');
          }
        }
      });
    };

    navDashboard?.addEventListener('click', () => switchTab(navDashboard, dashboardSection));
    navOrders?.addEventListener('click', () => switchTab(navOrders, ordersSection));
    navProducts?.addEventListener('click', () => switchTab(navProducts, productsSection));
    navBlogs?.addEventListener('click', () => switchTab(navBlogs, blogsSection));

    // Initialize the default tab
    switchTab(navDashboard, dashboardSection);

    // Modal Setup helper
    const setupDialog = (dialogId, openBtnId, onOpen = null) => {
      const dialog = document.getElementById(dialogId);
      if (!dialog) return;

      if (openBtnId) {
        const openBtn = document.getElementById(openBtnId);
        openBtn?.addEventListener('click', () => {
          const errorDiv = dialog.querySelector('.text-red-500');
          if (errorDiv) errorDiv.classList.add('hidden');
          if (onOpen) onOpen();
          dialog.showModal();
        });
      }

      dialog.querySelectorAll('.close-dialog-btn').forEach(btn => {
        btn.addEventListener('click', () => dialog.close());
      });
    };

    // Helper for generating slugs
    const slugify = (text) => {
      return text
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/[\s_]+/g, '-')
        .replace(/^-+|-+$/g, '');
    };

    // Initialize Tiptap Editors
    let addEditor = null;
    let editEditor = null;

    const addEditorEl = document.getElementById('add-blog-editor');
    if (addEditorEl) {
      addEditor = new Editor({
        element: addEditorEl,
        extensions: [StarterKit],
        content: '',
      });
    }

    const editEditorEl = document.getElementById('edit-blog-editor');
    if (editEditorEl) {
      editEditor = new Editor({
        element: editEditorEl,
        extensions: [StarterKit],
        content: '',
      });
    }

    // Toolbar logic helper
    const setupToolbar = (toolbarId, editorInstance) => {
      const toolbar = document.getElementById(toolbarId);
      if (!toolbar || !editorInstance) return;

      toolbar.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const cmd = btn.dataset.cmd;
          if (!cmd) return;

          if (cmd === 'h1') {
            editorInstance.chain().focus().toggleHeading({ level: 1 }).run();
          } else if (cmd === 'h2') {
            editorInstance.chain().focus().toggleHeading({ level: 2 }).run();
          } else if (cmd === 'h3') {
            editorInstance.chain().focus().toggleHeading({ level: 3 }).run();
          } else if (cmd === 'bold') {
            editorInstance.chain().focus().toggleBold().run();
          } else if (cmd === 'italic') {
            editorInstance.chain().focus().toggleItalic().run();
          } else if (cmd === 'bulletList') {
            editorInstance.chain().focus().toggleBulletList().run();
          } else if (cmd === 'orderedList') {
            editorInstance.chain().focus().toggleOrderedList().run();
          }
          
          updateButtonStates(toolbar, editorInstance);
        });
      });

      editorInstance.on('selectionUpdate', () => updateButtonStates(toolbar, editorInstance));
      editorInstance.on('transaction', () => updateButtonStates(toolbar, editorInstance));
    };

    const updateButtonStates = (toolbar, editorInstance) => {
      toolbar.querySelectorAll('button').forEach(btn => {
        const cmd = btn.dataset.cmd;
        let isActive = false;

        if (cmd === 'h1') isActive = editorInstance.isActive('heading', { level: 1 });
        else if (cmd === 'h2') isActive = editorInstance.isActive('heading', { level: 2 });
        else if (cmd === 'h3') isActive = editorInstance.isActive('heading', { level: 3 });
        else if (cmd === 'bold') isActive = editorInstance.isActive('bold');
        else if (cmd === 'italic') isActive = editorInstance.isActive('italic');
        else if (cmd === 'bulletList') isActive = editorInstance.isActive('bulletList');
        else if (cmd === 'orderedList') isActive = editorInstance.isActive('orderedList');

        if (isActive) {
          btn.classList.add('bg-stone-300', 'border-stone-400');
          btn.classList.remove('bg-white', 'border-stone-200');
        } else {
          btn.classList.remove('bg-stone-300', 'border-stone-400');
          btn.classList.add('bg-white', 'border-stone-200');
        }
      });
    };

    setupToolbar('add-blog-toolbar', addEditor);
    setupToolbar('edit-blog-toolbar', editEditor);

    // Setup dialog modals
    setupDialog('add-product-dialog', 'open-add-dialog-btn');
    setupDialog('edit-product-dialog');
    setupDialog('add-blog-dialog', 'open-add-blog-btn', () => {
      // Clear add editor content when opening add post modal
      if (addEditor) {
        addEditor.commands.setContent('');
      }
      const previewContainer = document.getElementById('add-blog-image-preview-container');
      if (previewContainer) previewContainer.classList.add('hidden');
      const uploadStatus = document.getElementById('add-blog-upload-status');
      if (uploadStatus) uploadStatus.classList.add('hidden');
    });
    setupDialog('edit-blog-dialog');

    // Image Upload helper
    const setupImageUpload = (fileInputId, textInputId, previewContainerId, previewId, statusId) => {
      const fileInput = document.getElementById(fileInputId);
      const textInput = document.getElementById(textInputId);
      const previewContainer = document.getElementById(previewContainerId);
      const preview = document.getElementById(previewId);
      const status = document.getElementById(statusId);

      if (!fileInput || !textInput) return;

      fileInput.addEventListener('change', async () => {
        const file = fileInput.files?.[0];
        if (!file) return;

        if (status) {
          status.textContent = 'Uploading image...';
          status.classList.remove('hidden', 'text-red-500', 'text-green-600');
          status.classList.add('text-stone-500');
        }

        const formData = new FormData();
        formData.append('file', file);

        try {
          const res = await fetch('http://localhost:3001/api/blogs/upload', {
            method: 'POST',
            headers: {
              'Authorization': `Bearer ${token}`
            },
            body: formData
          });

          if (res.ok) {
            const data = await res.json();
            textInput.value = data.imageUrl;
            
            if (preview && previewContainer) {
              preview.src = `http://localhost:3001${data.imageUrl}`;
              previewContainer.classList.remove('hidden');
            }

            if (status) {
              status.textContent = 'Upload successful!';
              status.classList.remove('text-stone-500', 'text-red-500');
              status.classList.add('text-green-600');
            }
          } else {
            const data = await res.json();
            if (status) {
              status.textContent = data.message || 'Upload failed.';
              status.classList.remove('text-stone-500', 'text-green-600');
              status.classList.add('text-red-500');
            }
          }
        } catch (err) {
          console.error(err);
          if (status) {
            status.textContent = 'Network error during upload.';
            status.classList.remove('text-stone-500', 'text-green-600');
            status.classList.add('text-red-500');
          }
        }
      });

      // Also listen to textInput changes to update preview
      textInput.addEventListener('input', () => {
        if (textInput.value) {
          let src = textInput.value;
          if (!src.startsWith('http') && src.startsWith('/')) {
            src = `http://localhost:3001${src}`;
          }
          if (preview && previewContainer) {
            preview.src = src;
            previewContainer.classList.remove('hidden');
          }
        } else {
          if (previewContainer) {
            previewContainer.classList.add('hidden');
          }
        }
      });
    };

    setupImageUpload('add-blog-image-file', 'add-blog-image', 'add-blog-image-preview-container', 'add-blog-image-preview', 'add-blog-upload-status');
    setupImageUpload('edit-blog-image-file', 'edit-blog-image', 'edit-blog-image-preview-container', 'edit-blog-image-preview', 'edit-blog-upload-status');

    // Add auto-slug generation to forms (Products)
    const addName = document.getElementById('add-name');
    const addSlug = document.getElementById('add-slug');
    if (addName && addSlug) {
      addName.addEventListener('input', () => {
        addSlug.value = slugify(addName.value);
      });
    }

    const editName = document.getElementById('edit-name');
    const editSlug = document.getElementById('edit-slug');
    if (editName && editSlug) {
      editName.addEventListener('input', () => {
        editSlug.value = slugify(editName.value);
      });
    }

    // Add auto-slug generation to forms (Blogs)
    const addBlogTitle = document.getElementById('add-blog-title');
    const addBlogSlug = document.getElementById('add-blog-slug');
    if (addBlogTitle && addBlogSlug) {
      addBlogTitle.addEventListener('input', () => {
        addBlogSlug.value = slugify(addBlogTitle.value);
      });
    }

    const editBlogTitle = document.getElementById('edit-blog-title');
    const editBlogSlug = document.getElementById('edit-blog-slug');
    if (editBlogTitle && editBlogSlug) {
      editBlogTitle.addEventListener('input', () => {
        editBlogSlug.value = slugify(editBlogTitle.value);
      });
    }

    // Add Product Submit Handler
    const addForm = document.getElementById('add-product-form');
    const addError = document.getElementById('add-error');

    addForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (addError) addError.classList.add('hidden');

      const name = document.getElementById('add-name').value;
      const slug = document.getElementById('add-slug').value;
      const price = parseFloat(document.getElementById('add-price').value);
      const stockQuantity = parseInt(document.getElementById('add-stock').value, 10);
      const imageUrl = document.getElementById('add-image').value;
      const description = document.getElementById('add-desc').value;
      
      const sizesStr = document.getElementById('add-sizes').value;
      const sizes = sizesStr.split(',').map(s => s.trim()).filter(Boolean);
      
      const colorsStr = document.getElementById('add-colors').value;
      const colors = colorsStr.split(',').map(c => c.trim()).filter(Boolean);

      const categoryId = parseInt(document.getElementById('add-category').value, 10);

      const payload = { name, slug, price, stockQuantity, imageUrl, description, sizes, colors, categoryId };

      try {
        const res = await fetch('http://localhost:3001/api/products', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          if (addError) {
            addError.textContent = Array.isArray(data.message) ? data.message.join(', ') : (data.message || 'Failed to create product.');
            addError.classList.remove('hidden');
          }
        }
      } catch (err) {
        console.error(err);
        if (addError) {
          addError.textContent = 'Could not connect to the backend server.';
          addError.classList.remove('hidden');
        }
      }
    });

    // Edit Product Setup & Submit Handler
    const editDialog = document.getElementById('edit-product-dialog');
    const editForm = document.getElementById('edit-product-form');
    const editError = document.getElementById('edit-error');

    document.querySelectorAll('.edit-prod-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (editError) editError.classList.add('hidden');
        
        const id = btn.dataset.id || '';
        const name = btn.dataset.name || '';
        const slug = btn.dataset.slug || '';
        const price = btn.dataset.price || '';
        const stock = btn.dataset.stock || '';
        const image = btn.dataset.image || '';
        const desc = btn.dataset.desc || '';
        const sizes = JSON.parse(btn.dataset.sizes || '[]');
        const colors = JSON.parse(btn.dataset.colors || '[]');
        const category = btn.dataset.category || '1';

        document.getElementById('edit-id').value = id;
        document.getElementById('edit-name').value = name;
        document.getElementById('edit-slug').value = slug;
        document.getElementById('edit-price').value = price;
        document.getElementById('edit-stock').value = stock;
        document.getElementById('edit-image').value = image;
        document.getElementById('edit-desc').value = desc;
        document.getElementById('edit-sizes').value = sizes.join(', ');
        document.getElementById('edit-colors').value = colors.join(', ');
        document.getElementById('edit-category').value = category;

        editDialog?.showModal();
      });
    });

    editForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (editError) editError.classList.add('hidden');

      const id = document.getElementById('edit-id').value;
      const name = document.getElementById('edit-name').value;
      const slug = document.getElementById('edit-slug').value;
      const price = parseFloat(document.getElementById('edit-price').value);
      const stockQuantity = parseInt(document.getElementById('edit-stock').value, 10);
      const imageUrl = document.getElementById('edit-image').value;
      const description = document.getElementById('edit-desc').value;
      
      const sizesStr = document.getElementById('edit-sizes').value;
      const sizes = sizesStr.split(',').map(s => s.trim()).filter(Boolean);
      
      const colorsStr = document.getElementById('edit-colors').value;
      const colors = colorsStr.split(',').map(c => c.trim()).filter(Boolean);

      const categoryId = parseInt(document.getElementById('edit-category').value, 10);

      const payload = { name, slug, price, stockQuantity, imageUrl, description, sizes, colors, categoryId };

      try {
        const res = await fetch(`http://localhost:3001/api/products/${id}`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          if (editError) {
            editError.textContent = Array.isArray(data.message) ? data.message.join(', ') : (data.message || 'Failed to update product.');
            editError.classList.remove('hidden');
          }
        }
      } catch (err) {
        console.error(err);
        if (editError) {
          editError.textContent = 'Could not connect to the backend server.';
          editError.classList.remove('hidden');
        }
      }
    });

    // Delete Product Handler
    document.querySelectorAll('.delete-prod-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const name = btn.dataset.name;

        if (!id || !name) return;

        if (confirm(`Are you sure you want to delete product "${name}"?`)) {
          try {
            const res = await fetch(`http://localhost:3001/api/products/${id}`, {
              method: 'DELETE',
              headers: {
                'Authorization': `Bearer ${token}`
              }
            });

            if (res.ok) {
              window.location.reload();
            } else {
              const data = await res.json();
              alert(data.message || 'Failed to delete product.');
            }
          } catch (err) {
            console.error(err);
            alert('Could not connect to the backend server.');
          }
        }
      });
    });

    // Add Blog Submit Handler
    const addBlogForm = document.getElementById('add-blog-form');
    const addBlogError = document.getElementById('add-blog-error');

    addBlogForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (addBlogError) addBlogError.classList.add('hidden');

      const title = document.getElementById('add-blog-title').value;
      const slug = document.getElementById('add-blog-slug').value;
      const summary = document.getElementById('add-blog-summary').value;
      const imageUrl = document.getElementById('add-blog-image').value;
      const content = addEditor ? addEditor.getHTML() : '';
      const categoryIdVal = document.getElementById('add-blog-category').value;
      const categoryId = categoryIdVal ? parseInt(categoryIdVal, 10) : null;

      const payload = { title, slug, summary, imageUrl, content, categoryId };

      try {
        const res = await fetch('http://localhost:3001/api/blogs', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          if (addBlogError) {
            addBlogError.textContent = Array.isArray(data.message) ? data.message.join(', ') : (data.message || 'Failed to create blog post.');
            addBlogError.classList.remove('hidden');
          }
        }
      } catch (err) {
        console.error(err);
        if (addBlogError) {
          addBlogError.textContent = 'Could not connect to the backend server.';
          addBlogError.classList.remove('hidden');
        }
      }
    });

    // Edit Blog Setup & Submit Handler
    const editBlogDialog = document.getElementById('edit-blog-dialog');
    const editBlogForm = document.getElementById('edit-blog-form');
    const editBlogError = document.getElementById('edit-blog-error');

    document.querySelectorAll('.edit-blog-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (editBlogError) editBlogError.classList.add('hidden');
        
        const id = btn.dataset.id || '';
        const title = btn.dataset.title || '';
        const slug = btn.dataset.slug || '';
        const summary = btn.dataset.summary || '';
        const content = btn.dataset.content || '';
        const image = btn.dataset.image || '';
        const categoryId = btn.dataset.category || '';

        document.getElementById('edit-blog-id').value = id;
        document.getElementById('edit-blog-title').value = title;
        document.getElementById('edit-blog-slug').value = slug;
        document.getElementById('edit-blog-summary').value = summary;
        document.getElementById('edit-blog-image').value = image;
        document.getElementById('edit-blog-category').value = categoryId;

        // Set Tiptap content
        if (editEditor) {
          editEditor.commands.setContent(content);
        }

        // Set preview image if exists
        const previewContainer = document.getElementById('edit-blog-image-preview-container');
        const preview = document.getElementById('edit-blog-image-preview');
        const uploadStatus = document.getElementById('edit-blog-upload-status');
        if (uploadStatus) uploadStatus.classList.add('hidden');
        if (image) {
          let src = image;
          if (!src.startsWith('http') && src.startsWith('/')) {
            src = `http://localhost:3001${src}`;
          }
          if (preview && previewContainer) {
            preview.src = src;
            previewContainer.classList.remove('hidden');
          }
        } else {
          if (previewContainer) previewContainer.classList.add('hidden');
        }

        editBlogDialog?.showModal();
      });
    });

    editBlogForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (editBlogError) editBlogError.classList.add('hidden');

      const id = document.getElementById('edit-blog-id').value;
      const title = document.getElementById('edit-blog-title').value;
      const slug = document.getElementById('edit-blog-slug').value;
      const summary = document.getElementById('edit-blog-summary').value;
      const imageUrl = document.getElementById('edit-blog-image').value;
      const content = editEditor ? editEditor.getHTML() : '';
      const categoryIdVal = document.getElementById('edit-blog-category').value;
      const categoryId = categoryIdVal ? parseInt(categoryIdVal, 10) : null;

      const payload = { title, slug, summary, imageUrl, content, categoryId };

      try {
        const res = await fetch(`http://localhost:3001/api/blogs/${id}`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          if (editBlogError) {
            editBlogError.textContent = Array.isArray(data.message) ? data.message.join(', ') : (data.message || 'Failed to update blog post.');
            editBlogError.classList.remove('hidden');
          }
        }
      } catch (err) {
        console.error(err);
        if (editBlogError) {
          editBlogError.textContent = 'Could not connect to the backend server.';
          editBlogError.classList.remove('hidden');
        }
      }
    });

    // Delete Blog Handler
    document.querySelectorAll('.delete-blog-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const title = btn.dataset.title;

        if (!id || !title) return;

        if (confirm(`Are you sure you want to delete blog post "${title}"?`)) {
          try {
            const res = await fetch(`http://localhost:3001/api/blogs/${id}`, {
              method: 'DELETE',
              headers: {
                'Authorization': `Bearer ${token}`
              }
            });

            if (res.ok) {
              window.location.reload();
            } else {
              const data = await res.json();
              alert(data.message || 'Failed to delete blog post.');
            }
          } catch (err) {
            console.error(err);
            alert('Could not connect to the backend server.');
          }
        }
      });
    });

    // Blog Category Submit Handler
    const createCatForm = document.getElementById('create-blog-cat-form');
    createCatForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = document.getElementById('new-blog-cat-name').value;
      const slug = document.getElementById('new-blog-cat-slug').value;

      try {
        const res = await fetch('http://localhost:3001/api/blogs/categories', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ name, slug })
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          alert(data.message || 'Failed to create category.');
        }
      } catch (err) {
        console.error(err);
        alert('Could not connect to backend server.');
      }
    });

    // Delete Blog Category Handler
    document.querySelectorAll('.delete-blog-cat-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const name = btn.dataset.name;
        if (!id || !name) return;

        if (confirm(`Are you sure you want to delete blog category "${name}"? Blogs in this category will be uncategorized.`)) {
          try {
            const res = await fetch(`http://localhost:3001/api/blogs/categories/${id}`, {
              method: 'DELETE',
              headers: {
                'Authorization': `Bearer ${token}`
              }
            });

            if (res.ok) {
              window.location.reload();
            } else {
              const data = await res.json();
              alert(data.message || 'Failed to delete category.');
            }
          } catch (err) {
            console.error(err);
            alert('Could not connect to server.');
          }
        }
      });
    });

    // Auto-slug for category
    const catNameInput = document.getElementById('new-blog-cat-name') as HTMLInputElement;
    const catSlugInput = document.getElementById('new-blog-cat-slug') as HTMLInputElement;
    if (catNameInput && catSlugInput) {
      catNameInput.addEventListener('input', () => {
        catSlugInput.value = slugify(catNameInput.value);
      });
    }

    // Product Category Submit Handler
    const createProdCatForm = document.getElementById('create-prod-cat-form');
    createProdCatForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = (document.getElementById('new-prod-cat-name') as HTMLInputElement).value;
      const slug = (document.getElementById('new-prod-cat-slug') as HTMLInputElement).value;

      try {
        const res = await fetch('http://localhost:3001/api/products/categories', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ name, slug })
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          alert(data.message || 'Failed to create category.');
        }
      } catch (err) {
        console.error(err);
        alert('Could not connect to backend server.');
      }
    });

    // Delete Product Category Handler
    document.querySelectorAll('.delete-prod-cat-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id;
        const name = (btn as HTMLElement).dataset.name;
        if (!id || !name) return;

        if (confirm(`Are you sure you want to delete product category "${name}"? Products in this category will be uncategorized.`)) {
          try {
            const res = await fetch(`http://localhost:3001/api/products/categories/${id}`, {
              method: 'DELETE',
              headers: {
                'Authorization': `Bearer ${token}`
              }
            });

            if (res.ok) {
              window.location.reload();
            } else {
              const data = await res.json();
              alert(data.message || 'Failed to delete category.');
            }
          } catch (err) {
            console.error(err);
            alert('Could not connect to server.');
          }
        }
      });
    });

    // Auto-slug for product category
    const prodCatNameInput = document.getElementById('new-prod-cat-name') as HTMLInputElement;
    const prodCatSlugInput = document.getElementById('new-prod-cat-slug') as HTMLInputElement;
    if (prodCatNameInput && prodCatSlugInput) {
      prodCatNameInput.addEventListener('input', () => {
        prodCatSlugInput.value = slugify(prodCatNameInput.value);
      });
    }

    // Inline Category Form Init
    const initInlineCategoryForm = (mode: 'add' | 'edit') => {
      const btnOpen = document.getElementById(`btn-create-category-inline-${mode}`);
      const btnCancel = document.getElementById(`btn-cancel-category-inline-${mode}`);
      const btnSubmit = document.getElementById(`btn-submit-category-inline-${mode}`);
      const form = document.getElementById(`inline-category-form-${mode}`);
      const input = document.getElementById(`inline-category-name-${mode}`) as HTMLInputElement;
      const errorDiv = document.getElementById(`inline-category-error-${mode}`);
      const select = document.getElementById(`${mode}-category`) as HTMLSelectElement;

      if (!btnOpen || !btnCancel || !btnSubmit || !form || !input || !errorDiv || !select) return;

      btnOpen.addEventListener('click', () => {
        form.classList.remove('hidden');
        input.value = '';
        input.focus();
        errorDiv.classList.add('hidden');
      });

      btnCancel.addEventListener('click', () => {
        form.classList.add('hidden');
      });

      btnSubmit.addEventListener('click', async () => {
        const name = input.value.trim();
        if (!name) {
          errorDiv.textContent = 'Category name is required';
          errorDiv.classList.remove('hidden');
          return;
        }
        const slug = slugify(name);

        try {
          const res = await fetch('http://localhost:3001/api/products/categories', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({ name, slug })
          });

          const data = await res.json();

          if (res.ok) {
            const newId = data.id;
            const newOption1 = new Option(name, String(newId));
            const newOption2 = new Option(name, String(newId));
            
            const selectAdd = document.getElementById('add-category') as HTMLSelectElement;
            const selectEdit = document.getElementById('edit-category') as HTMLSelectElement;
            
            if (selectAdd) selectAdd.add(newOption1);
            if (selectEdit) selectEdit.add(newOption2);

            // Select this new option in the active dropdown
            select.value = String(newId);

            // Hide the inline form
            form.classList.add('hidden');
          } else {
            errorDiv.textContent = data.message || 'Failed to create category';
            errorDiv.classList.remove('hidden');
          }
        } catch (err) {
          console.error(err);
          errorDiv.textContent = 'Could not connect to backend server';
          errorDiv.classList.remove('hidden');
        }
      });
    };

    initInlineCategoryForm('add');
    initInlineCategoryForm('edit');
  </script>
</Layout>
