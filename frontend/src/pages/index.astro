---
import Layout from '../layouts/Layout.astro';
import { HeroBanner } from '../components/common/banners';
import { useTranslations } from '../lib/translations';

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';
const t = useTranslations(lang);

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return `${BACKEND_URL}${url}`;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=2';
};
---

<Layout 
  title={lang === 'en' ? "ACHI | ASPIRE to be AUTHENTIC" : "ACHI | แรงบันดาลใจสู่ตัวตนที่แท้จริง"} 
  description={lang === 'en' ? "Explore the ACHI 2026 Spring Collection featuring clean cuts, tailored outfits, and premium fabrics." : "สำรวจคอลเลกชันฤดูใบไม้ผลิ ACHI 2026 ที่โดดเด่นด้วยดีไซน์เรียบหรู เสื้อผ้าตัดเย็บประณีต และเนื้อผ้าเกรดพรีเมียม"} 
  showHeroHeader={true}
>
  <HeroBanner
    title={t('home.hero.title')}
    subtitle={t('home.hero.subtitle')}
    description={t('home.hero.description')}
    imageUrl={resolveImage('/assets/images/hero-authentic.png')}
    ctaText={t('home.hero.cta')}
    ctaLink="/products"
  />

  <!-- New Arrivals Magazine Grid -->
  <section class="bg-white py-24 border-y border-gray-100">
    <div class="max-w-[1440px] mx-auto px-6 mb-12">
      <h2 class="font-sans text-5xl sm:text-6xl font-bold tracking-tighter text-brand-charcoal uppercase">
        {t('home.new_arrivals')}
      </h2>
    </div>

    <!-- Full width edge-to-edge grid with zero gap -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 w-full">
      <!-- Card 1: PREMIUM -->
      <a href="/products/new-arrivals" class="group relative aspect-[3/4] overflow-hidden bg-gray-100 block transition-all duration-500 ease-out hover:scale-115 hover:z-10 hover:shadow-[0_25px_60px_rgba(0,0,0,0.2)]">
        <img 
          src={resolveImage('/assets/images/new-arrival-premium.png')} 
          alt="New Arrival Premium" 
          class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103"
        />
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-all duration-500"></div>
      </a>

      <!-- Card 2: HARBOUR -->
      <a href="/products/new-arrivals" class="group relative aspect-[3/4] overflow-hidden bg-gray-100 block transition-all duration-500 ease-out hover:scale-115 hover:z-10 hover:shadow-[0_25px_60px_rgba(0,0,0,0.2)]">
        <img 
          src={resolveImage('/assets/images/new-arrival-harbour.png')} 
          alt="New Arrival Harbour" 
          class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103"
        />
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-all duration-500"></div>
      </a>

      <!-- Card 3: STORM -->
      <a href="/products/new-arrivals" class="group relative aspect-[3/4] overflow-hidden bg-gray-100 block transition-all duration-500 ease-out hover:scale-115 hover:z-10 hover:shadow-[0_25px_60px_rgba(0,0,0,0.2)]">
        <img 
          src={resolveImage('/assets/images/new-arrival-storm.png')} 
          alt="New Arrival Storm" 
          class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103"
        />
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-all duration-500"></div>
      </a>
    </div>

    <div class="max-w-[1440px] mx-auto px-6 text-center mt-16">
      <a 
        href="/collections" 
        class="inline-block border border-brand-charcoal text-brand-charcoal hover:bg-brand-charcoal hover:text-white px-12 py-3.5 rounded-full text-xs uppercase tracking-widest font-medium transition-all duration-300 cursor-pointer"
      >
        {lang === 'en' ? "View collection" : "ดูคอลเลกชัน"}
      </a>
    </div>
  </section>

  <!-- Side-by-Side Category Banners (MEN & WOMEN) -->
  <section class="w-full py-16 bg-white">
    <div class="max-w-[1440px] mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Left Column: MEN -->
      <a href="/products/men" class="relative aspect-[3/4] overflow-hidden rounded-sm group block bg-gray-100">
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${resolveImage('/assets/images/men-category.png')}');`}></div>
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/35 transition-all"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <h2 class="font-serif text-white text-4xl sm:text-6xl tracking-[0.15em] font-light uppercase group-hover:tracking-[0.2em] transition-all duration-500">
            {t('home.men')}
          </h2>
        </div>
      </a>

      <!-- Right Column: WOMEN -->
      <a href="/products/women" class="relative aspect-[3/4] overflow-hidden rounded-sm group block bg-gray-100">
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${resolveImage('/assets/images/women-category.png')}');`}></div>
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/35 transition-all"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <h2 class="font-serif text-white text-4xl sm:text-6xl tracking-[0.15em] font-light uppercase group-hover:tracking-[0.2em] transition-all duration-500">
            {t('home.women')}
          </h2>
        </div>
      </a>
    </div>
  </section>
</Layout>

