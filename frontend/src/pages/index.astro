---
import Layout from '../layouts/Layout.astro';
import { HeroBanner } from '../components/common/banners';
import { useTranslations, translateProduct } from '../lib/translations';

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';
const t = useTranslations(lang);

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return url;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=3';
};

let pageSettings = {
  hero_home: '',
  hero_shop: '',
  hero_collections: '',
  hero_blog: ''
} as Record<string, string>;

try {
  const res = await fetch(`${BACKEND_URL}/api/web-image/settings`);
  if (res.ok) {
    pageSettings = await res.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching page settings failed.', err);
}

let bestSellersList = [] as any[];
try {
  const res = await fetch(`${BACKEND_URL}/api/products?collection=best-sellers&page=1&limit=4`);
  if (res.ok) {
    bestSellersList = await res.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching best sellers failed.', err);
}

const bestSellers = bestSellersList.map(p => translateProduct(p, lang));

let homeSets = [] as any[];
try {
  const res = await fetch(`${BACKEND_URL}/api/collections`);
  if (res.ok) {
    const allCols = await res.json();
    homeSets = allCols
      .filter((c: any) => c.showOnHome && c.isVisible);
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching home sets failed.', err);
}

const defaultHomeSets = [
  {
    id: 'premium',
    title: lang === 'en' ? 'Premium' : 'พรีเมียม',
    imageUrl: '/assets/images/new-arrival-premium.png',
    link: `/${lang}/products/new-arrivals`
  },
  {
    id: 'harbour',
    title: lang === 'en' ? 'Harbour' : 'ฮาร์เบอร์',
    imageUrl: '/assets/images/new-arrival-harbour.png',
    link: `/${lang}/products/new-arrivals`
  },
  {
    id: 'storm',
    title: lang === 'en' ? 'Storm' : 'สตอร์ม',
    imageUrl: '/assets/images/new-arrival-storm.png',
    link: `/${lang}/products/new-arrivals`
  }
];

const displayHomeSets = homeSets.length > 0 ? homeSets : defaultHomeSets;

const getSetLink = (set: any) => {
  if (set.link) return set.link;
  return `/${lang}/products/new-arrivals?set=${set.id}`;
};

const getColorsArray = (colors: any) => {
  if (!colors) return [];
  if (Array.isArray(colors)) return colors;
  try {
    const parsed = typeof colors === 'string' ? JSON.parse(colors) : colors;
    return Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    if (typeof colors === 'string' && colors.includes(',')) {
      return colors.split(',').map(s => s.trim()).filter(Boolean);
    }
    if (typeof colors === 'string' && colors.trim() !== '') {
      return [colors.trim()];
    }
    return [];
  }
};


const categories = [
  {
    titleEn: "T-Shirts & Polos",
    titleTh: "เสื้อยืดและเสื้อโปโล",
    image: "/assets/images/shirt-cat-men.png",
    link: "/products?query=T-shirt",
    query: "T-shirt",
    descriptionEn: "Essential everyday tops",
    descriptionTh: "เสื้อตัวเก่งสำหรับทุกวัน"
  },
  {
    titleEn: "Hoodies & Jackets",
    titleTh: "เสื้อฮู้ดและเสื้อนอก",
    image: "/assets/images/products/hoodie.png",
    link: "/products?query=Hoodie",
    query: "Hoodie",
    descriptionEn: "Comfortable outer layers",
    descriptionTh: "เสื้อคลุมและเอาต์เตอร์แวร์"
  },
  {
    titleEn: "Pants, Shorts & Skirts",
    titleTh: "กางเกงและกระโปรง",
    image: "/assets/images/bottoms-cat-men.png",
    link: "/products?query=pants,shorts,skirts,jeans",
    query: "pants,shorts,skirts,jeans",
    descriptionEn: "Tailored bottomwear styles",
    descriptionTh: "กางเกงและกระโปรงหลากสไตล์"
  },
  {
    titleEn: "Bags & Accessories",
    titleTh: "กระเป๋าและเครื่องประดับ",
    image: "/assets/images/bag-cat-women.png",
    link: "/products?query=Bags",
    query: "Bags",
    descriptionEn: "Complete your premium look",
    descriptionTh: "เครื่องประดับตกแต่งลุคพรีเมียม"
  }
];
---

<Layout 
  title={lang === 'en' ? "ACHI | ASPIRE to be AUTHENTIC" : "ACHI | แรงบันดาลใจสู่ตัวตนที่แท้จริง"} 
  description={lang === 'en' ? "Explore the ACHI 2026 Spring Collection featuring clean cuts, tailored outfits, and premium fabrics." : "สำรวจคอลเลกชันฤดูใบไม้ผลิ ACHI 2026 ที่โดดเด่นด้วยดีไซน์เรียบหรู เสื้อผ้าตัดเย็บประณีต และเนื้อผ้าเกรดพรีเมียม"} 
  showHeroHeader={true}
>
  <HeroBanner
    title={t('home.hero.title')}
    subtitle={t('home.hero.subtitle')}
    description={t('home.hero.description')}
    imageUrl={resolveImage(pageSettings.hero_home || '/assets/images/hero-authentic.png')}
    ctaText={t('home.hero.cta')}
    ctaLink="/products"
  />

  <!-- Shop by Category Section -->
  <section class="max-w-[1440px] mx-auto px-6 py-20 border-t border-gray-100">
    <div class="mb-12 relative flex flex-col items-center md:flex-row md:items-end md:justify-between min-h-[60px] gap-4 md:gap-0">
      <!-- Left side: Gender Selector (Red Box) -->
      <div class="order-2 md:order-1 z-20 pointer-events-auto">
        <div class="flex items-center gap-1 bg-stone-100 p-1 rounded-full border border-stone-200/60 inline-flex">
          <button 
            data-gender-tab="all" 
            class="px-4 py-1.5 text-[10px] tracking-widest uppercase font-medium rounded-full transition-all duration-300 bg-brand-charcoal text-white cursor-pointer"
          >
            {lang === 'en' ? "All" : "ทั้งหมด"}
          </button>
          <button 
            data-gender-tab="men" 
            class="px-4 py-1.5 text-[10px] tracking-widest uppercase font-medium rounded-full transition-all duration-300 text-gray-500 hover:text-brand-charcoal cursor-pointer"
          >
            {lang === 'en' ? "Men" : "ชาย"}
          </button>
          <button 
            data-gender-tab="women" 
            class="px-4 py-1.5 text-[10px] tracking-widest uppercase font-medium rounded-full transition-all duration-300 text-gray-500 hover:text-brand-charcoal cursor-pointer"
          >
            {lang === 'en' ? "Women" : "หญิง"}
          </button>
        </div>
      </div>

      <!-- Center Title -->
      <div class="category-title-section w-full text-center md:absolute md:left-1/2 md:-translate-x-1/2 md:bottom-0 pointer-events-none z-10 order-1 md:order-2">
        <span class="text-[10px] tracking-[0.2em] uppercase text-gray-400 font-light block mb-2 animate-micro">
          {lang === 'en' ? "Categories" : "หมวดหมู่สินค้า"}
        </span>
        <h2 class="font-serif text-3xl tracking-widest text-brand-charcoal uppercase font-light">
          {lang === 'en' ? "Shop By Category" : "ช้อปตามหมวดหมู่"}
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
      {categories.map((category) => (
        <a 
          href={category.link} 
          data-category-card
          data-base-query={category.query}
          class="group relative aspect-[3/4] overflow-hidden rounded-sm bg-stone-100 block transition-all duration-500 hover:shadow-lg"
        >
          {/* Background Image */}
          <div 
            class="absolute inset-0 bg-cover bg-center transition-transform duration-[1200ms] ease-out scale-100 group-hover:scale-105" 
            style={`background-image: url('${resolveImage(category.image)}');`}
          ></div>
          
          {/* Gradient Overlay */}
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-500"></div>
          
          {/* Content */}
          <div class="absolute inset-0 p-6 flex flex-col justify-end text-white z-10">
            <span class="text-[9px] uppercase tracking-widest text-gray-300 font-light mb-1.5 transform translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 delay-75">
              {lang === 'en' ? category.descriptionEn : category.descriptionTh}
            </span>
            <h3 
              data-category-title
              data-original-en={category.titleEn}
              data-original-th={category.titleTh}
              class="font-serif text-base sm:text-lg tracking-wider font-light uppercase leading-snug"
            >
              {lang === 'en' ? category.titleEn : category.titleTh}
            </h3>
            <div class="mt-4 flex items-center gap-2 text-[10px] tracking-widest uppercase font-semibold text-brand-gold opacity-0 group-hover:opacity-100 transform -translate-x-2 group-hover:translate-x-0 transition-all duration-500">
              {lang === 'en' ? "Explore" : "สำรวจ"} &rarr;
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <script is:inline>
    (() => {
      const initTabs = () => {
        const tabs = document.querySelectorAll('[data-gender-tab]');
        const cards = document.querySelectorAll('[data-category-card]');

        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            const gender = tab.getAttribute('data-gender-tab');

            // Update active tab styling
            tabs.forEach(t => {
              t.classList.remove('bg-brand-charcoal', 'text-white');
              t.classList.add('text-gray-500', 'hover:text-brand-charcoal');
            });
            tab.classList.add('bg-brand-charcoal', 'text-white');
            tab.classList.remove('text-gray-500', 'hover:text-brand-charcoal');

            // Update cards href & titles dynamically
            const currentLang = document.documentElement.lang || 'th';
            cards.forEach(card => {
              const query = card.getAttribute('data-base-query');
              const titleEl = card.querySelector('[data-category-title]');
              let finalQuery = query;
              let finalTitleEn = titleEl ? titleEl.getAttribute('data-original-en') : '';
              let finalTitleTh = titleEl ? titleEl.getAttribute('data-original-th') : '';

              if (gender === 'men' && query === 'pants,shorts,skirts,jeans') {
                finalQuery = 'pants,shorts,jeans';
                finalTitleEn = 'Pants & Shorts';
                finalTitleTh = 'กางเกง';
              }

              if (titleEl) {
                titleEl.textContent = currentLang === 'en' ? finalTitleEn : finalTitleTh;
              }

              if (gender === 'all') {
                card.setAttribute('href', `/products?query=${finalQuery}`);
              } else {
                card.setAttribute('href', `/products?categorySlug=${gender}&query=${finalQuery}`);
              }
            });
          });
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTabs);
      } else {
        initTabs();
      }
    })();
  </script>

  <!-- New Arrivals Magazine Grid -->
  <section class="bg-white py-24 border-y border-gray-100">
    <div class="new-arrivals-title max-w-[1440px] mx-auto px-6 mb-12">
      <h2 class="font-sans text-5xl sm:text-6xl font-bold tracking-tighter text-brand-charcoal uppercase">
        {t('home.new_arrivals')}
      </h2>
    </div>

    <!-- Free Scroll Carousel container -->
    <div class="free-scroll-carousel flex overflow-x-auto select-none cursor-grab active:cursor-grabbing scrollbar-none w-full gap-6 px-6 md:px-12 py-4">
      {[...displayHomeSets, ...displayHomeSets].map((set) => (
        <a 
          href={getSetLink(set)} 
          data-new-arrival-item
          class="group relative min-w-[80vw] sm:min-w-[48vw] md:min-w-[32vw] aspect-[3/4] overflow-hidden bg-gray-100 block transition-all duration-500 ease-out hover:scale-[1.01] hover:shadow-[0_20px_45px_rgba(0,0,0,0.12)] rounded-sm"
        >
          <img 
            src={resolveImage(set.imageUrl)} 
            alt={set.title} 
            draggable="false"
            class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-103"
          />
          {/* Overlay gradient */}
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-500"></div>
          
          {/* Text content overlay */}
          <div class="absolute inset-x-0 bottom-8 px-6 text-center text-white z-10">
            <span class="text-[9px] uppercase tracking-widest text-brand-gold font-bold block mb-1">
              {lang === 'en' ? "COLLECTION SET" : "เซ็ตคอลเลกชัน"}
            </span>
            <h3 class="font-serif text-lg sm:text-xl tracking-widest uppercase font-light leading-snug">
              {set.title}
            </h3>
            <div class="mt-3 text-[9px] tracking-widest uppercase font-semibold text-white/80 opacity-0 group-hover:opacity-100 transform translate-y-2 group-hover:translate-y-0 transition-all duration-500">
              {lang === 'en' ? "Explore Collection" : "สำรวจคอลเลกชัน"} &rarr;
            </div>
          </div>
          
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-all duration-500"></div>
        </a>
      ))}
    </div>
  </section>

  <!-- Best Sellers Section -->
  <section class="max-w-[1440px] mx-auto px-6 py-24 bg-white border-b border-gray-100">
    <div class="best-sellers-title-section flex flex-col sm:flex-row sm:items-end justify-between mb-12 border-b border-gray-100 pb-6 gap-4">
      <div>
        <span class="text-[10px] tracking-[0.2em] uppercase text-gray-400 font-light block mb-2 animate-micro">
          {lang === 'en' ? "Top Demands" : "สินค้าเป็นที่ต้องการสูงสุด"}
        </span>
        <h2 class="font-serif text-4xl sm:text-5xl tracking-wide text-brand-charcoal uppercase font-light">
          {lang === 'en' ? "Best Sellers" : "สินค้าขายดี"}
        </h2>
      </div>
      <div>
        <a 
          href="/products/best-sellers" 
          class="inline-flex items-center gap-2 border border-brand-charcoal hover:bg-brand-charcoal hover:text-white text-brand-charcoal px-8 py-3 text-xs uppercase tracking-widest font-semibold transition-all duration-300 rounded-sm"
        >
          {lang === 'en' ? "View More" : "ดูทั้งหมด"} &rarr;
        </a>
      </div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
      {bestSellers.map((product) => (
        <div class="best-sellers-card bg-white p-6 border border-gray-100 rounded-sm relative flex flex-col justify-between aspect-[1/1] product-card-hover group">
          {/* Heart Button */}
          <button
            class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal focus:outline-none cursor-pointer z-20"
            data-favorite-btn data-discount={product.activeDiscountPercent || 0}
            data-id={product.id}
            data-name={product.name}
            data-price={product.price}
            data-image={product.imageUrl}
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
          </button>
          
          <div class="flex-grow flex items-center justify-center overflow-hidden aspect-[4/3] relative my-4">
            {product.activeDiscountPercent > 0 && (
              <span class="absolute top-2 left-2 z-20 bg-red-600 text-white text-[9px] uppercase tracking-widest font-bold px-2.5 py-1 rounded-sm shadow-sm">
                -{product.activeDiscountPercent}%
              </span>
            )}
            <img src={resolveImage(product.imageUrl)} alt={product.name} class="max-h-[85%] object-contain mix-blend-multiply transition-transform duration-500 group-hover:scale-105" />
          </div>
          
          <div>
            <div class="flex items-center justify-between gap-4">
              <h3 class="font-serif text-xs font-semibold tracking-wider text-brand-charcoal uppercase leading-tight">{product.name}</h3>
              {/* Color swatches */}
              {getColorsArray(product.colors).length > 0 && (
                <div class="flex gap-1.5 shrink-0">
                  {getColorsArray(product.colors).map((color: string) => (
                    <span class="w-3.5 h-3.5 rounded-full border border-stone-300 block shadow-xs" style={{ backgroundColor: color }}></span>
                  ))}
                </div>
              )}
            </div>
            
            {product.activeDiscountPercent > 0 ? (
              <div class="flex items-center gap-3 mt-2">
                <span class="text-xs text-red-600 font-bold">${(Number(product.price) * (1 - product.activeDiscountPercent / 100)).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>
                <span class="text-[10px] text-gray-400 line-through font-light">${Number(product.price).toLocaleString()}</span>
              </div>
            ) : (
              <span class="text-xs text-brand-gold font-medium mt-2 block">${Number(product.price).toLocaleString()}</span>
            )}
          </div>
          <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
        </div>
      ))}
    </div>
    {bestSellers.length === 0 && (
      <div class="text-center py-20 text-stone-400 font-light italic text-sm border border-dashed border-stone-200 rounded-sm mt-8">
        {lang === 'en' ? 'Our best-selling products will be showcased here soon.' : 'ขออภัย ยังไม่มีสินค้าขายดีในขณะนี้ สินค้าใหม่จะได้รับการอัปเดตเร็วๆ นี้'}
      </div>
    )}
  </section>

  <style>
    /* Hide scrollbars for the carousel */
    .free-scroll-carousel::-webkit-scrollbar {
      display: none;
    }
    .free-scroll-carousel {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    /* Initial state for Motion scroll animations */
    .hero-subtitle,
    .hero-title,
    .hero-description,
    .hero-cta,
    .category-title-section,
    [data-category-card],
    .new-arrivals-title,
    [data-new-arrival-item],
    .best-sellers-title-section,
    .best-sellers-card {
      opacity: 0;
    }
  </style>

  <script>
    import { initHomePageAnimations, initFreeScrollCarousel } from "../lib/animations";
    try {
      initHomePageAnimations();
      initFreeScrollCarousel();
    } catch (err) {
      console.error('[Motion API Error] Home page animations failed.', err);
    }
  </script>
</Layout>
