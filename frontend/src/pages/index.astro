---
import Layout from '../layouts/Layout.astro';
import { HeroBanner } from '../components/common/banners';
import { Heart } from '../components/common/icons';

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return `${BACKEND_URL}${url}`;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=2';
};
---

<Layout title="ACHI | ASPIRE to be AUTHENTIC" description="Explore the ACHI 2026 Spring Collection featuring clean cuts, tailored outfits, and premium fabrics." showHeroHeader={true}>
  <HeroBanner
    title="ASPIRE to be<br/><span class='italic font-normal'>AUTHENTIC.</span>"
    subtitle="2026 Spring Collection"
    description="Minimalist High-Quality - That's the Way We Do Business. Explore apparel designed for daily functionality."
    imageUrl={resolveImage('/assets/images/hero-authentic.png')}
    ctaText="Shop now"
    ctaLink="/products"
  />

  <!-- Side-by-Side Category Banners (MEN & WOMEN) -->
  <section class="w-full py-16 bg-white">
    <div class="max-w-[1440px] mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Left Column: MEN -->
      <a href="/products/men" class="relative aspect-[3/4] overflow-hidden rounded-sm group block bg-gray-100">
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${resolveImage('/assets/images/men-category.png')}');`}></div>
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/35 transition-all"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <h2 class="font-serif text-white text-4xl sm:text-6xl tracking-[0.15em] font-light uppercase group-hover:tracking-[0.2em] transition-all duration-500">
            MEN
          </h2>
        </div>
      </a>

      <!-- Right Column: WOMEN -->
      <a href="/products/women" class="relative aspect-[3/4] overflow-hidden rounded-sm group block bg-gray-100">
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${resolveImage('/assets/images/women-category.png')}');`}></div>
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/35 transition-all"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <h2 class="font-serif text-white text-4xl sm:text-6xl tracking-[0.15em] font-light uppercase group-hover:tracking-[0.2em] transition-all duration-500">
            WOMEN
          </h2>
        </div>
      </a>
    </div>
  </section>

  <!-- New Arrivals Collage Grid -->
  <section class="bg-[#F2F4F8] py-24 border-y border-gray-100">
    <div class="max-w-[1440px] mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-serif text-3xl sm:text-4xl tracking-wide font-semibold text-brand-charcoal uppercase">
          New Arrivals
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 items-stretch">
        <!-- Col 1: Item 1 & Item 2 Stack -->
        <div class="flex flex-col gap-8 justify-between">
          <!-- Item 1: Polo -->
          <div class="bg-white p-6 border border-gray-100 rounded-sm relative flex flex-col justify-between aspect-[1/1] product-card-hover group">
            <button class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal focus:outline-none cursor-pointer">
              <Heart />
            </button>
            <div class="flex-grow flex items-center justify-center overflow-hidden aspect-[4/3] relative my-4">
              <img src={resolveImage('/assets/images/polo-dark.png')} alt="generic shirt" class="max-h-[85%] object-contain mix-blend-multiply" />
            </div>
            <div>
              <h3 class="font-serif text-xs font-semibold tracking-wider text-brand-charcoal uppercase leading-tight">generic shirt</h3>
              <span class="text-xs text-gray-500 mt-2 block">$567</span>
            </div>
            <a href="/products/105" class="absolute inset-0 z-10" aria-label="View Product"></a>
          </div>
          
          <!-- Item 2: Watch -->
          <div class="bg-white p-6 border border-gray-100 rounded-sm relative flex flex-col justify-between aspect-[1/1] product-card-hover group">
            <button class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal focus:outline-none cursor-pointer">
              <Heart />
            </button>
            <div class="flex-grow flex items-center justify-center overflow-hidden aspect-[4/3] relative my-4">
              <img src={resolveImage('/assets/images/watch-dark.png')} alt="generic watch" class="max-h-[85%] object-contain mix-blend-multiply" />
            </div>
            <div>
              <h3 class="font-serif text-xs font-semibold tracking-wider text-brand-charcoal uppercase leading-tight">generic watch</h3>
              <span class="text-xs text-gray-500 mt-2 block">$567</span>
            </div>
            <a href="/products/106" class="absolute inset-0 z-10" aria-label="View Product"></a>
          </div>
        </div>

        <!-- Col 2: Tall vertical Model Photo (Col 2 & Col 3 middle) -->
        <div class="md:col-span-2 relative aspect-[3/4] md:aspect-auto overflow-hidden bg-gray-200 rounded-sm">
          <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${resolveImage('/assets/images/collage-model.png')}');`}></div>
        </div>

        <!-- Col 3: Item 3 & Item 4 Stack -->
        <div class="flex flex-col gap-8 justify-between">
          <!-- Item 3: Pants -->
          <div class="bg-white p-6 border border-gray-100 rounded-sm relative flex flex-col justify-between aspect-[1/1] product-card-hover group">
            <button class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal focus:outline-none cursor-pointer">
              <Heart />
            </button>
            <div class="flex-grow flex items-center justify-center overflow-hidden aspect-[4/3] relative my-4">
              <img src={resolveImage('/assets/images/pants-cream.png')} alt="generic pants" class="max-h-[85%] object-contain mix-blend-multiply" />
            </div>
            <div>
              <h3 class="font-serif text-xs font-semibold tracking-wider text-brand-charcoal uppercase leading-tight">generic pants</h3>
              <span class="text-xs text-gray-500 mt-2 block">$569</span>
            </div>
            <a href="/products/107" class="absolute inset-0 z-10" aria-label="View Product"></a>
          </div>

          <!-- Item 4: Shoes -->
          <div class="bg-white p-6 border border-gray-100 rounded-sm relative flex flex-col justify-between aspect-[1/1] product-card-hover group">
            <button class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal focus:outline-none cursor-pointer">
              <Heart />
            </button>
            <div class="flex-grow flex items-center justify-center overflow-hidden aspect-[4/3] relative my-4">
              <img src={resolveImage('/assets/images/shoes-white.png')} alt="generic shoes" class="max-h-[85%] object-contain mix-blend-multiply" />
            </div>
            <div>
              <h3 class="font-serif text-xs font-semibold tracking-wider text-brand-charcoal uppercase leading-tight">generic shoes</h3>
              <span class="text-xs text-gray-500 mt-2 block">$567</span>
            </div>
            <a href="/products/108" class="absolute inset-0 z-10" aria-label="View Product"></a>
          </div>
        </div>
      </div>

      <div class="text-center mt-16">
        <a href="/products" class="border border-brand-charcoal text-brand-charcoal hover:bg-brand-charcoal hover:text-white px-12 py-3.5 rounded-full text-xs uppercase tracking-widest font-medium transition-all duration-300">
          view more
        </a>
      </div>
    </div>
  </section>
</Layout>
