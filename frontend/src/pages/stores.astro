---
import Layout from '../layouts/Layout.astro';
---

<Layout title="STORE LOCATOR | ACHI Studio" description="Find ACHI flagship stores and premium branches in Bangkok.">
  <!-- Top Header -->
  <section class="bg-stone-50 border-b border-stone-200/60 py-16 text-center">
    <div class="max-w-[800px] mx-auto px-6">
      <h1 class="font-serif text-3xl tracking-widest text-brand-charcoal uppercase leading-tight">STORE LOCATOR</h1>
      <p class="text-[10px] tracking-[0.2em] uppercase text-stone-400 mt-1 font-light">Find an ACHI branch near you</p>
    </div>
  </section>

  <div class="max-w-[1000px] mx-auto px-6 py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Branch 1 -->
      <div class="bg-white border border-stone-200/80 p-6 rounded-sm flex flex-col justify-between hover:border-brand-gold transition-colors duration-300">
        <div class="space-y-4">
          <div class="aspect-[4/3] bg-stone-100 rounded-sm flex items-center justify-center text-[10px] uppercase tracking-widest text-stone-400 font-light border border-stone-200/50">
            [Sukhumvit Flagship]
          </div>
          <h2 class="font-serif text-base uppercase tracking-wider text-brand-charcoal font-medium">ACHI FLAGSHIP STUDIO</h2>
          <p class="text-xs text-stone-500 font-light leading-relaxed">
            Sukhumvit Road, Khlong Toei, Bangkok 10110
          </p>
        </div>
        <div class="border-t border-stone-100 pt-4 mt-6 text-[10px] text-stone-400 font-light space-y-1">
          <span class="block">Hours: 10:00 AM - 9:00 PM Daily</span>
          <span class="block">Phone: +66 2 123 4567</span>
        </div>
      </div>

      <!-- Branch 2 -->
      <div class="bg-white border border-stone-200/80 p-6 rounded-sm flex flex-col justify-between hover:border-brand-gold transition-colors duration-300">
        <div class="space-y-4">
          <div class="aspect-[4/3] bg-stone-100 rounded-sm flex items-center justify-center text-[10px] uppercase tracking-widest text-stone-400 font-light border border-stone-200/50">
            [Iconsiam Studio]
          </div>
          <h2 class="font-serif text-base uppercase tracking-wider text-brand-charcoal font-medium">ACHI ICONSIAM BRANCH</h2>
          <p class="text-xs text-stone-500 font-light leading-relaxed">
            Level 2, ICONSIAM, Charoen Nakhon Rd, Bangkok 10600
          </p>
        </div>
        <div class="border-t border-stone-100 pt-4 mt-6 text-[10px] text-stone-400 font-light space-y-1">
          <span class="block">Hours: 10:00 AM - 10:00 PM Daily</span>
          <span class="block">Phone: +66 2 765 4321</span>
        </div>
      </div>

      <!-- Branch 3 -->
      <div class="bg-white border border-stone-200/80 p-6 rounded-sm flex flex-col justify-between hover:border-brand-gold transition-colors duration-300">
        <div class="space-y-4">
          <div class="aspect-[4/3] bg-stone-100 rounded-sm flex items-center justify-center text-[10px] uppercase tracking-widest text-stone-400 font-light border border-stone-200/50">
            [Centralworld Studio]
          </div>
          <h2 class="font-serif text-base uppercase tracking-wider text-brand-charcoal font-medium">ACHI CENTRALWORLD BRANCH</h2>
          <p class="text-xs text-stone-500 font-light leading-relaxed">
            1st Floor, Centralworld, Ratchadamri Rd, Bangkok 10330
          </p>
        </div>
        <div class="border-t border-stone-100 pt-4 mt-6 text-[10px] text-stone-400 font-light space-y-1">
          <span class="block">Hours: 10:00 AM - 10:00 PM Daily</span>
          <span class="block">Phone: +66 2 987 6543</span>
        </div>
      </div>

    </div>
  </div>
</Layout>
