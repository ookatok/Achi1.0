---
import Layout from '../../layouts/Layout.astro';
const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';
---

<Layout 
  title={lang === 'en' ? "Contact Us | ACHI Studio" : "ติดต่อเรา | ACHI Studio"} 
  description={lang === 'en' ? "Get in touch with the ACHI customer support team." : "ติดต่อทีมบริการช่วยเหลือลูกค้าของ ACHI"}
>
  <div class="max-w-[1100px] mx-auto px-6 py-16 relative">
    {/* Close X Button at top right of contact block */}
    <a href="/" class="absolute top-6 right-6 text-brand-charcoal hover:opacity-75 transition-opacity" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </a>

    {/* Section Header */}
    <div class="text-center mb-16 pt-8">
      <h1 class="motion-title font-serif text-4xl tracking-[0.2em] font-medium text-brand-charcoal">
        {lang === 'en' ? "CONTACT US" : "ติดต่อเรา"}
      </h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start mt-8">
      {/* Left Column: Form */}
      <form class="motion-item space-y-6" id="contact-form">
        <!-- Honeypot field (Invisible to users, autocomplete off, tabindex -1) -->
        <div class="absolute opacity-0 -z-50 pointer-events-none w-0 h-0 overflow-hidden" aria-hidden="true">
          <label for="website">Website</label>
          <input
            id="website"
            type="text"
            name="website"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <div>
          <input
            type="text"
            id="name"
            required
            placeholder={lang === 'en' ? "Name" : "ชื่อ"}
            class="w-full px-4 py-3 bg-white border border-gray-300 focus:border-brand-gold outline-none transition-all text-xs font-light"
          />
        </div>

        <div>
          <input
            type="email"
            id="email"
            required
            placeholder={lang === 'en' ? "Email" : "อีเมล"}
            class="w-full px-4 py-3 bg-white border border-gray-300 focus:border-brand-gold outline-none transition-all text-xs font-light"
          />
        </div>

        <div>
          <input
            type="tel"
            id="phone"
            placeholder={lang === 'en' ? "Phone" : "เบอร์โทรศัพท์"}
            class="w-full px-4 py-3 bg-white border border-gray-300 focus:border-brand-gold outline-none transition-all text-xs font-light"
          />
        </div>

        <div>
          <div class="relative">
            <select
              id="topic"
              required
              class="w-full px-4 py-3 bg-white border border-gray-300 focus:border-brand-gold outline-none transition-all text-xs font-light appearance-none text-gray-500"
            >
              <option value="" disabled selected>{lang === 'en' ? "Select a topic" : "เลือกหัวข้อสอบถาม"}</option>
              <option value="orders">{lang === 'en' ? "Orders & Delivery" : "การสั่งซื้อและการจัดส่ง"}</option>
              <option value="returns">{lang === 'en' ? "Returns & Refunds" : "การคืนสินค้าและการคืนเงิน"}</option>
              <option value="product-care">{lang === 'en' ? "Product Care" : "การดูแลรักษาผลิตภัณฑ์"}</option>
              <option value="others">{lang === 'en' ? "Other Inquiry" : "สอบถามเรื่องอื่นๆ"}</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-500">
              <svg class="fill-current h-3 w-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
                <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/>
              </svg>
            </div>
          </div>
        </div>

        <div>
          <textarea
            id="description"
            rows="6"
            required
            placeholder={lang === 'en' ? "Description" : "รายละเอียด"}
            class="w-full p-4 bg-white border border-gray-300 focus:border-brand-gold outline-none text-xs font-light resize-none transition-all"
          ></textarea>
        </div>

        <div>
          <button
            type="submit"
            class="bg-[#8F4F06] text-white hover:bg-opacity-95 px-10 py-3 text-xs tracking-widest uppercase font-semibold transition-all cursor-pointer"
          >
            {lang === 'en' ? "Send" : "ส่งข้อความ"}
          </button>
        </div>
      </form>

      {/* Right Column: Contact Details */}
      <div class="motion-item space-y-8 pl-0 md:pl-8">
        <h2 class="font-serif text-2xl font-light tracking-wide text-brand-charcoal mb-6">
          {lang === 'en' ? "Contact details" : "ข้อมูลติดต่อ"}
        </h2>

        <div class="space-y-6 text-xs tracking-widest font-light text-gray-600 uppercase">
          {/* Email */}
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 flex items-center justify-center bg-gray-50 rounded-sm">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5 text-gray-500">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.626a2.25 2.25 0 0 1-2.5 0L3.105 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <a href="mailto:example@email.com" class="text-brand-charcoal hover:underline lowercase">example@email.com</a>
            </div>
          </div>

          {/* Phone */}
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 flex items-center justify-center bg-gray-50 rounded-sm">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5 text-gray-500">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.502-5.187-3.865-6.69-6.69l1.293-.97a1.242 1.242 0 0 0 .417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
            </div>
            <div class="text-brand-charcoal">
              012-345-6789
            </div>
          </div>

          {/* Line App */}
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 flex items-center justify-center bg-gray-50 rounded-sm">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5 text-gray-500">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379L12 21.75V17.77a48.108 48.108 0 0 0 3.478-.397c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.02Z" />
              </svg>
            </div>
            <div class="text-brand-charcoal">
              lineexample
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      const form = document.getElementById('contact-form');
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();

          const submitBtn = form.querySelector('button[type="submit"]');
          const isEn = document.documentElement.lang === 'en';

          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = isEn ? 'Sending...' : 'กำลังส่งข้อความ...';
          }

          const payload = {
            name: document.getElementById('name').value,
            email: document.getElementById('email').value,
            phone: document.getElementById('phone').value || null,
            topic: document.getElementById('topic').value,
            description: document.getElementById('description').value,
            website: document.getElementById('website').value,
          };

          try {
            const res = await fetch('http://localhost:3001/api/contacts', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify(payload),
            });

            if (res.ok) {
              window.showStatusAlert(200, isEn ? 'Thank you for contacting us. We will get back to you shortly.' : 'ขอบคุณสำหรับการติดต่อเรา เราจะตอบกลับคุณโดยเร็วที่สุด', null, true, () => {
                form.reset();
              });
            } else {
              const data = await res.json();
              window.showStatusAlert(res.status, null, data ? data.message : (isEn ? 'Could not send message' : 'ไม่สามารถส่งข้อความได้'));
            }
          } catch (err) {
            console.error(err);
            window.showStatusAlert(0, isEn ? 'Could not submit form. Please check if the backend server is online.' : 'ไม่สามารถส่งแบบฟอร์มได้ กรุณาตรวจสอบว่าเซิร์ฟเวอร์แบ็คเอนด์ออนไลน์อยู่หรือไม่');
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = isEn ? 'Send' : 'ส่งข้อความ';
            }
          }
        });
      }
    })();
  </script>
</Layout>
