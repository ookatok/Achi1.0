---
import Layout from '../../layouts/Layout.astro';

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return `${BACKEND_URL}${url}`;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=2';
};

let productsList = [] as any[];

try {
  const res = await fetch(`${BACKEND_URL}/api/products?categorySlug=women`);
  if (res.ok) {
    productsList = await res.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching women products failed. Using mocks.', err);
}

// Fallback Mock items matching Figma design exactly
const mockProducts = [
  { id: 101, name: "Generic T-shirt 1", price: "499.00", imageUrl: "/assets/images/tshirt-1.png" },
  { id: 102, name: "Generic T-shirt 2", price: "499.00", imageUrl: "/assets/images/polo-dark.png" },
  { id: 103, name: "Generic T-shirt 3", price: "499.00", imageUrl: "/assets/images/pants-cream.png" },
  { id: 104, name: "Generic T-shirt 4", price: "499.00", imageUrl: "/assets/images/shoes-white.png" }
];

const displayProducts = productsList.length > 0 ? productsList : mockProducts;
---

<Layout title="Women's Fashion | ACHI Studio" description="Discover the Summer Collection. Shop ACHI's latest women's clothing, bags, and accessories." showHeroHeader={true}>
  <!-- Women's Hero Section -->
  <section class="w-full relative h-[100vh] bg-[#3B3835] flex items-center text-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-65" style={`background-image: url('${resolveImage('/assets/images/women-hero.png')}');`}></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black via-transparent to-transparent opacity-40"></div>
    
    <div class="relative w-full max-w-[1440px] mx-auto px-6 pt-24 flex flex-col justify-center items-start h-full">
      <h1 class="font-serif text-5xl sm:text-8xl tracking-tight leading-none mb-4 uppercase">
        Women's<br/>
        <span class="text-brand-gold italic font-normal">Fashion</span>
      </h1>
      <p class="font-sans text-xs sm:text-sm tracking-widest font-light mb-10 text-gray-300 uppercase">
        Discover the Summer Collection.
      </p>
      
      <a href="#women-catalog" class="border border-white hover:bg-white hover:text-brand-charcoal text-white px-10 py-3.5 text-xs uppercase tracking-widest font-medium transition-all duration-300 rounded-sm">
        Shop now
      </a>
    </div>
  </section>

  <!-- Categories Collage Grid (Bags, Caps) -->
  <section class="max-w-[1440px] mx-auto px-6 py-24" id="women-catalog">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-24">
      <!-- Col 1: Bags -->
      <a href="/products?colors=&sizes=&query=bag" class="relative aspect-[4/5] bg-gray-50 overflow-hidden rounded-sm group block">
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${resolveImage('/assets/images/bag-cat-women.png')}');`}></div>
        <div class="absolute inset-0 bg-black/10 group-hover:bg-black/25 transition-all"></div>
        <div class="absolute bottom-6 left-6 text-white z-10">
          <span class="font-serif text-xl font-medium tracking-widest underline decoration-brand-gold decoration-2 underline-offset-4 font-bold">BAGS</span>
        </div>
      </a>

      <!-- Col 2: Caps -->
      <a href="/products?colors=&sizes=&query=cap" class="relative aspect-[4/5] bg-gray-50 overflow-hidden rounded-sm group block">
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${resolveImage('/assets/images/cap-cat-women.png')}');`}></div>
        <div class="absolute inset-0 bg-black/10 group-hover:bg-black/25 transition-all"></div>
        <div class="absolute bottom-6 left-6 text-white z-10">
          <span class="font-serif text-xl font-medium tracking-widest underline decoration-brand-gold decoration-2 underline-offset-4 font-bold">CAPS</span>
        </div>
      </a>
    </div>

    <!-- Product Grid: Summer Arrivals -->
    <div class="space-y-12">
      <div class="text-center">
        <h2 class="font-serif text-3xl tracking-wide font-semibold text-brand-charcoal uppercase">
          Women's Collection
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
        {displayProducts.map((product: any) => (
          <div class="bg-white p-6 border border-gray-100 rounded-sm relative flex flex-col justify-between aspect-[1/1] product-card-hover group">
            {/* Heart Button */}
            <button
              class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal focus:outline-none cursor-pointer z-20"
              data-favorite-btn
              data-id={product.id}
              data-name={product.name}
              data-price={product.price}
              data-image={product.imageUrl}
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
            </button>
            <div class="flex-grow flex items-center justify-center overflow-hidden aspect-[4/3] relative my-4">
              <img src={resolveImage(product.imageUrl)} alt={product.name} class="max-h-[85%] object-contain mix-blend-multiply transition-transform duration-500 group-hover:scale-105" />
            </div>
            <div>
              <h3 class="font-serif text-xs font-semibold tracking-wider text-brand-charcoal uppercase leading-tight">{product.name}</h3>
              <span class="text-xs text-brand-gold font-medium mt-2 block">${Number(product.price).toLocaleString()}</span>
            </div>
            <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
