---
import Layout from '../../layouts/Layout.astro';
import { CollectionBanner } from '../../components/common/banners';
import { Heart } from '../../components/common/icons';
import { translateProduct } from '../../lib/translations';
import Pagination from '../../components/common/Pagination.astro';

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

const page = parseInt(Astro.url.searchParams.get('page') || '1', 10);
const limit = 8;

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return url;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=3';
};

let productsList = [] as any[];
let totalProducts = 0;

try {
  const res = await fetch(`${BACKEND_URL}/api/products?categorySlug=accessories&page=${page}&limit=${limit}`);
  if (res.ok) {
    productsList = await res.json();
  }

  const countRes = await fetch(`${BACKEND_URL}/api/products?categorySlug=accessories`);
  if (countRes.ok) {
    const allProducts = await countRes.json();
    totalProducts = allProducts.length;
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching products failed.', err);
}

const displayProducts = productsList.map(p => translateProduct(p, lang));
const paginatedList = displayProducts;
const totalPages = Math.max(1, Math.ceil(totalProducts / limit));

const getColorsArray = (colors: any) => {
  if (!colors) return [];
  if (Array.isArray(colors)) return colors;
  try {
    const parsed = typeof colors === 'string' ? JSON.parse(colors) : colors;
    return Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    if (typeof colors === 'string' && colors.includes(',')) {
      return colors.split(',').map(s => s.trim()).filter(Boolean);
    }
    if (typeof colors === 'string' && colors.trim() !== '') {
      return [colors.trim()];
    }
    return [];
  }
};
---

<Layout title={lang === 'en' ? "Accessories | ACHI Studio" : "เครื่องประดับ | ACHI Studio"} description={lang === 'en' ? "Complete your look with ACHI's curated selection of minimalist accessories." : "เติมเต็มลุคของคุณด้วยเครื่องประดับมินิมอลที่คัดสรรมาอย่างดีจาก ACHI"} showHeroHeader={true}>
  <CollectionBanner
    title={lang === 'en' ? "Accessories" : "เครื่องประดับ"}
    subtitle={lang === 'en' ? "Curated Essentials" : "ของใช้จำเป็นที่คัดสรรมาอย่างดี"}
    rightText={lang === 'en' ? "Complete Your Look" : "เติมเต็มลุคของคุณ"}
    imageUrl="/assets/images/banners/accessories.png?v=3"
    bgColor="#2E312F"
  />

  <!-- Filter Bar Info -->
  <section class="border-b border-gray-100 bg-white">
    <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between text-[11px] uppercase tracking-wider font-light text-gray-400">
      <nav class="flex items-center gap-2">
        <a href="/" class="hover:text-brand-charcoal transition-colors">{lang === 'en' ? "Home" : "หน้าแรก"}</a>
        <span>/</span>
        <a href="/products" class="hover:text-brand-charcoal transition-colors">{lang === 'en' ? "Shop" : "ช้อป"}</a>
        <span>/</span>
        <span class="text-brand-charcoal">{lang === 'en' ? "Accessories" : "เครื่องประดับ"}</span>
      </nav>
      <span>{lang === 'en' ? `Showing ${displayProducts.length} items` : `แสดงทั้งหมด ${displayProducts.length} รายการ`}</span>
    </div>
  </section>

  <!-- Product Grid -->
  <div class="max-w-[1440px] mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      {paginatedList.map((product: any) => (
        <div class="flex flex-col justify-between p-6 bg-white border border-gray-100 rounded-sm product-card-hover group relative">
          <!-- Heart Favorite Button -->
          <button
            class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal transition-colors focus:outline-none cursor-pointer z-20"
            data-favorite-btn
            data-id={product.id}
            data-name={product.name}
            data-price={product.price}
            data-image={product.imageUrl}
          >
            <Heart />
          </button>

          <!-- Product Image Box -->
          <div class="aspect-[1/1] overflow-hidden flex flex-col items-center justify-center bg-gray-50 border border-gray-100/50 rounded-sm mb-6 relative group">
            {product.imageUrl ? (
              <img src={product.imageUrl} alt={product.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            ) : (
              <span class="text-[9px] uppercase tracking-[0.2em] text-gray-400 text-center font-light leading-relaxed">
                [Image: {product.name}]
              </span>
            )}
          </div>

          <!-- Product Details -->
          <div>
            <div class="flex items-center justify-between gap-4">
              <h3 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight">
                {product.name}
              </h3>
              {/* Color swatches */}
              {getColorsArray(product.colors).length > 0 && (
                <div class="flex gap-1.5 shrink-0">
                  {getColorsArray(product.colors).map((color: string) => (
                    <span class="w-3.5 h-3.5 rounded-full border border-stone-300 block shadow-xs" style={{ backgroundColor: color }}></span>
                  ))}
                </div>
              )}
            </div>
            <span class="text-xs text-brand-gold font-medium mt-2 block">${Number(product.price).toLocaleString()}</span>
          </div>

          <!-- Clickable Area Link -->
          <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
        </div>
      ))}
        </div>

    <!-- Pagination Component -->
    <Pagination totalPages={totalPages} />
  </div>
</Layout>
