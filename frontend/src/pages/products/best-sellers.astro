---
import Layout from '../../layouts/Layout.astro';
import { translateProduct } from '../../lib/translations';
import Pagination from '../../components/common/Pagination.astro';

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

const page = parseInt(Astro.url.searchParams.get('page') || '1', 10);
const limit = 8;

// Fetch user session for token authorization if needed
let productsList = [] as any[];

try {
  const res = await fetch(`${BACKEND_URL}/api/products?collection=best-sellers&page=${page}&limit=${limit}`);
  if (res.ok) {
    productsList = await res.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching best sellers failed. Using mocks.', err);
}

// Fallback Mock items matching the premium aesthetic
const mockBestSellers = [
  { id: 501, name: "Classic Cotton Trench Coat", price: "650.00", imageUrl: "/assets/images/products/trenchcoat.png" },
  { id: 502, name: "Tailored Wool Trouser Set", price: "320.00", imageUrl: "/assets/images/set3.png" },
  { id: 503, name: "Oversized Soft Cashmere Sweater", price: "420.00", imageUrl: "/assets/images/set2.png" },
  { id: 504, name: "Premium Tailored Cotton Shirt", price: "190.00", imageUrl: "/assets/images/shirt-cat-men.png" },
];

const useMocks = productsList.length === 0;
const displayRawList = useMocks ? mockBestSellers : productsList;
const displayProducts = displayRawList.map(p => translateProduct(p, lang));

// Paginate in-memory if we are using mocks
const startIndex = (page - 1) * limit;
const endIndex = startIndex + limit;
const paginatedList = useMocks ? displayProducts.slice(startIndex, endIndex) : displayProducts;
---

<Layout title={lang === 'en' ? "Best Sellers | ACHI Studio" : "สินค้าขายดี | ACHI Studio"} description={lang === 'en' ? "Shop our most coveted and signature e-commerce fashion items." : "ช้อปสินค้าแฟชั่นที่ได้รับความนิยมสูงสุดและเป็นเอกลักษณ์เฉพาะตัวของเรา"} showHeroHeader={true}>
  <!-- Best Sellers Hero Banner -->
  <section class="w-full relative h-[60vh] bg-[#22252A] flex items-center justify-center text-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/assets/images/banners/best-sellers.png?v=2');"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-60"></div>
    
    <div class="relative w-full max-w-[1440px] mx-auto px-6 flex flex-col justify-end h-full pb-16">
      <div class="flex items-end justify-between w-full">
        <div>
          <span class="border border-white border-opacity-40 px-3 py-1 text-[10px] tracking-widest uppercase font-light rounded-full mb-4 inline-block">{lang === 'en' ? "Best Sellers" : "สินค้าขายดี"}</span>
          <h1 class="font-serif text-5xl sm:text-7xl font-bold tracking-tight uppercase leading-none">{lang === 'en' ? "Most Coveted" : "สินค้าขายดีที่สุด"}</h1>
        </div>
        <div class="hidden sm:block text-right text-[11px] tracking-[0.35em] text-gray-300 uppercase font-light">
          {lang === 'en' ? "Time-Tested Classics" : "ความคลาสสิกที่ผ่านการพิสูจน์ตามกาลเวลา"}
        </div>
      </div>
    </div>
  </section>

  <!-- Filter Bar Info -->
  <section class="border-b border-gray-100 bg-white">
    <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between text-[11px] uppercase tracking-wider font-light text-gray-400">
      <nav class="flex items-center gap-2">
        <a href="/" class="hover:text-brand-charcoal transition-colors">{lang === 'en' ? "Home" : "หน้าแรก"}</a>
        <span>/</span>
        <a href="/products" class="hover:text-brand-charcoal transition-colors">{lang === 'en' ? "Shop" : "ช้อป"}</a>
        <span>/</span>
        <span class="text-brand-charcoal">{lang === 'en' ? "Best Sellers" : "สินค้าขายดี"}</span>
      </nav>
      <span>{lang === 'en' ? `Showing ${displayProducts.length} items` : `แสดงทั้งหมด ${displayProducts.length} รายการ`}</span>
    </div>
  </section>

  <!-- Product Grid -->
  <div class="max-w-[1440px] mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      {paginatedList.map((product: any) => (
        <div class="flex flex-col justify-between p-6 bg-white border border-gray-100 rounded-sm product-card-hover group relative">
          <!-- Heart Favorite Button -->
          <button
            class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal transition-colors focus:outline-none cursor-pointer z-20"
            data-favorite-btn
            data-id={product.id}
            data-name={product.name}
            data-price={product.price}
            data-image={product.imageUrl}
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
          </button>

          <!-- Product Image Box -->
          <div class="aspect-[1/1] overflow-hidden flex flex-col items-center justify-center bg-gray-50 border border-gray-100/50 rounded-sm mb-6 relative group">
            {product.imageUrl ? (
              <img src={product.imageUrl} alt={product.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            ) : (
              <span class="text-[9px] uppercase tracking-[0.2em] text-gray-400 text-center font-light leading-relaxed">
                [Image: {product.name}]
              </span>
            )}
          </div>

          <!-- Product Details -->
          <div>
            <h3 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight">
              {product.name}
            </h3>
            <span class="text-xs text-brand-gold font-medium mt-2 block">${Number(product.price).toLocaleString()}</span>
          </div>

          <!-- Clickable Area Link -->
          <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
        </div>
      ))}
        </div>

    <!-- Pagination Component -->
    <Pagination totalPages={5} />
  </div>
</Layout>
