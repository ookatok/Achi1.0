---
import Layout from '../../layouts/Layout.astro';
import { translateProduct } from '../../lib/translations';
import Pagination from '../../components/common/Pagination.astro';

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

const page = Astro.url.searchParams.get('page') ? parseInt(Astro.url.searchParams.get('page')!, 10) : 1;
const limit = 5;

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return url;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=3';
};

let rawProducts = [] as any[];

try {
  const res = await fetch(`${BACKEND_URL}/api/products?collection=best-sellers&limit=100`);
  if (res.ok) {
    rawProducts = await res.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching best seller products failed.', err);
}

const translatedProducts = rawProducts.map(p => translateProduct(p, lang));
const sortedBestSellers = [...translatedProducts].sort((a: any, b: any) => (b.salesCount || 0) - (a.salesCount || 0));

const top5 = sortedBestSellers.slice(0, 5);
const paginatedList = sortedBestSellers.slice((page - 1) * limit, page * limit);
const totalPages = Math.max(1, Math.ceil(sortedBestSellers.length / limit));

const getColorsArray = (colors: any) => {
  if (!colors) return [];
  if (Array.isArray(colors)) return colors;
  try {
    const parsed = typeof colors === 'string' ? JSON.parse(colors) : colors;
    return Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    if (typeof colors === 'string' && colors.includes(',')) {
      return colors.split(',').map(s => s.trim()).filter(Boolean);
    }
    if (typeof colors === 'string' && colors.trim() !== '') {
      return [colors.trim()];
    }
    return [];
  }
};
---

<Layout title={lang === 'en' ? "Best Sellers | ACHI Studio" : "สินค้าขายดี | ACHI Studio"} description={lang === 'en' ? "Shop our most coveted and signature e-commerce fashion items." : "ช้อปสินค้าแฟชั่นที่ได้รับความนิยมสูงสุดและเป็นเอกลักษณ์เฉพาะตัวของเรา"} showHeroHeader={true}>
