              <h3 class="font-serif text-lg font-normal tracking-wide uppercase">{top5[0]?.name}</h3>
              <p class="text-[10px] text-stone-400 font-light truncate max-w-md">{top5[0]?.description || (lang === 'en' ? "Premium design with tailored aesthetics." : "การออกแบบระดับพรีเมียมด้วยความประณีต")}</p>
            </div>
            <div class="text-right shrink-0">
              {top5[0]?.activeDiscountPercent > 0 ? (
                <div class="flex flex-col items-end">
                  <span class="text-lg font-serif font-bold text-red-500">${(Number(top5[0].price) * (1 - top5[0].activeDiscountPercent / 100)).toLocaleString()}</span>
