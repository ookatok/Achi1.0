          <div class="flex flex-wrap gap-4">
            <a href="#all-best-sellers" class="bg-brand-charcoal text-white hover:bg-brand-gold hover:text-brand-charcoal px-6 py-3.5 rounded-sm text-[10px] font-bold uppercase tracking-widest transition-all duration-300">
