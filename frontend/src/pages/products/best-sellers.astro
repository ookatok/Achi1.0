                <img src={resolveImage(top5[4].imageUrl)} alt={top5[4].name} class="max-h-[85%] object-contain mix-blend-multiply transition-transform duration-500 group-hover:scale-105" />
              </div>
              <a href={`/products/${top5[4].id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- ALL BEST SELLERS VERTICAL LIST (Accommodation layout pattern) -->
  <section class="max-w-[1440px] mx-auto px-6 py-20 space-y-12" id="all-best-sellers">
    <div class="text-center space-y-2">
      <span class="text-[9px] uppercase tracking-[0.35em] text-stone-400 font-semibold">{lang === 'en' ? "COMPLETE LIST" : "รายการสินค้าทั้งหมด"}</span>
      <h2 class="font-serif text-3xl sm:text-4xl font-normal tracking-wide text-brand-charcoal uppercase">{lang === 'en' ? "All Best Sellers" : "สินค้าขายดีทั้งหมด"}</h2>
    </div>

    <!-- Category Tabs Selector -->
    <div class="flex justify-center mb-12" id="category-tabs-container">
      <div class="inline-flex p-1 bg-stone-100 rounded-full border border-stone-200">
        <button 
          class="category-tab-btn px-6 py-2 rounded-full text-xs uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer bg-brand-charcoal text-white shadow-xs"
          data-category="all"
        >
          {lang === 'en' ? "All Items" : "สินค้าทั้งหมด"}
        </button>
        <button 
          class="category-tab-btn px-6 py-2 rounded-full text-xs uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer text-stone-400 hover:text-brand-charcoal"
          data-category="men"
        >
          {lang === 'en' ? "Men" : "ผู้ชาย"}
        </button>
        <button 
          class="category-tab-btn px-6 py-2 rounded-full text-xs uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer text-stone-400 hover:text-brand-charcoal"
          data-category="women"
        >
          {lang === 'en' ? "Women" : "ผู้หญิง"}
        </button>
        <button 
          class="category-tab-btn px-6 py-2 rounded-full text-xs uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer text-stone-400 hover:text-brand-charcoal"
          data-category="accessories"
        >
          {lang === 'en' ? "Accessories" : "เครื่องประดับ"}
        </button>
      </div>
    </div>

    <!-- Vertical rows list of products -->
    <div class="space-y-8" id="best-sellers-rows-container">
      {paginatedList.map((product: any, index: number) => {
        const rankNumber = (page - 1) * limit + index + 1;
        const prodColors = getColorsArray(product.colors);
        const prodSizes = getColorsArray(product.sizes);
        
        return (
          <div 
            class="flex flex-col lg:flex-row bg-white border border-stone-100 rounded-sm p-6 gap-6 hover:shadow-lg transition-all duration-500 relative product-best-seller-row"
            data-category={product.categorySlug || 'clothing'}
          >
            <!-- Column 1: Image Wrapper (with rank badge) -->
            <div class="w-full lg:w-[240px] aspect-[1/1] overflow-hidden flex items-center justify-center bg-stone-50 border border-stone-100/50 rounded-sm shrink-0 relative group">
              <span class="absolute top-4 left-4 z-20 bg-brand-charcoal text-white text-[9px] uppercase tracking-widest font-bold px-2 py-1 rounded-sm shadow-sm">
                Rank #{rankNumber}
              </span>

              {product.activeDiscountPercent > 0 && (
                <span class="absolute top-4 right-4 z-20 bg-red-600 text-white text-[8px] uppercase tracking-widest font-bold px-2 py-0.5 rounded-sm shadow-sm animate-pulse">
                  -{product.activeDiscountPercent}%
                </span>
              )}

              {product.imageUrl ? (
                <img src={resolveImage(product.imageUrl)} alt={product.name} class="max-h-[85%] object-contain mix-blend-multiply transition-transform duration-500 group-hover:scale-105" />
              ) : (
                <span class="text-[9px] uppercase tracking-[0.2em] text-gray-400 text-center font-light">[Image]</span>
              )}
              
              <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
            </div>

            <!-- Column 2: Product Name & description details -->
            <div class="flex-1 flex flex-col justify-between py-1 text-left space-y-4">
              <div class="space-y-2">
                <span class="text-[8px] uppercase tracking-[0.25em] text-brand-gold font-bold block">
                  {product.categoryName || (lang === 'en' ? 'Clothing' : 'เสื้อผ้า')}
                </span>
                <h3 class="font-serif text-xl font-normal tracking-wide text-brand-charcoal uppercase leading-tight hover:text-brand-gold transition-colors">
                  <a href={`/products/${product.id}`}>{product.name}</a>
                </h3>
                <p class="text-xs text-stone-500 font-light leading-relaxed max-w-xl">
                  {product.description || (lang === 'en' ? 'No description available for this signature best seller.' : 'ไม่มีรายละเอียดคำบรรยายสำหรับสินค้าชิ้นนี้')}
                </p>
              </div>

              <div>
                <a href={`/products/${product.id}`} class="text-[10px] tracking-[0.2em] font-semibold text-brand-charcoal uppercase inline-flex items-center gap-1.5 border-b border-brand-charcoal/25 pb-0.5 hover:text-brand-gold hover:border-brand-gold transition-colors">
                  {lang === 'en' ? "Explore Product" : "สำรวจดีลสินค้า"} &rarr;
                </a>
              </div>
            </div>

            <!-- Column 3: Pricing & Specifications -->
            <div class="w-full lg:w-[220px] shrink-0 border-t lg:border-t-0 lg:border-x border-stone-100 py-4 lg:py-0 px-0 lg:px-6 flex flex-col justify-center text-left space-y-4">
              <div class="space-y-1">
                <span class="text-[8px] uppercase tracking-widest text-stone-400 font-bold block">{lang === 'en' ? "PRICE DETAILS" : "รายละเอียดราคา"}</span>
                <div class="flex items-baseline gap-2.5">
                  {product.activeDiscountPercent > 0 ? (
                    <>
                      <span class="text-lg font-serif font-bold text-red-600">${(Number(product.price) * (1 - product.activeDiscountPercent / 100)).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>
                      <span class="text-xs text-stone-400 line-through font-light">${Number(product.price).toLocaleString()}</span>
                    </>
                  ) : (
                    <span class="text-lg font-serif font-bold text-brand-gold">${Number(product.price).toLocaleString()}</span>
                  )}
                </div>
              </div>

              <div class="space-y-1.5">
                <span class="text-[8px] uppercase tracking-widest text-stone-400 font-bold block">{lang === 'en' ? "AVAILABILITY" : "สถานะสินค้า"}</span>
                <div class="text-[10px] space-y-1 font-sans text-stone-600">
                  <div class="flex justify-between">
                    <span class="font-light">{lang === 'en' ? "Stock Status:" : "สถานะคลัง:"}</span>
                    <span class={`font-bold ${product.stockQuantity === 0 ? 'text-red-500' : product.stockQuantity < 5 ? 'text-amber-500' : 'text-green-600'}`}>
                      {product.stockQuantity === 0 ? (lang === 'en' ? 'Out of Stock' : 'สินค้าหมด') : product.stockQuantity < 5 ? (lang === 'en' ? 'Low Stock' : 'เหลือจำนวนน้อย') : (lang === 'en' ? 'In Stock' : 'มีสินค้าจำหน่าย')}
                    </span>
                  </div>
                  <div class="flex justify-between">
                    <span class="font-light">{lang === 'en' ? "Product ID:" : "รหัสสินค้า:"}</span>
                    <span class="font-mono text-[9px] font-bold text-brand-charcoal">ACHI-{product.id}</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Column 4: Features & Cart CTA -->
            <div class="w-full lg:w-[220px] shrink-0 flex flex-col justify-center text-left space-y-4">
              {/* Colors & Sizes option previews */}
              <div class="space-y-2">
                {prodColors.length > 0 && (
                  <div class="flex items-center gap-2">
                    <span class="text-[8px] uppercase tracking-wider font-semibold text-stone-400 shrink-0 w-8">{lang === 'en' ? "Colors:" : "สี:"}</span>
                    <div class="flex flex-wrap gap-1">
                      {prodColors.slice(0, 3).map((color: string) => (
                        <span class="w-3.5 h-3.5 rounded-full border border-stone-300 block shadow-xs" style={{ backgroundColor: color }}></span>
                      ))}
                    </div>
                  </div>
                )}

                {prodSizes.length > 0 && (
                  <div class="flex items-center gap-2">
                    <span class="text-[8px] uppercase tracking-wider font-semibold text-stone-400 shrink-0 w-8">{lang === 'en' ? "Sizes:" : "ไซส์:"}</span>
                    <div class="flex flex-wrap gap-1">
                      {prodSizes.slice(0, 4).map((size: string) => (
                        <span class="text-[8px] bg-stone-100 text-stone-700 px-1.5 py-0.5 rounded-sm font-mono font-bold uppercase">{size}</span>
                      ))}
                    </div>
                  </div>
                )}
              </div>

              <div class="space-y-1.5 text-[9px] uppercase tracking-wider font-semibold text-stone-400">
                <div class="flex items-center gap-1.5 text-stone-500">
                  <span class="text-green-600 font-bold">✓</span> {lang === 'en' ? "Premium Quality Material" : "วัสดุคุณภาพเกรดพรีเมียม"}
                </div>
                <div class="flex items-center gap-1.5 text-stone-500">
                  <span class="text-green-600 font-bold">✓</span> {lang === 'en' ? "Signature Comfortable Fit" : "สวมใส่สบายเป็นเอกลักษณ์"}
                </div>
              </div>

              <div>
                <a 
                  href={`/products/${product.id}`}
                  class="block text-center bg-brand-charcoal text-white hover:bg-brand-gold hover:text-brand-charcoal py-3 rounded-sm text-[10px] font-bold uppercase tracking-widest transition-all duration-300 w-full"
                >
                  {lang === 'en' ? "Explore Deal" : "จองสินค้าชิ้นนี้"}
                </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Pagination Component -->
    <Pagination totalPages={totalPages} />
  </section>

  <!-- Client-side script for tab filtering -->
  <script is:inline>
    (function() {
      const tabButtons = document.querySelectorAll('.category-tab-btn');
      const rows = document.querySelectorAll('.product-best-seller-row');

      if (tabButtons.length > 0 && rows.length > 0) {
        tabButtons.forEach(btn => {
          btn.addEventListener('click', () => {
            // Update active states
            tabButtons.forEach(b => {
              b.classList.remove('bg-brand-charcoal', 'text-white', 'shadow-xs');
              b.classList.add('text-stone-400');
            });
            btn.classList.add('bg-brand-charcoal', 'text-white', 'shadow-xs');
            btn.classList.remove('text-stone-400');

            const category = btn.getAttribute('data-category');

            rows.forEach(row => {
              const rowCategory = row.getAttribute('data-category');
              const matches = category === 'all' || rowCategory === category;

              if (matches) {
                row.classList.remove('hidden');
                row.style.opacity = '0';
                setTimeout(() => {
                  row.style.transition = 'opacity 350ms ease';
                  row.style.opacity = '1';
                }, 50);
              } else {
                row.classList.add('hidden');
              }
            });
          });
        });
      }
    })();
  </script>
</Layout>
