            <div class="text-left space-y-2">
              <div class="flex justify-between items-start gap-4">
                <h3 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight truncate">{top5[1].name}</h3>
                {top5[1].activeDiscountPercent > 0 ? (
                  <span class="text-xs text-red-600 font-bold">${(Number(top5[1].price) * (1 - top5[1].activeDiscountPercent / 100)).toLocaleString()}</span>
                ) : (
                  <span class="text-xs text-brand-gold font-medium">${Number(top5[1].price).toLocaleString()}</span>
                )}
              </div>
              <p class="text-[9px] text-stone-400 font-light truncate">{top5[1].description}</p>
            </div>
            <a href={`/products/${top5[1].id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
          </div>
