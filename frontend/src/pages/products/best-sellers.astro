          {/* Rank 5 (Horizontal Card) */}
          {top5[4] && (
            <div class="flex-1 bg-white border border-stone-100 rounded-sm p-4 shadow-xs hover:shadow-md transition-shadow flex items-center justify-between gap-6 group relative">
              <div class="flex-1 text-left space-y-3">
