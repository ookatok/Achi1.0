        {/* Rank 3 (Vertical Card) */}
        {top5[2] && (
          <div class="flex flex-col justify-between p-5 bg-white border border-stone-100 rounded-sm shadow-xs group relative hover:shadow-md transition-shadow">
            <div class="absolute top-5 left-5 z-20 bg-stone-100 border border-stone-200 text-stone-600 text-[8px] uppercase tracking-widest font-bold px-2 py-1 rounded-sm shadow-xs">
              {lang === 'en' ? "Rank #3" : "อันดับ 3"}
            </div>
            <div class="aspect-[1/1] overflow-hidden flex items-center justify-center bg-gray-50 border border-gray-100/50 rounded-sm mb-5 relative">
              <img src={resolveImage(top5[2].imageUrl)} alt={top5[2].name} class="max-h-[85%] object-contain mix-blend-multiply transition-transform duration-500 group-hover:scale-105" />
            </div>
            <div class="text-left space-y-2">
              <div class="flex justify-between items-start gap-4">
                <h3 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight truncate">{top5[2].name}</h3>
                {top5[2].activeDiscountPercent > 0 ? (
                  <span class="text-xs text-red-600 font-bold">${(Number(top5[2].price) * (1 - top5[2].activeDiscountPercent / 100)).toLocaleString()}</span>
                ) : (
                  <span class="text-xs text-brand-gold font-medium">${Number(top5[2].price).toLocaleString()}</span>
                )}
              </div>
              <p class="text-[9px] text-stone-400 font-light truncate">{top5[2].description}</p>
            </div>
            <a href={`/products/${top5[2].id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
          </div>
        )}

        {/* Columns 3 & 4 (Span 2 Columns): Rank 4 & 5 horizontal stacked */}
        <div class="lg:col-span-2 flex flex-col gap-6">
          {/* Rank 4 (Horizontal Card) */}
          {top5[3] && (
            <div class="flex-1 bg-white border border-stone-100 rounded-sm p-4 shadow-xs hover:shadow-md transition-shadow flex items-center justify-between gap-6 group relative">
              <div class="flex-1 text-left space-y-3">
                <div>
                  <span class="bg-stone-100 border border-stone-200 text-stone-600 text-[8px] uppercase tracking-widest font-bold px-2 py-0.5 rounded-sm shadow-xs inline-block mb-1">Rank #4</span>
                  <h4 class="font-serif text-sm font-semibold tracking-widest text-brand-charcoal uppercase leading-tight">{top5[3].name}</h4>
                </div>
                <p class="text-[9px] text-stone-400 font-light line-clamp-2 leading-relaxed">{top5[3].description}</p>
                <div class="flex items-center gap-3">
                  {top5[3].activeDiscountPercent > 0 ? (
                    <span class="text-xs text-red-600 font-bold">${(Number(top5[3].price) * (1 - top5[3].activeDiscountPercent / 100)).toLocaleString()}</span>
                  ) : (
                    <span class="text-xs text-brand-gold font-medium">${Number(top5[3].price).toLocaleString()}</span>
                  )}
                  <span class="text-[9px] tracking-wider uppercase font-semibold text-brand-charcoal border-b border-brand-charcoal/30 pb-0.5 group-hover:text-brand-gold group-hover:border-brand-gold transition-colors">{lang === 'en' ? "Explore &rarr;" : "สำรวจชิ้นนี้ &rarr;"}</span>
                </div>
              </div>
              <div class="w-1/3 aspect-[1/1] overflow-hidden flex items-center justify-center bg-gray-50 border border-gray-100/50 rounded-sm shrink-0">
                <img src={resolveImage(top5[3].imageUrl)} alt={top5[3].name} class="max-h-[85%] object-contain mix-blend-multiply transition-transform duration-500 group-hover:scale-105" />
              </div>
              <a href={`/products/${top5[3].id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
