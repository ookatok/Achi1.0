              <span class="text-xs font-bold uppercase tracking-widest font-serif">VOGUE</span>
              <span class="text-xs font-bold uppercase tracking-widest font-serif">ELLE</span>
              <span class="text-xs font-bold uppercase tracking-widest font-serif">GQ</span>
              <span class="text-xs font-bold uppercase tracking-widest font-serif">BAZAAR</span>
