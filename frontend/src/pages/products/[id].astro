---
import Layout from '../../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';
import { translateProduct } from '../../lib/translations';

// Fetch user session for token authorization
const session = await getSession(Astro.request);
const token = (session as any)?.accessToken;

const { id } = Astro.params;

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return `${BACKEND_URL}${url}`;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=2';
};

let product = null;

try {
  const res = await fetch(`${BACKEND_URL}/api/products/${id}`);
  if (res.ok) {
    product = await res.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching product details failed. Using Figma mock product.', err);
}

// Fallback Mock Product if API is offline or database item is missing
const mockProduct = {
  id: Number(id) || 1,
  name: "Generic T-shirt 1",
  price: "499.00",
  imageUrl: "/assets/images/tshirt-1.png",
  description: "Minimalist cotton crewneck t-shirt with contrasting neck ribbing.",
  sizes: ["S", "M", "L", "XL"],
  colors: ["#94B2E6", "#F3F1EC"], // Soft Blue, Soft Cream swatches matching screenshot
  tags: [
    { id: 1, name: "summer", slug: "summer" },
    { id: 2, name: "basics", slug: "basics" },
    { id: 3, name: "new", slug: "new" }
  ]
};

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

const displayProduct = translateProduct(product || mockProduct, lang);

const parseArray = (val: any) => {
  if (!val) return [];
  if (Array.isArray(val)) return val;
  try {
    const parsed = typeof val === 'string' ? JSON.parse(val) : val;
    return Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    return [];
  }
};

const displayColors = parseArray(displayProduct.colors);
const displaySizes = parseArray(displayProduct.sizes);
const displayTags = parseArray(displayProduct.tags);
---

<Layout 
  title={`${displayProduct.name} | ACHI Studio`} 
  description={displayProduct.description}
>
  <div class="max-w-[1440px] mx-auto px-6 py-16">
    {/* Breadcrumbs */}
    <nav class="text-xs uppercase tracking-widest text-gray-400 font-light mb-8">
      <a href="/products" class="hover:text-brand-charcoal transition-colors">
        {lang === 'en' ? "Clothing" : "เสื้อผ้า"}
      </a>
      <span class="mx-2">/</span>
      <span class="text-brand-charcoal">{displayProduct.name}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- Left Column: Vertical Image Stack -->
      <div class="space-y-8 flex flex-col items-center">
        <!-- Main Product Image -->
        <div class="w-full bg-gray-50 overflow-hidden flex items-center justify-center p-8 aspect-[1/1] rounded-sm relative">
          <img
            src={resolveImage(displayProduct.imageUrl)}
            alt={displayProduct.name}
            class="max-h-[90%] object-contain mix-blend-multiply"
          />
        </div>

        {/* Alternate Gray Image Placeholders from Figma design PDP */}
        <div class="w-full bg-gray-100 flex items-center justify-center aspect-[1/1] text-gray-400 font-light uppercase tracking-widest text-sm rounded-sm">
          {lang === 'en' ? "image" : "รูปภาพ"}
        </div>

        <div class="w-full bg-gray-100 flex items-center justify-center aspect-[1/1] text-gray-400 font-light uppercase tracking-widest text-sm rounded-sm">
          {lang === 'en' ? "image" : "รูปภาพ"}
        </div>
      </div>

      <!-- Right Column: Product Details & Options -->
      <div class="space-y-8 lg:sticky lg:top-28">
        <div>
          <h1 class="font-serif text-3xl font-bold tracking-wide text-brand-charcoal mb-4 uppercase">
            {displayProduct.name}
          </h1>
          
          <div class="text-xl font-semibold text-brand-charcoal mb-6">
            ${Number(displayProduct.price).toLocaleString()}
          </div>
          
          <p class="text-xs text-gray-500 font-light leading-relaxed mb-4">
            {lang === 'en' 
              ? "incl. tax. Shipping costs showing post coding: Free returns until 14 days."
              : "รวมภาษีมูลค่าเพิ่มแล้ว | ค่าจัดส่งคำนวณขณะชำระเงิน | คืนสินค้าฟรีภายใน 14 วัน"
            }
          </p>
        </div>

        {/* Option: Colors Swatches */}
        {displayColors && displayColors.length > 0 && (
          <div>
            <h4 class="block text-xs uppercase tracking-wider font-semibold text-gray-400 mb-3">
              {lang === 'en' ? "Product colors" : "สีของผลิตภัณฑ์"}
            </h4>
            <div class="flex gap-3">
              {displayColors.map((color: string, index: number) => (
                <button
                  class={`w-7 h-7 rounded-full border border-gray-200 block shadow-sm focus:outline-none cursor-pointer color-option-btn ${index === 0 ? 'ring-2 ring-brand-charcoal ring-offset-2' : ''}`}
                  style={{ backgroundColor: color }}
                  data-color={color}
                ></button>
              ))}
            </div>
          </div>
        )}

        {/* Option: Sizes Divisors & Tags */}
        {((displaySizes && displaySizes.length > 0) || (displayTags && displayTags.length > 0)) && (
          <div>
            <div class="flex justify-between items-center mb-3">
              {displaySizes && displaySizes.length > 0 && (
                <h4 class="block text-xs uppercase tracking-wider font-semibold text-gray-400">
                  {lang === 'en' ? "Product size" : "ขนาดไซส์สินค้า"}
                </h4>
              )}
            </div>
            
            <div class="flex justify-between items-center">
              {displaySizes && displaySizes.length > 0 ? (
                <div class="flex items-center gap-4 text-xs font-light tracking-wider text-gray-500">
                  {displaySizes.map((size: string, index: number) => (
                    <>
                      {index > 0 && <span class="text-gray-300">|</span>}
                      <button
                        class={`hover:text-brand-charcoal transition-colors focus:outline-none cursor-pointer size-option-btn ${index === 0 ? 'font-semibold text-brand-charcoal' : ''}`}
                        data-size={size}
                      >
                        {size}
                      </button>
                    </>
                  ))}
                </div>
              ) : <div></div>}
              
              {/* Product Tags */}
              {displayTags && displayTags.length > 0 && (
                <div class="flex gap-2">
                  {displayTags.map((tag: any) => (
                    <span class="text-[9px] uppercase tracking-widest text-stone-500 border border-stone-200 px-2.5 py-0.5 rounded-full bg-stone-50/50 hover:bg-stone-100 hover:text-brand-charcoal hover:border-brand-charcoal transition-all font-sans font-medium cursor-default">
                      {typeof tag === 'object' ? (lang === 'en' ? tag.name : (tag.name === 'summer' ? 'ฤดูร้อน' : tag.name === 'basics' ? 'เบสิก' : tag.name === 'new' ? 'ใหม่' : tag.name)) : tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </div>
        )}

        {/* Add To Cart & Favorite Row */}
        <div>
          <div class="flex gap-4">
            <button
              id="add-to-cart-btn"
              class="flex-grow bg-brand-charcoal text-white hover:bg-brand-gold hover:text-brand-charcoal py-4 rounded-sm text-xs uppercase tracking-[0.2em] font-semibold transition-all duration-300 cursor-pointer"
            >
              {lang === 'en' ? "ADD TO CART" : "เพิ่มลงในตะกร้า"}
            </button>
            <button
              id="favorite-detail-btn"
              class="px-5 border border-gray-200 hover:border-brand-charcoal rounded-sm text-gray-400 hover:text-brand-charcoal transition-all cursor-pointer flex items-center justify-center focus:outline-none"
              data-favorite-btn
              data-id={displayProduct.id}
              data-name={displayProduct.name}
              data-price={displayProduct.price}
              data-image={displayProduct.imageUrl}
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
              </svg>
            </button>
          </div>
          <div id="cart-msg" class="hidden mt-4 p-4 text-xs font-medium rounded-sm"></div>
        </div>

        {/* Accordions */}
        <div class="border-t border-gray-200 pt-4 divide-y divide-gray-200 text-xs tracking-wider uppercase font-light text-gray-600">
          <div class="py-4">
            <details class="group cursor-pointer">
              <summary class="flex justify-between items-center focus:outline-none select-none">
                <span>{lang === 'en' ? "Check in-store Availability" : "ตรวจสอบสินค้าคงเหลือหน้าร้าน"}</span>
                <span class="transition-transform duration-300 group-open:rotate-180">▼</span>
              </summary>
              <div class="mt-4 text-gray-500 font-light normal-case tracking-normal leading-relaxed pl-2">
                {lang === 'en'
                  ? "Available at ACHI Flagship Studio and selected branches in Bangkok."
                  : "มีจำหน่ายที่ ACHI แฟลกชิป สตูดิโอ และสาขาชั้นนำอื่นๆ ที่กำหนดในกรุงเทพมหานคร"
                }
              </div>
            </details>
          </div>

          <div class="py-4">
            <details class="group cursor-pointer">
              <summary class="flex justify-between items-center focus:outline-none select-none">
                <span>{lang === 'en' ? "Fit Details" : "รายละเอียดรูปทรงเสื้อผ้า"}</span>
                <span class="transition-transform duration-300 group-open:rotate-180">▼</span>
              </summary>
              <div class="mt-4 text-gray-500 font-light normal-case tracking-normal leading-relaxed pl-2">
                {lang === 'en'
                  ? "Relaxed fit contours, designed for everyday minimal chic style. Model is wearing size L."
                  : "รูปทรงทรงหลวมสบาย (Relaxed Fit) ออกแบบมาเพื่อสไตล์มินิมอลเก๋ไก๋ในทุกๆ วัน นายแบบ/นางแบบสวมใส่ขนาดไซส์ L"
                }
              </div>
            </details>
          </div>

          <div class="py-4">
            <details class="group cursor-pointer">
              <summary class="flex justify-between items-center focus:outline-none select-none">
                <span>{lang === 'en' ? "Materials" : "วัสดุและส่วนประกอบ"}</span>
                <span class="transition-transform duration-300 group-open:rotate-180">▼</span>
              </summary>
              <div class="mt-4 text-gray-500 font-light normal-case tracking-normal leading-relaxed pl-2">
                {lang === 'en'
                  ? "100% premium organic cotton. Clean double-needle stitched seams."
                  : "ผลิตจากฝ้ายออร์แกนิกเกรดพรีเมียม 100% แนวตะเข็บเย็บเข็มคู่ประณีตและเรียบร้อย"
                }
              </div>
            </details>
          </div>

          <div class="py-4">
            <details class="group cursor-pointer">
              <summary class="flex justify-between items-center focus:outline-none select-none">
                <span>{lang === 'en' ? "Shipping and returns" : "การจัดส่งและการคืนสินค้า"}</span>
                <span class="transition-transform duration-300 group-open:rotate-180">▼</span>
              </summary>
              <div class="mt-4 text-gray-500 font-light normal-case tracking-normal leading-relaxed pl-2">
                {lang === 'en'
                  ? "Free standard delivery. Easy and unconditional returns up to 14 days."
                  : "จัดส่งมาตรฐานฟรี คืนสินค้าได้ง่ายและไม่มีเงื่อนไขภายในระยะเวลา 14 วัน"
                }
              </div>
            </details>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ token, productId: displayProduct.id, lang }}>
    let selectedColor = '';
    let selectedSize = '';
    const isEn = lang === 'en';

    // Handle option selectors highlights
    const colorButtons = document.querySelectorAll('.color-option-btn');
    const sizeButtons = document.querySelectorAll('.size-option-btn');

    if (colorButtons.length > 0) {
      selectedColor = colorButtons[0].getAttribute('data-color') || '';
      colorButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          colorButtons.forEach(b => b.classList.remove('ring-2', 'ring-brand-charcoal', 'ring-offset-2'));
          btn.classList.add('ring-2', 'ring-brand-charcoal', 'ring-offset-2');
          selectedColor = btn.getAttribute('data-color') || '';
        });
      });
    }

    if (sizeButtons.length > 0) {
      selectedSize = sizeButtons[0].getAttribute('data-size') || '';
      sizeButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          sizeButtons.forEach(b => b.classList.remove('font-semibold', 'text-brand-charcoal'));
          btn.classList.add('font-semibold', 'text-brand-charcoal');
          selectedSize = btn.getAttribute('data-size') || '';
        });
      });
    }

    // Add to cart click event
    const addToCartBtn = document.getElementById('add-to-cart-btn');
    const cartMsg = document.getElementById('cart-msg');

    if (addToCartBtn) {
      addToCartBtn.addEventListener('click', async () => {
        if (!token) {
          window.location.href = `/auth/signin?callbackUrl=${encodeURIComponent(window.location.pathname)}`;
          return;
        }

        addToCartBtn.disabled = true;
        addToCartBtn.textContent = isEn ? 'ADDING TO CART...' : 'กำลังเพิ่มลงในตะกร้า...';

        try {
          const res = await fetch('http://localhost:3001/api/cart/add', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
              productId,
              quantity: 1,
              size: selectedSize || undefined,
              color: selectedColor || undefined
            })
          });

          const data = await res.json();

          if (res.ok) {
            if (cartMsg) {
              cartMsg.textContent = isEn ? 'Item added to your cart successfully!' : 'เพิ่มสินค้าลงในตะกร้าของคุณเรียบร้อยแล้ว!';
              cartMsg.className = 'mt-4 p-4 text-xs font-medium rounded-sm bg-green-50 border-l-2 border-green-500 text-green-600 block';
            }
            // Dispatch event to update the cart badge count in navigation
            window.dispatchEvent(new CustomEvent('cart-updated'));
          } else {
            throw new Error(data.message || (isEn ? 'Could not add item' : 'ไม่สามารถเพิ่มสินค้าลงในตะกร้าได้'));
          }
        } catch (err) {
          console.error(err);
          if (cartMsg) {
            cartMsg.textContent = err.message || (isEn ? 'An error occurred.' : 'เกิดข้อผิดพลาดขึ้น');
            cartMsg.className = 'mt-4 p-4 text-xs font-medium rounded-sm bg-red-50 border-l-2 border-red-500 text-red-600 block';
          }
        } finally {
          addToCartBtn.disabled = false;
          addToCartBtn.textContent = isEn ? 'ADD TO CART' : 'เพิ่มลงในตะกร้า';
        }
      });
    }
  </script>
</Layout>
