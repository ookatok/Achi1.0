import Layout from '../../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';
import { translateProduct } from '../../lib/translations';
import Pagination from '../../components/common/Pagination.astro';

const { id } = Astro.params;
const isNumericId = id && /^\d+$/.test(id);
const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return url;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=3';
};

const parseArray = (val: any) => {
  if (!val) return [];
  if (Array.isArray(val)) return val;
  try {
    const parsed = typeof val === 'string' ? JSON.parse(val) : val;
    return Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    if (typeof val === 'string' && val.includes(',')) {
      return val.split(',').map(s => s.trim()).filter(Boolean);
    }
    if (typeof val === 'string' && val.trim() !== '') {
      return [val.trim()];
    }
    return [];
  }
};

// ----------------------------------------------------
// Branch A: Product Detail (Numeric ID)
// ----------------------------------------------------
let displayProduct = null;
let displayColors = [];
let displaySizes = [];
let displayTags = [];
let displayImages = [];
let token = null;

// ----------------------------------------------------
// Branch B: Collection (Slug ID)
// ----------------------------------------------------
let displayProducts = [];
let title = '';
let desc = '';
let coverImage = null;
let collectionTotalPages = 1;
let collectionData = null as any;

if (isNumericId) {
  // Fetch user session for token authorization
  const session = await getSession(Astro.request);
  token = (session as any)?.accessToken;

  let product = null;
  try {
    const res = await fetch(`${BACKEND_URL}/api/products/${id}`);
    if (res.ok) {
      product = await res.json();
    }
  } catch (err) {
    console.error('[NestJS API Error] Fetching product details failed.', err);
  }

  displayProduct = product ? translateProduct(product, lang) : null;

  if (displayProduct) {
    displayColors = parseArray(displayProduct.colors);
    displaySizes = parseArray(displayProduct.sizes);
    displayTags = parseArray(displayProduct.tags);
    displayImages = parseArray(displayProduct.images);
  }
} else {
  // Collection logic
  const collection = id;
  const page = parseInt(Astro.url.searchParams.get('page') || '1', 10);
  const limit = 8;

  let productsList = [] as any[];
  let totalCollectionProducts = 0;

  try {
    // 1. Fetch collection details
    const colRes = await fetch(`${BACKEND_URL}/api/collections`);
    if (colRes.ok) {
      const cols = await colRes.json();
      collectionData = cols.find((c: any) => c.slug === collection);
    }

    // 2. Fetch products associated with this collection
    const res = await fetch(`${BACKEND_URL}/api/products?collection=${collection}&page=${page}&limit=${limit}`);
    if (res.ok) {
      productsList = await res.json();
    }

    // Fetch total count for pagination
    const countRes = await fetch(`${BACKEND_URL}/api/products?collection=${collection}`);
    if (countRes.ok) {
      const allColProducts = await countRes.json();
      totalCollectionProducts = allColProducts.length;
    }
  } catch (err) {
    console.error('[NestJS API Error] Fetching dynamic collection failed.', err);
  }

  displayProducts = productsList.map(p => translateProduct(p, lang));
  title = collectionData ? collectionData.title : (collection ? collection.toUpperCase() : 'Collection');
  desc = collectionData ? collectionData.description : '';
  coverImage = collectionData ? collectionData.imageUrl : null;
  collectionTotalPages = Math.max(1, Math.ceil(totalCollectionProducts / limit));
}

const SEEDED_COLLECTIONS_FALLBACK: Record<string, {
  storyTitle: { en: string; th: string };
  storySubtitle: { en: string; th: string };
  storyParagraphs: { en: string[]; th: string[] };
  sideImage: string;
  galleryImages: string[];
}> = {
  'spring-blossom-2026': {
    storyTitle: {
      en: "Chasing the Vernal Light",
      th: "เมื่อแสงแรกแห่งฤดูใบไม้ผลิมาเยือน"
    },
    storySubtitle: {
      en: "A study in fresh beginnings, tailored fluidity, and breathable premium linen.",
      th: "การค้นหารูปแบบการแต่งกายที่เบาสบาย ทรงเสื้อที่พริ้วไหวประณีต และความหรูหราของผ้าลินินคุณภาพสูง"
    },
    storyParagraphs: {
      en: [
        "The Spring Blossom 2026 collection marks a return to nature's softest textures and clean architectural lines. Inspired by the quiet bloom of cherry blossoms against raw concrete structures, this collection explores the dialogue between soft seasonal transitions and daily urban utility.",
        "We focus on carefully selected light linen, organic cotton, and breathable knits that flow with movement. From transitional trench coats to daily polo shirts and minimal leather sneakers, each silhouette is tailored to represent a sense of refined ease and natural comfort for your daily routines."
      ],
      th: [
        "คอลเลกชัน Spring Blossom 2026 เป็นสัญลักษณ์ของการหวนคืนสู่ผิวสัมผัสที่อ่อนโยนของธรรมชาติและเส้นสายทางสถาปัตยกรรมที่เรียบง่าย ได้รับแรงบันดาลใจจากการเบ่งบานอย่างเงียบสงบของดอกซากุระตัดกับโครงสร้างคอนกรีตที่ดิบเท่ คอลเลกชันนี้สำรวจบทสนทนาระหว่างการเปลี่ยนผ่านของฤดูกาลที่อ่อนโยนและประโยชน์ใช้สอยในเมืองใหญ่",
        "เราเน้นที่การคัดสรรผ้าลินินเนื้อบางเบา ผ้าฝ้ายออร์แกนิก และเสื้อถักที่ระบายอากาศได้ดี ซึ่งเคลื่อนไหวไปพร้อมกับคุณ ตั้งแต่เสื้อโค้ทเทรนช์สำหรับช่วงเปลี่ยนฤดู ไปจนถึงเสื้อโปโลที่สวมใส่ได้ทุกวันและรองเท้าผ้าใบหนังดีไซน์มินิมอล ทุกชิ้นส่วนถูกตัดเย็บเพื่อสะท้อนถึงความประณีตและความสบายตามธรรมชาติในชีวิตประจำวันของคุณ"
      ]
    },
    sideImage: "/assets/images/editorial-side.png",
    galleryImages: [
      "/assets/images/spring_lookbook1.png",
      "/assets/images/spring_lookbook2.png",
      "/assets/images/spring_lookbook3.png"
    ]
  },
  'summer-essentials-2026': {
    storyTitle: {
      en: "Sun-Drenched Simplicity",
      th: "ความเรียบง่ายภายใต้แสงแดดอบอุ่น"
    },
    storySubtitle: {
      en: "Breathable fabrics, relaxed cuts, and curated essentials for the warm season.",
      th: "ผ้าที่ระบายอากาศได้ดี ทรงหลวมสบาย และไอเท็มจำเป็นที่ได้รับการคัดสรรสำหรับฤดูร้อน"
    },
    storyParagraphs: {
      en: [
        "Our Summer Essentials 2026 collection is inspired by sun-drenched coastlines and slow living. Emphasizing ease and breathability, the collection highlights lightweight linens, relaxed trousers, and versatile accessories designed to keep you cool and chic.",
        "Designed for the hottest days, the selection features minimalist watches, cream tailored trousers, and soft leather sandals. Each piece is crafted to transition effortlessly from beachside strolls to warm city nights, capturing the ultimate summer mood."
      ],
      th: [
        "คอลเลกชัน Summer Essentials 2026 ของเราได้รับแรงบันดาลใจจากชายฝั่งทะเลที่อาบไปด้วยแสงแดดและการใช้ชีวิตที่ช้าลง โดยเน้นที่ความสบายและการระบายอากาศเป็นหลัก คอลเลกชันนี้นำเสนอผ้าลินินน้ำหนักเบา กางเกงทรงหลวม และเครื่องประดับสารพัดประโยชน์ที่ออกแบบมาเพื่อให้คุณรู้สึกเย็นและมีสไตล์",
        "ออกแบบมาสำหรับวันที่มีอากาศร้อนที่สุด คอลเลกชันนี้ประกอบด้วยนาฬิกาดีไซน์มินิมอล กางเกงสแล็กสีครีม และรองเท้าแตะหนังนุ่ม ทุกชิ้นสร้างสรรค์ขึ้นเพื่อสวมใส่ได้อย่างง่ายดายตั้งแต่การเดินเล่นริมหาดไปจนถึงค่ำคืนที่อบอุ่นในเมืองใหญ่ สะท้อนถึงอารมณ์แห่งฤดูร้อนที่แท้จริง"
      ]
    },
    sideImage: "/assets/images/set1.png",
    galleryImages: [
      "/assets/images/women-hero.png",
      "/assets/images/set2.png",
      "/assets/images/set3.png"
    ]
  }
};

let parsedStoryParagraphsEn = [];
let parsedStoryParagraphsTh = [];
let parsedGalleryImages = [];

if (collectionData) {
  try {
    parsedStoryParagraphsEn = collectionData.storyParagraphsEn ? JSON.parse(collectionData.storyParagraphsEn) : [];
  } catch (e) {
    parsedStoryParagraphsEn = collectionData.storyParagraphsEn ? [collectionData.storyParagraphsEn] : [];
  }

  try {
    parsedStoryParagraphsTh = collectionData.storyParagraphsTh ? JSON.parse(collectionData.storyParagraphsTh) : [];
  } catch (e) {
    parsedStoryParagraphsTh = collectionData.storyParagraphsTh ? [collectionData.storyParagraphsTh] : [];
  }

  try {
    parsedGalleryImages = collectionData.galleryImages ? JSON.parse(collectionData.galleryImages) : [];
  } catch (e) {
    parsedGalleryImages = [];
  }
}

// Check if database contains story details, otherwise use fallback for seeded ones
const dbHasStory = collectionData && (collectionData.storyTitleEn || collectionData.storyTitleTh);
const fallbackMeta = id && !isNumericId ? SEEDED_COLLECTIONS_FALLBACK[id] : null;

const metadata = dbHasStory ? {
  storyTitle: {
    en: collectionData.storyTitleEn || collectionData.title,
    th: collectionData.storyTitleTh || collectionData.title,
  },
  storySubtitle: {
    en: collectionData.storySubtitleEn || '',
    th: collectionData.storySubtitleTh || '',
  },
  storyParagraphs: {
    en: parsedStoryParagraphsEn,
    th: parsedStoryParagraphsTh,
  },
  sideImage: collectionData.storyImageUrl || collectionData.imageUrl || '/assets/images/editorial-side.png',
  galleryImages: parsedGalleryImages,
} : fallbackMeta;

const productId = displayProduct?.id || null;

const modelImages = [] as string[];
if (collectionData) {
  if (collectionData.storyImageUrl) modelImages.push(collectionData.storyImageUrl);
  if (parsedGalleryImages && parsedGalleryImages.length > 0) {
    modelImages.push(...parsedGalleryImages);
  }
} else if (metadata) {
  if (metadata.sideImage) modelImages.push(metadata.sideImage);
  if (metadata.galleryImages && metadata.galleryImages.length > 0) {
    modelImages.push(...metadata.galleryImages);
  }
}
const finalModelImages = modelImages.filter(Boolean).slice(0, 3);
