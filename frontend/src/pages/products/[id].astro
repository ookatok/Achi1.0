              {product.activeDiscountPercent > 0 && (
                <span class="absolute top-6 left-6 z-20 bg-red-600 text-white text-[9px] uppercase tracking-widest font-bold px-2.5 py-1 rounded-sm shadow-sm">
                  -{product.activeDiscountPercent}%
                </span>
              )}
              {product.imageUrl ? (
                <img src={resolveImage(product.imageUrl)} alt={product.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102" />
              ) : (
                <span class="text-[9px] uppercase tracking-[0.2em] text-gray-400 text-center font-light leading-relaxed">
                  [Image: {product.name}]
                </span>
              )}
              {product.status === 'inactive' && (
                <div class="absolute inset-0 bg-stone-900/40 backdrop-blur-xs flex items-center justify-center z-10">
                  <span class="text-white text-[10px] uppercase tracking-widest font-semibold border border-white/60 px-3 py-1.5 rounded-sm">
                    {lang === 'en' ? 'Not Available' : 'งดจำหน่าย'}
                  </span>
                </div>
              )}
            </div>

              {product.activeDiscountPercent > 0 ? (
                <div class="flex items-center gap-3 mt-2">
                  <span class="text-xs text-red-600 font-bold">${(Number(product.price) * (1 - product.activeDiscountPercent / 100)).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>
                  <span class="text-[10px] text-gray-400 line-through font-light">${Number(product.price).toLocaleString()}</span>
                </div>
              ) : (
                <span class="text-xs text-brand-gold font-medium mt-2 block">${Number(product.price).toLocaleString()}</span>
              )}

            <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
          </div>
        ))}
        {displayProducts.length === 0 && (
          <div class="col-span-full text-center py-12 text-stone-400 font-light italic text-sm">
            {lang === 'en' ? 'No products in this collection' : 'ไม่มีสินค้าในคอลเลกชันนี้'}
          </div>
        )}
      </div>

      <!-- Pagination Component -->
      {displayProducts.length > 0 && <Pagination totalPages={collectionTotalPages} />}
    </div>

    <script is:inline>
      (function() {
        const frames = document.querySelectorAll('.lookbook-frame');
        const prevBtn = document.getElementById('gallery-prev-btn');
        const nextBtn = document.getElementById('gallery-next-btn');

        if (frames.length > 3) {
          let currentPage = 0;
          const totalPages = Math.ceil(frames.length / 3);

          const updateGallery = () => {
            frames.forEach((frame) => {
              const idx = parseInt(frame.getAttribute('data-index') || '0', 10);
              const start = currentPage * 3;
              const end = start + 3;

              if (idx >= start && idx < end) {
                frame.style.display = '';
                // Force redraw for opacity transition
                setTimeout(() => {
                  frame.style.opacity = '1';
                }, 10);
              } else {
                frame.style.opacity = '0';
                frame.style.display = 'none';
              }
            });

            // Update prev button state
            if (prevBtn) {
              if (currentPage === 0) {
                prevBtn.setAttribute('disabled', 'true');
                prevBtn.style.opacity = '0';
                prevBtn.style.pointerEvents = 'none';
              } else {
                prevBtn.removeAttribute('disabled');
                prevBtn.style.opacity = '1';
                prevBtn.style.pointerEvents = 'auto';
              }
            }

            // Update next button state
            if (nextBtn) {
              if (currentPage === totalPages - 1) {
                nextBtn.setAttribute('disabled', 'true');
                nextBtn.style.opacity = '0';
                nextBtn.style.pointerEvents = 'none';
              } else {
                nextBtn.removeAttribute('disabled');
                nextBtn.style.opacity = '1';
                nextBtn.style.pointerEvents = 'auto';
              }
            }
          };

          // Event listeners
          prevBtn?.addEventListener('click', () => {
            if (currentPage > 0) {
              currentPage--;
              updateGallery();
            }
          });

          nextBtn?.addEventListener('click', () => {
            if (currentPage < totalPages - 1) {
              currentPage++;
              updateGallery();
            }
          });

          // Initialize
          updateGallery();
        } else {
          if (prevBtn) prevBtn.style.display = 'none';
          if (nextBtn) nextBtn.style.display = 'none';
        }
      })();
    </script>
  </Layout>
)}

