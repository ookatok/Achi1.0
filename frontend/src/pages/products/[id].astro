---
import Layout from '../../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';
import { translateProduct } from '../../lib/translations';
import Pagination from '../../components/common/Pagination.astro';

const { id } = Astro.params;
const isNumericId = id && /^\d+$/.test(id);
const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return `${BACKEND_URL}${url}`;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=2';
};

const parseArray = (val: any) => {
  if (!val) return [];
  if (Array.isArray(val)) return val;
  try {
    const parsed = typeof val === 'string' ? JSON.parse(val) : val;
    return Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    if (typeof val === 'string' && val.includes(',')) {
      return val.split(',').map(s => s.trim()).filter(Boolean);
    }
    if (typeof val === 'string' && val.trim() !== '') {
      return [val.trim()];
    }
    return [];
  }
};

// ----------------------------------------------------
// Branch A: Product Detail (Numeric ID)
// ----------------------------------------------------
let displayProduct = null;
let displayColors = [];
let displaySizes = [];
let displayTags = [];
let displayImages = [];
let token = null;

// ----------------------------------------------------
// Branch B: Collection (Slug ID)
// ----------------------------------------------------
let displayProducts = [];
let title = '';
let desc = '';
let coverImage = null;
let collectionTotalPages = 1;

if (isNumericId) {
  // Fetch user session for token authorization
  const session = await getSession(Astro.request);
  token = (session as any)?.accessToken;

  let product = null;
  try {
    const res = await fetch(`${BACKEND_URL}/api/products/${id}`);
    if (res.ok) {
      product = await res.json();
    }
  } catch (err) {
    console.error('[NestJS API Error] Fetching product details failed.', err);
  }

  displayProduct = product ? translateProduct(product, lang) : null;

  if (displayProduct) {
    displayColors = parseArray(displayProduct.colors);
    displaySizes = parseArray(displayProduct.sizes);
    displayTags = parseArray(displayProduct.tags);
    displayImages = parseArray(displayProduct.images);
  }
} else {
  // Collection logic
  const collection = id;
  const page = parseInt(Astro.url.searchParams.get('page') || '1', 10);
  const limit = 8;

  let productsList = [] as any[];
  let collectionData = null as any;
  let totalCollectionProducts = 0;

  try {
    // 1. Fetch collection details
    const colRes = await fetch(`${BACKEND_URL}/api/collections`);
    if (colRes.ok) {
      const cols = await colRes.json();
      collectionData = cols.find((c: any) => c.slug === collection);
    }

    // 2. Fetch products associated with this collection
    const res = await fetch(`${BACKEND_URL}/api/products?collection=${collection}&page=${page}&limit=${limit}`);
    if (res.ok) {
      productsList = await res.json();
    }

    // Fetch total count for pagination
    const countRes = await fetch(`${BACKEND_URL}/api/products?collection=${collection}`);
    if (countRes.ok) {
      const allColProducts = await countRes.json();
      totalCollectionProducts = allColProducts.length;
    }
  } catch (err) {
    console.error('[NestJS API Error] Fetching dynamic collection failed.', err);
  }

  displayProducts = productsList.map(p => translateProduct(p, lang));
  title = collectionData ? collectionData.title : (collection ? collection.toUpperCase() : 'Collection');
  desc = collectionData ? collectionData.description : '';
  coverImage = collectionData ? collectionData.imageUrl : null;
  collectionTotalPages = Math.max(1, Math.ceil(totalCollectionProducts / limit));
}

const productId = displayProduct?.id || null;
---

{isNumericId ? (
  displayProduct ? (
    <Layout 
      title={`${displayProduct?.name} | ACHI Studio`} 
      description={displayProduct?.description}
    >
      <div class="max-w-[1440px] mx-auto px-6 py-16">
        {/* Breadcrumbs */}
        <nav class="text-xs uppercase tracking-widest text-gray-400 font-light mb-8">
          <a href="/products" class="hover:text-brand-charcoal transition-colors">
            {lang === 'en' ? "Clothing" : "เสื้อผ้า"}
          </a>
          <span class="mx-2">/</span>
          <span class="text-brand-charcoal">{displayProduct?.name}</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
          <!-- Left Column: Vertical Image Stack -->
          <div id="product-images-column" class="space-y-8 flex flex-col items-center">
            <!-- Main Product Image -->
            <div class="w-full bg-gray-50 overflow-hidden flex items-center justify-center p-8 aspect-[1/1] rounded-sm relative shrink-0 product-image-container" data-color="default">
              <img
                src={resolveImage(displayProduct?.imageUrl)}
                alt={displayProduct?.name}
                class="max-h-[90%] object-contain mix-blend-multiply"
              />
            </div>

            <!-- Mapped Color Images -->
            {displayImages && displayImages.map((imgItem: any) => (
              <div 
                class="w-full bg-gray-50 overflow-hidden flex items-center justify-center p-8 aspect-[1/1] rounded-sm relative shrink-0 product-image-container"
                data-color={imgItem.color || ''}
              >
                <img
                  src={resolveImage(imgItem.imageUrl)}
                  alt={`${displayProduct?.name} - ${imgItem.color || 'detail'}`}
                  class="max-h-[90%] object-contain mix-blend-multiply"
                />
              </div>
            ))}

            {/* Alternate Gray Image Placeholders if no additional images are uploaded */}
            {(!displayImages || displayImages.length === 0) && (
              <>
                <div class="w-full bg-gray-100 flex items-center justify-center aspect-[1/1] text-gray-400 font-light uppercase tracking-widest text-sm rounded-sm shrink-0">
                  {lang === 'en' ? "image" : "รูปภาพ"}
                </div>
                <div class="w-full bg-gray-100 flex items-center justify-center aspect-[1/1] text-gray-400 font-light uppercase tracking-widest text-sm rounded-sm shrink-0">
                  {lang === 'en' ? "image" : "รูปภาพ"}
                </div>
              </>
            )}
          </div>

          <!-- Right Column: Product Details & Options -->
          <div class="space-y-8 lg:sticky lg:top-28">
          <div>
            <h1 class="font-serif text-3xl font-bold tracking-wide text-brand-charcoal mb-4 uppercase">
              {displayProduct?.name}
            </h1>
            
            {displayProduct?.status === 'inactive' && (
              <div class="mb-4">
                <span class="inline-block bg-red-50 text-red-600 border border-red-100 text-[10px] uppercase tracking-widest font-semibold px-2.5 py-1 rounded-sm">
                  {lang === 'en' ? 'Not Available' : 'งดจำหน่าย'}
                </span>
              </div>
            )}
            
            <div class="text-xl font-semibold text-brand-charcoal mb-6">
              ${Number(displayProduct?.price).toLocaleString()}
            </div>
            
            <p class="text-xs text-gray-500 font-light leading-relaxed mb-4">
              {lang === 'en' 
                ? "incl. tax. Shipping costs showing post coding: Free returns until 14 days."
                : "รวมภาษีมูลค่าเพิ่มแล้ว | ค่าจัดส่งคำนวณขณะชำระเงิน | คืนสินค้าฟรีภายใน 14 วัน"
              }
            </p>
          </div>

          {/* Option: Colors Swatches */}
          {displayColors && displayColors.length > 0 && (
            <div>
              <h4 class="block text-xs uppercase tracking-wider font-semibold text-gray-400 mb-3">
                {lang === 'en' ? "Product colors" : "สีของผลิตภัณฑ์"}
              </h4>
              <div class="flex gap-3">
                {displayColors.map((color: string, index: number) => (
                  <button
                    class={`w-7 h-7 rounded-full border border-stone-300 block shadow-xs focus:outline-none cursor-pointer color-option-btn ${index === 0 ? 'ring-2 ring-brand-charcoal ring-offset-2' : ''}`}
                    style={{ backgroundColor: color }}
                    data-color={color}
                  ></button>
                ))}
              </div>
            </div>
          )}

          {/* Option: Sizes Divisors & Tags */}
          {((displaySizes && displaySizes.length > 0) || (displayTags && displayTags.length > 0)) && (
            <div>
              <div class="flex justify-between items-center mb-3">
                {displaySizes && displaySizes.length > 0 && (
                  <h4 class="block text-xs uppercase tracking-wider font-semibold text-gray-400">
                    {lang === 'en' ? "Product size" : "ขนาดไซส์สินค้า"}
                  </h4>
                )}
              </div>
              
              <div class="flex justify-between items-center">
                {displaySizes && displaySizes.length > 0 ? (
                  <div class="flex items-center gap-4 text-xs font-light tracking-wider text-gray-500">
                    {displaySizes.map((size: string, index: number) => (
                      <>
                        {index > 0 && <span class="text-gray-300">|</span>}
                        <button
                          class={`hover:text-brand-charcoal transition-colors focus:outline-none cursor-pointer size-option-btn ${index === 0 ? 'font-semibold text-brand-charcoal' : ''}`}
                          data-size={size}
                        >
                          {size}
                        </button>
                      </>
                    ))}
                  </div>
                ) : <div></div>}
                
                {/* Product Tags */}
                {displayTags && displayTags.length > 0 && (
                  <div class="flex gap-2">
                    {displayTags.map((tag: any) => (
                      <span class="text-[9px] uppercase tracking-widest text-stone-500 border border-stone-200 px-2.5 py-0.5 rounded-full bg-stone-50/50 hover:bg-stone-100 hover:text-brand-charcoal hover:border-brand-charcoal transition-all font-sans font-medium cursor-default">
                        {typeof tag === 'object' ? (lang === 'en' ? tag.name : (tag.name === 'summer' ? 'ฤดูร้อน' : tag.name === 'basics' ? 'เบสิก' : tag.name === 'new' ? 'ใหม่' : tag.name)) : tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          )}

          {/* Add To Cart & Favorite Row */}
          <div>
            <div class="flex gap-4">
              <button
                id="add-to-cart-btn"
                disabled={displayProduct?.status === 'inactive'}
                class={`flex-grow py-4 rounded-sm text-xs uppercase tracking-[0.2em] font-semibold transition-all duration-300 ${displayProduct?.status === 'inactive' ? 'bg-stone-200 text-stone-400 border border-stone-300 cursor-not-allowed' : 'bg-brand-charcoal text-white hover:bg-brand-gold hover:text-brand-charcoal cursor-pointer'}`}
              >
                {displayProduct?.status === 'inactive'
                  ? (lang === 'en' ? "NOT AVAILABLE" : "งดจำหน่าย")
                  : (lang === 'en' ? "ADD TO CART" : "เพิ่มลงในตะกร้า")
                }
              </button>
              <button
                id="favorite-detail-btn"
                class="px-5 border border-gray-200 hover:border-brand-charcoal rounded-sm text-gray-400 hover:text-brand-charcoal transition-all cursor-pointer flex items-center justify-center focus:outline-none"
                data-favorite-btn
                data-id={displayProduct?.id}
                data-name={displayProduct?.name}
                data-price={displayProduct?.price}
                data-image={displayProduct?.imageUrl}
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                </svg>
              </button>
            </div>
            <div id="cart-msg" class="hidden mt-4 p-4 text-xs font-medium rounded-sm"></div>
          </div>

          {/* Accordions */}
          <div class="border-t border-gray-200 pt-4 divide-y divide-gray-200 text-xs tracking-wider uppercase font-light text-gray-600">
            <div class="py-4">
              <details class="group cursor-pointer">
                <summary class="flex justify-between items-center focus:outline-none select-none">
                  <span>{lang === 'en' ? "Check in-store Availability" : "ตรวจสอบสินค้าคงเหลือหน้าร้าน"}</span>
                  <span class="transition-transform duration-300 group-open:rotate-180">▼</span>
                </summary>
                <div class="mt-4 text-gray-500 font-light normal-case tracking-normal leading-relaxed pl-2">
                  {lang === 'en'
                    ? "Available at ACHI Flagship Studio and selected branches in Bangkok."
                    : "มีจำหน่ายที่ ACHI แฟลกชิป สตูดิโอ และสาขาชั้นนำอื่นๆ ที่กำหนดในกรุงเทพมหานคร"
                  }
                </div>
              </details>
            </div>

            <div class="py-4">
              <details class="group cursor-pointer">
                <summary class="flex justify-between items-center focus:outline-none select-none">
                  <span>{lang === 'en' ? "Fit Details" : "รายละเอียดรูปทรงเสื้อผ้า"}</span>
                  <span class="transition-transform duration-300 group-open:rotate-180">▼</span>
                </summary>
                <div class="mt-4 text-gray-500 font-light normal-case tracking-normal leading-relaxed pl-2">
                  {lang === 'en'
                    ? "Relaxed fit contours, designed for everyday minimal chic style. Model is wearing size L."
                    : "รูปทรงทรงหลวมสบาย (Relaxed Fit) ออกแบบมาเพื่อสไตล์มินิมอลเก๋ไก๋ในทุกๆ วัน นายแบบ/นางแบบสวมใส่ขนาดไซส์ L"
                  }
                </div>
              </details>
            </div>

            <div class="py-4">
              <details class="group cursor-pointer">
                <summary class="flex justify-between items-center focus:outline-none select-none">
                  <span>{lang === 'en' ? "Materials" : "วัสดุและส่วนประกอบ"}</span>
                  <span class="transition-transform duration-300 group-open:rotate-180">▼</span>
                </summary>
                <div class="mt-4 text-gray-500 font-light normal-case tracking-normal leading-relaxed pl-2">
                  {lang === 'en'
                    ? "100% premium organic cotton. Clean double-needle stitched seams."
                    : "ผลิตจากฝ้ายออร์แกนิกเกรดพรีเมียม 100% แนวตะเข็บเย็บเข็มคู่ประณีตและเรียบร้อย"
                  }
                </div>
              </details>
            </div>

            <div class="py-4">
              <details class="group cursor-pointer">
                <summary class="flex justify-between items-center focus:outline-none select-none">
                  <span>{lang === 'en' ? "Shipping and returns" : "การจัดส่งและการคืนสินค้า"}</span>
                  <span class="transition-transform duration-300 group-open:rotate-180">▼</span>
                </summary>
                <div class="mt-4 text-gray-500 font-light normal-case tracking-normal leading-relaxed pl-2">
                  {lang === 'en'
                    ? "Free standard delivery. Easy and unconditional returns up to 14 days."
                    : "จัดส่งมาตรฐานฟรี คืนสินค้าได้ง่ายและไม่มีเงื่อนไขภายในระยะเวลา 14 วัน"
                  }
                </div>
              </details>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script is:inline define:vars={{ token, productId, lang }}>
      let selectedColor = '';
      let selectedSize = '';
      const isEn = lang === 'en';

      const colorButtons = document.querySelectorAll('.color-option-btn');
      const sizeButtons = document.querySelectorAll('.size-option-btn');

      if (colorButtons.length > 0) {
        selectedColor = colorButtons[0].getAttribute('data-color') || '';
        colorButtons.forEach(btn => {
          btn.addEventListener('click', () => {
            colorButtons.forEach(b => b.classList.remove('ring-2', 'ring-brand-charcoal', 'ring-offset-2'));
            btn.classList.add('ring-2', 'ring-brand-charcoal', 'ring-offset-2');
            selectedColor = btn.getAttribute('data-color') || '';

            // Find matching image container
            const imageContainers = document.querySelectorAll('.product-image-container');
            let matchedContainer = null;
            imageContainers.forEach(container => {
              if (container.getAttribute('data-color') === selectedColor) {
                matchedContainer = container;
              }
            });

            if (matchedContainer) {
              matchedContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            } else {
              // Scroll back to main cover
              const defaultContainer = document.querySelector('.product-image-container[data-color="default"]');
              if (defaultContainer) {
                defaultContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              }
            }
          });
        });
      }

      if (sizeButtons.length > 0) {
        selectedSize = sizeButtons[0].getAttribute('data-size') || '';
        sizeButtons.forEach(btn => {
          btn.addEventListener('click', () => {
            sizeButtons.forEach(b => b.classList.remove('font-semibold', 'text-brand-charcoal'));
            btn.classList.add('font-semibold', 'text-brand-charcoal');
            selectedSize = btn.getAttribute('data-size') || '';
          });
        });
      }

      const addToCartBtn = document.getElementById('add-to-cart-btn');
      const cartMsg = document.getElementById('cart-msg');

      if (addToCartBtn) {
        addToCartBtn.addEventListener('click', async () => {
          if (!token) {
            window.location.href = `/auth/signin?callbackUrl=${encodeURIComponent(window.location.pathname)}`;
            return;
          }

          addToCartBtn.disabled = true;
          addToCartBtn.textContent = isEn ? 'ADDING TO CART...' : 'กำลังเพิ่มลงในตะกร้า...';

          try {
            const res = await fetch('http://localhost:3001/api/cart/add', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
              },
              body: JSON.stringify({
                productId,
                quantity: 1,
                size: selectedSize || undefined,
                color: selectedColor || undefined
              })
            });

            const data = await res.json();

            if (res.ok) {
              if (cartMsg) {
                cartMsg.textContent = isEn ? 'Item added to your cart successfully!' : 'เพิ่มสินค้าลงในตะกร้าของคุณเรียบร้อยแล้ว!';
                cartMsg.className = 'mt-4 p-4 text-xs font-medium rounded-sm bg-green-50 border-l-2 border-green-500 text-green-600 block';
              }
              window.dispatchEvent(new CustomEvent('cart-updated'));
            } else {
              throw new Error(data.message || (isEn ? 'Could not add item' : 'ไม่สามารถเพิ่มสินค้าลงในตะกร้าได้'));
            }
          } catch (err) {
            console.error(err);
            if (cartMsg) {
              cartMsg.textContent = err.message || (isEn ? 'An error occurred.' : 'เกิดข้อผิดพลาดขึ้น');
              cartMsg.className = 'mt-4 p-4 text-xs font-medium rounded-sm bg-red-50 border-l-2 border-red-500 text-red-600 block';
            }
          } finally {
            addToCartBtn.disabled = false;
            addToCartBtn.textContent = isEn ? 'ADD TO CART' : 'เพิ่มลงในตะกร้า';
          }
        });
      }
    </script>

  </Layout>
  ) : (
    <Layout title={lang === 'en' ? "Product Not Found | ACHI Studio" : "ไม่พบสินค้า | ACHI Studio"}>
      <div class="max-w-[1440px] mx-auto px-6 py-32 text-center">
        <h1 class="font-serif text-3xl sm:text-5xl font-bold tracking-wide text-brand-charcoal mb-4 uppercase">
          {lang === 'en' ? "Product Not Found" : "ไม่พบสินค้า"}
        </h1>
        <p class="text-sm font-light text-gray-500 mb-8 max-w-md mx-auto leading-relaxed">
          {lang === 'en' 
            ? "The product you are looking for might have been removed, had its name changed, or is temporarily unavailable."
            : "ไม่พบสินค้าที่คุณกำลังมองหา สินค้านี้อาจถูกนำออก เปลี่ยนชื่อ หรือไม่เปิดให้บริการชั่วคราว"
          }
        </p>
        <a href="/products" class="inline-block bg-brand-charcoal text-white hover:bg-brand-gold hover:text-brand-charcoal px-8 py-4 rounded-sm text-xs uppercase tracking-[0.2em] font-semibold transition-all duration-300">
          {lang === 'en' ? "BACK TO CATALOG" : "กลับไปยังแค็ตตาล็อก"}
        </a>
      </div>
    </Layout>
  )
) : (
  <Layout 
    title={lang === 'en' ? `${title} | ACHI Studio` : `${title} | ACHI Studio`} 
    description={desc || (lang === 'en' ? "Shop seasonal collection items." : "ช้อปสินค้าประจำคอลเลกชัน")} 
    showHeroHeader={true}
  >
    <section class="w-full relative h-[60vh] bg-[#222222] flex items-center justify-center text-white overflow-hidden">
      {coverImage ? (
        <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${resolveImage(coverImage)}');`}></div>
      ) : (
        <div class="absolute inset-0 bg-cover bg-center opacity-40" style="background-image: url('/assets/images/collection-hero.png?v=2');"></div>
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-70"></div>
      
      <div class="relative w-full max-w-[1440px] mx-auto px-6 flex flex-col justify-end h-full pb-16">
        <div class="flex items-end justify-between w-full">
          <div>
            <span class="border border-white border-opacity-40 px-3 py-1 text-[10px] tracking-widest uppercase font-light rounded-full mb-4 inline-block">
              {lang === 'en' ? "Collection" : "คอลเลกชัน"}
            </span>
            <h1 class="font-serif text-5xl sm:text-7xl font-bold tracking-tight uppercase leading-none">
              {title}
            </h1>
            {desc && (
              <p class="text-xs sm:text-sm tracking-widest font-light text-gray-300 max-w-xl mt-4 uppercase leading-relaxed">
                {desc}
              </p>
            )}
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-gray-100 bg-white">
      <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between text-[11px] uppercase tracking-wider font-light text-gray-400">
        <nav class="flex items-center gap-2">
          <a href="/" class="hover:text-brand-charcoal transition-colors">{lang === 'en' ? "Home" : "หน้าแรก"}</a>
          <span>/</span>
          <a href="/collections" class="hover:text-brand-charcoal transition-colors">{lang === 'en' ? "Collections" : "คอลเลกชัน"}</a>
          <span>/</span>
          <span class="text-brand-charcoal">{title}</span>
        </nav>
        <span>{lang === 'en' ? `Showing ${displayProducts.length} items` : `แสดงทั้งหมด ${displayProducts.length} รายการ`}</span>
      </div>
    </section>

    <div class="max-w-[1440px] mx-auto px-6 py-16">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
        {displayProducts.map((product: any) => (
          <div class="flex flex-col justify-between p-6 bg-white border border-gray-100 rounded-sm product-card-hover group relative">
            <button class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal transition-colors focus:outline-none cursor-pointer z-20">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
              </svg>
            </button>

            <!-- Product Image Box -->
            <div class="aspect-[1/1] overflow-hidden flex flex-col items-center justify-center bg-gray-50 border border-gray-100/50 rounded-sm mb-6 relative group">
              {product.imageUrl ? (
                <img src={resolveImage(product.imageUrl)} alt={product.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
              ) : (
                <span class="text-[9px] uppercase tracking-[0.2em] text-gray-400 text-center font-light leading-relaxed">
                  [Image: {product.name}]
                </span>
              )}
              {product.status === 'inactive' && (
                <div class="absolute inset-0 bg-stone-900/40 backdrop-blur-xs flex items-center justify-center z-10">
                  <span class="text-white text-[10px] uppercase tracking-widest font-semibold border border-white/60 px-3 py-1.5 rounded-sm">
                    {lang === 'en' ? 'Not Available' : 'งดจำหน่าย'}
                  </span>
                </div>
              )}
            </div>

            <div>
              <div class="flex items-center justify-between gap-4">
                <h3 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight">
                  {product.name}
                </h3>
                {/* Color swatches */}
                {parseArray(product.colors).length > 0 && (
                  <div class="flex gap-1.5 shrink-0">
                    {parseArray(product.colors).map((color: string) => (
                      <span class="w-3.5 h-3.5 rounded-full border border-stone-300 block shadow-xs" style={{ backgroundColor: color }}></span>
                    ))}
                  </div>
                )}
              </div>
              <span class="text-xs text-brand-gold font-medium mt-2 block">${Number(product.price).toLocaleString()}</span>
            </div>

            <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
          </div>
        ))}
        {displayProducts.length === 0 && (
          <div class="col-span-full text-center py-12 text-stone-400 font-light italic text-sm">
            {lang === 'en' ? 'No products in this collection' : 'ไม่มีสินค้าในคอลเลกชันนี้'}
          </div>
        )}
      </div>

      <!-- Pagination Component -->
      {displayProducts.length > 0 && <Pagination totalPages={collectionTotalPages} />}
    </div>
  </Layout>
)}

