---
import Layout from '../../layouts/Layout.astro';

let productsList = [] as any[];

try {
  const res = await fetch(`${BACKEND_URL}/api/products?collection=summer`);
  if (res.ok) {
    productsList = await res.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching summer failed. Using mocks.', err);
}

const mockSummer = [
  { id: 1201, name: "Breezy Linen Button-Down", price: "110.00" },
  { id: 1202, name: "Relaxed Tailored Linen Shorts", price: "95.00" },
  { id: 1203, name: "Lightweight Cotton Sun Dress", price: "240.00" },
  { id: 1204, name: "Straw Woven Bucket Hat", price: "65.00" },
];

const displayProducts = productsList.length > 0 ? productsList : mockSummer;
---

<Layout title="Summer Collection | ACHI Studio" description="Lightweight linen shirts, relaxed shorts, and summer hats." showHeroHeader={true}>
  <section class="w-full relative h-[60vh] bg-[#3C382F] flex items-center justify-center text-white overflow-hidden">
    <div class="absolute inset-0 bg-[#444036] flex items-center justify-center">
      <span class="text-xs uppercase tracking-[0.4em] text-white/30 font-light">[Image: Summer Collection Hero Banner]</span>
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-60"></div>
    
    <div class="relative w-full max-w-[1440px] mx-auto px-6 flex flex-col justify-end h-full pb-16">
      <div class="flex items-end justify-between w-full">
        <div>
          <span class="border border-white border-opacity-40 px-3 py-1 text-[10px] tracking-widest uppercase font-light rounded-full mb-4 inline-block">Summer Collection</span>
          <h1 class="font-serif text-5xl sm:text-7xl font-bold tracking-tight uppercase leading-none">Summer</h1>
        </div>
        <div class="hidden sm:block text-right text-[11px] tracking-[0.35em] text-gray-300 uppercase font-light">
          Warm Weather Apparel
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-gray-100 bg-white">
    <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between text-[11px] uppercase tracking-wider font-light text-gray-400">
      <nav class="flex items-center gap-2">
        <a href="/" class="hover:text-brand-charcoal transition-colors">Home</a>
        <span>/</span>
        <a href="/products" class="hover:text-brand-charcoal transition-colors">Shop</a>
        <span>/</span>
        <span class="text-brand-charcoal">Summer</span>
      </nav>
      <span>Showing {displayProducts.length} items</span>
    </div>
  </section>

  <div class="max-w-[1440px] mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      {displayProducts.map((product: any) => (
        <div class="flex flex-col justify-between p-6 bg-white border border-gray-100 rounded-sm product-card-hover group relative">
          <button class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal transition-colors focus:outline-none cursor-pointer z-20">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
          </button>

          <div class="aspect-[1/1] overflow-hidden flex flex-col items-center justify-center bg-gray-50 border border-gray-100/50 rounded-sm mb-6 p-4">
            <span class="text-[9px] uppercase tracking-[0.2em] text-gray-400 text-center font-light leading-relaxed">
              [Image: {product.name}]
            </span>
          </div>

          <div>
            <h3 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight">
              {product.name}
            </h3>
            <span class="text-xs text-brand-gold font-medium mt-2 block">${Number(product.price).toLocaleString()}</span>
          </div>

          <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
        </div>
      ))}
    </div>
  </div>
</Layout>
