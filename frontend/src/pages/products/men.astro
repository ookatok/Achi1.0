---
import Layout from '../../layouts/Layout.astro';
import { translateProduct } from '../../lib/translations';
import Pagination from '../../components/common/Pagination.astro';

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

const page = parseInt(Astro.url.searchParams.get('page') || '1', 10);
const limit = 8;

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return url;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=3';
};

let productsList = [] as any[];
let totalProducts = 0;

try {
  const res = await fetch(`${BACKEND_URL}/api/products?categorySlug=men&page=${page}&limit=${limit}`);
  if (res.ok) {
    productsList = await res.json();
  }

  const countRes = await fetch(`${BACKEND_URL}/api/products?categorySlug=men`);
  if (countRes.ok) {
    const allProducts = await countRes.json();
    totalProducts = allProducts.length;
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching products failed.', err);
}

const displayProducts = productsList.map(p => translateProduct(p, lang));
const paginatedList = displayProducts;
const totalPages = Math.max(1, Math.ceil(totalProducts / limit));

const getColorsArray = (colors: any) => {
  if (!colors) return [];
  if (Array.isArray(colors)) return colors;
  try {
    const parsed = typeof colors === 'string' ? JSON.parse(colors) : colors;
    return Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    if (typeof colors === 'string' && colors.includes(',')) {
      return colors.split(',').map(s => s.trim()).filter(Boolean);
    }
    if (typeof colors === 'string' && colors.trim() !== '') {
      return [colors.trim()];
    }
    return [];
  }
};
---

<Layout title={lang === 'en' ? "Men's Fashion | ACHI Studio" : "แฟชั่นผู้ชาย | ACHI Studio"} description={lang === 'en' ? "New season, new looks. Shop ACHI's latest men's clothing, outerwear, and accessories." : "ซีซันใหม่ ลุคใหม่ ช้อปเสื้อผ้าผู้ชาย เสื้อตัวนอก และเครื่องประดับล่าสุดจาก ACHI"} showHeroHeader={true}>
  <!-- Men's Hero Section -->
  <section class="w-full relative h-[100vh] bg-[#3B3835] flex items-center text-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-65" style={`background-image: url('${resolveImage('/assets/images/men-hero.png')}');`}></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black via-transparent to-transparent opacity-40"></div>
    
    <div class="relative w-full max-w-[1440px] mx-auto px-6 pt-24 flex flex-col justify-center items-start h-full">
      <h1 class="font-serif text-5xl sm:text-8xl tracking-tight leading-none mb-4 uppercase">
        {lang === 'en' ? "Men's" : "แฟชั่น"}<br/>
        <span class="text-brand-gold italic font-normal">{lang === 'en' ? "Fashion" : "ผู้ชาย"}</span>
      </h1>
      <p class="font-sans text-xs sm:text-sm tracking-widest font-light mb-10 text-gray-300 uppercase">
        {lang === 'en' ? "New Season, New Looks." : "ซีซันใหม่ ลุคใหม่"}
      </p>
      
      <a href="#men-catalog" class="border border-white hover:bg-white hover:text-brand-charcoal text-white px-10 py-3.5 text-xs uppercase tracking-widest font-medium transition-all duration-300 rounded-sm">
        {lang === 'en' ? "Shop now" : "ช้อปเลย"}
      </a>
    </div>
  </section>

  <!-- Categories Collage Grid (Shirt, Bottoms, Cap) -->
  <section class="max-w-[1440px] mx-auto px-6 py-24" id="men-catalog">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24">
      <!-- Col 1: Shirt -->
      <a href="/products?colors=&sizes=&query=shirt" class="relative aspect-[4/5] bg-gray-50 overflow-hidden rounded-sm group block">
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${resolveImage('/assets/images/shirt-cat-men.png')}');`}></div>
        <div class="absolute inset-0 bg-black/10 group-hover:bg-black/25 transition-all"></div>
        <div class="absolute bottom-6 left-6 text-white z-10">
          <span class="font-serif text-xl font-medium tracking-widest underline decoration-brand-gold decoration-2 underline-offset-4 font-bold">{lang === 'en' ? "SHIRT" : "เสื้อเชิ้ต"}</span>
        </div>
      </a>

      <!-- Col 2: Bottoms -->
      <a href="/products?colors=&sizes=&query=pants" class="relative aspect-[4/5] bg-gray-50 overflow-hidden rounded-sm group block">
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${resolveImage('/assets/images/bottoms-cat-men.png')}');`}></div>
        <div class="absolute inset-0 bg-black/10 group-hover:bg-black/25 transition-all"></div>
        <div class="absolute bottom-6 left-6 text-white z-10">
          <span class="font-serif text-xl font-medium tracking-widest underline decoration-brand-gold decoration-2 underline-offset-4 font-bold">{lang === 'en' ? "BOTTOMS" : "กางเกง"}</span>
        </div>
      </a>

      <!-- Col 3: Cap -->
      <a href="/products?colors=&sizes=&query=cap" class="relative aspect-[4/5] bg-gray-50 overflow-hidden rounded-sm group block">
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style={`background-image: url('${resolveImage('/assets/images/cap-cat-men.png')}');`}></div>
        <div class="absolute inset-0 bg-black/10 group-hover:bg-black/25 transition-all"></div>
        <div class="absolute bottom-6 left-6 text-white z-10">
          <span class="font-serif text-xl font-medium tracking-widest underline decoration-brand-gold decoration-2 underline-offset-4 font-bold">{lang === 'en' ? "CAP" : "หมวก"}</span>
        </div>
      </a>
    </div>

    <!-- Product Grid: Outfit Sets -->
    <div class="space-y-12">
      <div class="text-center">
        <h2 class="font-serif text-3xl tracking-wide font-semibold text-brand-charcoal uppercase">
          {lang === 'en' ? "Men's Sets" : "เซ็ตสำหรับผู้ชาย"}
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {paginatedList.map((product: any) => (
          <div class="bg-white p-6 border border-gray-100 rounded-sm relative flex flex-col justify-between aspect-[1/1] product-card-hover group">
            {/* Heart Button */}
            <button
              class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal focus:outline-none cursor-pointer z-20"
              data-favorite-btn
              data-id={product.id}
              data-name={product.name}
              data-price={product.price}
              data-image={product.imageUrl}
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
            </button>
            <div class="flex-grow flex items-center justify-center overflow-hidden aspect-[4/3] relative my-4">
              <img src={resolveImage(product.imageUrl)} alt={product.name} class="max-h-[85%] object-contain mix-blend-multiply transition-transform duration-500 group-hover:scale-105" />
            </div>
            <div>
              <div class="flex items-center justify-between gap-4">
                <h3 class="font-serif text-xs font-semibold tracking-wider text-brand-charcoal uppercase leading-tight">{product.name}</h3>
                {/* Color swatches */}
                {getColorsArray(product.colors).length > 0 && (
                  <div class="flex gap-1.5 shrink-0">
                    {getColorsArray(product.colors).map((color: string) => (
                      <span class="w-3.5 h-3.5 rounded-full border border-stone-300 block shadow-xs" style={{ backgroundColor: color }}></span>
                    ))}
                  </div>
                )}
              </div>
              <span class="text-xs text-brand-gold font-medium mt-2 block">${Number(product.price).toLocaleString()}</span>
            </div>
            <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
          </div>
        ))}
      </div>

      <!-- Pagination Component -->
      <Pagination totalPages={totalPages} />
    </div>
  </section>
</Layout>
