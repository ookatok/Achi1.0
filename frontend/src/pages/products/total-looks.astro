---
import Layout from '../../layouts/Layout.astro';
const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return url;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=3';
};

let sets = [] as any[];

try {
  const res = await fetch(`${BACKEND_URL}/api/collections`);
  if (res.ok) {
    const rawCols = await res.json();
    sets = rawCols
      .filter((c: any) => c.slug === 'new-arrivals' || c.slug.startsWith('new-arrivals-'))
      .sort((a: any, b: any) => b.id - a.id);
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching collections failed in total-looks.astro', err);
}
---

<Layout 
  title={lang === 'en' ? "Total Looks | ACHI Studio" : "ลุคทั้งหมด | ACHI Studio"} 
  description={lang === 'en' ? "Complete outfit configurations designed as matching sets." : "ชุดแต่งกายครบชุดที่ออกแบบมาให้เข้าชุดกันอย่างลงตัว"} 
  showHeroHeader={true}
>
  {/* Editorial Collection Hero Banner */}
  <section class="w-full relative h-[45vh] bg-[#3C3C3C] flex items-center justify-center text-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-70" style="background-image: url('/assets/images/set1.png?v=3');"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
    
    <div class="relative w-full max-w-[1440px] mx-auto px-6 flex flex-col justify-end h-full pb-16">
      <div class="flex items-end justify-between w-full">
        <div>
          <span class="border border-white border-opacity-40 px-3 py-1 text-[10px] tracking-widest uppercase font-light rounded-full mb-4 inline-block">
            {lang === 'en' ? "COMPLETE OUTFITS" : "ชุดแต่งกายครบชุด"}
          </span>
          <h1 class="font-serif text-4xl sm:text-6xl font-bold tracking-tight uppercase leading-none">
            {lang === 'en' ? "Total Looks" : "ลุคทั้งหมด"}
          </h1>
          <p class="text-xs sm:text-sm tracking-widest font-light text-gray-300 max-w-xl mt-4 uppercase leading-relaxed">
            {lang === 'en' ? "Styled outfit configurations designed as matching sets" : "เซ็ตเสื้อผ้าที่ได้รับการจัดสรรและออกแบบมาอย่างลงตัวในลุคเดียว"}
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Breadcrumb Bar */}
  <section class="border-b border-gray-100 bg-white">
    <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between text-[11px] uppercase tracking-wider font-light text-gray-400">
      <nav class="flex items-center gap-2">
        <a href="/" class="hover:text-brand-charcoal transition-colors">{lang === 'en' ? "Home" : "หน้าแรก"}</a>
        <span>/</span>
        <a href="/products" class="hover:text-brand-charcoal transition-colors">{lang === 'en' ? "Shop" : "ช้อป"}</a>
        <span>/</span>
        <span class="text-brand-charcoal">{lang === 'en' ? "Total Looks" : "ลุคทั้งหมด"}</span>
      </nav>
      <span>{lang === 'en' ? `Showing ${sets.length} sets` : `แสดงทั้งหมด ${sets.length} เซ็ต`}</span>
    </div>
  </section>

  {/* Custom Sets Grid */}
  <section class="max-w-[1440px] mx-auto px-6 py-24 bg-white">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
      {sets.map((col) => (
        <div class="flex flex-col group">
          {/* Card Image Container */}
          <a href={`/products/${col.slug}`} class="relative aspect-[3/4] overflow-hidden bg-gray-100 rounded-sm block">
            <img 
              src={resolveImage(col.imageUrl)} 
              alt={col.title} 
              class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-black/10 group-hover:bg-black/25 transition-all duration-300"></div>
            
            {/* Floating Category Label & Discount Badge */}
            <div class="absolute top-6 left-6 flex flex-col gap-2">
              <span class="bg-white/90 backdrop-blur-sm px-3.5 py-1.5 text-[9px] tracking-[0.2em] uppercase font-light text-brand-charcoal rounded-sm shadow-sm">
                {lang === 'en' ? 'VIEW LOOK' : 'ดูสไตล์'}
              </span>
              {col.discountPercent > 0 && (
                <span class="bg-red-600 text-white text-[9px] uppercase tracking-widest font-bold px-2.5 py-1 rounded-sm shadow-sm block w-fit">
                  -{col.discountPercent}%
                </span>
              )}
            </div>
          </a>
          
          {/* Card Details */}
          <div class="mt-6 flex flex-col items-start">
            <h3 class="font-serif text-xl sm:text-2xl font-normal tracking-wide text-brand-charcoal uppercase group-hover:text-brand-gold transition-colors duration-300">
              <a href={`/products/${col.slug}`}>{col.title}</a>
            </h3>
            <p class="text-xs text-gray-500 font-light tracking-wide mt-2 sm:mt-3 leading-relaxed uppercase">
              {col.products ? `${col.products.length} ${lang === 'en' ? 'products included' : 'รายการสินค้าในเซ็ต'}` : `0 ${lang === 'en' ? 'products' : 'รายการ'}`}
            </p>
            <a href={`/products/${col.slug}`} class="text-[11px] tracking-[0.2em] font-medium text-brand-charcoal uppercase mt-4 inline-flex items-center gap-1.5 border-b border-brand-charcoal/30 pb-0.5 group-hover:border-brand-gold group-hover:text-brand-gold transition-all duration-300">
              {lang === 'en' ? 'SHOP THE LOOK' : 'ช้อปสไตล์นี้'}
              <svg class="w-3 h-3 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
      {sets.length === 0 && (
        <div class="col-span-full text-center py-12 text-stone-400 font-light italic text-sm">
          {lang === 'en' ? 'No styled sets found' : 'ไม่พบเซ็ตชุดแต่งกายในขณะนี้'}
        </div>
      )}
    </div>
  </section>
</Layout>
