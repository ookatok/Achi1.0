---
import Layout from '../../layouts/Layout.astro';

let productsList = [] as any[];

try {
  const res = await fetch(`${BACKEND_URL}/api/products?collection=total-looks`);
  if (res.ok) {
    productsList = await res.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching total looks failed. Using mocks.', err);
}

const mockLooks = [
  { id: 901, name: "The Monochromatic Linen Set", price: "490.00", imageUrl: "/assets/images/set1.png" },
  { id: 902, name: "Modern Utility Overall Suit", price: "410.00", imageUrl: "/assets/images/set2.png" },
  { id: 903, name: "Premium Relaxed Loungewear Set", price: "360.00" },
  { id: 904, name: "Classic Tailored Three-Piece Suit", price: "850.00" },
];

const displayProducts = productsList.length > 0 ? productsList : mockLooks;
---

<Layout title="Total Looks | ACHI Studio" description="Complete outfit configurations designed as matching sets." showHeroHeader={true}>
  <section class="w-full relative h-[60vh] bg-[#282828] flex items-center justify-center text-white overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/assets/images/set1.png?v=2');"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-60"></div>
    
    <div class="relative w-full max-w-[1440px] mx-auto px-6 flex flex-col justify-end h-full pb-16">
      <div class="flex items-end justify-between w-full">
        <div>
          <span class="border border-white border-opacity-40 px-3 py-1 text-[10px] tracking-widest uppercase font-light rounded-full mb-4 inline-block">Complete Outfits</span>
          <h1 class="font-serif text-5xl sm:text-7xl font-bold tracking-tight uppercase leading-none">Total Looks</h1>
        </div>
        <div class="hidden sm:block text-right text-[11px] tracking-[0.35em] text-gray-300 uppercase font-light">
          Styled Outfit Sets
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-gray-100 bg-white">
    <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between text-[11px] uppercase tracking-wider font-light text-gray-400">
      <nav class="flex items-center gap-2">
        <a href="/" class="hover:text-brand-charcoal transition-colors">Home</a>
        <span>/</span>
        <a href="/products" class="hover:text-brand-charcoal transition-colors">Shop</a>
        <span>/</span>
        <span class="text-brand-charcoal">Total Looks</span>
      </nav>
      <span>Showing {displayProducts.length} items</span>
    </div>
  </section>

  <div class="max-w-[1440px] mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      {displayProducts.map((product: any) => (
        <div class="flex flex-col justify-between p-6 bg-white border border-gray-100 rounded-sm product-card-hover group relative">
          <button class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal transition-colors focus:outline-none cursor-pointer z-20">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
          </button>

          <!-- Product Image Box -->
          <div class="aspect-[1/1] overflow-hidden flex flex-col items-center justify-center bg-gray-50 border border-gray-100/50 rounded-sm mb-6 relative group">
            {product.imageUrl ? (
              <img src={product.imageUrl} alt={product.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            ) : (
              <span class="text-[9px] uppercase tracking-[0.2em] text-gray-400 text-center font-light leading-relaxed">
                [Image: {product.name}]
              </span>
            )}
          </div>

          <div>
            <h3 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight">
              {product.name}
            </h3>
            <span class="text-xs text-brand-gold font-medium mt-2 block">${Number(product.price).toLocaleString()}</span>
          </div>

          <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
        </div>
      ))}
    </div>
  </div>
</Layout>
