---
import Layout from '../../layouts/Layout.astro';
import { translateProduct } from '../../lib/translations';
import Pagination from '../../components/common/Pagination.astro';

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return url;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=3';
};

// Fetch query params for filters
const categorySlug = Astro.url.searchParams.get('categorySlug') || '';
const tags = Astro.url.searchParams.get('tags') || '';
const minPrice = Astro.url.searchParams.get('minPrice') || '';
const maxPrice = Astro.url.searchParams.get('maxPrice') || '';
const sizes = Astro.url.searchParams.get('sizes') || '';
const colors = Astro.url.searchParams.get('colors') || '';
const searchQuery = Astro.url.searchParams.get('query') || '';

const selectedCategories = categorySlug ? categorySlug.split(',') : [];
const selectedTags = tags ? tags.split(',') : [];

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

const page = parseInt(Astro.url.searchParams.get('page') || '1', 10);
const limit = 8;

let productsList = [] as any[];
let categoriesList = [] as any[];
let tagsList = [] as any[];

// Build query string for API
const queryParams = new URLSearchParams();
if (categorySlug) queryParams.set('categorySlug', categorySlug);
if (minPrice) queryParams.set('minPrice', minPrice);
if (maxPrice) queryParams.set('maxPrice', maxPrice);
if (sizes) queryParams.set('sizes', sizes);
if (colors) queryParams.set('colors', colors);
if (tags) queryParams.set('tags', tags);
if (searchQuery) queryParams.set('query', searchQuery);
queryParams.set('page', String(page));
queryParams.set('limit', String(limit));

let totalCount = 0;

try {
  // 1. Fetch products
  const res = await fetch(`${BACKEND_URL}/api/products?${queryParams.toString()}`);
  if (res.ok) {
    productsList = await res.json();
  }

  // 2. Fetch categories
  const catRes = await fetch(`${BACKEND_URL}/api/products/categories`);
  if (catRes.ok) {
    categoriesList = await catRes.json();
  }

  // 3. Fetch tags
  const tagRes = await fetch(`${BACKEND_URL}/api/products/tags`);
  if (tagRes.ok) {
    tagsList = await tagRes.json();
  }

  // Fetch total count for pagination by querying without page/limit
  const countParams = new URLSearchParams(queryParams);
  countParams.delete('page');
  countParams.delete('limit');
  const countRes = await fetch(`${BACKEND_URL}/api/products?${countParams.toString()}`);
  if (countRes.ok) {
    const allProducts = await countRes.json();
    totalCount = allProducts.length;
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching catalog data failed.', err);
}

let pageSettings = {
  hero_home: '',
  hero_shop: '',
  hero_collections: '',
  hero_blog: ''
} as Record<string, string>;

try {
  const res = await fetch(`${BACKEND_URL}/api/web-image/settings`);
  if (res.ok) {
    pageSettings = await res.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching page settings failed.', err);
}

const isFiltered = !!(categorySlug || minPrice || maxPrice || sizes || colors || tags || searchQuery);
const displayList = productsList.map(product => translateProduct(product, lang));
const pageList = displayList;
const totalPages = Math.max(1, Math.ceil(totalCount / limit));

const getColorsArray = (colors: any) => {
  if (!colors) return [];
  if (Array.isArray(colors)) return colors;
  try {
    const parsed = typeof colors === 'string' ? JSON.parse(colors) : colors;
    return Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    if (typeof colors === 'string' && colors.includes(',')) {
      return colors.split(',').map(s => s.trim()).filter(Boolean);
    }
    if (typeof colors === 'string' && colors.trim() !== '') {
      return [colors.trim()];
    }
    return [];
  }
};

const displayCategories = categoriesList.map(c => ({
  id: c.id,
  slug: c.slug,
  nameEn: c.name.charAt(0).toUpperCase() + c.name.slice(1),
  nameTh: c.name === 'men' ? 'ผู้ชาย' : c.name === 'women' ? 'ผู้หญิง' : c.name === 'accessories' ? 'เครื่องประดับ' : c.name
}));

const displayTags = tagsList.map(t => ({
  id: t.id,
  slug: t.slug,
  nameEn: t.name.charAt(0).toUpperCase() + t.name.slice(1),
  nameTh: t.name === 'summer' ? 'ฤดูร้อน' : t.name === 'basics' ? 'เบสิก' : t.name === 'new' ? 'ใหม่' : t.name
}));
---

<Layout 
  title={lang === 'en' ? "SHOP | ACHI Studio" : "ช้อป | ACHI Studio"} 
  description={lang === 'en' ? "Explore ACHI's custom tailored outerwear, statement collections, and basic essentials." : "สำรวจคอลเลกชันเสื้อผ้าของ ACHI ทั้งแบบเอาต์เตอร์แวร์คลาสสิก เสื้อยืด และเสื้อเชิ้ตมินิมอล"} 
  showHeroHeader={true}
>
  <section class="w-full relative h-[50vh] bg-[#3C3C3C] flex items-center justify-center text-white overflow-hidden">
    {pageSettings.hero_shop && <div class="absolute inset-0 bg-cover bg-center opacity-70" style={`background-image: url('${resolveImage(pageSettings.hero_shop)}');`}></div>}
    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
    
    <div class="relative w-full max-w-[1440px] mx-auto px-6 flex flex-col justify-end h-full pb-16">
      <div class="flex items-end justify-between w-full">
        <div>
          <span class="border border-white border-opacity-40 px-3 py-1 text-[10px] tracking-widest uppercase font-light rounded-full mb-4 inline-block">
            {searchQuery ? (lang === 'en' ? "Search" : "ผลการค้นหา") : "ACHI STUDIO"}
          </span>
          <h1 class="font-serif text-5xl sm:text-7xl font-bold tracking-tight uppercase leading-none">
            {searchQuery ? `"${searchQuery}"` : (lang === 'en' ? "THE CATALOG" : "แค็ตตาล็อก")}
          </h1>
        </div>
        <div class="hidden sm:block text-right text-[11px] tracking-[0.35em] text-gray-300 uppercase font-light">
          {searchQuery ? (lang === 'en' ? "Filtered Results" : "รายการคัดกรอง") : (lang === 'en' ? "ALL PRODUCTS" : "สินค้าทั้งหมด")}
        </div>
      </div>
    </div>
  </section>

  {/* Active Filters Bar */}
  {isFiltered && (
    <div class="max-w-[1440px] mx-auto px-6 pt-8 flex flex-wrap gap-3 items-center text-[10px] tracking-wider uppercase font-light text-gray-400">
      <span class="font-medium text-brand-charcoal text-xs mr-2">{lang === 'en' ? "Active filters:" : "ตัวกรองที่เลือก:"}</span>
      
      {selectedCategories.map(cat => {
        const matchingCat = displayCategories.find(c => c.slug === cat);
        const displayName = matchingCat ? (lang === 'en' ? matchingCat.nameEn : matchingCat.nameTh) : cat;
        return (
          <span class="border border-gray-200 px-3 py-1.5 rounded-full flex items-center gap-2 bg-gray-50 text-brand-charcoal">
            {lang === 'en' ? "Category" : "หมวดหมู่"}: {displayName}
            <a href={Astro.url.pathname + "?" + (() => { 
              const p = new URLSearchParams(Astro.url.search); 
              const cats = selectedCategories.filter(c => c !== cat);
              if (cats.length > 0) p.set('categorySlug', cats.join(','));
              else p.delete('categorySlug');
              return p.toString(); 
            })()} class="hover:text-red-500 font-bold ml-1">×</a>
          </span>
        );
      })}

      {selectedTags.map(tag => {
        const matchingTag = displayTags.find(t => t.slug === tag);
        const displayName = matchingTag ? (lang === 'en' ? matchingTag.nameEn : matchingTag.nameTh) : tag;
        return (
          <span class="border border-gray-200 px-3 py-1.5 rounded-full flex items-center gap-2 bg-gray-50 text-brand-charcoal">
            {lang === 'en' ? "Tag" : "แท็ก"}: {displayName}
            <a href={Astro.url.pathname + "?" + (() => { 
              const p = new URLSearchParams(Astro.url.search); 
              const tgs = selectedTags.filter(t => t !== tag);
              if (tgs.length > 0) p.set('tags', tgs.join(','));
              else p.delete('tags');
              return p.toString(); 
            })()} class="hover:text-red-500 font-bold ml-1">×</a>
          </span>
        );
      })}

      {minPrice && maxPrice && (
        <span class="border border-gray-200 px-3 py-1.5 rounded-full flex items-center gap-2 bg-gray-50 text-brand-charcoal">
          {lang === 'en' ? "Price" : "ราคา"}: ${minPrice} - ${maxPrice}
          <a href={Astro.url.pathname + "?" + (() => { const p = new URLSearchParams(Astro.url.search); p.delete('minPrice'); p.delete('maxPrice'); return p.toString(); })()} class="hover:text-red-500 font-bold ml-1">×</a>
        </span>
      )}

      {colors && (
        <span class="border border-gray-200 px-3 py-1.5 rounded-full flex items-center gap-2 bg-gray-50 text-brand-charcoal">
          {lang === 'en' ? "Color" : "สี"}: {colors === '#94B2E6' ? (lang === 'en' ? 'Soft Blue' : 'สีฟ้าอ่อน') : colors === '#F3F1EC' ? (lang === 'en' ? 'Soft Cream' : 'สีครีมอ่อน') : colors === '#1B2F50' ? (lang === 'en' ? 'Navy' : 'สีกรมท่า') : colors}
          <a href={Astro.url.pathname + "?" + (() => { const p = new URLSearchParams(Astro.url.search); p.delete('colors'); return p.toString(); })()} class="hover:text-red-500 font-bold ml-1">×</a>
        </span>
      )}

      {sizes && (
        <span class="border border-gray-200 px-3 py-1.5 rounded-full flex items-center gap-2 bg-gray-50 text-brand-charcoal">
          {lang === 'en' ? "Size" : "ขนาด (ไซส์)"}: {sizes}
          <a href={Astro.url.pathname + "?" + (() => { const p = new URLSearchParams(Astro.url.search); p.delete('sizes'); return p.toString(); })()} class="hover:text-red-500 font-bold ml-1">×</a>
        </span>
      )}

      {searchQuery && (
        <span class="border border-gray-200 px-3 py-1.5 rounded-full flex items-center gap-2 bg-gray-50 text-brand-charcoal">
          {lang === 'en' ? "Search" : "ค้นหา"}: "{searchQuery}"
          <a href={Astro.url.pathname + "?" + (() => { const p = new URLSearchParams(Astro.url.search); p.delete('query'); return p.toString(); })()} class="hover:text-red-500 font-bold ml-1">×</a>
        </span>
      )}

      <a href="/products" class="text-brand-gold font-medium underline underline-offset-4 ml-4">{lang === 'en' ? "Clear All" : "ล้างทั้งหมด"}</a>
    </div>
  )}

  {/* Main Layout Section: Sidebar + Product Grid */}
  <div class="max-w-[1440px] mx-auto px-6 py-16 flex flex-col lg:flex-row gap-12">
    
    {/* Left Column: Filter Sidebar */}
    <aside class="w-full lg:w-60 shrink-0 space-y-4 lg:space-y-8 lg:sticky lg:top-28 self-start">
      {/* Mobile Filter Toggle Button */}
      <div class="lg:hidden flex items-center justify-between border-b border-gray-100 pb-4">
        <button 
          id="mobile-filter-toggle-btn" 
          class="flex items-center gap-2.5 text-xs font-semibold tracking-widest text-brand-charcoal uppercase focus:outline-none cursor-pointer py-1"
          type="button"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" />
          </svg>
          <span>{lang === 'en' ? "Filter Options" : "ตัวกรองสินค้า"}</span>
        </button>
        <span class="text-[10px] text-gray-400 tracking-wider uppercase">{pageList.length} {lang === 'en' ? "Items" : "รายการ"}</span>
      </div>

      {/* Mobile filter backdrop overlay */}
      <div id="mobile-filter-backdrop" class="fixed inset-0 bg-black/40 backdrop-blur-xs z-40 transition-opacity duration-300 opacity-0 pointer-events-none lg:hidden"></div>

      {/* Filter Sidebar Content (Hidden on Mobile by default, visible on Desktop) */}
      <div id="sidebar-filters-content" class="hidden lg:block space-y-8 mt-4 lg:mt-0">
        {/* Drawer Header Close Button on Mobile */}
        <div class="lg:hidden flex items-center justify-between mb-8 pb-4 border-b border-gray-100">
          <span class="font-serif text-sm font-semibold tracking-wider text-brand-charcoal uppercase">
            {lang === 'en' ? "Filters" : "ตัวกรอง"}
          </span>
          <button type="button" id="mobile-filter-close-btn" class="text-gray-400 hover:text-brand-charcoal p-1 focus:outline-none cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      
      {/* Categories Filter (Checkboxes) */}
      <div class="border-b border-gray-100 pb-6">
        <h4 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase mb-4">
          {lang === 'en' ? "Categories" : "หมวดหมู่"}
        </h4>
        <div class="space-y-3">
          {displayCategories.map(cat => {
            const isChecked = selectedCategories.includes(cat.slug);
            return (
              <label class="flex items-center gap-3 text-xs tracking-wider text-gray-500 uppercase cursor-pointer hover:text-brand-charcoal select-none">
                <input 
                  type="checkbox" 
                  name="category-checkbox" 
                  value={cat.slug} 
                  checked={isChecked}
                  class="w-4 h-4 border border-gray-300 rounded-sm accent-brand-charcoal cursor-pointer"
                />
                <span>{lang === 'en' ? cat.nameEn : cat.nameTh}</span>
              </label>
            )
          })}
        </div>
      </div>

      {/* Tags Filter (Checkboxes) */}
      <div class="border-b border-gray-100 pb-6">
        <h4 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase mb-4">
          {lang === 'en' ? "Tags" : "แท็กสินค้า"}
        </h4>
        <div class="space-y-3">
          {displayTags.map(tag => {
            const isChecked = selectedTags.includes(tag.slug);
            return (
              <label class="flex items-center gap-3 text-xs tracking-wider text-gray-500 uppercase cursor-pointer hover:text-brand-charcoal select-none">
                <input 
                  type="checkbox" 
                  name="tag-checkbox" 
                  value={tag.slug} 
                  checked={isChecked}
                  class="w-4 h-4 border border-gray-300 rounded-sm accent-brand-charcoal cursor-pointer"
                />
                <span>{lang === 'en' ? tag.nameEn : tag.nameTh}</span>
              </label>
            )
          })}
        </div>
      </div>

      {/* Price Filter (Custom Dropdown + Inputs) */}
      <div class="border-b border-gray-100 pb-6">
        <h4 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase mb-3">
          {lang === 'en' ? "Price Range" : "ช่วงราคา"}
        </h4>
        
        <div class="relative w-full mb-3 select-none">
          <button type="button" id="price-dropdown-btn" class="w-full bg-gray-50 border border-gray-200 px-3 py-2.5 rounded-sm outline-none text-xs uppercase tracking-wider font-light text-gray-600 focus:border-brand-gold flex items-center justify-between cursor-pointer">
            <span id="price-dropdown-selected">
              {minPrice === '0' && maxPrice === '500' ? (lang === 'en' ? "Under $500" : "ต่ำกว่า $500") : 
               minPrice === '500' && maxPrice === '1000' ? "$500 - $1,000" : 
               (minPrice || maxPrice) ? (lang === 'en' ? "Custom Range" : "กำหนดช่วงราคาเอง") : 
               (lang === 'en' ? "All Prices" : "ทุกช่วงราคา")}
            </span>
            <span class="text-[8px] transition-transform duration-300 dropdown-arrow">▼</span>
          </button>
          <div id="price-dropdown-menu" class="absolute left-0 w-full bg-white border border-gray-200 mt-1 shadow-md z-30 rounded-sm py-1 custom-dropdown-menu">
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="">{lang === 'en' ? "All Prices" : "ทุกช่วงราคา"}</div>
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="0-500">{lang === 'en' ? "Under $500" : "ต่ำกว่า $500"}</div>
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="500-1000">$500 - $1,000</div>
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="custom">{lang === 'en' ? "Custom Range" : "กำหนดช่วงราคาเอง"}</div>
          </div>
        </div>

        {/* Custom Input Fields */}
        <div id="custom-price-container" class="flex items-center gap-2 text-xs text-brand-charcoal">
          <div class="flex items-center bg-gray-50 border border-gray-200 rounded-sm px-2 py-1 w-1/2">
            <span class="text-gray-400 mr-1 font-light">$</span>
            <input 
              type="number" 
              id="price-min-input" 
              min="0" 
              value={minPrice || ""} 
              class="w-full bg-transparent outline-none text-xs font-medium text-brand-charcoal"
              placeholder="Min"
            />
          </div>
          <span class="text-gray-400 font-light">-</span>
          <div class="flex items-center bg-gray-50 border border-gray-200 rounded-sm px-2 py-1 w-1/2">
            <span class="text-gray-400 mr-1 font-light">$</span>
            <input 
              type="number" 
              id="price-max-input" 
              min="0" 
              value={maxPrice || ""} 
              class="w-full bg-transparent outline-none text-xs font-medium text-brand-charcoal"
              placeholder="Max"
            />
          </div>
        </div>
      </div>

      {/* Color Filter (Custom Dropdown) */}
      <div class="border-b border-gray-100 pb-6">
        <h4 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase mb-3">
          {lang === 'en' ? "Color" : "สี"}
        </h4>
        <input type="hidden" id="color-filter" value={colors || ""} />
        <div class="relative w-full select-none">
          <button type="button" id="color-dropdown-btn" class="w-full bg-gray-50 border border-gray-200 px-3 py-2.5 rounded-sm outline-none text-xs uppercase tracking-wider font-light text-gray-600 focus:border-brand-gold flex items-center justify-between cursor-pointer">
            <span id="color-dropdown-selected">
              {colors === '#94B2E6' ? (lang === 'en' ? "Soft Blue" : "สีฟ้าอ่อน") : 
               colors === '#F3F1EC' ? (lang === 'en' ? "Soft Cream" : "สีครีมอ่อน") : 
               colors === '#1B2F50' ? (lang === 'en' ? "Navy" : "สีกรมท่า") : 
               (lang === 'en' ? "All Colors" : "ทุกสี")}
            </span>
            <span class="text-[8px] transition-transform duration-300 dropdown-arrow">▼</span>
          </button>
          <div id="color-dropdown-menu" class="absolute left-0 w-full bg-white border border-gray-200 mt-1 shadow-md z-30 rounded-sm py-1 custom-dropdown-menu">
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="">{lang === 'en' ? "All Colors" : "ทุกสี"}</div>
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="#94B2E6">{lang === 'en' ? "Soft Blue" : "สีฟ้าอ่อน"}</div>
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="#F3F1EC">{lang === 'en' ? "Soft Cream" : "สีครีมอ่อน"}</div>
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="#1B2F50">{lang === 'en' ? "Navy" : "สีกรมท่า"}</div>
          </div>
        </div>
      </div>

      {/* Size Filter (Custom Dropdown) */}
      <div class="pb-6">
        <h4 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase mb-3">
          {lang === 'en' ? "Size" : "ขนาด (ไซส์)"}
        </h4>
        <input type="hidden" id="size-filter" value={sizes || ""} />
        <div class="relative w-full select-none">
          <button type="button" id="size-dropdown-btn" class="w-full bg-gray-50 border border-gray-200 px-3 py-2.5 rounded-sm outline-none text-xs uppercase tracking-wider font-light text-gray-600 focus:border-brand-gold flex items-center justify-between cursor-pointer">
            <span id="size-dropdown-selected">
              {sizes ? sizes : (lang === 'en' ? "All Sizes" : "ทุกขนาด")}
            </span>
            <span class="text-[8px] transition-transform duration-300 dropdown-arrow">▼</span>
          </button>
          <div id="size-dropdown-menu" class="absolute left-0 w-full bg-white border border-gray-200 mt-1 shadow-md z-30 rounded-sm py-1 custom-dropdown-menu">
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="">{lang === 'en' ? "All Sizes" : "ทุกขนาด"}</div>
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="S">S</div>
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="M">M</div>
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="L">L</div>
            <div class="px-3 py-2 hover:bg-gray-50 cursor-pointer text-xs uppercase tracking-wider font-light text-gray-600" data-value="XL">XL</div>
          </div>
        </div>
      </div>
      </div>
    </aside>

    {/* Right Column: Products Content */}
    <div class="flex-grow">
      
      {/* Clean Grid Section of Products */}
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
        {pageList.map((product: any) => (
          <div class="flex flex-col justify-between p-4 bg-white border border-gray-100 rounded-sm product-card-hover group relative">
            {/* Heart Favorite Button */}
            <button
              class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal transition-colors focus:outline-none cursor-pointer z-20"
              data-favorite-btn data-discount={product.activeDiscountPercent || 0}
              data-id={product.id}
              data-name={product.name}
              data-price={product.price}
              data-image={product.imageUrl}
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
              </svg>
            </button>

            <!-- Product Image Box -->
            <div class="aspect-[1/1] overflow-hidden flex flex-col items-center justify-center bg-gray-50 border border-gray-100/50 rounded-sm mb-6 relative group">
              {product.activeDiscountPercent > 0 && (
                <span class="absolute top-6 left-6 z-20 bg-red-600 text-white text-[9px] uppercase tracking-widest font-bold px-2.5 py-1 rounded-sm shadow-sm">
                  -{product.activeDiscountPercent}%
                </span>
              )}
              {product.imageUrl ? (
                <img src={resolveImage(product.imageUrl)} alt={product.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
              ) : (
                <span class="text-[9px] uppercase tracking-[0.2em] text-gray-400 text-center font-light leading-relaxed">
                  [Image: {product.name}]
                </span>
              )}
              {product.status === 'inactive' && (
                <div class="absolute inset-0 bg-stone-900/40 backdrop-blur-xs flex items-center justify-center z-10">
                  <span class="text-white text-[10px] uppercase tracking-widest font-semibold border border-white/60 px-3 py-1.5 rounded-sm">
                    {lang === 'en' ? 'Not Available' : 'งดจำหน่าย'}
                  </span>
                </div>
              )}
            </div>

            {/* Product Details */}
            <div>
              <div class="flex items-center justify-between gap-4">
                <h3 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight">
                  {product.name}
                </h3>
                {/* Color swatches */}
                {getColorsArray(product.colors).length > 0 && (
                  <div class="flex gap-1.5 shrink-0">
                    {getColorsArray(product.colors).map((color: string) => (
                      <span class="w-3.5 h-3.5 rounded-full border border-stone-300 block shadow-xs" style={{ backgroundColor: color }}></span>
                    ))}
                  </div>
                )}
              </div>
              <div class="flex items-center justify-between mt-2">
                {product.activeDiscountPercent > 0 ? (
                  <div class="flex items-center gap-2">
                    <span class="text-xs text-red-600 font-bold">${(Number(product.price) * (1 - product.activeDiscountPercent / 100)).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>
                    <span class="text-[10px] text-gray-400 line-through font-light">${Number(product.price).toLocaleString()}</span>
                  </div>
                ) : (
                  <span class="text-xs text-brand-gold font-medium">${Number(product.price).toLocaleString()}</span>
                )}
                {product.status !== 'inactive' && (
                  product.stockQuantity > 0 ? (
                    <span class="text-[9px] uppercase tracking-wider text-stone-500 font-light">
                      {product.stockQuantity} pcs
                    </span>
                  ) : product.allowOnOrder ? (
                    <span class="text-[9px] uppercase tracking-wider text-amber-600 font-bold bg-amber-50 border border-amber-100 px-1 py-0.5 rounded-sm">
                      {lang === 'en' ? 'Pre-Order' : 'สั่งจอง'}
                    </span>
                  ) : (
                    <span class="text-[9px] uppercase tracking-wider text-red-500 font-bold bg-red-50 border border-red-100 px-1 py-0.5 rounded-sm">
                      {lang === 'en' ? 'Out of stock' : 'หมด'}
                    </span>
                  )
                )}
              </div>
            </div>
            
            {/* Clickable Area Link */}
            <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
          </div>
        ))}
        {pageList.length === 0 && (
          <div class="col-span-full text-center py-24 text-stone-400 font-light italic text-sm border border-dashed border-stone-200 rounded-sm">
            {isFiltered 
              ? (lang === 'en' ? 'No products match your selected filters' : 'ไม่พบสินค้าที่ตรงตามเงื่อนไขการค้นหา')
              : (lang === 'en' ? 'Our products catalog is being prepared. New items will be uploaded soon!' : 'ขออภัย ทางร้านกำลังเตรียมข้อมูลแค็ตตาล็อกสินค้าใหม่ สินค้าจะได้รับการอัปเดตเร็วๆ นี้!')
            }
          </div>
        )}
      </div>

      {/* Pagination Component */}
      {pageList.length > 0 && <Pagination totalPages={totalPages} />}
    </div>
  </div>

  <style>
    /* Custom Dropdown animation styling */
    .custom-dropdown-menu {
      transform: translateY(-10px);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.25s ease, visibility 0.3s;
    }
    .custom-dropdown-menu.open {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    /* Hide standard chrome spin buttons on numeric input fields */
    #price-min-input::-webkit-outer-spin-button,
    #price-min-input::-webkit-inner-spin-button,
    #price-max-input::-webkit-outer-spin-button,
    #price-max-input::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }
    #price-min-input,
    #price-max-input {
      -moz-appearance: textfield;
    }

    /* Mobile drawer styles */
    @media (max-width: 1023px) {
      #sidebar-filters-content {
        position: fixed;
        top: 0;
        left: -100%;
        width: 320px;
        height: 100vh;
        background-color: white;
        z-index: 50;
        padding: 24px;
        box-shadow: 5px 0 30px rgba(0,0,0,0.12);
        overflow-y: auto;
        transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        margin-top: 0 !important;
        display: block !important;
      }
      #sidebar-filters-content.open {
        left: 0;
      }
      #mobile-filter-backdrop.open {
        opacity: 1;
        pointer-events: auto;
      }
      body.drawer-open {
        overflow: hidden;
      }
    }
  </style>

  <script is:inline>
    const categoryCheckboxes = document.querySelectorAll('input[name="category-checkbox"]');
    const tagCheckboxes = document.querySelectorAll('input[name="tag-checkbox"]');
    const colorFilter = document.getElementById('color-filter');
    const sizeFilter = document.getElementById('size-filter');
    const minInput = document.getElementById('price-min-input');
    const maxInput = document.getElementById('price-max-input');

    const updateFilters = () => {
      const params = new URLSearchParams(window.location.search);
      
      // Categories (Checkboxes)
      const selectedCats = [];
      categoryCheckboxes.forEach(cb => {
        if (cb.checked) selectedCats.push(cb.value);
      });
      if (selectedCats.length > 0) {
        params.set('categorySlug', selectedCats.join(','));
      } else {
        params.delete('categorySlug');
      }

      // Tags (Checkboxes)
      const selectedTgs = [];
      tagCheckboxes.forEach(cb => {
        if (cb.checked) selectedTgs.push(cb.value);
      });
      if (selectedTgs.length > 0) {
        params.set('tags', selectedTgs.join(','));
      } else {
        params.delete('tags');
      }

      // Price Range fields
      if (minInput && maxInput) {
        const minVal = minInput.value.trim();
        const maxVal = maxInput.value.trim();
        if (minVal !== '') {
          params.set('minPrice', minVal);
        } else {
          params.delete('minPrice');
        }
        if (maxVal !== '') {
          params.set('maxPrice', maxVal);
        } else {
          params.delete('maxPrice');
        }
      }

      // Color
      if (colorFilter && colorFilter.value) {
        params.set('colors', colorFilter.value);
      } else {
        params.delete('colors');
      }

      // Size
      if (sizeFilter && sizeFilter.value) {
        params.set('sizes', sizeFilter.value);
      } else {
        params.delete('sizes');
      }

      // Reset to page 1 when filter changes
      params.set('page', '1');

      window.location.search = params.toString();
    };

    // Add change listeners
    categoryCheckboxes.forEach(cb => cb.addEventListener('change', updateFilters));
    tagCheckboxes.forEach(cb => cb.addEventListener('change', updateFilters));

    // Custom Dropdown Menus Setup
    const setupCustomDropdown = (btnId, menuId, selectedId, hiddenInputId) => {
      const btn = document.getElementById(btnId);
      const menu = document.getElementById(menuId);
      const selected = document.getElementById(selectedId);
      const hiddenInput = hiddenInputId ? document.getElementById(hiddenInputId) : null;
      const arrow = btn?.querySelector('.dropdown-arrow');

      if (!btn || !menu) return;

      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        
        // Close all other dropdowns first
        document.querySelectorAll('.custom-dropdown-menu').forEach(m => {
          if (m !== menu) {
            m.classList.remove('open');
            m.parentElement?.querySelector('.dropdown-arrow')?.classList.remove('rotate-180');
          }
        });

        const isOpen = menu.classList.contains('open');
        if (isOpen) {
          menu.classList.remove('open');
          arrow?.classList.remove('rotate-180');
        } else {
          menu.classList.add('open');
          arrow?.classList.add('rotate-180');
        }
      });

      menu.querySelectorAll('[data-value]').forEach(option => {
        option.addEventListener('click', () => {
          const value = option.getAttribute('data-value') || '';
          const text = option.textContent || '';
          
          if (selected) selected.textContent = text;
          if (hiddenInput) {
            hiddenInput.value = value;
            updateFilters();
          }

          menu.classList.remove('open');
          arrow?.classList.remove('rotate-180');
        });
      });
    };

    setupCustomDropdown('color-dropdown-btn', 'color-dropdown-menu', 'color-dropdown-selected', 'color-filter');
    setupCustomDropdown('size-dropdown-btn', 'size-dropdown-menu', 'size-dropdown-selected', 'size-filter');

    // Custom setup for Price Dropdown due to extra logic with input fields
    const priceBtn = document.getElementById('price-dropdown-btn');
    const priceMenu = document.getElementById('price-dropdown-menu');
    const priceSelected = document.getElementById('price-dropdown-selected');
    const priceArrow = priceBtn?.querySelector('.dropdown-arrow');

    if (priceBtn && priceMenu && minInput && maxInput) {
      priceBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        document.querySelectorAll('.custom-dropdown-menu').forEach(m => {
          if (m !== priceMenu) {
            m.classList.remove('open');
            m.parentElement?.querySelector('.dropdown-arrow')?.classList.remove('rotate-180');
          }
        });
        const isOpen = priceMenu.classList.contains('open');
        if (isOpen) {
          priceMenu.classList.remove('open');
          priceArrow?.classList.remove('rotate-180');
        } else {
          priceMenu.classList.add('open');
          priceArrow?.classList.add('rotate-180');
        }
      });

      priceMenu.querySelectorAll('[data-value]').forEach(option => {
        option.addEventListener('click', () => {
          const value = option.getAttribute('data-value') || '';
          
          if (value === '') {
            minInput.value = '';
            maxInput.value = '';
            updateFilters();
          } else if (value === '0-500') {
            minInput.value = '0';
            maxInput.value = '500';
            updateFilters();
          } else if (value === '500-1000') {
            minInput.value = '500';
            maxInput.value = '1000';
            updateFilters();
          } else if (value === 'custom') {
            priceSelected.textContent = option.textContent;
            minInput.focus();
          }

          priceMenu.classList.remove('open');
          priceArrow?.classList.remove('rotate-180');
        });
      });

      // Typing in input fields updates select/dropdown text state
      const syncInputsToDropdownText = () => {
        const minVal = minInput.value.trim();
        const maxVal = maxInput.value.trim();
        if (minVal === '' && maxVal === '') {
          priceSelected.textContent = priceMenu.querySelector('[data-value=""]')?.textContent || 'All Prices';
        } else if (minVal === '0' && maxVal === '500') {
          priceSelected.textContent = priceMenu.querySelector('[data-value="0-500"]')?.textContent || 'Under $500';
        } else if (minVal === '500' && maxVal === '1000') {
          priceSelected.textContent = priceMenu.querySelector('[data-value="500-1000"]')?.textContent || '$500 - $1,000';
        } else {
          priceSelected.textContent = priceMenu.querySelector('[data-value="custom"]')?.textContent || 'Custom Range';
        }
      };

      minInput.addEventListener('input', syncInputsToDropdownText);
      maxInput.addEventListener('input', syncInputsToDropdownText);

      minInput.addEventListener('change', updateFilters);
      maxInput.addEventListener('change', updateFilters);
    }

    // Close all dropdowns when clicking outside
    document.addEventListener('click', () => {
      document.querySelectorAll('.custom-dropdown-menu').forEach(menu => {
        menu.classList.remove('open');
        menu.parentElement?.querySelector('.dropdown-arrow')?.classList.remove('rotate-180');
      });
    });

    // Mobile toggle filter sidebar drawer script
    const mobileFilterToggleBtn = document.getElementById('mobile-filter-toggle-btn');
    const sidebarFiltersContent = document.getElementById('sidebar-filters-content');
    const mobileFilterCloseBtn = document.getElementById('mobile-filter-close-btn');
    const mobileFilterBackdrop = document.getElementById('mobile-filter-backdrop');

    const openDrawer = () => {
      sidebarFiltersContent?.classList.add('open');
      mobileFilterBackdrop?.classList.add('open');
      document.body.classList.add('drawer-open');
    };

    const closeDrawer = () => {
      sidebarFiltersContent?.classList.remove('open');
      mobileFilterBackdrop?.classList.remove('open');
      document.body.classList.remove('drawer-open');
    };

    if (mobileFilterToggleBtn) {
      mobileFilterToggleBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        openDrawer();
      });
    }

    if (mobileFilterCloseBtn) {
      mobileFilterCloseBtn.addEventListener('click', closeDrawer);
    }

    if (mobileFilterBackdrop) {
      mobileFilterBackdrop.addEventListener('click', closeDrawer);
    }

    // Close mobile drawer on ESC key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDrawer();
    });
  </script>
</Layout>
