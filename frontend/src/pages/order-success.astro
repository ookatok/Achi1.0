---
import Layout from '../layouts/Layout.astro';
import { getSession } from 'auth-astro/server';

const session = await getSession(Astro.request);
const token = (session as any)?.accessToken;

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

if (!token) {
  return Astro.redirect(`/${lang}/auth/signin`);
}

// Get orderId from query parameter
const orderId = Astro.url.searchParams.get('orderId') || '';
---

<Layout 
  title={lang === 'en' ? "Order Confirmed | ACHI Studio" : "ยืนยันการสั่งซื้อ | ACHI Studio"} 
  description={lang === 'en' ? "Your order has been placed successfully." : "ทำการสั่งซื้อและประมวลผลสำเร็จแล้ว"}
>
  <div class="min-h-[60vh] flex flex-col justify-center items-center px-6 text-center">
    <div class="w-16 h-16 bg-green-50 text-green-500 rounded-full flex items-center justify-center mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
      </svg>
    </div>
    
    <span class="text-xs uppercase tracking-widest text-brand-gold font-semibold mb-2">
      {lang === 'en' ? "Order Confirmed" : "สั่งซื้อเสร็จสมบูรณ์"}
    </span>
    <h1 class="font-serif text-3xl font-bold tracking-tight text-brand-charcoal mb-4">
      {lang === 'en' ? "Thank You for Your Order" : "ขอบคุณสำหรับคำสั่งซื้อของคุณ"}
    </h1>
    <p class="text-sm text-gray-500 max-w-md font-light mb-8">
      {lang === 'en'
        ? `Your payment has been simulated successfully and order has been logged. Your order confirmation reference is `
        : `การจำลองการชำระเงินของคุณเสร็จสมบูรณ์และได้รับการบันทึกระบบเรียบร้อยแล้ว หมายเลขอ้างอิงคำสั่งซื้อของคุณคือ `
      }
      <strong class="text-brand-charcoal">#{orderId}</strong>.
    </p>

    <div class="flex gap-4">
      <a href="/products" class="bg-brand-charcoal text-white hover:bg-brand-gold hover:text-brand-charcoal px-8 py-3 rounded-sm text-xs uppercase tracking-wider font-semibold transition-all">
        {lang === 'en' ? "Continue Shopping" : "ช้อปปิ้งต่อ"}
      </a>
      <a href="/" class="border border-gray-200 text-brand-charcoal hover:bg-gray-50 px-8 py-3 rounded-sm text-xs uppercase tracking-wider font-semibold transition-all">
        {lang === 'en' ? "Home" : "หน้าแรก"}
      </a>
    </div>
  </div>
</Layout>
