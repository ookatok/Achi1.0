---
import Layout from '../../layouts/Layout.astro';
import { translateBlog } from '../../lib/translations';

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';

const { id } = Astro.params;

let blog = null as any;

try {
  const res = await fetch(`http://localhost:3001/api/blogs/${id}`);
  if (res.ok) {
    blog = await res.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching blog detail failed.', err);
}

const displayBlog = blog ? translateBlog(blog, lang) : null;

const resolveImage = (url: string) => {
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  if (url.startsWith('/assets/uploads/')) {
    return `${BACKEND_URL}${url}`;
  }
  return url;
};
---

{displayBlog ? (
  <Layout title={`${displayBlog.title} | ACHI Studio`} description={displayBlog.summary} showHeroHeader={true}>
    <article class="w-full bg-[#FAF9F6] min-h-screen">
      <!-- Header Banner -->
      <div class="w-full relative h-[60vh] bg-stone-900 overflow-hidden flex items-end">
        {displayBlog.imageUrl ? (
          <img 
            src={resolveImage(displayBlog.imageUrl)} 
            alt={displayBlog.title} 
            class="absolute inset-0 w-full h-full object-cover opacity-60"
          />
        ) : (
          <div class="absolute inset-0 bg-[#3B3835] opacity-60"></div>
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
        
        <div class="relative w-full max-w-[900px] mx-auto px-6 pb-16 z-10 text-white space-y-4">
          <div class="flex items-center gap-3 text-[10px] uppercase tracking-widest text-stone-300 font-semibold">
            {displayBlog.categoryName && (
              <>
                <span class="text-brand-gold font-bold">{displayBlog.categoryName}</span>
                <span class="w-1.5 h-1.5 rounded-full bg-stone-500"></span>
              </>
            )}
            <span>{lang === 'en' ? "By" : "โดย"} {displayBlog.authorName || 'ACHI Studio'}</span>
            <span class="w-1.5 h-1.5 rounded-full bg-brand-gold"></span>
            <span>{new Date(displayBlog.createdAt).toLocaleDateString(lang === 'en' ? 'en-US' : 'th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </div>
          
          <h1 class="font-serif text-3xl sm:text-5xl tracking-wide leading-tight uppercase">
            {displayBlog.title}
          </h1>
          
          {displayBlog.summary && (
            <p class="font-sans text-xs sm:text-sm text-stone-200/90 font-light tracking-wide max-w-[700px] leading-relaxed">
              {displayBlog.summary}
            </p>
          )}
        </div>
      </div>

      <!-- Article Body -->
      <div class="max-w-[750px] mx-auto px-6 py-24 bg-white border-x border-stone-200/50 shadow-sm min-h-[50vh]">
        <!-- Content Container -->
        <div class="font-sans text-stone-700 text-sm leading-relaxed font-light space-y-6 blog-content" set:html={displayBlog.content} />

        <!-- Footer back button -->
        <div class="mt-16 pt-8 border-t border-stone-100 flex justify-between items-center">
          <a 
            href="/blog" 
            class="inline-flex items-center text-[10px] uppercase tracking-widest font-semibold text-stone-500 hover:text-brand-charcoal transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="w-4 h-4 mr-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
            </svg>
            {lang === 'en' ? "Back to all posts" : "ย้อนกลับไปบล็อกทั้งหมด"}
          </a>
        </div>
      </div>
    </article>
  </Layout>
) : (
  <Layout title={lang === 'en' ? "Blog Post Not Found | ACHI Studio" : "ไม่พบโพสต์บล็อก | ACHI Studio"} showHeroHeader={true}>
    <div class="max-w-[1440px] mx-auto px-6 py-32 text-center bg-white min-h-[50vh]">
      <h1 class="font-serif text-3xl sm:text-5xl font-bold tracking-wide text-brand-charcoal mb-4 uppercase">
        {lang === 'en' ? "Blog Post Not Found" : "ไม่พบโพสต์บล็อก"}
      </h1>
      <p class="text-sm font-light text-gray-500 mb-8 max-w-md mx-auto leading-relaxed">
        {lang === 'en' 
          ? "The article you are looking for might have been removed, had its name changed, or is temporarily unavailable."
          : "ไม่พบบทความบล็อกที่คุณกำลังมองหา บทความนี้อาจถูกนำออก เปลี่ยนชื่อ หรือไม่เปิดให้บริการชั่วคราว"
        }
      </p>
      <a href="/blog" class="inline-block bg-brand-charcoal text-white hover:bg-brand-gold hover:text-brand-charcoal px-8 py-4 rounded-sm text-xs uppercase tracking-[0.2em] font-semibold transition-all duration-300">
        {lang === 'en' ? "BACK TO BLOG" : "กลับไปยังบล็อก"}
      </a>
    </div>
  </Layout>
)}

  <style>
    .blog-content :global(h1) {
      font-size: 1.75rem;
      font-weight: 700;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      color: #1c1917;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .blog-content :global(h2) {
      font-size: 1.4rem;
      font-weight: 600;
      margin-top: 1.75rem;
      margin-bottom: 0.5rem;
      color: #1c1917;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .blog-content :global(h3) {
      font-size: 1.15rem;
      font-weight: 600;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
      color: #1c1917;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .blog-content :global(p) {
      margin-bottom: 1rem;
      line-height: 1.75;
    }
    .blog-content :global(ul) {
      list-style-type: disc;
      padding-left: 1.5rem;
      margin-bottom: 1rem;
    }
    .blog-content :global(ol) {
      list-style-type: decimal;
      padding-left: 1.5rem;
      margin-bottom: 1rem;
    }
    .blog-content :global(blockquote) {
      border-left: 2px solid #e7e5e4;
      padding-left: 1rem;
      color: #78716c;
      font-style: italic;
      margin-bottom: 1rem;
    }
  </style>
</Layout>
