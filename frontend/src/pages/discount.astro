---
import Layout from '../layouts/Layout.astro';
import { useTranslations, translateProduct } from '../lib/translations';
import Pagination from '../components/common/Pagination.astro';

const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';
const t = useTranslations(lang);

const resolveImage = (url: string) => {
  if (url && url.startsWith('/assets/uploads/')) {
    return url;
  }
  if (!url) return '/assets/images/placeholder-product.png';
  if (url.startsWith('http')) return url;
  return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=3';
};

// Fetch query params for filters
const categorySlug = Astro.url.searchParams.get('categorySlug') || '';
const minPrice = Astro.url.searchParams.get('minPrice') || '';
const maxPrice = Astro.url.searchParams.get('maxPrice') || '';
const sizes = Astro.url.searchParams.get('sizes') || '';
const colors = Astro.url.searchParams.get('colors') || '';
const searchQuery = Astro.url.searchParams.get('query') || '';

const limit = 8;

let rawProducts = [] as any[];
let rawCollections = [] as any[];

try {
  // Fetch products with high limit to filter discounts on frontend
  const res = await fetch(`${BACKEND_URL}/api/products?limit=1000`);
  if (res.ok) {
    rawProducts = await res.json();
  }

  // Fetch collections
  const colRes = await fetch(`${BACKEND_URL}/api/collections`);
  if (colRes.ok) {
    rawCollections = await colRes.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching discount items failed.', err);
}

let pageSettings = {
  hero_discount: ''
} as Record<string, string>;

try {
  const res = await fetch(`${BACKEND_URL}/api/web-image/settings`);
  if (res.ok) {
    pageSettings = await res.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching page settings failed.', err);
}

const getColorsArray = (colors: any) => {
  if (!colors) return [];
  if (Array.isArray(colors)) return colors;
  try {
    const parsed = typeof colors === 'string' ? JSON.parse(colors) : colors;
    return Array.isArray(parsed) ? parsed : [];
  } catch (e) {
    if (typeof colors === 'string' && colors.includes(',')) {
      return colors.split(',').map(s => s.trim()).filter(Boolean);
    }
    if (typeof colors === 'string' && colors.trim() !== '') {
      return [colors.trim()];
    }
    return [];
  }
};

// 1. Filter discounted products (activeDiscountPercent > 0)
const discountedProducts = rawProducts.filter((p: any) => p.activeDiscountPercent > 0);

// Apply query filters to products
const filteredProducts = discountedProducts.filter((product: any) => {
  if (categorySlug && product.categorySlug !== categorySlug) return false;
  
  const salePrice = Number(product.price) * (1 - product.activeDiscountPercent / 100);
  if (minPrice && salePrice < parseFloat(minPrice)) return false;
  if (maxPrice && salePrice > parseFloat(maxPrice)) return false;
  
  if (sizes) {
    const sizeArr = sizes.split(',').map(s => s.trim().toLowerCase());
    const prodSizes = getColorsArray(product.sizes).map((s: string) => s.toLowerCase());
    if (!sizeArr.every(s => prodSizes.includes(s))) return false;
  }
  
  if (colors) {
    const colorArr = colors.split(',').map(c => c.trim().toLowerCase());
    const prodColors = getColorsArray(product.colors).map((c: string) => c.toLowerCase());
    if (!colorArr.every(c => prodColors.includes(c))) return false;
  }
  
  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    const matchesName = product.name?.toLowerCase().includes(q);
    const matchesDesc = product.description?.toLowerCase().includes(q);
    if (!matchesName && !matchesDesc) return false;
  }
  
  return true;
});

const displayProducts = filteredProducts.map(product => translateProduct(product, lang));
const sortedProducts = [...displayProducts].sort((a: any, b: any) => (b.activeDiscountPercent || 0) - (a.activeDiscountPercent || 0));
const totalCount = filteredProducts.length;
const totalPages = Math.max(1, Math.ceil(totalCount / limit));

// 2. Filter discounted collections (discountPercent > 0)
const discountedCollections = rawCollections.filter((c: any) => c.discountPercent > 0);

const isFiltered = !!(categorySlug || minPrice || maxPrice || sizes || colors || searchQuery);

// Helper to determine original price and discount percentage
const getDiscountDetails = (product: any) => {
  const priceNum = Number(product.price);
  const percent = product.activeDiscountPercent || 0;
  const salePrice = (priceNum * (1 - percent / 100)).toFixed(2);
  return {
    originalPrice: priceNum.toFixed(2),
    salePrice,
    percent
  };
};
---

<Layout 
  title={lang === 'en' ? "Discounts | ACHI Studio" : "สินค้าลดราคา | ACHI Studio"} 
  description={lang === 'en' ? "Shop minimalist outerwear, statement collections, and basic essentials on discount." : "ช้อปเสื้อผ้าดีไซน์มินิมอลและเครื่องแต่งกายราคาพิเศษที่ลดราคาพิเศษจาก ACHI"} 
  showHeroHeader={true}
>
  {/* Editorial Collection Hero Banner */}
  <section class="w-full relative h-[45vh] bg-[#3C3C3C] flex items-center justify-center text-white overflow-hidden">
    {pageSettings.hero_discount && <div class="absolute inset-0 bg-cover bg-center opacity-70" style={`background-image: url('${resolveImage(pageSettings.hero_discount)}');`}></div>}
    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
    
    <div class="relative w-full max-w-[1440px] mx-auto px-6 flex flex-col justify-end h-full pb-16">
      <div class="flex items-end justify-between w-full">
        <div>
          <span class="border border-white border-opacity-40 px-3 py-1 text-[10px] tracking-widest uppercase font-light rounded-full mb-4 inline-block">
            {lang === 'en' ? "OFFERS" : "ส่วนลดพิเศษ"}
          </span>
          <h1 class="font-serif text-4xl sm:text-6xl font-bold tracking-tight uppercase leading-none">
            {t('discount.hero.title')}
          </h1>
        </div>
        <div class="hidden sm:block text-right text-[11px] tracking-[0.35em] text-gray-300 uppercase font-light max-w-[400px]">
          {t('discount.hero.subtitle')}
        </div>
      </div>
    </div>
  </section>

  {/* Filter Dropdowns Bar */}
  <section class="border-y border-gray-200 bg-white">
    <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center gap-8 text-[11px] uppercase tracking-wider font-light text-gray-500 overflow-x-auto">
      <span class="text-brand-charcoal font-semibold">{lang === 'en' ? "FILTER BY" : "กรองตาม"}</span>
      
      <select id="price-filter" class="bg-transparent border-none outline-none hover:text-brand-charcoal transition-colors cursor-pointer text-[11px] uppercase tracking-wider font-light text-gray-500">
        <option value="">{lang === 'en' ? "Price" : "ราคา"}</option>
        <option value="0-500" selected={minPrice === '0' && maxPrice === '500'}>{lang === 'en' ? "Under $500" : "ต่ำกว่า $500"}</option>
        <option value="500-1000" selected={minPrice === '500' && maxPrice === '1000'}>$500 - $1,000</option>
      </select>

      <select id="color-filter" class="bg-transparent border-none outline-none hover:text-brand-charcoal transition-colors cursor-pointer text-[11px] uppercase tracking-wider font-light text-gray-500">
        <option value="">{lang === 'en' ? "Color" : "สี"}</option>
        <option value="#94B2E6" selected={colors === '#94B2E6'}>{lang === 'en' ? "Soft Blue" : "สีฟ้าอ่อน"}</option>
        <option value="#F3F1EC" selected={colors === '#F3F1EC'}>{lang === 'en' ? "Soft Cream" : "สีครีมอ่อน"}</option>
        <option value="#1B2F50" selected={colors === '#1B2F50'}>{lang === 'en' ? "Navy" : "สีกรมท่า"}</option>
      </select>

      <select id="size-filter" class="bg-transparent border-none outline-none hover:text-brand-charcoal transition-colors cursor-pointer text-[11px] uppercase tracking-wider font-light text-gray-500">
        <option value="">{lang === 'en' ? "Size" : "ขนาด (ไซส์)"}</option>
        <option value="S" selected={sizes === 'S'}>S</option>
        <option value="M" selected={sizes === 'M'}>M</option>
        <option value="L" selected={sizes === 'L'}>L</option>
        <option value="XL" selected={sizes === 'XL'}>XL</option>
      </select>

      <select id="gender-filter" class="bg-transparent border-none outline-none hover:text-brand-charcoal transition-colors cursor-pointer text-[11px] uppercase tracking-wider font-light text-gray-500">
        <option value="">{lang === 'en' ? "Gender" : "เพศ"}</option>
        <option value="men" selected={categorySlug === 'men'}>{lang === 'en' ? "Male" : "ผู้ชาย"}</option>
        <option value="women" selected={categorySlug === 'women'}>{lang === 'en' ? "Female" : "ผู้หญิง"}</option>
      </select>
    </div>
  </section>

  {/* Active Filters Bar */}
  {isFiltered && (
    <div class="max-w-[1440px] mx-auto px-6 pt-8 flex flex-wrap gap-3 items-center text-[10px] tracking-wider uppercase font-light text-gray-400">
      <span class="font-medium text-brand-charcoal text-xs mr-2">{lang === 'en' ? "Active filters:" : "ตัวกรองที่เลือก:"}</span>
      {categorySlug && (
        <span class="border border-gray-200 px-3 py-1.5 rounded-full flex items-center gap-2 bg-gray-50 text-brand-charcoal">
          {lang === 'en' ? "Category" : "หมวดหมู่"}: {categorySlug === 'men' ? (lang === 'en' ? 'Male' : 'ผู้ชาย') : (categorySlug === 'women' ? (lang === 'en' ? 'Female' : 'ผู้หญิง') : categorySlug)}
          <a href={Astro.url.pathname + "?" + (() => { const p = new URLSearchParams(Astro.url.search); p.delete('categorySlug'); return p.toString(); })()} class="hover:text-red-500 font-bold ml-1">×</a>
        </span>
      )}
      {minPrice && maxPrice && (
        <span class="border border-gray-200 px-3 py-1.5 rounded-full flex items-center gap-2 bg-gray-50 text-brand-charcoal">
          {lang === 'en' ? "Price" : "ราคา"}: ${minPrice} - ${maxPrice}
          <a href={Astro.url.pathname + "?" + (() => { const p = new URLSearchParams(Astro.url.search); p.delete('minPrice'); p.delete('maxPrice'); return p.toString(); })()} class="hover:text-red-500 font-bold ml-1">×</a>
        </span>
      )}
      {colors && (
        <span class="border border-gray-200 px-3 py-1.5 rounded-full flex items-center gap-2 bg-gray-50 text-brand-charcoal">
          {lang === 'en' ? "Color" : "สี"}: {colors === '#94B2E6' ? (lang === 'en' ? 'Soft Blue' : 'สีฟ้าอ่อน') : colors === '#F3F1EC' ? (lang === 'en' ? 'Soft Cream' : 'สีครีมอ่อน') : colors === '#1B2F50' ? (lang === 'en' ? 'Navy' : 'สีกรมท่า') : colors}
          <a href={Astro.url.pathname + "?" + (() => { const p = new URLSearchParams(Astro.url.search); p.delete('colors'); return p.toString(); })()} class="hover:text-red-500 font-bold ml-1">×</a>
        </span>
      )}
      {sizes && (
        <span class="border border-gray-200 px-3 py-1.5 rounded-full flex items-center gap-2 bg-gray-50 text-brand-charcoal">
          {lang === 'en' ? "Size" : "ขนาด (ไซส์)"}: {sizes}
          <a href={Astro.url.pathname + "?" + (() => { const p = new URLSearchParams(Astro.url.search); p.delete('sizes'); return p.toString(); })()} class="hover:text-red-500 font-bold ml-1">×</a>
        </span>
      )}
      {searchQuery && (
        <span class="border border-gray-200 px-3 py-1.5 rounded-full flex items-center gap-2 bg-gray-50 text-brand-charcoal">
          {lang === 'en' ? "Search" : "ค้นหา"}: "{searchQuery}"
          <a href={Astro.url.pathname + "?" + (() => { const p = new URLSearchParams(Astro.url.search); p.delete('query'); return p.toString(); })()} class="hover:text-red-500 font-bold ml-1">×</a>
        </span>
      )}
      <a href="/discount" class="text-brand-gold font-medium underline underline-offset-4 ml-4">{lang === 'en' ? "Clear All" : "ล้างทั้งหมด"}</a>
    </div>
  )}

  <script is:inline>
    const priceFilter = document.getElementById('price-filter');
    const colorFilter = document.getElementById('color-filter');
    const sizeFilter = document.getElementById('size-filter');
    const genderFilter = document.getElementById('gender-filter');

    const updateFilters = () => {
      const params = new URLSearchParams(window.location.search);
      
      // Price
      if (priceFilter && priceFilter.value) {
        const [min, max] = priceFilter.value.split('-');
        params.set('minPrice', min);
        params.set('maxPrice', max);
      } else {
        params.delete('minPrice');
        params.delete('maxPrice');
      }

      // Color
      if (colorFilter && colorFilter.value) {
        params.set('colors', colorFilter.value);
      } else {
        params.delete('colors');
      }

      // Size
      if (sizeFilter && sizeFilter.value) {
        params.set('sizes', sizeFilter.value);
      } else {
        params.delete('sizes');
      }

      // Gender / Category
      if (genderFilter && genderFilter.value) {
        params.set('categorySlug', genderFilter.value);
      } else {
        params.delete('categorySlug');
      }

      window.location.search = params.toString();
    };

    [priceFilter, colorFilter, sizeFilter, genderFilter].forEach(el => {
      if (el) el.addEventListener('change', updateFilters);
    });
  </script>

  <div class="max-w-[1440px] mx-auto px-6 py-16 space-y-20">
    {/* Editorial / Mixed Layout Section */}
    {discountedCollections.length > 0 && (
      <div class="relative mb-20 group animate-fade-in" id="editorial-sets-carousel">
        <div class="flex justify-between items-center mb-8 border-b border-stone-100 pb-4">
          <h2 class="font-serif text-2xl font-normal tracking-wide text-brand-charcoal uppercase">
            {lang === 'en' ? "Discounted Looks" : "เซ็ตแต่งกายลดราคาพิเศษ"}
          </h2>
          <span class="text-[10px] text-stone-400 font-light tracking-widest uppercase">
            {discountedCollections.length} {lang === 'en' ? "Looks Available" : "ลุคที่มีจำหน่าย"}
          </span>
        </div>
        
        {/* Slides Container */}
        <div class="relative overflow-hidden w-full rounded-sm">
          {discountedCollections.map((set: any, setIndex: number) => {
            const setCoverImage = set.imageUrl || '/assets/images/placeholder-product.png';
            const setProductIds = set.products ? set.products.map((p: any) => p.id) : [];
            const setFullProducts = rawProducts.filter((p: any) => setProductIds.includes(p.id));
            const displaySetProducts = setFullProducts.map((p: any) => translateProduct(p, lang));
            
            return (
              <div 
                class={`editorial-set-slide grid grid-cols-1 lg:grid-cols-2 gap-12 items-start transition-all duration-700 ease-in-out ${setIndex === 0 ? 'opacity-100 relative z-10' : 'opacity-0 absolute inset-0 pointer-events-none z-0'}`}
                data-index={setIndex}
              >
                <!-- Left Column: Set Cover Image -->
                <div class="relative bg-stone-100 aspect-[3/4] overflow-hidden rounded-sm shadow-xs group/img">
                  <div 
                    class="absolute inset-0 bg-cover bg-center transition-transform duration-[8000ms] ease-out scale-100 group-[.active-slide]:scale-105" 
                    style={`background-image: url('${resolveImage(setCoverImage)}');`}
                  ></div>
                  
                  {/* Premium Badge indicating set name & discount */}
                  <div class="absolute bottom-6 left-6 bg-brand-charcoal/90 text-white backdrop-blur-xs px-4 py-2.5 rounded-sm text-[10px] uppercase tracking-widest font-semibold z-20 flex flex-col gap-1 shadow-md">
                    <span>{set.title}</span>
                    <span class="text-red-500 font-bold text-xs">{lang === 'en' ? "SET DISCOUNT" : "ลดเซ็ตนี้"} -{set.discountPercent}%</span>
                  </div>
                </div>

                <!-- Right Column: Editorial Product Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                  {displaySetProducts.map((product: any) => {
                    const prodDetails = getDiscountDetails(product);
                    return (
                      <div class="flex flex-col justify-between p-4 bg-white border border-gray-100 rounded-sm product-card-hover group/card relative shadow-xs">
                        {/* Heart Favorite Button */}
                        <button
                          class="absolute top-6 right-6 text-gray-400 hover:text-brand-charcoal transition-colors focus:outline-none cursor-pointer z-20"
                          data-favorite-btn
                          data-id={product.id}
                          data-name={product.name}
                          data-price={product.price}
                          data-image={product.imageUrl}
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                          </svg>
                        </button>

                        {/* Product Image */}
                        <div class="aspect-[1/1] overflow-hidden flex items-center justify-center bg-gray-50 mb-6 relative">
                          {product.activeDiscountPercent > 0 && (
                            <span class="absolute top-6 left-6 z-20 bg-red-600 text-white text-[9px] uppercase tracking-widest font-bold px-2.5 py-1 rounded-sm shadow-sm">
                              -{product.activeDiscountPercent}% OFF
                            </span>
                          )}
                          <img
                            src={resolveImage(product.imageUrl)}
                            alt={product.name}
                            class="max-h-[85%] object-contain mix-blend-multiply transition-transform duration-500 group-hover/card:scale-105"
                          />
                        </div>

                        {/* Product Details */}
                        <div>
                          <div class="flex items-center justify-between gap-4">
                            <h3 class="font-serif text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight truncate">
                              {product.name}
                            </h3>
                            {getColorsArray(product.colors).length > 0 && (
                              <div class="flex gap-1.5 shrink-0">
                                {getColorsArray(product.colors).slice(0, 3).map((color: string) => (
                                  <span class="w-3 h-3 rounded-full border border-stone-300 block shadow-xs" style={{ backgroundColor: color }}></span>
                                ))}
                              </div>
                            )}
                          </div>
                          <div class="flex items-center gap-3 mt-2">
                            <span class="text-xs text-red-600 font-bold">${Number(prodDetails.salePrice).toLocaleString()}</span>
                            <span class="text-[10px] text-gray-400 line-through font-light">${Number(prodDetails.originalPrice).toLocaleString()}</span>
                          </div>
                        </div>
                        
                        {/* Clickable Area Link */}
                        <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </div>

        {/* Carousel Navigation Indicators */}
        {discountedCollections.length > 1 && (
          <div class="flex justify-center items-center gap-3 mt-8">
            <button id="carousel-prev-btn" class="text-stone-400 hover:text-brand-charcoal transition-colors p-2 text-xs uppercase tracking-widest font-semibold cursor-pointer">&larr; Prev</button>
            <div class="flex gap-2">
              {discountedCollections.map((_: any, idx: number) => (
                <button 
                  class={`carousel-indicator-bar w-8 h-1 transition-all duration-300 rounded-full cursor-pointer ${idx === 0 ? 'bg-brand-charcoal w-12' : 'bg-stone-200 hover:bg-stone-300'}`}
                  data-slide-to={idx}
                ></button>
              ))}
            </div>
            <button id="carousel-next-btn" class="text-stone-400 hover:text-brand-charcoal transition-colors p-2 text-xs uppercase tracking-widest font-semibold cursor-pointer">Next &rarr;</button>
          </div>
        )}
      </div>
    )}

    <!-- Section: Discounted Pieces -->
    <div id="pieces-container" class="space-y-12 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 border-b border-stone-100 pb-4">
        <h2 class="font-serif text-2xl font-normal tracking-wide text-brand-charcoal uppercase">
          {lang === 'en' ? "Discounted Pieces" : "ดีลสินค้าเดี่ยวลดราคา"}
        </h2>
        
        <!-- Savings Tiers Filter -->
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-[9px] uppercase tracking-widest font-semibold text-stone-400 mr-2">{lang === 'en' ? "Savings:" : "ระดับการลดราคา:"}</span>
          <button class="tier-filter-btn px-3 py-1.5 rounded-full border border-stone-200 text-[9px] font-semibold uppercase tracking-wider transition-all duration-300 cursor-pointer bg-brand-charcoal text-white shadow-xs" data-tier="all">
            {lang === 'en' ? "All Deals" : "ทั้งหมด"}
          </button>
          <button class="tier-filter-btn px-3 py-1.5 rounded-full border border-stone-200 text-[9px] font-semibold uppercase tracking-wider transition-all duration-300 cursor-pointer text-stone-500 hover:text-brand-charcoal bg-stone-50" data-tier="high">
            30%+ OFF
          </button>
          <button class="tier-filter-btn px-3 py-1.5 rounded-full border border-stone-200 text-[9px] font-semibold uppercase tracking-wider transition-all duration-300 cursor-pointer text-stone-500 hover:text-brand-charcoal bg-stone-50" data-tier="mid">
            20% - 30% OFF
          </button>
          <button class="tier-filter-btn px-3 py-1.5 rounded-full border border-stone-200 text-[9px] font-semibold uppercase tracking-wider transition-all duration-300 cursor-pointer text-stone-500 hover:text-brand-charcoal bg-stone-50" data-tier="low">
            Up to 20% OFF
          </button>
        </div>
      </div>

      <!-- Standard 4-Column Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
        {sortedProducts.map((product: any, index: number) => {
          const details = getDiscountDetails(product);
          const isMaxDiscount = index === 0 && (product.activeDiscountPercent || 0) > 0;
          const isHidden = index >= limit && !isMaxDiscount;
          const prodSizes = getColorsArray(product.sizes);
          const prodColors = getColorsArray(product.colors);
          
          return (
            <div 
              class={`flex flex-col justify-between rounded-sm product-card-hover group product-card-wrapper transition-all duration-500 relative ${isMaxDiscount ? 'md:col-span-2 md:row-span-2 p-6 md:p-8 bg-stone-900 text-white border border-brand-gold/30 shadow-xl' : 'p-4 bg-white border border-stone-100'} ${isHidden ? 'js-expandable-card hidden' : ''}`}
              data-discount-val={product.activeDiscountPercent}
            >
              {/* Discount Percentage Badge */}
              <span class={`absolute z-20 bg-red-600 text-white uppercase tracking-widest font-bold rounded-sm shadow-sm animate-pulse ${isMaxDiscount ? 'text-[11px] px-3.5 py-2 top-8 left-8' : 'text-[9px] px-2.5 py-1 top-6 left-6'}`}>
                -{details.percent}% OFF
              </span>

              {/* Heart Favorite Button */}
              <button
                class={`absolute z-20 transition-colors focus:outline-none cursor-pointer ${isMaxDiscount ? 'top-8 right-8 text-stone-400 hover:text-white' : 'top-6 right-6 text-gray-400 hover:text-brand-charcoal'}`}
                data-favorite-btn data-discount={product.activeDiscountPercent || 0}
                data-id={product.id}
                data-name={product.name}
                data-price={product.price}
                data-image={product.imageUrl}
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                </svg>
              </button>

              {/* Product Image Box */}
              <div class={`aspect-[1/1] overflow-hidden flex items-center justify-center rounded-sm mb-6 relative ${isMaxDiscount ? 'bg-stone-950/40 border border-stone-800' : 'bg-gray-50 border border-gray-100/50'}`}>
                {product.imageUrl ? (
                  <img src={resolveImage(product.imageUrl)} alt={product.name} class={`max-h-[85%] object-contain transition-transform duration-500 group-hover:scale-105 ${isMaxDiscount ? 'mix-blend-normal' : 'mix-blend-multiply'}`} />
                ) : (
                  <span class="text-[9px] uppercase tracking-[0.2em] text-gray-400 text-center font-light leading-relaxed">
                    [Image: {product.name}]
                  </span>
                )}
                
                {product.status === 'inactive' && (
                  <div class="absolute inset-0 bg-stone-900/40 backdrop-blur-xs flex items-center justify-center z-10">
                    <span class="text-white text-[10px] uppercase tracking-widest font-semibold border border-white/60 px-3 py-1.5 rounded-sm">
                      {lang === 'en' ? 'Not Available' : 'งดจำหน่าย'}
                    </span>
                  </div>
                )}
              </div>

              {/* Product Details */}
              <div class="space-y-4">
                <div class="space-y-1">
                  <span class="text-[8px] uppercase tracking-[0.25em] text-brand-gold font-bold block">
                    {product.categoryName || (lang === 'en' ? 'Clothing' : 'เสื้อผ้า')}
                  </span>
                  <div class="flex items-start justify-between gap-4">
                    <h3 class={`font-serif tracking-widest uppercase leading-tight ${isMaxDiscount ? 'text-lg md:text-xl font-bold' : 'text-xs font-semibold text-brand-charcoal'}`}>
                      {product.name}
                    </h3>
                  </div>
                  
                  <!-- Pricing Row showing Sale and Original prices -->
                  <div class="flex items-center gap-3 mt-2">
                    <span class={`font-bold ${isMaxDiscount ? 'text-lg text-red-500' : 'text-xs text-red-600'}`}>${Number(details.salePrice).toLocaleString()}</span>
                    <span class={`font-light line-through ${isMaxDiscount ? 'text-xs text-stone-400' : 'text-[10px] text-gray-400'}`}>${Number(details.originalPrice).toLocaleString()}</span>
                  </div>
                </div>

                {/* UX Enhancement: direct display of size and color options */}
                <div class={`pt-2.5 border-t space-y-2 ${isMaxDiscount ? 'border-stone-800' : 'border-stone-100'}`}>
                  {prodColors.length > 0 && (
                    <div class="flex items-center gap-2">
                      <span class="text-[8px] uppercase tracking-wider font-semibold text-stone-400 shrink-0 w-10">{lang === 'en' ? "Colors:" : "สี:"}</span>
                      <div class="flex flex-wrap gap-1">
                        {prodColors.map((color: string) => (
                          <span 
                            class={`inline-flex items-center gap-1 text-[8px] px-1.5 py-0.5 rounded-sm font-sans border ${isMaxDiscount ? 'bg-stone-800 border-stone-750 text-stone-300' : 'bg-stone-50 border-stone-200 text-stone-600'}`}
                          >
                            {color.startsWith('#') && (
                              <span class="w-2 h-2 rounded-full border border-stone-300 shrink-0 block" style={{ backgroundColor: color }}></span>
                            )}
                            {color}
                          </span>
                        ))}
                      </div>
                    </div>
                  )}

                  {prodSizes.length > 0 && (
                    <div class="flex items-center gap-2">
                      <span class="text-[8px] uppercase tracking-wider font-semibold text-stone-400 shrink-0 w-10">{lang === 'en' ? "Sizes:" : "ไซส์:"}</span>
                      <div class="flex flex-wrap gap-1">
                        {prodSizes.map((size: string) => (
                          <span class={`text-[8px] px-1.5 py-0.5 rounded-sm font-mono font-bold uppercase ${isMaxDiscount ? 'bg-stone-800 text-white' : 'bg-stone-100 text-stone-700'}`}>{size}</span>
                        ))}
                      </div>
                    </div>
                  )}
                </div>

                {isMaxDiscount && (
                  <div class="pt-4 mt-2">
                    <span class="inline-block text-center bg-brand-gold text-brand-charcoal hover:bg-white hover:text-brand-charcoal px-6 py-2.5 rounded-sm text-[9px] font-bold uppercase tracking-widest transition-all duration-300 w-full">
                      {lang === 'en' ? "Claim Deal Now" : "ช้อปดีลนี้ทันที"} &rarr;
                    </span>
                  </div>
                )}
              </div>
              
              {/* Clickable Area Link */}
              <a href={`/products/${product.id}`} class="absolute inset-0 z-10" aria-label="View Details"></a>
            </div>
          );
        })}
      </div>

      {displayProducts.length === 0 && (
        <div class="text-center py-24 text-stone-400 italic font-light text-sm bg-stone-50 border border-dashed border-stone-200 rounded-sm w-full">
          {isFiltered
            ? (lang === 'en' ? "No discounted products match your criteria." : "ไม่มีสินค้าลดราคาที่ตรงตามเงื่อนไขของคุณ")
            : (lang === 'en' ? "There are no discount deals active at the moment. Please check back later!" : "ขออภัย ขณะนี้ยังไม่มีรายการสินค้าลดราคาพิเศษ โปรดติดตามโปรโมชันใหม่เร็วๆ นี้!")
          }
        </div>
      )}

      {displayProducts.length > limit && (
        <div class="flex justify-center mt-16 animate-fade-in" id="view-all-container">
          <button
            id="view-all-deals-btn"
            class="px-8 py-4 border border-brand-charcoal text-brand-charcoal hover:bg-brand-charcoal hover:text-white text-xs font-bold uppercase tracking-widest transition-all duration-300 cursor-pointer rounded-sm"
          >
            {lang === 'en' ? "View All Products" : "ดูสินค้าทั้งหมด"}
          </button>
        </div>
      )}

      {/* Pagination Component */}
      {totalPages > 1 && (
        <div id="discount-pagination" class="pt-6">
          <Pagination totalPages={totalPages} />
        </div>
      )}
    </div>
  </div>

  <script is:inline>
    (function() {
      // 1. Editorial Sets Carousel Slider
      const carousel = document.getElementById('editorial-sets-carousel');
      if (carousel) {
        const slides = carousel.querySelectorAll('.editorial-set-slide');
        const indicators = carousel.querySelectorAll('.carousel-indicator-bar');
        const prevBtn = document.getElementById('carousel-prev-btn');
        const nextBtn = document.getElementById('carousel-next-btn');

        if (slides.length > 1) {
          let currentIndex = 0;
          let intervalId = null;

          const showSlide = (index) => {
            // Handle wrapping
            if (index >= slides.length) index = 0;
            if (index < 0) index = slides.length - 1;

            // Update active slide classes
            slides.forEach((slide, idx) => {
              if (idx === index) {
                slide.classList.remove('opacity-0', 'absolute', 'pointer-events-none', 'z-0');
                slide.classList.add('opacity-100', 'relative', 'z-10');
                slide.classList.add('active-slide');
              } else {
                slide.classList.remove('opacity-100', 'relative', 'z-10');
                slide.classList.remove('active-slide');
                slide.classList.add('opacity-0', 'absolute', 'pointer-events-none', 'z-0');
              }
            });

            // Update indicators
            indicators.forEach((ind, idx) => {
              if (idx === index) {
                ind.classList.remove('bg-stone-200', 'hover:bg-stone-300');
                ind.classList.add('bg-brand-charcoal', 'w-12');
              } else {
                ind.classList.remove('bg-brand-charcoal', 'w-12');
                ind.classList.add('bg-stone-200', 'hover:bg-stone-300');
              }
            });

            currentIndex = index;
          };

          const startAutoPlay = () => {
            stopAutoPlay();
            intervalId = setInterval(() => {
              showSlide(currentIndex + 1);
            }, 7000); // Rotate every 7 seconds
          };

          const stopAutoPlay = () => {
            if (intervalId) {
              clearInterval(intervalId);
              intervalId = null;
            }
          };

          // Initialize first slide
          showSlide(0);
          startAutoPlay();

          // Event Listeners
          prevBtn?.addEventListener('click', () => {
            showSlide(currentIndex - 1);
            startAutoPlay();
          });

          nextBtn?.addEventListener('click', () => {
            showSlide(currentIndex + 1);
            startAutoPlay();
          });

          indicators.forEach((ind, idx) => {
            ind.addEventListener('click', () => {
              showSlide(idx);
              startAutoPlay();
            });
          });

          // Pause on hover
          carousel.addEventListener('mouseenter', stopAutoPlay);
          carousel.addEventListener('mouseleave', startAutoPlay);
        }
      }

      // 2. Savings Tiers Filtering
      const tierButtons = document.querySelectorAll('.tier-filter-btn');
      const productCards = document.querySelectorAll('.product-card-wrapper');
      const viewAllBtn = document.getElementById('view-all-deals-btn');
      const expandableCards = document.querySelectorAll('.js-expandable-card');
      const paginationContainer = document.getElementById('discount-pagination');

      if (tierButtons.length > 0 && productCards.length > 0) {
        tierButtons.forEach(btn => {
          btn.addEventListener('click', () => {
            // Update active state style
            tierButtons.forEach(b => {
              b.classList.remove('bg-brand-charcoal', 'text-white', 'shadow-xs');
              b.classList.add('text-stone-500', 'bg-stone-50');
            });
            btn.classList.add('bg-brand-charcoal', 'text-white', 'shadow-xs');
            btn.classList.remove('text-stone-500', 'bg-stone-50');

            const tier = btn.getAttribute('data-tier');
            
            productCards.forEach(card => {
              const discount = parseFloat(card.getAttribute('data-discount-val') || '0');
              let matches = false;
              
              if (tier === 'all') {
                if (viewAllBtn && viewAllBtn.classList.contains('js-clicked')) {
                  matches = true;
                } else {
                  matches = !card.classList.contains('js-expandable-card');
                }
              }
              else if (tier === 'high' && discount >= 30) matches = true;
              else if (tier === 'mid' && discount >= 20 && discount < 30) matches = true;
              else if (tier === 'low' && discount < 20) matches = true;

              if (matches) {
                card.classList.remove('hidden');
                card.style.opacity = '0';
                setTimeout(() => {
                  card.style.transition = 'opacity 300ms ease';
                  card.style.opacity = '1';
                }, 50);
              } else {
                card.classList.add('hidden');
              }
            });

            // Adjust view all button visibility depending on tier filter
            if (viewAllBtn) {
              if (tier === 'all') {
                if (!viewAllBtn.classList.contains('js-clicked')) {
                  const viewAllContainer = document.getElementById('view-all-container');
                  if (viewAllContainer) viewAllContainer.classList.remove('hidden');
                  viewAllBtn.classList.remove('hidden');
                  if (paginationContainer) paginationContainer.classList.remove('hidden');
                }
              } else {
                const viewAllContainer = document.getElementById('view-all-container');
                if (viewAllContainer) viewAllContainer.classList.add('hidden');
                viewAllBtn.classList.add('hidden');
                if (paginationContainer) paginationContainer.classList.add('hidden');
              }
            }
          });
        });
      }

      // 3. View All Button handler
      if (viewAllBtn && expandableCards.length > 0) {
        viewAllBtn.addEventListener('click', () => {
          viewAllBtn.classList.add('js-clicked');
          expandableCards.forEach(card => {
            card.classList.remove('hidden');
            card.style.opacity = '0';
            setTimeout(() => {
              card.style.transition = 'opacity 300ms ease';
              card.style.opacity = '1';
            }, 50);
          });
          viewAllBtn.classList.add('hidden');
          const viewAllContainer = document.getElementById('view-all-container');
          if (viewAllContainer) viewAllContainer.classList.add('hidden');
          if (paginationContainer) paginationContainer.classList.add('hidden');
        });
      }
    })();
  </script>
</Layout>
