                        <li><a href={l('/products?categorySlug=women&query=Polo')} class="hover:text-brand-gold">{t('menu.women_polo')}</a></li>
                        <li><a href={l('/products?categorySlug=women&query=Hoodie')} class="hover:text-brand-gold">{t('menu.women_hoodie')}</a></li>
                        <li><a href={l('/products?categorySlug=women&query=Jeans')} class="hover:text-brand-gold">{t('menu.women_jeans')}</a></li>
