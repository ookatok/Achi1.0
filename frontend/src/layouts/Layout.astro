    <!-- Client-side script to toggle search overlay and handle live search -->
    <script>
      const searchBtn = document.getElementById('search-btn');
      const closeSearchBtn = document.getElementById('close-search-btn');
      const searchOverlay = document.getElementById('search-overlay');
      const searchInput = document.getElementById('search-input') as HTMLInputElement;
      const clearSearchBtn = document.getElementById('clear-search-btn');

      const searchPreviewContainer = document.getElementById('search-preview-container');
      const searchPreviewResults = document.getElementById('search-preview-results');
      const searchPreviewEmpty = document.getElementById('search-preview-empty');
      const searchSuggestions = document.getElementById('search-suggestions');

      const resolveImage = (url: string) => {
        if (!url) return '/assets/images/placeholder-product.png';
        if (url.startsWith('http') || url.startsWith('data:')) return url;
        if (url.startsWith('/assets/uploads/')) {
          return `http://localhost:3001${url}`;
        }
        return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=2';
      };

      let debounceTimer: number;

      const performSearch = async (query: string) => {
        if (!query.trim()) {
          if (searchPreviewContainer) searchPreviewContainer.classList.add('hidden');
          if (searchPreviewEmpty) searchPreviewEmpty.classList.add('hidden');
          if (searchSuggestions) searchSuggestions.classList.remove('hidden');
          if (searchPreviewResults) searchPreviewResults.innerHTML = '';
          return;
        }

        try {
          const res = await fetch(`http://localhost:3001/api/products?query=${encodeURIComponent(query)}`);
          if (res.ok) {
            const products = await res.json();
            
            if (products.length > 0) {
              if (searchPreviewEmpty) searchPreviewEmpty.classList.add('hidden');
              if (searchSuggestions) searchSuggestions.classList.add('hidden');
              if (searchPreviewContainer) searchPreviewContainer.classList.remove('hidden');
              
              if (searchPreviewResults) {
                searchPreviewResults.innerHTML = products.map((product: any) => {
                  const price = isNaN(Number(product.price)) ? product.price : Number(product.price).toLocaleString();
                  const displayName = (window as any).translateProductName(product.name, (window as any).currentLang);
                  return `
                    <div class="flex items-center gap-4 p-3 bg-gray-50/50 border border-gray-100 rounded-sm hover:border-brand-charcoal transition-all relative group">
                      <div class="w-16 h-16 bg-white border border-gray-100 flex items-center justify-center overflow-hidden shrink-0 rounded-sm">
                        <img src="${resolveImage(product.imageUrl)}" alt="${displayName}" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
                      </div>
                      <div class="flex-grow">
                        <h5 class="text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight group-hover:text-brand-gold transition-colors">
                          ${displayName}
                        </h5>
                        <span class="text-xs text-brand-gold font-medium mt-1.5 block">
                          $${price}
                        </span>
                      </div>
                      <a href="/${(window as any).currentLang}/products/${product.id}" class="absolute inset-0 z-10" aria-label="View Details"></a>
                    </div>
                  `;
                }).join('');
              }
            } else {
              if (searchPreviewContainer) searchPreviewContainer.classList.add('hidden');
              if (searchSuggestions) searchSuggestions.classList.add('hidden');
              if (searchPreviewEmpty) searchPreviewEmpty.classList.remove('hidden');
              if (searchPreviewResults) searchPreviewResults.innerHTML = '';
            }
          }
        } catch (e) {
          console.error('Failed to perform live search', e);
        }
      };

      if (searchBtn && searchOverlay) {
        searchBtn.addEventListener('click', () => {
          searchOverlay.classList.remove('hidden');
          document.body.style.overflow = 'hidden'; // Lock background scroll
          if (searchInput) {
            searchInput.value = '';
            performSearch('');
            if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
            searchInput.focus();
          }
        });
      }

      if (closeSearchBtn && searchOverlay) {
        closeSearchBtn.addEventListener('click', () => {
          searchOverlay.classList.add('hidden');
          document.body.style.overflow = ''; // Unlock background scroll
          if (searchInput) {
            searchInput.value = '';
            performSearch('');
            if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
          }
        });
      }

      const searchOverlayFocusBtn = document.getElementById('search-overlay-focus-btn');
      if (searchOverlayFocusBtn && searchInput) {
        searchOverlayFocusBtn.addEventListener('click', () => {
          searchInput.focus();
        });
      }

      if (searchInput) {
        searchInput.addEventListener('input', () => {
          clearTimeout(debounceTimer);
          
          const val = searchInput.value;
          if (val.length > 0) {
            if (clearSearchBtn) clearSearchBtn.classList.remove('hidden');
          } else {
            if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
          }

          debounceTimer = window.setTimeout(() => {
            performSearch(val);
          }, 250);
        });

        if (clearSearchBtn) {
          clearSearchBtn.addEventListener('click', () => {
            searchInput.value = '';
            clearSearchBtn.classList.add('hidden');
            performSearch('');
            searchInput.focus();
          });
        }
      }
    </script>

    <!-- Client-side script for sticky header and shop mega menu transitions -->
    <script is:inline>
      const stickyHeader = document.querySelector('header');
      const isHeroHeader = stickyHeader?.getAttribute('data-hero') === 'true';
      const shopMenuBtn = document.getElementById('shop-menu-btn');
      const shopMegaMenu = document.getElementById('shop-mega-menu');

      const handleStickyScroll = () => {
        if (!stickyHeader) return;
        const isMenuOpen = shopMegaMenu && (shopMegaMenu.classList.contains('block') || !shopMegaMenu.classList.contains('hidden'));
        
        if (window.scrollY > 20 || isMenuOpen) {
          stickyHeader.classList.add('scrolled');
          if (isHeroHeader) {
            stickyHeader.classList.remove('bg-transparent', 'text-white', 'border-transparent');
            stickyHeader.classList.add('bg-white/90', 'text-brand-charcoal', 'border-gray-200/50', 'shadow-sm', 'backdrop-blur-md');
          } else {
            stickyHeader.classList.add('shadow-md');
          }
        } else {
          stickyHeader.classList.remove('scrolled');
          if (isHeroHeader) {
            stickyHeader.classList.add('bg-transparent', 'text-white', 'border-transparent');
            stickyHeader.classList.remove('bg-white/90', 'text-brand-charcoal', 'border-gray-200/50', 'shadow-sm', 'backdrop-blur-md');
          } else {
            stickyHeader.classList.remove('shadow-md');
          }
        }
      };

      if (stickyHeader) {
        window.addEventListener('scroll', handleStickyScroll);
        // Initial check in case of page reload when already scrolled down
        handleStickyScroll();
      }

      if (shopMenuBtn && shopMegaMenu) {
        const backdrop = document.getElementById('mega-menu-backdrop');

        shopMenuBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isHidden = shopMegaMenu.classList.contains('hidden');
          if (isHidden) {
            shopMegaMenu.classList.remove('hidden');
            shopMegaMenu.classList.add('block');
            if (backdrop) backdrop.classList.remove('hidden');
          } else {
            shopMegaMenu.classList.remove('block');
            shopMegaMenu.classList.add('hidden');
            if (backdrop) backdrop.classList.add('hidden');
          }
          handleStickyScroll();
        });

        // Close when clicking outside
        document.addEventListener('click', (e) => {
          if (shopMegaMenu && !shopMegaMenu.contains(e.target) && e.target !== shopMenuBtn) {
            shopMegaMenu.classList.remove('block');
            shopMegaMenu.classList.add('hidden');
            if (backdrop) backdrop.classList.add('hidden');
            handleStickyScroll();
          }
        });

        if (backdrop) {
          backdrop.addEventListener('click', () => {
            shopMegaMenu.classList.remove('block');
            shopMegaMenu.classList.add('hidden');
            backdrop.classList.add('hidden');
            handleStickyScroll();
          });
        }
      }
    </script>
    <!-- Client-side script to highlight active links and toggle clothing menu -->
    <script is:inline>
      const currentPathName = window.location.pathname + window.location.search;
      
      // 1. Highlight active sub-links in the mega menu
      document.querySelectorAll('#shop-mega-menu a').forEach(link => {
        const href = link.getAttribute('href');
        if (href) {
          // Normalize paths for matching
          const normalizedHref = href.endsWith('/') ? href.slice(0, -1) : href;
          const normalizedCurrent = currentPathName.endsWith('/') ? currentPathName.slice(0, -1) : currentPathName;
          
          if (normalizedCurrent === normalizedHref || (normalizedHref !== '' && normalizedHref !== '/products' && normalizedCurrent.startsWith(normalizedHref))) {
            link.classList.add('active');
          }
        }
      });

      // 2. Highlight active main navigation items (HOME, SHOP, New Arrivals, BLOG)
      const mainLinks = document.querySelectorAll('header nav a, header nav button#shop-menu-btn');
      mainLinks.forEach(link => {
        const href = link.getAttribute('href');
        const id = link.getAttribute('id');
        const normalizedCurrent = currentPathName.endsWith('/') ? currentPathName.slice(0, -1) : currentPathName;

        if (id === 'shop-menu-btn') {
          // Active if pathname starts with /products
          if (window.location.pathname.startsWith('/products')) {
            link.classList.add('active');
          }
        } else if (href) {
          const normalizedHref = href.endsWith('/') ? href.slice(0, -1) : href;
          if (normalizedHref === '' && normalizedCurrent === '') {
            link.classList.add('active');
          } else if (normalizedHref !== '' && normalizedCurrent.startsWith(normalizedHref)) {
            link.classList.add('active');
          }
        }
      });

      // 3. Obsolete clothing subcategory toggle logic removed
    </script>

    <!-- Client-side script for Favorites Wishlist sync and click tracking -->
    <script is:inline>
      (function() {
        const STORAGE_KEY = 'achi_favorites';

        const getFavorites = () => {
          try {
            const data = localStorage.getItem(STORAGE_KEY);
            return data ? JSON.parse(data) : [];
          } catch (e) {
            return [];
          }
        };

        const saveFavorites = (favs) => {
          try {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(favs));
          } catch (e) {
            console.error('Failed to save favorites', e);
          }
        };

        const updateFavoriteBadge = (count) => {
          const badges = [document.getElementById('favorite-badge'), document.getElementById('search-favorite-badge')];
          badges.forEach(badge => {
            if (!badge) return;
            badge.textContent = count;
            if (count > 0) {
              badge.classList.remove('scale-0');
              badge.classList.add('scale-100');
            } else {
              badge.classList.remove('scale-100');
              badge.classList.add('scale-0');
            }
          });
        };

        const syncFavoriteButtons = () => {
          const favs = getFavorites();
          updateFavoriteBadge(favs.length);

          const favIds = new Set(favs.map(f => String(f.id)));
          
          document.querySelectorAll('[data-favorite-btn]').forEach(btn => {
            const id = btn.getAttribute('data-id');
            if (id && favIds.has(String(id))) {
              btn.classList.add('is-favorite');
            } else {
              btn.classList.remove('is-favorite');
            }
          });
        };

        const toggleFavorite = (product) => {
          let favs = getFavorites();
          const index = favs.findIndex(f => String(f.id) === String(product.id));

          if (index > -1) {
            favs.splice(index, 1);
          } else {
            favs.push(product);
          }

          saveFavorites(favs);
          syncFavoriteButtons();

          // Dispatch a custom event so the favorite page or other elements can react if they want
          window.dispatchEvent(new CustomEvent('achi-favorites-updated', { detail: favs }));
        };

        // Initialize and bind click handlers
        const initFavorites = () => {
          syncFavoriteButtons();

          // Global click event listener for event delegation
          document.addEventListener('click', (e) => {
            const btn = e.target.closest('[data-favorite-btn]');
            if (!btn) return;

            e.preventDefault();
            e.stopPropagation();

            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name') || '';
            const price = btn.getAttribute('data-price') || '';
            const imageUrl = btn.getAttribute('data-image') || '';

            if (id) {
              toggleFavorite({ id, name, price, imageUrl });
            }
          });
        };

        // Run on DOMContentLoaded or immediately if already loaded
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initFavorites);
        } else {
          initFavorites();
        }

        // Expose to window so other pages can easily check/manipulate if needed
        window.achiFavorites = {
          get: getFavorites,
          toggle: toggleFavorite,
          sync: syncFavoriteButtons
        };
      })();
    </script>

    <!-- Client-side script for Language Selector Toggle -->
    <script is:inline>
      document.querySelectorAll('.language-selector-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const pathname = window.location.pathname;
          let newPath = pathname;
          let newLang = 'th';

          if (pathname.startsWith('/th/')) {
            newPath = '/en/' + pathname.slice(4);
            newLang = 'en';
          } else if (pathname === '/th') {
            newPath = '/en';
            newLang = 'en';
          } else if (pathname.startsWith('/en/')) {
            newPath = '/th/' + pathname.slice(4);
            newLang = 'th';
          } else if (pathname === '/en') {
            newPath = '/th';
            newLang = 'th';
          } else {
            // Fallback if no prefix is present (should not happen normally due to middleware redirect)
            const cookies = document.cookie.split(';');
            let currentLang = 'th';
            for (let cookie of cookies) {
              const [name, value] = cookie.trim().split('=');
              if (name === 'lang') {
                currentLang = value;
                break;
              }
            }
            newLang = currentLang === 'en' ? 'th' : 'en';
            newPath = '/' + newLang + pathname;
          }

          // Update the cookie so the preference is stored
          document.cookie = `lang=${newLang};path=/;max-age=31536000;samesite=lax`;
          // Navigate to the new localized URL
          window.location.href = newPath + window.location.search + window.location.hash;
        });
      });
    </script>

    <!-- Client-side script for Cart Badge syncing -->
    <script is:inline define:vars={{ token }}>
      (function() {
        if (!token) return;

        const updateCartBadges = async () => {
          try {
            const res = await fetch('http://localhost:3001/api/cart', {
              headers: {
                'Authorization': `Bearer ${token}`
              }
            });
            if (res.ok) {
              const cartData = await res.json();
              const count = cartData.items?.reduce((sum, item) => sum + item.quantity, 0) || 0;
              
              const badges = [document.getElementById('cart-badge'), document.getElementById('search-cart-badge')];
              badges.forEach(badge => {
                if (!badge) return;
                badge.textContent = count;
                if (count > 0) {
                  badge.classList.remove('scale-0');
                  badge.classList.add('scale-100');
                } else {
                  badge.classList.remove('scale-100');
                  badge.classList.add('scale-0');
                }
              });
            }
          } catch (e) {
            console.error('Failed to update cart badge', e);
          }
        };

        // Listen for cart update event
        window.addEventListener('cart-updated', updateCartBadges);
      })();
    </script>

    <!-- Client-side script for Product Card Image Sliders -->
    <script is:inline>
      (function() {
        const clientResolveImage = (url) => {
          if (!url) return '/assets/images/placeholder-product.png';
          if (url.startsWith('http') || url.startsWith('data:')) return url;
          if (url.startsWith('/assets/uploads/')) {
            return `http://localhost:3001${url}`;
          }
          return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=2';
        };

        const getProductImages = (name, mainImage) => {
          const nameLower = (name || '').toLowerCase();
          const alternates = [];

          if (nameLower.includes('tshirt') || nameLower.includes('t-shirt') || nameLower.includes('tee') || nameLower.includes('tank top')) {
            alternates.push('/assets/images/tshirt-1.png', '/assets/images/products/tshirt.png', '/assets/images/polo-dark.png');
          } else if (nameLower.includes('polo') || nameLower.includes('shirt') || nameLower.includes('blouse')) {
            alternates.push('/assets/images/polo-dark.png', '/assets/images/shirt-cat-men.png', '/assets/images/products/tshirt.png');
          } else if (nameLower.includes('hoodie') || nameLower.includes('cardigan') || nameLower.includes('jacket') || nameLower.includes('trench') || nameLower.includes('coat')) {
            alternates.push('/assets/images/products/hoodie.png', '/assets/images/products/cardigan.png', '/assets/images/products/leatherjacket.png', '/assets/images/products/trenchcoat.png');
          } else if (nameLower.includes('pants') || nameLower.includes('shorts') || nameLower.includes('jeans') || nameLower.includes('sweatpants') || nameLower.includes('trouser') || nameLower.includes('skirt') || nameLower.includes('chinos')) {
            alternates.push('/assets/images/pants-cream.png', '/assets/images/products/sweatpants.png', '/assets/images/bottoms-cat-men.png');
          } else if (nameLower.includes('belt') || nameLower.includes('sunglasses') || nameLower.includes('necklace') || nameLower.includes('candle') || nameLower.includes('bag') || nameLower.includes('cap')) {
            alternates.push('/assets/images/products/belt.png', '/assets/images/products/sunglasses.png', '/assets/images/products/necklace.png', '/assets/images/products/candle.png');
          } else {
            alternates.push('/assets/images/tshirt-1.png', '/assets/images/polo-dark.png', '/assets/images/pants-cream.png', '/assets/images/shoes-white.png');
          }

          const all = [mainImage, ...alternates]
            .map(u => u ? u.trim() : '')
            .filter(Boolean);
          
          const unique = [...new Set(all)];
          return unique.slice(0, 3);
        };

        const initProductCardSliders = () => {
          const cards = document.querySelectorAll('.product-card-hover');
          cards.forEach(card => {
            if (card.dataset.sliderInitialized === 'true') return;
            if (card.id && card.id.startsWith('cart-item')) return;
            card.dataset.sliderInitialized = 'true';

            const img = card.querySelector('img');
            if (!img) return;

            const imgContainer = img.parentElement;
            if (!imgContainer) return;

            // Ensure container has relative styling
            imgContainer.classList.add('relative');

            const mainImage = img.getAttribute('src') || '';
            const name = (card.querySelector('h3')?.textContent || card.querySelector('[data-name]')?.getAttribute('data-name') || img.alt || '').trim();

            const images = getProductImages(name, mainImage);
            if (images.length <= 1) return;

            imgContainer.dataset.currentIndex = '0';

            // Create Left Arrow
            const prevBtn = document.createElement('button');
            prevBtn.className = 'absolute left-2.5 top-1/2 -translate-y-1/2 w-7 h-7 rounded-full bg-white/90 hover:bg-white text-brand-charcoal border border-gray-100 flex items-center justify-center shadow-sm z-30 cursor-pointer focus:outline-none select-none prev-img-btn';
            prevBtn.setAttribute('aria-label', 'Previous image');
            prevBtn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
              </svg>
            `;

            // Create Right Arrow
            const nextBtn = document.createElement('button');
            nextBtn.className = 'absolute right-2.5 top-1/2 -translate-y-1/2 w-7 h-7 rounded-full bg-white/90 hover:bg-white text-brand-charcoal border border-gray-100 flex items-center justify-center shadow-sm z-30 cursor-pointer focus:outline-none select-none next-img-btn';
            nextBtn.setAttribute('aria-label', 'Next image');
            nextBtn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
              </svg>
            `;

            // Create Dot Indicators
            const dotsContainer = document.createElement('div');
            dotsContainer.className = 'absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-30 dot-indicators-container';
            dotsContainer.innerHTML = images.map((_, i) => `
              <span class="w-1.5 h-1.5 rounded-full border border-white/50 transition-all ${i === 0 ? 'bg-brand-charcoal scale-110' : 'bg-white/60'}" data-index="${i}"></span>
            `).join('');

            // Append to container
            imgContainer.appendChild(prevBtn);
            imgContainer.appendChild(nextBtn);
            imgContainer.appendChild(dotsContainer);

            const updateImage = (index) => {
              img.src = clientResolveImage(images[index]);
              imgContainer.dataset.currentIndex = String(index);
              
              const dots = dotsContainer.querySelectorAll('span');
              dots.forEach((dot, i) => {
                if (i === index) {
                  dot.className = 'w-1.5 h-1.5 rounded-full border border-white/50 transition-all bg-brand-charcoal scale-110';
                } else {
                  dot.className = 'w-1.5 h-1.5 rounded-full border border-white/50 transition-all bg-white/60';
                }
              });
            };

            // Event listeners with click event isolation
            prevBtn.addEventListener('click', (e) => {
              e.preventDefault();
              e.stopPropagation();
              let index = parseInt(imgContainer.dataset.currentIndex || '0', 10);
              index = (index - 1 + images.length) % images.length;
              updateImage(index);
            });

            nextBtn.addEventListener('click', (e) => {
              e.preventDefault();
              e.stopPropagation();
              let index = parseInt(imgContainer.dataset.currentIndex || '0', 10);
              index = (index + 1) % images.length;
              updateImage(index);
            });
          });
        };

        // Initialize on DOM load
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initProductCardSliders);
        } else {
          initProductCardSliders();
        }

        // Also watch for DOM changes (like live search popup adding new product elements)
        const observer = new MutationObserver((mutations) => {
          let hasNewCards = false;
          mutations.forEach(m => {
            if (m.addedNodes.length > 0) {
              hasNewCards = true;
            }
          });
          if (hasNewCards) {
            initProductCardSliders();
          }
        });
        observer.observe(document.body, { childList: true, subtree: true });
      })();
    </script>
  </body>
</html>
