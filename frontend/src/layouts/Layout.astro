---
import '../styles/global.css';
import { Search, Cart, Globe, XIcon, User, Heart } from '../components/common/icons';
import { getSession } from 'auth-astro/server';
import { useTranslations } from '../lib/translations';

interface Props {
  title: string;
  description?: string;
  showHeroHeader?: boolean;
  isAdminPanel?: boolean;
  pendingOrdersCount?: number;
}

const { title, description = 'ACHI | Cool Every Day', showHeroHeader = false, isAdminPanel = false, pendingOrdersCount = 0 } = Astro.props;
const session = await getSession(Astro.request);
const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';
const t = useTranslations(lang);

const l = (path: string) => {
  if (path.startsWith('http') || path.startsWith('mailto:') || path.startsWith('tel:')) {
    return path;
  }
  const cleanPath = path.startsWith('/') ? path : `/${path}`;
  return `/${lang}${cleanPath === '/' ? '' : cleanPath}`;
};

const token = (session as any)?.accessToken || '';
let cartCount = 0;

if (token) {
  try {
    const res = await fetch('http://localhost:3001/api/cart', {
      headers: {
        'Authorization': `Bearer ${token}`
      }
    });
    if (res.ok) {
      const cartData = await res.json();
      cartCount = cartData.items?.reduce((sum: number, item: any) => sum + item.quantity, 0) || 0;
    }
  } catch (err) {
    console.error('[NestJS API Error] Fetching cart in Layout failed.', err);
  }
}

let categoriesList = [] as any[];
let tagsList = [] as any[];

try {
  const catRes = await fetch(`${BACKEND_URL}/api/products/categories`);
  if (catRes.ok) {
    categoriesList = await catRes.json();
  }
  const tagRes = await fetch(`${BACKEND_URL}/api/products/tags`);
  if (tagRes.ok) {
    tagsList = await tagRes.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching categories/tags in Layout.astro failed.', err);
}

// Fallback lists
const fallbackCategories = [
  { id: 1, slug: 'men', name: 'men' },
  { id: 2, slug: 'women', name: 'women' },
  { id: 3, slug: 'accessories', name: 'accessories' },
];

const fallbackTags = [
  { id: 1, slug: 'new', name: 'new' },
  { id: 2, slug: 'basics', name: 'basics' },
  { id: 3, slug: 'summer', name: 'summer' },
];

const displayCategories = categoriesList.length > 0
  ? categoriesList.map(c => ({
      id: c.id,
      slug: c.slug,
      nameEn: c.name.charAt(0).toUpperCase() + c.name.slice(1),
      nameTh: c.name === 'men' ? 'ผู้ชาย' : c.name === 'women' ? 'ผู้หญิง' : c.name === 'accessories' ? 'เครื่องประดับ' : c.name
    }))
  : fallbackCategories.map(c => ({
      id: c.id,
      slug: c.slug,
      nameEn: c.name.charAt(0).toUpperCase() + c.name.slice(1),
      nameTh: c.name === 'men' ? 'ผู้ชาย' : c.name === 'women' ? 'ผู้หญิง' : c.name === 'accessories' ? 'เครื่องประดับ' : c.name
    }));

const displayTags = tagsList.length > 0
  ? tagsList.map(t => ({
      id: t.id,
      slug: t.slug,
      nameEn: t.name.charAt(0).toUpperCase() + t.name.slice(1),
      nameTh: t.name === 'summer' ? 'ฤดูร้อน' : t.name === 'basics' ? 'เบสิก' : t.name === 'new' ? 'ใหม่' : t.name
    }))
  : fallbackTags.map(t => ({
      id: t.id,
      slug: t.slug,
      nameEn: t.name.charAt(0).toUpperCase() + t.name.slice(1),
      nameTh: t.name === 'summer' ? 'ฤดูร้อน' : t.name === 'basics' ? 'เบสิก' : t.name === 'new' ? 'ใหม่' : t.name
    }));

const pathname = Astro.url.pathname;
const urlParams = Astro.url.searchParams;
const tabParam = urlParams.get('tab');

let resolvedActiveTab = 'heroes';
if (pathname.includes('/admin/products') || pathname.includes('/admin/new-arrival-sets')) {
  resolvedActiveTab = 'products';
} else if (pathname.includes('/admin/collections')) {
  resolvedActiveTab = 'collections';
} else if (pathname.includes('/admin/blogs')) {
  resolvedActiveTab = 'blogs';
} else if (pathname.includes('/admin/orders')) {
  resolvedActiveTab = 'orders';
} else if (pathname.includes('/admin/faqs')) {
  resolvedActiveTab = 'faqs';
} else if (pathname.includes('/admin/contacts')) {
  resolvedActiveTab = 'contacts';
} else if (tabParam) {
  resolvedActiveTab = tabParam;
}
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Google Fonts for Figma Typography matching Outfit & Playfair -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <title>{title}</title>
    <style is:global>
      /* Force Outfit font globally for a unified minimal aesthetic */
      *, *::before, *::after {
        font-family: 'Outfit', sans-serif !important;
      }

      /* Apps Navigation Drawer Styles */
      #apps-nav-drawer {
        position: fixed;
        top: 0;
        right: -320px;
        width: 320px;
        height: 100vh;
        background-color: white;
        z-index: 50;
        padding: 24px;
        box-shadow: -5px 0 30px rgba(0,0,0,0.15);
        overflow-y: auto;
        transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        display: flex;
        flex-direction: column;
      }
      #apps-nav-drawer.open {
        right: 0;
      }
      #apps-drawer-backdrop.open {
        opacity: 1;
        pointer-events: auto;
      }
      body.apps-drawer-open {
        overflow: hidden;
      }

      /* Mobile Nav Drawer Styles */
      #mobile-nav-drawer {
        position: fixed;
        top: 0;
        left: -320px;
        width: 320px;
        height: 100vh;
        background-color: white;
        z-index: 50;
        padding: 24px;
        box-shadow: 5px 0 30px rgba(0,0,0,0.15);
        overflow-y: auto;
        transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        display: flex;
        flex-direction: column;
      }
      #mobile-nav-drawer.open {
        left: 0;
      }
      #mobile-nav-backdrop.open {
        opacity: 1;
        pointer-events: auto;
      }
      body.nav-drawer-open {
        overflow: hidden;
      }

      /* Global details dropdown slide-down animation */
      details[open] > summary ~ * {
        animation: details-sweep 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }

      @keyframes details-sweep {
        0% {
          opacity: 0;
          transform: translateY(-10px);
        }
        100% {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* Initial state for Motion scroll/load animations */
      .motion-title,
      .motion-desc,
      .motion-item {
        opacity: 0;
      }

      #shop-mega-menu {
        transform: translateY(-20px);
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.35s ease, visibility 0.4s;
      }
      #shop-mega-menu.open {
        transform: translateY(0);
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
      }
      #mega-menu-backdrop {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: opacity 0.3s ease, visibility 0.3s;
      }
      #mega-menu-backdrop.open {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
      }

      #shop-mega-menu a {
        color: #1c1917 !important; /* text-brand-charcoal (black) */
        transition: color 0.2s ease-in-out;
      }
      #shop-mega-menu a:hover {
        color: #a8a29e !important; /* text-stone-400 (grey) */
      }
      #shop-mega-menu a.active {
        color: #a8a29e !important; /* active link is grey */
      }
      
      /* Underline for active main nav links and buttons */
      header nav a,
      header nav button#shop-menu-btn {
        border-bottom: 2px solid transparent;
        padding-bottom: 4px;
        transition: border-color 0.3s ease-in-out, opacity 0.2s ease-in-out;
      }
      
      header nav a.active,
      header nav button.active {
        border-bottom-color: currentColor !important;
      }
      
      /* Typography reset to ensure buttons look exactly like neighboring links */
      #shop-menu-btn,
      header nav button {
        font-family: 'Outfit', sans-serif !important;
        font-weight: 300 !important; /* Outfit-light font weight */
        color: inherit;
      }

      /* Admin tab buttons active and hover state overrides */
      header nav button[id^="nav-tab-"],
      header nav a[id^="nav-tab-"] {
        border-bottom: 2px solid transparent;
        padding-bottom: 4px;
        transition: border-color 0.3s ease-in-out, color 0.3s ease-in-out;
      }
      header nav button[id^="nav-tab-"].active,
      header nav a[id^="nav-tab-"].active {
        border-bottom-color: #1c1917 !important; /* text-brand-charcoal */
        color: #1c1917 !important;
        font-weight: 600 !important;
      }
      header nav button[id^="nav-tab-"]:not(.active),
      header nav a[id^="nav-tab-"]:not(.active) {
        border-bottom-color: transparent !important;
        color: #a8a29e !important; /* text-stone-400 / text-gray-400 */
        font-weight: 300 !important;
      }
      header nav button[id^="nav-tab-"]:not(.active):hover,
      header nav a[id^="nav-tab-"]:not(.active):hover {
        color: #1c1917 !important;
      }

      /* Favorites active state styling */
      [data-favorite-btn].is-favorite {
        color: #1c1917 !important; /* brand-charcoal */
      }
      [data-favorite-btn].is-favorite svg {
        fill: #1c1917 !important;
        stroke: #1c1917 !important;
      }

      /* Product Card Slider Overrides */
      .prev-img-btn, .next-img-btn {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease-in-out;
      }
      .dot-indicators-container {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease-in-out, transform 0.2s ease-in-out;
      }
      .product-card-hover:hover .prev-img-btn,
      .product-card-hover:hover .next-img-btn,
      .product-card-hover:hover .dot-indicators-container {
        opacity: 1;
        pointer-events: auto;
      }
    </style>
    <script is:inline set:html={`
      window.currentLang = "${lang}";
      window.productTranslations = {
        "generic shirt": "เสื้อเชิ้ตดีไซน์คลาสสิก",
        "generic watch": "นาฬิกาข้อมือมินิมอล",
        "generic pants": "กางเกงสแล็กทรงสลิม",
        "generic shoes": "รองเท้าผ้าใบสีขาวพรีเมียม",
        "generic t-shirt 1": "เสื้อยืดคอกลมมินิมอล 1",
        "generic t-shirt 2": "เสื้อโปโลผ้าทอลาย 2",
        "generic t-shirt 3": "กางเกงชิโน่ขาเต่อ 3",
        "generic t-shirt 4": "รองเท้าคลาสสิกสนีกเกอร์ 4",
        "generic set 1": "ชุดเซ็ตเสื้อผ้าเข้าชุด 1",
        "generic set 2": "ชุดเซ็ตเสื้อผ้าเข้าชุด 2",
        "generic set 3": "ชุดเซ็ตเสื้อผ้าเข้าชุด 3"
      };
      window.translateProductName = function(name, currentLang) {
        if (!name) return name;
        if (currentLang === 'th') {
          const key = name.toLowerCase().trim();
          return window.productTranslations[key] || name;
        }
        return name.replace(/\\b\\w/g, function(c) { return c.toUpperCase(); });
      };
    `} />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-brand-charcoal font-sans">
    {isAdminPanel ? (
      <div class="min-h-screen w-full flex flex-col md:flex-row bg-[#f8fafc] text-slate-800 font-sans">
        <!-- Sidebar on the left -->
        <aside id="admin-sidebar" class="fixed inset-y-0 left-0 z-50 w-64 bg-slate-900 text-slate-200 transform -translate-x-full md:translate-x-0 md:sticky md:top-0 md:h-screen transition-transform duration-300 ease-in-out flex flex-col border-r border-slate-800 shrink-0">
          <!-- Sidebar Header -->
          <div class="h-24 px-6 flex flex-col justify-center border-b border-slate-800">
            <a href={l('/')} class="font-serif text-2xl tracking-[0.2em] font-light leading-none text-white pl-[0.1em] decoration-transparent">A C H I</a>
            <div class="w-24 border-t border-slate-700 my-1.5 opacity-30"></div>
            <span class="text-[9px] tracking-[0.3em] uppercase text-slate-400 font-light block leading-none pl-[0.1em]">{lang === 'en' ? 'STUDIO ADMIN' : 'ผู้ดูแลระบบ'}</span>
          </div>

          <!-- Sidebar Navigation -->
          <nav class="flex-grow px-4 py-6 space-y-1.5 overflow-y-auto">
            <!-- Dashboard Tab -->
            <a 
              href={l('/admin')} 
              id="nav-tab-dashboard" 
              class={`flex items-center gap-3.5 px-4 py-3 rounded-lg text-xs uppercase tracking-wider font-medium transition-all duration-200 decoration-transparent ${
                resolvedActiveTab === 'dashboard' 
                  ? 'bg-white/10 text-white font-semibold active' 
                  : 'text-slate-400 hover:bg-white/5 hover:text-white'
              }`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
              <span>{t('nav.dashboard')}</span>
            </a>

            <!-- Orders Tab -->
            <a 
              href={l('/admin?tab=orders')} 
              id="nav-tab-orders" 
              class={`flex items-center justify-between px-4 py-3 rounded-lg text-xs uppercase tracking-wider font-medium transition-all duration-200 decoration-transparent ${
                resolvedActiveTab === 'orders' 
                  ? 'bg-white/10 text-white font-semibold active' 
                  : 'text-slate-400 hover:bg-white/5 hover:text-white'
              }`}
            >
              <div class="flex items-center gap-3.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
                <span>{t('nav.orders')}</span>
              </div>
              <span id="nav-orders-badge" class={`inline-flex items-center justify-center bg-red-500 text-white text-[9px] font-bold min-w-[18px] h-[18px] px-1.5 rounded-full ${pendingOrdersCount > 0 ? '' : 'hidden'}`}>
                {pendingOrdersCount}
              </span>
            </a>

            <!-- Products Tab -->
            <a 
              href={l('/admin?tab=products')} 
              id="nav-tab-products" 
              class={`flex items-center gap-3.5 px-4 py-3 rounded-lg text-xs uppercase tracking-wider font-medium transition-all duration-200 decoration-transparent ${
                resolvedActiveTab === 'products' 
                  ? 'bg-white/10 text-white font-semibold active' 
                  : 'text-slate-400 hover:bg-white/5 hover:text-white'
              }`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
              <span>{t('nav.products')}</span>
            </a>

            <!-- Collections Tab -->
            <a 
              href={l('/admin?tab=collections')} 
              id="nav-tab-collections" 
              class={`flex items-center gap-3.5 px-4 py-3 rounded-lg text-xs uppercase tracking-wider font-medium transition-all duration-200 decoration-transparent ${
                resolvedActiveTab === 'collections' 
                  ? 'bg-white/10 text-white font-semibold active' 
                  : 'text-slate-400 hover:bg-white/5 hover:text-white'
              }`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
              <span>{t('nav.collections')}</span>
            </a>

            <!-- Blogs Tab -->
            <a 
              href={l('/admin?tab=blogs')} 
              id="nav-tab-blogs" 
              class={`flex items-center gap-3.5 px-4 py-3 rounded-lg text-xs uppercase tracking-wider font-medium transition-all duration-200 decoration-transparent ${
                resolvedActiveTab === 'blogs' 
                  ? 'bg-white/10 text-white font-semibold active' 
                  : 'text-slate-400 hover:bg-white/5 hover:text-white'
              }`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
              <span>{t('nav.blogs')}</span>
            </a>

            <!-- Contacts Tab -->
            <a 
              href={l('/admin?tab=contacts')} 
              id="nav-tab-contacts" 
              class={`flex items-center gap-3.5 px-4 py-3 rounded-lg text-xs uppercase tracking-wider font-medium transition-all duration-200 decoration-transparent ${
                resolvedActiveTab === 'contacts' 
                  ? 'bg-white/10 text-white font-semibold active' 
                  : 'text-slate-400 hover:bg-white/5 hover:text-white'
              }`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
              <span>{t('nav.contacts')}</span>
            </a>

            <!-- FAQs Tab -->
            <a 
              href={l('/admin?tab=faqs')} 
              id="nav-tab-faqs" 
              class={`flex items-center gap-3.5 px-4 py-3 rounded-lg text-xs uppercase tracking-wider font-medium transition-all duration-200 decoration-transparent ${
                resolvedActiveTab === 'faqs' 
                  ? 'bg-white/10 text-white font-semibold active' 
                  : 'text-slate-400 hover:bg-white/5 hover:text-white'
              }`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{t('nav.faqs')}</span>
            </a>

            <!-- Hero Banners Tab -->
            <a 
              href={l('/admin?tab=heroes')} 
              id="nav-tab-heroes" 
              class={`flex items-center gap-3.5 px-4 py-3 rounded-lg text-xs uppercase tracking-wider font-medium transition-all duration-200 decoration-transparent ${
                resolvedActiveTab === 'heroes' 
                  ? 'bg-white/10 text-white font-semibold active' 
                  : 'text-slate-400 hover:bg-white/5 hover:text-white'
              }`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span>{t('nav.heroes')}</span>
            </a>
          </nav>

          <!-- Sidebar Footer with Logout -->
          <div class="p-4 border-t border-slate-800">
            <button
              id="sidebar-signout-btn"
              class="w-full flex items-center justify-center gap-2 border border-slate-700 text-slate-300 hover:bg-white/5 hover:text-white px-4 py-2.5 rounded-lg text-xs uppercase tracking-widest font-semibold transition-all duration-200 cursor-pointer"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
              <span>{t('admin.signout')}</span>
            </button>
          </div>
        </aside>

        <!-- Sidebar mobile overlay backdrop -->
        <div id="admin-sidebar-backdrop" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-40 hidden md:hidden"></div>

        <!-- Main Workspace -->
        <div class="flex-grow flex flex-col min-w-0">
          <!-- Top Dashboard Header -->
          <header class="h-24 bg-white border-b border-slate-200/60 px-6 flex items-center justify-between sticky top-0 z-30 shadow-sm/50">
            <div class="flex items-center gap-4">
              <!-- Mobile menu hamburger toggle -->
