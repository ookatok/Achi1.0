                      <ul class="space-y-3 text-[11px] tracking-widest text-gray-500 font-light uppercase">
                        <li><a href={l('/products/new-arrivals')} class="hover:text-brand-gold">{t('nav.new_arrivals')}</a></li>
                        <li><a href={l('/products/best-sellers')} class="hover:text-brand-gold">{t('menu.best_sellers')}</a></li>
                        <li><a href={l('/products/trending')} class="hover:text-brand-gold">{t('menu.trending')}</a></li>
                        <li><a href={l('/discount')} class="hover:text-brand-gold">{t('nav.discount')}</a></li>
                      </ul>
                    </div>

                    <!-- Column 5: Collections -->
                    <div>
                      <h4 class="font-medium text-gray-400 text-[11px] uppercase tracking-wider mb-4 border-b border-gray-100 pb-2">{t('menu.collections')}</h4>
                      <ul class="space-y-3 text-[11px] tracking-widest text-gray-500 font-light uppercase">
                        <li><a href={l('/collections')} class="hover:text-brand-gold">{t('menu.events')}</a></li>
                        <li><a href={l('/products/recommend')} class="hover:text-brand-gold">{t('menu.recommend')}</a></li>
                        <li><a href={l('/products/total-looks')} class="hover:text-brand-gold">{t('menu.total_looks')}</a></li>
                        <li><a href={l('/products/basics')} class="hover:text-brand-gold">{t('menu.basics')}</a></li>
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
              
              <a href={l('/collections')} class="hover:opacity-70 transition-opacity">{t('nav.collections')}</a>
              <a href={l('/blog')} class="hover:opacity-70 transition-opacity">{t('nav.blog')}</a>
              <a href={l('/contact')} class="hover:opacity-70 transition-opacity">{t('nav.contact')}</a>
            </>
          )}
        </nav>

        <!-- Right Side Icons -->
        <div class="flex items-center gap-6">
          <!-- Search Icon Button -->
          <button id="search-btn" class="hover:opacity-70 transition-opacity focus:outline-none cursor-pointer" aria-label="Search">
            <Search />
          </button>

          <!-- Favorite Icon Button -->
          <a href={l('/favorite')} class="hover:opacity-70 transition-opacity cursor-pointer relative" aria-label="Favorites" id="header-favorite-btn">
            <Heart />
