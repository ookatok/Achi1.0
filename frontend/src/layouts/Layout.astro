          </button>

          {session ? (
            <a href={l('/profile')} class="hover:opacity-70 transition-opacity cursor-pointer" aria-label="Profile">
              <User />
            </a>
          ) : (
            <a href={l('/auth/signin')} class="text-[11px] tracking-widest hover:opacity-70 transition-opacity uppercase font-light">{t('nav.signin')}</a>
          )}

          <!-- Close button -->
          <button id="close-search-btn" class="hover:opacity-70 transition-opacity focus:outline-none cursor-pointer ml-2" aria-label="Close Search">
            <XIcon class="w-6 h-6" />
          </button>
        </div>
      </div>

      <!-- Search Input Section -->
      <div class="flex-grow flex flex-col max-w-[800px] w-full mx-auto px-6 pt-16">
        <form action={l('/products')} method="GET" class="relative border-b border-gray-400 flex items-center py-4">
          <Search class="w-6 h-6 text-gray-400 mr-4" />
          <input
            type="text"
            name="query"
            placeholder={t('search.placeholder')}
            class="w-full bg-transparent text-xl font-light outline-none text-brand-charcoal placeholder-gray-400"
            autocomplete="off"
            id="search-input"
          />
          <button type="reset" id="clear-search-btn" class="text-gray-400 hover:text-brand-charcoal focus:outline-none hidden">
            <XIcon class="w-5 h-5" />
