    <!-- Client-side script to toggle search overlay and handle live search -->
    <script>
      const searchBtn = document.getElementById('search-btn');
      const closeSearchBtn = document.getElementById('close-search-btn');
      const searchOverlay = document.getElementById('search-overlay');
      const searchInput = document.getElementById('search-input') as HTMLInputElement;
      const clearSearchBtn = document.getElementById('clear-search-btn');

      const searchPreviewContainer = document.getElementById('search-preview-container');
      const searchPreviewResults = document.getElementById('search-preview-results');
      const searchPreviewEmpty = document.getElementById('search-preview-empty');
      const searchSuggestions = document.getElementById('search-suggestions');

      const resolveImage = (url: string) => {
        if (!url) return '/assets/images/placeholder-product.png';
        if (url.startsWith('http') || url.startsWith('data:')) return url;
        if (url.startsWith('/assets/uploads/')) {
          return url;
        }
        return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=3';
      };

      let debounceTimer: number;

      // Checkbox references
      const searchCatCheckboxes = document.querySelectorAll('input[name="search-category-checkbox"]');
      const searchTagCheckboxes = document.querySelectorAll('input[name="search-tag-checkbox"]');
      const filterToggleBtn = document.getElementById('search-filter-toggle-btn');
      const searchOverlayFilters = document.getElementById('search-overlay-filters');

      const clearSearchFilters = () => {
        searchCatCheckboxes.forEach((cb: any) => cb.checked = false);
        searchTagCheckboxes.forEach((cb: any) => cb.checked = false);
        if (searchOverlayFilters) {
          searchOverlayFilters.classList.add('hidden');
        }
        if (filterToggleBtn) {
          filterToggleBtn.classList.remove('text-brand-gold');
        }
      };

      // Toggle filter visibility
      if (filterToggleBtn && searchOverlayFilters) {
        filterToggleBtn.addEventListener('click', () => {
          const isHidden = searchOverlayFilters.classList.contains('hidden');
          if (isHidden) {
            searchOverlayFilters.classList.remove('hidden');
            filterToggleBtn.classList.add('text-brand-gold');
          } else {
            searchOverlayFilters.classList.add('hidden');
            filterToggleBtn.classList.remove('text-brand-gold');
          }
        });
      }

      const performSearch = async (query: string) => {
        const selectedCats: string[] = [];
        searchCatCheckboxes.forEach((cb: any) => {
          if (cb.checked) selectedCats.push(cb.value);
        });
        const selectedTgs: string[] = [];
        searchTagCheckboxes.forEach((cb: any) => {
          if (cb.checked) selectedTgs.push(cb.value);
        });

        if (!query.trim() && selectedCats.length === 0 && selectedTgs.length === 0) {
          if (searchPreviewContainer) searchPreviewContainer.classList.add('hidden');
          if (searchPreviewEmpty) searchPreviewEmpty.classList.add('hidden');
          if (searchSuggestions) searchSuggestions.classList.remove('hidden');
          if (searchPreviewResults) searchPreviewResults.innerHTML = '';
          return;
        }

        try {
          const params = new URLSearchParams();
          if (query.trim()) params.set('query', query);
          if (selectedCats.length > 0) params.set('categorySlug', selectedCats.join(','));
          if (selectedTgs.length > 0) params.set('tags', selectedTgs.join(','));

          const res = await fetch(`http://localhost:3001/api/products?${params.toString()}`);
          if (res.ok) {
            const products = await res.json();
            
            if (products.length > 0) {
              if (searchPreviewEmpty) searchPreviewEmpty.classList.add('hidden');
              if (searchSuggestions) searchSuggestions.classList.add('hidden');
              if (searchPreviewContainer) searchPreviewContainer.classList.remove('hidden');
              
              if (searchPreviewResults) {
                searchPreviewResults.innerHTML = products.map((product: any) => {
                  const price = isNaN(Number(product.price)) ? product.price : Number(product.price).toLocaleString();
                  const displayName = (window as any).translateProductName(product.name, (window as any).currentLang);
                  const isDiscounted = product.activeDiscountPercent > 0;
                  const discountBadgeHtml = isDiscounted ? `
                    <span class="absolute top-1 left-1 z-20 bg-red-600 text-white text-[7px] uppercase font-bold px-1 py-0.5 rounded-xs shadow-sm scale-95 origin-top-left">
                      -${product.activeDiscountPercent}%
                    </span>
                  ` : '';
                  const priceHtml = isDiscounted ? `
                    <div class="flex items-center gap-2 mt-1.5">
                      <span class="text-xs text-red-600 font-bold">$${(Number(product.price) * (1 - product.activeDiscountPercent / 100)).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>
                      <span class="text-[9px] text-gray-400 line-through font-light">$${price}</span>
                    </div>
                  ` : `
                    <span class="text-xs text-brand-gold font-medium mt-1.5 block">
                      $${price}
                    </span>
                  `;
                  return `
                    <div class="flex items-center gap-4 p-3 bg-gray-50/50 border border-gray-100 rounded-sm hover:border-brand-charcoal transition-all relative group">
                      <div class="w-16 h-16 bg-white border border-gray-100 flex items-center justify-center overflow-hidden shrink-0 rounded-sm relative">
                        ${discountBadgeHtml}
                        <img src="${resolveImage(product.imageUrl)}" alt="${displayName}" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
                      </div>
                      <div class="flex-grow">
                        <h5 class="text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight group-hover:text-brand-gold transition-colors">
                          ${displayName}
                        </h5>
                        ${priceHtml}
                      </div>
                      <a href="/${(window as any).currentLang}/products/${product.id}" class="absolute inset-0 z-10" aria-label="View Details"></a>
                    </div>
                  `;
                }).join('');
              }
            } else {
              if (searchPreviewContainer) searchPreviewContainer.classList.add('hidden');
              if (searchSuggestions) searchSuggestions.classList.add('hidden');
              if (searchPreviewEmpty) searchPreviewEmpty.classList.remove('hidden');
              if (searchPreviewResults) searchPreviewResults.innerHTML = '';
            }
          }
        } catch (e) {
          console.error('Failed to perform live search', e);
        }
      };

      // Listeners for checkbox filters
      const onFilterChange = () => {
        performSearch(searchInput.value);
      };
      searchCatCheckboxes.forEach(cb => cb.addEventListener('change', onFilterChange));
      searchTagCheckboxes.forEach(cb => cb.addEventListener('change', onFilterChange));

      if (searchBtn && searchOverlay) {
        searchBtn.addEventListener('click', () => {
          searchOverlay.classList.remove('hidden');
          document.body.style.overflow = 'hidden'; // Lock background scroll
          if (searchInput) {
            searchInput.value = '';
            clearSearchFilters();
            performSearch('');
            if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
            searchInput.focus();
          }
        });
      }

      if (closeSearchBtn && searchOverlay) {
        closeSearchBtn.addEventListener('click', () => {
          searchOverlay.classList.add('hidden');
          document.body.style.overflow = ''; // Unlock background scroll
          if (searchInput) {
            searchInput.value = '';
            clearSearchFilters();
            performSearch('');
            if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
          }
        });
      }

      const searchOverlayFocusBtn = document.getElementById('search-overlay-focus-btn');
      if (searchOverlayFocusBtn && searchInput) {
        searchOverlayFocusBtn.addEventListener('click', () => {
          searchInput.focus();
        });
      }

      if (searchInput) {
        searchInput.addEventListener('input', () => {
          clearTimeout(debounceTimer);
          
          const val = searchInput.value;
          if (val.length > 0) {
            if (clearSearchBtn) clearSearchBtn.classList.remove('hidden');
          } else {
            if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
          }

          debounceTimer = window.setTimeout(() => {
            performSearch(val);
          }, 250);
        });

        if (clearSearchBtn) {
          clearSearchBtn.addEventListener('click', () => {
            searchInput.value = '';
            clearSearchFilters();
            clearSearchBtn.classList.add('hidden');
            performSearch('');
            searchInput.focus();
          });
        }
      }
    </script>

    <!-- Client-side script for sticky header and shop mega menu transitions -->
    <script is:inline>
      const stickyHeader = document.querySelector('header');
      const isHeroHeader = stickyHeader?.getAttribute('data-hero') === 'true';
      const shopMenuBtn = document.getElementById('shop-menu-btn');
      const shopMegaMenu = document.getElementById('shop-mega-menu');

      const handleStickyScroll = () => {
        if (!stickyHeader) return;
        const isMenuOpen = shopMegaMenu && (shopMegaMenu.classList.contains('block') || !shopMegaMenu.classList.contains('hidden'));
        
        if (window.scrollY > 20 || isMenuOpen) {
          stickyHeader.classList.add('scrolled');
          if (isHeroHeader) {
            stickyHeader.classList.remove('bg-transparent', 'text-white', 'border-transparent');
            stickyHeader.classList.add('bg-white/90', 'text-brand-charcoal', 'border-gray-200/50', 'shadow-sm', 'backdrop-blur-md');
          } else {
            stickyHeader.classList.add('shadow-md');
          }
        } else {
          stickyHeader.classList.remove('scrolled');
          if (isHeroHeader) {
            stickyHeader.classList.add('bg-transparent', 'text-white', 'border-transparent');
            stickyHeader.classList.remove('bg-white/90', 'text-brand-charcoal', 'border-gray-200/50', 'shadow-sm', 'backdrop-blur-md');
          } else {
            stickyHeader.classList.remove('shadow-md');
          }
        }
      };

      if (stickyHeader) {
        window.addEventListener('scroll', handleStickyScroll);
        // Initial check in case of page reload when already scrolled down
        handleStickyScroll();
      }

      if (shopMenuBtn && shopMegaMenu) {
        const backdrop = document.getElementById('mega-menu-backdrop');

        shopMenuBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isHidden = shopMegaMenu.classList.contains('hidden');
          if (isHidden) {
            shopMegaMenu.classList.remove('hidden');
            shopMegaMenu.classList.add('block');
            if (backdrop) backdrop.classList.remove('hidden');
          } else {
            shopMegaMenu.classList.remove('block');
            shopMegaMenu.classList.add('hidden');
            if (backdrop) backdrop.classList.add('hidden');
          }
          handleStickyScroll();
        });

        // Close when clicking outside
        document.addEventListener('click', (e) => {
          if (shopMegaMenu && !shopMegaMenu.contains(e.target) && e.target !== shopMenuBtn) {
            shopMegaMenu.classList.remove('block');
            shopMegaMenu.classList.add('hidden');
            if (backdrop) backdrop.classList.add('hidden');
            handleStickyScroll();
          }
        });

        if (backdrop) {
          backdrop.addEventListener('click', () => {
            shopMegaMenu.classList.remove('block');
            shopMegaMenu.classList.add('hidden');
            backdrop.classList.add('hidden');
            handleStickyScroll();
          });
        }
      }
    </script>
    <!-- Client-side script to highlight active links and toggle clothing menu -->
    <script is:inline>
      const currentPathName = window.location.pathname + window.location.search;
      
      // 1. Highlight active sub-links in the mega menu
      document.querySelectorAll('#shop-mega-menu a').forEach(link => {
        const href = link.getAttribute('href');
        if (href) {
          // Normalize paths for matching
          const normalizedHref = href.endsWith('/') ? href.slice(0, -1) : href;
          const normalizedCurrent = currentPathName.endsWith('/') ? currentPathName.slice(0, -1) : currentPathName;
          
          if (normalizedCurrent === normalizedHref || (normalizedHref !== '' && normalizedHref !== '/products' && normalizedCurrent.startsWith(normalizedHref))) {
            link.classList.add('active');
          }
        }
      });

      // 2. Highlight active main navigation items (HOME, SHOP, New Arrivals, BLOG)
      const mainLinks = document.querySelectorAll('header nav a, header nav button#shop-menu-btn');
      mainLinks.forEach(link => {
        const href = link.getAttribute('href');
        const id = link.getAttribute('id');
        const normalizedCurrent = currentPathName.endsWith('/') ? currentPathName.slice(0, -1) : currentPathName;

        if (id && id.startsWith('nav-tab-')) {
          // Skip admin navigation tabs to handle them precisely below
          return;
        }

        if (id === 'shop-menu-btn') {
          // Active if pathname starts with /products
          if (window.location.pathname.startsWith('/products')) {
            link.classList.add('active');
          }
        } else if (href) {
          const normalizedHref = href.endsWith('/') ? href.slice(0, -1) : href;
          const isHomeLink = normalizedHref === '/en' || normalizedHref === '/th' || normalizedHref === '';
          if (isHomeLink) {
            if (normalizedCurrent === '/en' || normalizedCurrent === '/th' || normalizedCurrent === '') {
              link.classList.add('active');
            }
          } else if (normalizedCurrent.startsWith(normalizedHref)) {
            link.classList.add('active');
          }
        }
      });

      // 2b. Highlight active Admin Panel tabs precisely (DASHBOARD, ORDERS, PRODUCTS, COLLECTIONS, BLOGS, CONTACTS)
      if (window.location.pathname.includes('/admin')) {
        let activeTab = 'dashboard';
        const path = window.location.pathname;
        const urlParams = new URLSearchParams(window.location.search);
        const tabParam = urlParams.get('tab');

        if (path.includes('/admin/products') || path.includes('/admin/new-arrival-sets')) {
          activeTab = 'products';
        } else if (path.includes('/admin/collections')) {
          activeTab = 'collections';
        } else if (path.includes('/admin/blogs')) {
          activeTab = 'blogs';
        } else if (path.includes('/admin/orders')) {
          activeTab = 'orders';
        } else if (path.includes('/admin/faqs')) {
          activeTab = 'faqs';
        } else if (tabParam) {
          activeTab = tabParam;
        }

        const activeTabEl = document.getElementById(`nav-tab-${activeTab}`);
        if (activeTabEl) {
          activeTabEl.classList.add('active');
        }
      }

      // 3. Obsolete clothing subcategory toggle logic removed
    </script>

    <!-- Client-side script for Favorites Wishlist sync and click tracking -->
    <script is:inline define:vars={{ token, lang }}>
      (function() {
        const STORAGE_KEY = 'achi_favorites';

        const getFavorites = () => {
          if (!token) return [];
          try {
            const data = localStorage.getItem(STORAGE_KEY);
            return data ? JSON.parse(data) : [];
          } catch (e) {
            return [];
          }
        };

        const saveFavorites = (favs) => {
          if (!token) return;
          try {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(favs));
          } catch (e) {
            console.error('Failed to save favorites', e);
          }
        };

        const updateFavoriteBadge = (count) => {
          const badges = [document.getElementById('favorite-badge'), document.getElementById('search-favorite-badge')];
          badges.forEach(badge => {
            if (!badge) return;
            badge.textContent = count;
            if (count > 0) {
              badge.classList.remove('scale-0');
              badge.classList.add('scale-100');
            } else {
              badge.classList.remove('scale-100');
              badge.classList.add('scale-0');
            }
          });
        };

        const syncFavoriteButtons = () => {
          const favs = getFavorites();
          updateFavoriteBadge(favs.length);

          const favIds = new Set(favs.map(f => String(f.id)));
          
          document.querySelectorAll('[data-favorite-btn]').forEach(btn => {
            const id = btn.getAttribute('data-id');
            if (id && favIds.has(String(id))) {
              btn.classList.add('is-favorite');
            } else {
              btn.classList.remove('is-favorite');
            }
          });
        };

        const toggleFavorite = (product) => {
          if (!token) return;
          let favs = getFavorites();
          const index = favs.findIndex(f => String(f.id) === String(product.id));

          if (index > -1) {
            favs.splice(index, 1);
          } else {
            favs.push(product);
          }

          saveFavorites(favs);
          syncFavoriteButtons();

          // Dispatch a custom event so the favorite page or other elements can react if they want
          window.dispatchEvent(new CustomEvent('achi-favorites-updated', { detail: favs }));
        };

        // Initialize and bind click handlers
        const initFavorites = () => {
          syncFavoriteButtons();

          // Global click event listener for event delegation
          document.addEventListener('click', (e) => {
            const btn = e.target.closest('[data-favorite-btn]');
            if (!btn) return;

            e.preventDefault();
            e.stopPropagation();

            // Require sign in
            if (!token) {
              const isEn = lang === 'en';
              if (window.showStatusAlert) {
                window.showStatusAlert(
                  401,
                  isEn ? 'Please sign in to add favorites.' : 'กรุณาเข้าสู่ระบบเพื่อบันทึกสินค้าที่ชอบ',
                  null,
                  false,
                  () => {
                    window.location.href = `/${lang}/auth/signin`;
                  }
                );
              } else {
                alert(isEn ? 'Please sign in to add favorites.' : 'กรุณาเข้าสู่ระบบเพื่อบันทึกสินค้าที่ชอบ');
                window.location.href = `/${lang}/auth/signin`;
              }
              return;
            }

            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name') || '';
            const price = btn.getAttribute('data-price') || '';
            const imageUrl = btn.getAttribute('data-image') || '';
            const activeDiscountPercent = parseInt(btn.getAttribute('data-discount') || '0', 10);

            if (id) {
              toggleFavorite({ id, name, price, imageUrl, activeDiscountPercent });
            }
          });
        };

        // Run on DOMContentLoaded or immediately if already loaded
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initFavorites);
        } else {
          initFavorites();
        }

        // Expose to window so other pages can easily check/manipulate if needed
        window.achiFavorites = {
          get: getFavorites,
          toggle: toggleFavorite,
          sync: syncFavoriteButtons
        };
      })();
    </script>

    <!-- Client-side script for Language Selector Toggle -->
    <script is:inline>
      document.querySelectorAll('.language-selector-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const pathname = window.location.pathname;
          let newPath = pathname;
          let newLang = 'th';

          if (pathname.startsWith('/th/')) {
            newPath = '/en/' + pathname.slice(4);
            newLang = 'en';
          } else if (pathname === '/th') {
            newPath = '/en';
            newLang = 'en';
          } else if (pathname.startsWith('/en/')) {
            newPath = '/th/' + pathname.slice(4);
            newLang = 'th';
          } else if (pathname === '/en') {
            newPath = '/th';
            newLang = 'th';
          } else {
            // Fallback if no prefix is present (should not happen normally due to middleware redirect)
            const cookies = document.cookie.split(';');
            let currentLang = 'th';
            for (let cookie of cookies) {
              const [name, value] = cookie.trim().split('=');
              if (name === 'lang') {
                currentLang = value;
                break;
              }
            }
            newLang = currentLang === 'en' ? 'th' : 'en';
            newPath = '/' + newLang + pathname;
          }

          // Update the cookie so the preference is stored
          document.cookie = `lang=${newLang};path=/;max-age=31536000;samesite=lax`;
          // Navigate to the new localized URL
          window.location.href = newPath + window.location.search + window.location.hash;
        });
      });
    </script>

    <!-- Client-side script for Cart Badge syncing -->
    <script is:inline define:vars={{ token }}>
      (function() {
        if (!token) return;

        const updateCartBadges = async () => {
          try {
            const res = await fetch('http://localhost:3001/api/cart', {
              headers: {
                'Authorization': `Bearer ${token}`
              }
            });
            if (res.ok) {
              const cartData = await res.json();
              const count = cartData.items?.reduce((sum, item) => sum + item.quantity, 0) || 0;
              
              const badges = [document.getElementById('cart-badge'), document.getElementById('search-cart-badge')];
              badges.forEach(badge => {
                if (!badge) return;
                badge.textContent = count;
                if (count > 0) {
                  badge.classList.remove('scale-0');
                  badge.classList.add('scale-100');
                } else {
                  badge.classList.remove('scale-100');
                  badge.classList.add('scale-0');
                }
              });
            }
          } catch (e) {
            console.error('Failed to update cart badge', e);
          }
        };

        // Listen for cart update event
        window.addEventListener('cart-updated', updateCartBadges);
      })();
    </script>

    <!-- Client-side script for Product Card Image Sliders (Dynamically loads real product images) -->
    <script is:inline>
      (function() {
        const initProductCardSliders = () => {
          const cards = document.querySelectorAll('.product-card-hover');
          cards.forEach(async (card) => {
            if (card.dataset.sliderInitialized === 'true') return;
            if (card.id && card.id.startsWith('cart-item')) return;
            
            // Get product ID from the favorite button dataset
            const favBtn = card.querySelector('[data-id]');
            const productId = favBtn ? favBtn.getAttribute('data-id') : null;
            if (!productId) return;

            // Mark as initialized immediately to prevent duplicate requests
            card.dataset.sliderInitialized = 'true';

            try {
              const res = await fetch(`http://localhost:3001/api/products/${productId}`);
              if (!res.ok) return;
              const product = await res.json();

              const mainImage = product.imageUrl || '';
              let alternateImages = [];
              if (product.images) {
                let parsedImages = [];
                if (Array.isArray(product.images)) {
                  parsedImages = product.images;
                } else if (typeof product.images === 'string') {
                  try {
                    parsedImages = JSON.parse(product.images);
                  } catch (e) {
                    console.error('Error parsing product.images string', e);
                  }
                }
                if (Array.isArray(parsedImages)) {
                  alternateImages = parsedImages.map(imgItem => imgItem.imageUrl).filter(Boolean);
                }
              }

              // Combine main image with alternate color images
              const allImages = [mainImage, ...alternateImages];
              const uniqueImages = [...new Set(allImages)].map(u => {
                if (!u) return '';
                if (u.startsWith('http') || u.startsWith('data:')) return u;
                if (u.startsWith('/assets/uploads/')) {
                  return `http://localhost:3001${u}`;
                }
                return u;
              }).filter(Boolean);

              // Only initialize slider if there is more than 1 image
              if (uniqueImages.length <= 1) return;

              const img = card.querySelector('img');
              if (!img) return;

              const imgContainer = img.parentElement;
              if (!imgContainer) return;

              imgContainer.classList.add('relative');
              imgContainer.dataset.currentIndex = '0';

              // Create Left Arrow
              const prevBtn = document.createElement('button');
              prevBtn.className = 'absolute left-2.5 top-1/2 -translate-y-1/2 w-7 h-7 rounded-full bg-white/90 hover:bg-white text-brand-charcoal border border-gray-100 flex items-center justify-center shadow-sm z-30 cursor-pointer focus:outline-none select-none prev-img-btn';
              prevBtn.setAttribute('aria-label', 'Previous image');
              prevBtn.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
                </svg>
              `;

              // Create Right Arrow
              const nextBtn = document.createElement('button');
              nextBtn.className = 'absolute right-2.5 top-1/2 -translate-y-1/2 w-7 h-7 rounded-full bg-white/90 hover:bg-white text-brand-charcoal border border-gray-100 flex items-center justify-center shadow-sm z-30 cursor-pointer focus:outline-none select-none next-img-btn';
              nextBtn.setAttribute('aria-label', 'Next image');
              nextBtn.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                </svg>
              `;

              // Create Dot Indicators
              const dotsContainer = document.createElement('div');
              dotsContainer.className = 'absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-30 dot-indicators-container';
              dotsContainer.innerHTML = uniqueImages.map((_, i) => `
                <span class="w-1.5 h-1.5 rounded-full border border-white/50 transition-all ${i === 0 ? 'bg-brand-charcoal scale-110' : 'bg-white/60'}" data-index="${i}"></span>
              `).join('');

              // Append to container
              imgContainer.appendChild(prevBtn);
              imgContainer.appendChild(nextBtn);
              imgContainer.appendChild(dotsContainer);

              const updateImage = (index) => {
                img.src = uniqueImages[index];
                imgContainer.dataset.currentIndex = String(index);
                
                const dots = dotsContainer.querySelectorAll('span');
                dots.forEach((dot, i) => {
                  if (i === index) {
                    dot.className = 'w-1.5 h-1.5 rounded-full border border-white/50 transition-all bg-brand-charcoal scale-110';
                  } else {
                    dot.className = 'w-1.5 h-1.5 rounded-full border border-white/50 transition-all bg-white/60';
                  }
                });
              };

              // Event listeners with click event isolation
              prevBtn.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                let index = parseInt(imgContainer.dataset.currentIndex || '0', 10);
                index = (index - 1 + uniqueImages.length) % uniqueImages.length;
                updateImage(index);
              });

              nextBtn.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                let index = parseInt(imgContainer.dataset.currentIndex || '0', 10);
                index = (index + 1) % uniqueImages.length;
                updateImage(index);
              });
            } catch (err) {
              console.error('Failed to initialize dynamic slider for product', productId, err);
            }
          });
        };

        // Initialize on DOM load
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initProductCardSliders);
        } else {
          initProductCardSliders();
        }

        // Watch for DOM changes (like filter updates, new pages, etc.)
        const observer = new MutationObserver((mutations) => {
          let hasNewCards = false;
          mutations.forEach(m => {
            if (m.addedNodes.length > 0) {
              hasNewCards = true;
            }
          });
          if (hasNewCards) {
            initProductCardSliders();
          }
        });
        observer.observe(document.body, { childList: true, subtree: true });
      })();
    </script>

    <!-- Global Status Alert Modal -->
    <div id="status-alert-modal" class="fixed inset-0 bg-stone-900/40 backdrop-blur-xs z-[9999] flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
      <div class="bg-white border border-stone-200 shadow-xl max-w-sm w-full mx-4 rounded-sm p-6 transform scale-95 transition-transform duration-300 flex flex-col items-center text-center">
        <!-- Icon Container -->
        <div id="status-alert-icon-container" class="w-12 h-12 rounded-full flex items-center justify-center mb-4">
          <!-- Icon injected dynamically -->
        </div>
        <!-- Status Title -->
        <h3 id="status-alert-title" class="font-serif text-xs font-bold text-brand-charcoal mb-2 uppercase tracking-wider"></h3>
        <!-- Status Meaning/Friendly Message -->
        <p id="status-alert-friendly-msg" class="text-xs text-gray-500 font-light leading-relaxed mb-4"></p>
        <!-- Backend Message details (hidden if empty) -->
        <p id="status-alert-backend-details" class="text-[10px] text-gray-400 font-mono bg-stone-50 border border-stone-100 p-2.5 rounded-sm w-full text-left hidden overflow-x-auto max-h-24"></p>
        <!-- OK Button -->
        <button id="status-alert-ok-btn" type="button" class="w-full bg-brand-charcoal hover:bg-stone-800 text-white font-semibold text-[10px] tracking-widest uppercase py-3 rounded-sm transition-colors cursor-pointer mt-5 select-none focus:outline-none">
          {lang === 'en' ? 'OK' : 'ตกลง'}
        </button>
      </div>
    </div>

    <!-- Script for status popup alert -->
    <script is:inline define:vars={{ lang }}>
      (function() {
        const modal = document.getElementById('status-alert-modal');
        const iconContainer = document.getElementById('status-alert-icon-container');
        const titleEl = document.getElementById('status-alert-title');
        const friendlyEl = document.getElementById('status-alert-friendly-msg');
        const detailsEl = document.getElementById('status-alert-backend-details');
        const okBtn = document.getElementById('status-alert-ok-btn');

        if (!modal || !iconContainer || !titleEl || !friendlyEl || !detailsEl || !okBtn) return;

        let closeCallback = null;

        const closeModal = () => {
          modal.classList.add('opacity-0');
          modal.querySelector('div').classList.add('scale-95');
          modal.querySelector('div').classList.remove('scale-100');
          setTimeout(() => {
            modal.classList.add('hidden');
            if (closeCallback) {
              closeCallback();
              closeCallback = null;
            }
          }, 300);
        };

        okBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
          if (e.target === modal) closeModal();
        });

        // Global status meaning database
        const getStatusMeaning = (status, isSuccess) => {
          if (isSuccess) {
            return {
              title: lang === 'en' ? 'Success' : 'ทำรายการสำเร็จ',
              friendly: lang === 'en' ? 'Your action has been completed successfully.' : 'การดำเนินการของคุณเสร็จสมบูรณ์เรียบร้อยแล้ว'
            };
          }

          let title = '';
          let friendly = '';

          switch (status) {
            case 400:
              title = lang === 'en' ? 'Status 400: Invalid Input' : 'สถานะ 400: ข้อมูลไม่ถูกต้อง';
              friendly = lang === 'en' 
                ? 'The server was unable to process the request due to invalid input fields. Please check your entries.' 
                : 'เซิร์ฟเวอร์ไม่สามารถประมวลผลได้เนื่องจากข้อมูลบางอย่างไม่ถูกต้อง กรุณาตรวจสอบข้อมูลที่กรอก';
              break;
            case 401:
              title = lang === 'en' ? 'Status 401: Unauthorized' : 'สถานะ 401: กรุณาเข้าสู่ระบบ';
              friendly = lang === 'en'
                ? 'Your session has expired or you are not signed in. Please sign in to proceed.'
                : 'เซสชันหมดอายุหรือคุณยังไม่ได้เข้าสู่ระบบ กรุณาเข้าสู่ระบบใหม่อีกครั้ง';
              break;
            case 403:
              title = lang === 'en' ? 'Status 403: Forbidden' : 'สถานะ 403: ไม่มีสิทธิ์เข้าถึง';
              friendly = lang === 'en'
                ? 'You do not have permission to perform this action. Admin rights are required.'
                : 'คุณไม่มีสิทธิ์เข้าถึงหรือดำเนินการในส่วนนี้ (จำเป็นต้องใช้สิทธิ์ผู้ดูแลระบบ)';
              break;
            case 404:
              title = lang === 'en' ? 'Status 404: Not Found' : 'สถานะ 404: ไม่พบข้อมูล';
              friendly = lang === 'en'
                ? 'The requested page or item could not be found on the server. It might have been deleted.'
                : 'ไม่พบข้อมูลหรือหน้าที่ต้องการบนเซิร์ฟเวอร์ ข้อมูลอาจถูกลบหรือไม่มีอยู่จริง';
              break;
            case 409:
              title = lang === 'en' ? 'Status 409: Conflict' : 'สถานะ 409: ข้อมูลซ้ำซ้อน';
              friendly = lang === 'en'
                ? 'A conflict occurred. The value you entered (e.g. email or web slug) already exists in the system.'
                : 'เกิดการขัดแย้งของข้อมูล ข้อมูลที่คุณกรอก (เช่น อีเมล หรือลิงก์สินค้า) มีอยู่ในระบบแล้ว';
              break;
            case 500:
              title = lang === 'en' ? 'Status 500: Server Error' : 'สถานะ 500: เซิร์ฟเวอร์ขัดข้อง';
              friendly = lang === 'en'
                ? 'An internal error occurred on the server side. Please contact support if this persists.'
                : 'เกิดข้อผิดพลาดขัดข้องภายในระบบเซิร์ฟเวอร์ กรุณาลองใหม่อีกครั้งในภายหลัง';
              break;
            case 502:
            case 503:
            case 504:
              title = `Status ${status}: Service Offline`;
              title = lang === 'en' ? `Status ${status}: Service Offline` : `สถานะ ${status}: บริการออฟไลน์`;
              friendly = lang === 'en'
                ? 'The backend server is offline or under maintenance. Please try again later.'
                : 'เซิร์ฟเวอร์ขัดข้องชั่วคราวหรือปิดเพื่อปรับปรุงระบบ กรุณาตรวจสอบสถานะการเชื่อมต่อ';
              break;
            default:
              title = status ? `Status ${status}: Error` : (lang === 'en' ? 'Error occurred' : 'เกิดข้อผิดพลาด');
              friendly = lang === 'en'
                ? 'An unexpected network error occurred while connecting to the service.'
                : 'เกิดข้อผิดพลาดในการเชื่อมต่อเครือข่ายที่ไม่คาดคิด';
          }

          return { title, friendly };
        };

        // Attach global alert trigger to window
        window.showStatusAlert = (status, customFriendlyMsg, backendMsg, isSuccess = false, callback = null) => {
          closeCallback = callback;
          
          const meaning = getStatusMeaning(status, isSuccess);

          // Clear previous icon classes
          iconContainer.className = "w-12 h-12 rounded-full flex items-center justify-center mb-4";

          let iconHtml = '';
          if (isSuccess) {
            iconContainer.classList.add('bg-green-50', 'text-green-600', 'border', 'border-green-100');
            iconHtml = `
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
            `;
          } else {
            iconContainer.classList.add('bg-red-50', 'text-red-600', 'border', 'border-red-100');
            iconHtml = `
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
              </svg>
            `;
          }

          iconContainer.innerHTML = iconHtml;
          titleEl.textContent = meaning.title;
          friendlyEl.textContent = customFriendlyMsg || meaning.friendly;

          if (backendMsg) {
            detailsEl.textContent = Array.isArray(backendMsg) ? backendMsg.join(', ') : String(backendMsg);
            detailsEl.classList.remove('hidden');
          } else {
            detailsEl.classList.add('hidden');
          }

          // Open modal
          modal.classList.remove('hidden');
          modal.offsetHeight; // Force layout reflow
          modal.classList.remove('opacity-0');
          modal.querySelector('div').classList.remove('scale-95');
          modal.querySelector('div').classList.add('scale-100');
        };
      })();
    </script>
  </body>
</html>
