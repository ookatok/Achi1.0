    <!-- Script for status popup alert -->
    <script is:inline define:vars={{ lang }}>
      (function() {
        const modal = document.getElementById('status-alert-modal');
        const iconContainer = document.getElementById('status-alert-icon-container');
        const titleEl = document.getElementById('status-alert-title');
        const friendlyEl = document.getElementById('status-alert-friendly-msg');
        const detailsEl = document.getElementById('status-alert-backend-details');
        const okBtn = document.getElementById('status-alert-ok-btn');

        if (!modal || !iconContainer || !titleEl || !friendlyEl || !detailsEl || !okBtn) return;

        let closeCallback = null;

        const closeModal = () => {
          modal.classList.add('opacity-0');
          modal.querySelector('div').classList.add('scale-95');
          modal.querySelector('div').classList.remove('scale-100');
          setTimeout(() => {
            modal.classList.add('hidden');
            if (closeCallback) {
              closeCallback();
              closeCallback = null;
            }
          }, 300);
        };

        okBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
          if (e.target === modal) closeModal();
        });

        // Global status meaning database
        const getStatusMeaning = (status, isSuccess) => {
          if (isSuccess) {
            return {
              title: lang === 'en' ? 'Success' : 'ทำรายการสำเร็จ',
              friendly: lang === 'en' ? 'Your action has been completed successfully.' : 'การดำเนินการของคุณเสร็จสมบูรณ์เรียบร้อยแล้ว'
            };
          }

          let title = '';
          let friendly = '';

          switch (status) {
            case 400:
              title = lang === 'en' ? 'Status 400: Invalid Input' : 'สถานะ 400: ข้อมูลไม่ถูกต้อง';
              friendly = lang === 'en' 
                ? 'The server was unable to process the request due to invalid input fields. Please check your entries.' 
                : 'เซิร์ฟเวอร์ไม่สามารถประมวลผลได้เนื่องจากข้อมูลบางอย่างไม่ถูกต้อง กรุณาตรวจสอบข้อมูลที่กรอก';
              break;
            case 401:
              title = lang === 'en' ? 'Status 401: Unauthorized' : 'สถานะ 401: กรุณาเข้าสู่ระบบ';
              friendly = lang === 'en'
                ? 'Your session has expired or you are not signed in. Please sign in to proceed.'
                : 'เซสชันหมดอายุหรือคุณยังไม่ได้เข้าสู่ระบบ กรุณาเข้าสู่ระบบใหม่อีกครั้ง';
              break;
            case 403:
              title = lang === 'en' ? 'Status 403: Forbidden' : 'สถานะ 403: ไม่มีสิทธิ์เข้าถึง';
              friendly = lang === 'en'
                ? 'You do not have permission to perform this action. Admin rights are required.'
                : 'คุณไม่มีสิทธิ์เข้าถึงหรือดำเนินการในส่วนนี้ (จำเป็นต้องใช้สิทธิ์ผู้ดูแลระบบ)';
              break;
            case 404:
              title = lang === 'en' ? 'Status 404: Not Found' : 'สถานะ 404: ไม่พบข้อมูล';
              friendly = lang === 'en'
                ? 'The requested page or item could not be found on the server. It might have been deleted.'
                : 'ไม่พบข้อมูลหรือหน้าที่ต้องการบนเซิร์ฟเวอร์ ข้อมูลอาจถูกลบหรือไม่มีอยู่จริง';
              break;
            case 409:
              title = lang === 'en' ? 'Status 409: Conflict' : 'สถานะ 409: ข้อมูลซ้ำซ้อน';
              friendly = lang === 'en'
                ? 'A conflict occurred. The value you entered (e.g. email or web slug) already exists in the system.'
                : 'เกิดการขัดแย้งของข้อมูล ข้อมูลที่คุณกรอก (เช่น อีเมล หรือลิงก์สินค้า) มีอยู่ในระบบแล้ว';
              break;
            case 500:
              title = lang === 'en' ? 'Status 500: Server Error' : 'สถานะ 500: เซิร์ฟเวอร์ขัดข้อง';
              friendly = lang === 'en'
                ? 'An internal error occurred on the server side. Please contact support if this persists.'
                : 'เกิดข้อผิดพลาดขัดข้องภายในระบบเซิร์ฟเวอร์ กรุณาลองใหม่อีกครั้งในภายหลัง';
              break;
            case 502:
            case 503:
            case 504:
              title = `Status ${status}: Service Offline`;
              title = lang === 'en' ? `Status ${status}: Service Offline` : `สถานะ ${status}: บริการออฟไลน์`;
              friendly = lang === 'en'
                ? 'The backend server is offline or under maintenance. Please try again later.'
                : 'เซิร์ฟเวอร์ขัดข้องชั่วคราวหรือปิดเพื่อปรับปรุงระบบ กรุณาตรวจสอบสถานะการเชื่อมต่อ';
              break;
            default:
              title = status ? `Status ${status}: Error` : (lang === 'en' ? 'Error occurred' : 'เกิดข้อผิดพลาด');
              friendly = lang === 'en'
                ? 'An unexpected network error occurred while connecting to the service.'
                : 'เกิดข้อผิดพลาดในการเชื่อมต่อเครือข่ายที่ไม่คาดคิด';
          }

          return { title, friendly };
        };

        // Attach global alert trigger to window
        window.showStatusAlert = (status, customFriendlyMsg, backendMsg, isSuccess = false, callback = null) => {
          closeCallback = callback;
          
          const meaning = getStatusMeaning(status, isSuccess);

          // Clear previous icon classes
          iconContainer.className = "w-12 h-12 rounded-full flex items-center justify-center mb-4";

          let iconHtml = '';
          if (isSuccess) {
            iconContainer.classList.add('bg-green-50', 'text-green-600', 'border', 'border-green-100');
            iconHtml = `
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
            `;
          } else {
            iconContainer.classList.add('bg-red-50', 'text-red-600', 'border', 'border-red-100');
            iconHtml = `
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
              </svg>
            `;
          }

          iconContainer.innerHTML = iconHtml;
          titleEl.textContent = meaning.title;
          friendlyEl.textContent = customFriendlyMsg || meaning.friendly;

          if (backendMsg) {
            detailsEl.textContent = Array.isArray(backendMsg) ? backendMsg.join(', ') : String(backendMsg);
            detailsEl.classList.remove('hidden');
          } else {
            detailsEl.classList.add('hidden');
          }

          // Open modal
          modal.classList.remove('hidden');
          modal.offsetHeight; // Force layout reflow
          modal.classList.remove('opacity-0');
          modal.querySelector('div').classList.remove('scale-95');
          modal.querySelector('div').classList.add('scale-100');
        };
      })();
          // Admin Mobile Sidebar Toggle
      (function() {
        const toggleBtn = document.getElementById('admin-sidebar-toggle');
        const sidebar = document.getElementById('admin-sidebar');
        const backdrop = document.getElementById('admin-sidebar-backdrop');
        if (toggleBtn && sidebar && backdrop) {
          const toggleSidebar = () => {
            sidebar.classList.toggle('-translate-x-full');
            backdrop.classList.toggle('hidden');
          };
          toggleBtn.addEventListener('click', toggleSidebar);
          backdrop.addEventListener('click', toggleSidebar);
        }
      })();
    </script>
    <script>
    import { initPageReveal, initScrollReveal, initHeroScrollZoom } from "../lib/animations";

    try {
      initPageReveal();
      initScrollReveal();
      initHeroScrollZoom();
    } catch (err) {
      console.error('[Motion API Error] Global animations failed.', err);
    }
  </script>

  <script is:inline>
    (function() {
      // Mobile main menu toggle drawer script
      const mobileNavToggleBtn = document.getElementById('mobile-nav-toggle-btn');
      const mobileNavDrawer = document.getElementById('mobile-nav-drawer');
      const mobileNavCloseBtn = document.getElementById('mobile-nav-close-btn');
      const mobileNavBackdrop = document.getElementById('mobile-nav-backdrop');

      const openNavDrawer = () => {
        mobileNavDrawer?.classList.add('open');
        mobileNavBackdrop?.classList.add('open');
        document.body.classList.add('nav-drawer-open');
      };

      const closeNavDrawer = () => {
        mobileNavDrawer?.classList.remove('open');
        mobileNavBackdrop?.classList.remove('open');
        document.body.classList.remove('nav-drawer-open');
      };

      if (mobileNavToggleBtn) {
        mobileNavToggleBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          openNavDrawer();
        });
      }

      if (mobileNavCloseBtn) {
        mobileNavCloseBtn.addEventListener('click', closeNavDrawer);
      }

      if (mobileNavBackdrop) {
        mobileNavBackdrop.addEventListener('click', closeNavDrawer);
      }

      // Close mobile drawer on ESC key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeNavDrawer();
      });
    })();

    (function() {
      // Apps navigation menu toggle drawer script
      const appsNavToggleBtn = document.getElementById('apps-nav-toggle-btn');
      const appsNavDrawer = document.getElementById('apps-nav-drawer');
      const appsNavCloseBtn = document.getElementById('apps-nav-close-btn');
      const appsDrawerBackdrop = document.getElementById('apps-drawer-backdrop');

      const openAppsDrawer = () => {
        appsNavDrawer?.classList.add('open');
        appsDrawerBackdrop?.classList.add('open');
        document.body.classList.add('apps-drawer-open');
      };

      const closeAppsDrawer = () => {
        appsNavDrawer?.classList.remove('open');
        appsDrawerBackdrop?.classList.remove('open');
        document.body.classList.remove('apps-drawer-open');
      };

      if (appsNavToggleBtn) {
        appsNavToggleBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          openAppsDrawer();
        });
      }

      if (appsNavCloseBtn) {
        appsNavCloseBtn.addEventListener('click', closeAppsDrawer);
      }

      if (appsDrawerBackdrop) {
        appsDrawerBackdrop.addEventListener('click', closeAppsDrawer);
      }

      // Close mobile drawer on ESC key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeAppsDrawer();
      });
    })();
  </script>
  </body>
