    <!-- Client-side script to toggle search overlay and handle live search -->
    <script>
      const searchBtn = document.getElementById('search-btn');
      const closeSearchBtn = document.getElementById('close-search-btn');
      const searchOverlay = document.getElementById('search-overlay');
      const searchInput = document.getElementById('search-input') as HTMLInputElement;
      const clearSearchBtn = document.getElementById('clear-search-btn');

      const searchPreviewContainer = document.getElementById('search-preview-container');
      const searchPreviewResults = document.getElementById('search-preview-results');
      const searchPreviewEmpty = document.getElementById('search-preview-empty');
      const searchSuggestions = document.getElementById('search-suggestions');

      const resolveImage = (url: string) => {
        if (!url) return '/assets/images/placeholder-product.png';
        if (url.startsWith('http') || url.startsWith('data:')) return url;
        if (url.startsWith('/assets/uploads/')) {
          return url;
        }
        return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=3';
      };

      let debounceTimer: number;

      // Checkbox references
      const searchCatCheckboxes = document.querySelectorAll('input[name="search-category-checkbox"]');
      const searchTagCheckboxes = document.querySelectorAll('input[name="search-tag-checkbox"]');
      const filterToggleBtn = document.getElementById('search-filter-toggle-btn');
      const searchOverlayFilters = document.getElementById('search-overlay-filters');

      const clearSearchFilters = () => {
        searchCatCheckboxes.forEach((cb: any) => cb.checked = false);
        searchTagCheckboxes.forEach((cb: any) => cb.checked = false);
        if (searchOverlayFilters) {
          searchOverlayFilters.classList.add('hidden');
        }
        if (filterToggleBtn) {
          filterToggleBtn.classList.remove('text-brand-gold');
        }
      };

      // Toggle filter visibility
      if (filterToggleBtn && searchOverlayFilters) {
        filterToggleBtn.addEventListener('click', () => {
          const isHidden = searchOverlayFilters.classList.contains('hidden');
          if (isHidden) {
            searchOverlayFilters.classList.remove('hidden');
            filterToggleBtn.classList.add('text-brand-gold');
          } else {
            searchOverlayFilters.classList.add('hidden');
            filterToggleBtn.classList.remove('text-brand-gold');
          }
        });
      }

      const performSearch = async (query: string) => {
        const selectedCats: string[] = [];
        searchCatCheckboxes.forEach((cb: any) => {
          if (cb.checked) selectedCats.push(cb.value);
        });
        const selectedTgs: string[] = [];
        searchTagCheckboxes.forEach((cb: any) => {
          if (cb.checked) selectedTgs.push(cb.value);
        });

        if (!query.trim() && selectedCats.length === 0 && selectedTgs.length === 0) {
          if (searchPreviewContainer) searchPreviewContainer.classList.add('hidden');
          if (searchPreviewEmpty) searchPreviewEmpty.classList.add('hidden');
          if (searchSuggestions) searchSuggestions.classList.remove('hidden');
          if (searchPreviewResults) searchPreviewResults.innerHTML = '';
          return;
        }

        try {
          const params = new URLSearchParams();
          if (query.trim()) params.set('query', query);
          if (selectedCats.length > 0) params.set('categorySlug', selectedCats.join(','));
          if (selectedTgs.length > 0) params.set('tags', selectedTgs.join(','));

          const res = await fetch(`http://localhost:3001/api/products?${params.toString()}`);
          if (res.ok) {
            const products = await res.json();
            
            if (products.length > 0) {
              if (searchPreviewEmpty) searchPreviewEmpty.classList.add('hidden');
              if (searchSuggestions) searchSuggestions.classList.add('hidden');
              if (searchPreviewContainer) searchPreviewContainer.classList.remove('hidden');
              
              if (searchPreviewResults) {
                searchPreviewResults.innerHTML = products.map((product: any) => {
                  const price = isNaN(Number(product.price)) ? product.price : Number(product.price).toLocaleString();
                  const displayName = (window as any).translateProductName(product.name, (window as any).currentLang);
                  const isDiscounted = product.activeDiscountPercent > 0;
                  const discountBadgeHtml = isDiscounted ? `
                    <span class="absolute top-1 left-1 z-20 bg-red-600 text-white text-[7px] uppercase font-bold px-1 py-0.5 rounded-xs shadow-sm scale-95 origin-top-left">
                      -${product.activeDiscountPercent}%
                    </span>
                  ` : '';
                  const priceHtml = isDiscounted ? `
                    <div class="flex items-center gap-2 mt-1.5">
                      <span class="text-xs text-red-600 font-bold">$${(Number(product.price) * (1 - product.activeDiscountPercent / 100)).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>
                      <span class="text-[9px] text-gray-400 line-through font-light">$${price}</span>
                    </div>
                  ` : `
                    <span class="text-xs text-brand-gold font-medium mt-1.5 block">
                      $${price}
                    </span>
                  `;
                  return `
                    <div class="flex items-center gap-4 p-3 bg-gray-50/50 border border-gray-100 rounded-sm hover:border-brand-charcoal transition-all relative group">
                      <div class="w-16 h-16 bg-white border border-gray-100 flex items-center justify-center overflow-hidden shrink-0 rounded-sm relative">
                        ${discountBadgeHtml}
                        <img src="${resolveImage(product.imageUrl)}" alt="${displayName}" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
                      </div>
                      <div class="flex-grow">
                        <h5 class="text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight group-hover:text-brand-gold transition-colors">
                          ${displayName}
                        </h5>
                        ${priceHtml}
                      </div>
                      <a href="/${(window as any).currentLang}/products/${product.id}" class="absolute inset-0 z-10" aria-label="View Details"></a>
                    </div>
                  `;
                }).join('');
              }
            } else {
              if (searchPreviewContainer) searchPreviewContainer.classList.add('hidden');
              if (searchSuggestions) searchSuggestions.classList.add('hidden');
              if (searchPreviewEmpty) searchPreviewEmpty.classList.remove('hidden');
              if (searchPreviewResults) searchPreviewResults.innerHTML = '';
            }
          }
        } catch (e) {
          console.error('Failed to perform live search', e);
        }
      };

      // Listeners for checkbox filters
      const onFilterChange = () => {
        performSearch(searchInput.value);
      };
      searchCatCheckboxes.forEach(cb => cb.addEventListener('change', onFilterChange));
      searchTagCheckboxes.forEach(cb => cb.addEventListener('change', onFilterChange));

      if (searchBtn && searchOverlay) {
        searchBtn.addEventListener('click', () => {
          searchOverlay.classList.remove('hidden');
          document.body.style.overflow = 'hidden'; // Lock background scroll
          if (searchInput) {
            searchInput.value = '';
            clearSearchFilters();
            performSearch('');
            if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
            searchInput.focus();
          }
        });
      }

      if (closeSearchBtn && searchOverlay) {
        closeSearchBtn.addEventListener('click', () => {
          searchOverlay.classList.add('hidden');
          document.body.style.overflow = ''; // Unlock background scroll
          if (searchInput) {
            searchInput.value = '';
            clearSearchFilters();
            performSearch('');
            if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
          }
        });
      }

      const searchOverlayFocusBtn = document.getElementById('search-overlay-focus-btn');
      if (searchOverlayFocusBtn && searchInput) {
        searchOverlayFocusBtn.addEventListener('click', () => {
          searchInput.focus();
        });
      }

      if (searchInput) {
        searchInput.addEventListener('input', () => {
          clearTimeout(debounceTimer);
          
          const val = searchInput.value;
          if (val.length > 0) {
            if (clearSearchBtn) clearSearchBtn.classList.remove('hidden');
          } else {
            if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
          }

          debounceTimer = window.setTimeout(() => {
            performSearch(val);
          }, 250);
        });

        if (clearSearchBtn) {
          clearSearchBtn.addEventListener('click', () => {
            searchInput.value = '';
            clearSearchFilters();
            clearSearchBtn.classList.add('hidden');
            performSearch('');
            searchInput.focus();
          });
        }
      }
    </script>

    <!-- Client-side script for sticky header and shop mega menu transitions -->
    <script is:inline>
      const stickyHeader = document.querySelector('header');
      const isHeroHeader = stickyHeader?.getAttribute('data-hero') === 'true';
      const shopMenuBtn = document.getElementById('shop-menu-btn');
      const shopMegaMenu = document.getElementById('shop-mega-menu');

      const handleStickyScroll = () => {
        if (!stickyHeader) return;
        const isMenuOpen = shopMegaMenu && shopMegaMenu.classList.contains('open');
        
        if (window.scrollY > 20 || isMenuOpen) {
          stickyHeader.classList.add('scrolled');
          if (isHeroHeader) {
            stickyHeader.classList.remove('bg-transparent', 'text-white', 'border-transparent');
            stickyHeader.classList.add('bg-white/90', 'text-brand-charcoal', 'border-gray-200/50', 'shadow-sm', 'backdrop-blur-md');
          } else {
            stickyHeader.classList.add('shadow-md');
          }
        } else {
          stickyHeader.classList.remove('scrolled');
          if (isHeroHeader) {
            stickyHeader.classList.add('bg-transparent', 'text-white', 'border-transparent');
            stickyHeader.classList.remove('bg-white/90', 'text-brand-charcoal', 'border-gray-200/50', 'shadow-sm', 'backdrop-blur-md');
          } else {
            stickyHeader.classList.remove('shadow-md');
          }
        }
      };

      if (stickyHeader) {
        window.addEventListener('scroll', handleStickyScroll);
        // Initial check in case of page reload when already scrolled down
        handleStickyScroll();
      }

      if (shopMenuBtn && shopMegaMenu) {
        const backdrop = document.getElementById('mega-menu-backdrop');

        shopMenuBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = shopMegaMenu.classList.contains('open');
          if (!isOpen) {
            shopMegaMenu.classList.add('open');
            if (backdrop) backdrop.classList.add('open');
          } else {
            shopMegaMenu.classList.remove('open');
            if (backdrop) backdrop.classList.remove('open');
          }
          handleStickyScroll();
        });

        // Close when clicking outside
        document.addEventListener('click', (e) => {
          if (shopMegaMenu && !shopMegaMenu.contains(e.target) && e.target !== shopMenuBtn) {
            shopMegaMenu.classList.remove('open');
            if (backdrop) backdrop.classList.remove('open');
            handleStickyScroll();
          }
        });

        if (backdrop) {
          backdrop.addEventListener('click', () => {
            shopMegaMenu.classList.remove('open');
            backdrop.classList.remove('open');
            handleStickyScroll();
          });
        }
      }
    </script>
    <!-- Client-side script to highlight active links and toggle clothing menu -->
    <script is:inline>
      const currentPathName = window.location.pathname + window.location.search;
      
      // 1. Highlight active sub-links in the mega menu
      document.querySelectorAll('#shop-mega-menu a').forEach(link => {
        const href = link.getAttribute('href');
        if (href) {
          // Normalize paths for matching
          const normalizedHref = href.endsWith('/') ? href.slice(0, -1) : href;
          const normalizedCurrent = currentPathName.endsWith('/') ? currentPathName.slice(0, -1) : currentPathName;
          
          if (normalizedCurrent === normalizedHref || (normalizedHref !== '' && normalizedHref !== '/products' && normalizedCurrent.startsWith(normalizedHref))) {
            link.classList.add('active');
          }
        }
      });

      // 2. Highlight active main navigation items (HOME, SHOP, New Arrivals, BLOG)
      const mainLinks = document.querySelectorAll('header nav a, header nav button#shop-menu-btn');
      mainLinks.forEach(link => {
        const href = link.getAttribute('href');
        const id = link.getAttribute('id');
        const normalizedCurrent = currentPathName.endsWith('/') ? currentPathName.slice(0, -1) : currentPathName;

        if (id && id.startsWith('nav-tab-')) {
          // Skip admin navigation tabs to handle them precisely below
          return;
        }

        if (id === 'shop-menu-btn') {
          // Active if pathname starts with /products
          if (window.location.pathname.startsWith('/products')) {
            link.classList.add('active');
          }
        } else if (href) {
          const normalizedHref = href.endsWith('/') ? href.slice(0, -1) : href;
          const isHomeLink = normalizedHref === '/en' || normalizedHref === '/th' || normalizedHref === '';
          if (isHomeLink) {
            if (normalizedCurrent === '/en' || normalizedCurrent === '/th' || normalizedCurrent === '') {
              link.classList.add('active');
            }
          } else if (normalizedCurrent.startsWith(normalizedHref)) {
            link.classList.add('active');
          }
        }
      });

      // 2b. Highlight active Admin Panel tabs precisely (DASHBOARD, ORDERS, PRODUCTS, COLLECTIONS, BLOGS, CONTACTS)
      if (window.location.pathname.includes('/admin')) {
        let activeTab = 'dashboard';
        const path = window.location.pathname;
        const urlParams = new URLSearchParams(window.location.search);
        const tabParam = urlParams.get('tab');

        if (path.includes('/admin/products') || path.includes('/admin/new-arrival-sets')) {
          activeTab = 'products';
        } else if (path.includes('/admin/collections')) {
          activeTab = 'collections';
        } else if (path.includes('/admin/blogs')) {
          activeTab = 'blogs';
        } else if (path.includes('/admin/orders')) {
          activeTab = 'orders';
        } else if (path.includes('/admin/faqs')) {
          activeTab = 'faqs';
        } else if (tabParam) {
          activeTab = tabParam;
        }

        const activeTabEl = document.getElementById(`nav-tab-${activeTab}`);
        if (activeTabEl) {
          activeTabEl.classList.add('active');
        }
      }

      // 3. Obsolete clothing subcategory toggle logic removed
    </script>

    <!-- Client-side script for Favorites Wishlist sync and click tracking -->
    <script is:inline define:vars={{ token, lang }}>
      (function() {
        const STORAGE_KEY = 'achi_favorites';

        const getFavorites = () => {
          if (!token) return [];
          try {
            const data = localStorage.getItem(STORAGE_KEY);
            return data ? JSON.parse(data) : [];
          } catch (e) {
            return [];
          }
        };

        const saveFavorites = (favs) => {
          if (!token) return;
          try {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(favs));
          } catch (e) {
            console.error('Failed to save favorites', e);
          }
        };

        const updateFavoriteBadge = (count) => {
          const badges = [document.getElementById('favorite-badge'), document.getElementById('search-favorite-badge'), document.getElementById('apps-favorite-badge')];
          badges.forEach(badge => {
            if (!badge) return;
            badge.textContent = count;
            if (count > 0) {
              badge.classList.remove('scale-0');
              badge.classList.add('scale-100');
            } else {
              badge.classList.remove('scale-100');
              badge.classList.add('scale-0');
            }
          });
        };

        const syncFavoriteButtons = () => {
          const favs = getFavorites();
          updateFavoriteBadge(favs.length);

          const favIds = new Set(favs.map(f => String(f.id)));
          
          document.querySelectorAll('[data-favorite-btn]').forEach(btn => {
            const id = btn.getAttribute('data-id');
            if (id && favIds.has(String(id))) {
              btn.classList.add('is-favorite');
            } else {
              btn.classList.remove('is-favorite');
            }
          });
        };

        const toggleFavorite = (product) => {
          if (!token) return;
          let favs = getFavorites();
          const index = favs.findIndex(f => String(f.id) === String(product.id));

          if (index > -1) {
            favs.splice(index, 1);
          } else {
            favs.push(product);
          }

          saveFavorites(favs);
          syncFavoriteButtons();

          // Dispatch a custom event so the favorite page or other elements can react if they want
          window.dispatchEvent(new CustomEvent('achi-favorites-updated', { detail: favs }));
        };

        // Initialize and bind click handlers
        const initFavorites = () => {
          syncFavoriteButtons();

          // Global click event listener for event delegation
          document.addEventListener('click', (e) => {
            const btn = e.target.closest('[data-favorite-btn]');
            if (!btn) return;

            e.preventDefault();
            e.stopPropagation();

            // Require sign in
            if (!token) {
              const isEn = lang === 'en';
              if (window.showStatusAlert) {
                window.showStatusAlert(
                  401,
                  isEn ? 'Please sign in to add favorites.' : 'กรุณาเข้าสู่ระบบเพื่อบันทึกสินค้าที่ชอบ',
                  null,
                  false,
                  () => {
                    window.location.href = `/${lang}/auth/signin`;
                  }
                );
              } else {
                alert(isEn ? 'Please sign in to add favorites.' : 'กรุณาเข้าสู่ระบบเพื่อบันทึกสินค้าที่ชอบ');
                window.location.href = `/${lang}/auth/signin`;
              }
              return;
            }

            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name') || '';
            const price = btn.getAttribute('data-price') || '';
            const imageUrl = btn.getAttribute('data-image') || '';
            const activeDiscountPercent = parseInt(btn.getAttribute('data-discount') || '0', 10);

            if (id) {
              toggleFavorite({ id, name, price, imageUrl, activeDiscountPercent });
            }
          });
        };

        // Run on DOMContentLoaded or immediately if already loaded
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initFavorites);
        } else {
          initFavorites();
        }

        // Expose to window so other pages can easily check/manipulate if needed
        window.achiFavorites = {
          get: getFavorites,
          toggle: toggleFavorite,
          sync: syncFavoriteButtons
        };
      })();
    </script>

    <!-- Client-side script for Language Selector Toggle -->
    <script is:inline>
      document.querySelectorAll('.language-selector-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const pathname = window.location.pathname;
          let newPath = pathname;
          let newLang = 'th';

          if (pathname.startsWith('/th/')) {
            newPath = '/en/' + pathname.slice(4);
            newLang = 'en';
          } else if (pathname === '/th') {
            newPath = '/en';
            newLang = 'en';
          } else if (pathname.startsWith('/en/')) {
            newPath = '/th/' + pathname.slice(4);
            newLang = 'th';
          } else if (pathname === '/en') {
            newPath = '/th';
            newLang = 'th';
          } else {
            // Fallback if no prefix is present (should not happen normally due to middleware redirect)
            const cookies = document.cookie.split(';');
            let currentLang = 'th';
            for (let cookie of cookies) {
              const [name, value] = cookie.trim().split('=');
              if (name === 'lang') {
                currentLang = value;
                break;
              }
            }
            newLang = currentLang === 'en' ? 'th' : 'en';
            newPath = '/' + newLang + pathname;
          }

          // Update the cookie so the preference is stored
          document.cookie = `lang=${newLang};path=/;max-age=31536000;samesite=lax`;
          // Navigate to the new localized URL
          window.location.href = newPath + window.location.search + window.location.hash;
        });
      });
    </script>

