---
import '../styles/global.css';
import { Search, Cart, Globe, XIcon, User, Heart } from '../components/common/icons';
import { getSession } from 'auth-astro/server';
import { useTranslations } from '../lib/translations';

interface Props {
  title: string;
  description?: string;
  showHeroHeader?: boolean;
  isAdminPanel?: boolean;
  pendingOrdersCount?: number;
}

const { title, description = 'ACHI | Cool Every Day', showHeroHeader = false, isAdminPanel = false, pendingOrdersCount = 0 } = Astro.props;
const session = await getSession(Astro.request);
const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';
const t = useTranslations(lang);

const l = (path: string) => {
  if (path.startsWith('http') || path.startsWith('mailto:') || path.startsWith('tel:')) {
    return path;
  }
  const cleanPath = path.startsWith('/') ? path : `/${path}`;
  return `/${lang}${cleanPath === '/' ? '' : cleanPath}`;
};

const token = (session as any)?.accessToken || '';
let cartCount = 0;

if (token) {
  try {
    const res = await fetch('http://localhost:3001/api/cart', {
      headers: {
        'Authorization': `Bearer ${token}`
      }
    });
    if (res.ok) {
      const cartData = await res.json();
      cartCount = cartData.items?.reduce((sum: number, item: any) => sum + item.quantity, 0) || 0;
    }
  } catch (err) {
    console.error('[NestJS API Error] Fetching cart in Layout failed.', err);
  }
}
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Google Fonts for Figma Typography matching Outfit & Playfair -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <title>{title}</title>
    <style is:global>
      #shop-mega-menu a {
        color: #1c1917 !important; /* text-brand-charcoal (black) */
        transition: color 0.2s ease-in-out;
      }
      #shop-mega-menu a:hover {
        color: #a8a29e !important; /* text-stone-400 (grey) */
      }
      #shop-mega-menu a.active {
        color: #a8a29e !important; /* active link is grey */
      }
      
      /* Underline for active main nav links and buttons */
      header nav a,
      header nav button#shop-menu-btn {
        border-bottom: 2px solid transparent;
        padding-bottom: 4px;
        transition: border-color 0.3s ease-in-out, opacity 0.2s ease-in-out;
      }
      
      header nav a.active,
      header nav button.active {
        border-bottom-color: currentColor !important;
      }
      
      /* Typography reset to ensure buttons look exactly like neighboring links */
      #shop-menu-btn,
      header nav button {
        font-family: 'Outfit', sans-serif !important;
        font-weight: 300 !important; /* Outfit-light font weight */
        color: inherit;
      }

      /* Admin tab buttons active and hover state overrides */
      header nav button[id^="nav-tab-"] {
        border-bottom: 2px solid transparent;
        padding-bottom: 4px;
        transition: border-color 0.3s ease-in-out, color 0.3s ease-in-out;
      }
      header nav button[id^="nav-tab-"].active {
        border-bottom-color: #1c1917 !important; /* text-brand-charcoal */
        color: #1c1917 !important;
        font-weight: 600 !important;
      }
      header nav button[id^="nav-tab-"]:not(.active) {
        border-bottom-color: transparent !important;
        color: #a8a29e !important; /* text-stone-400 / text-gray-400 */
        font-weight: 300 !important;
      }
      header nav button[id^="nav-tab-"]:not(.active):hover {
        color: #1c1917 !important;
      }

      /* Favorites active state styling */
      [data-favorite-btn].is-favorite {
        color: #1c1917 !important; /* brand-charcoal */
      }
      [data-favorite-btn].is-favorite svg {
        fill: #1c1917 !important;
        stroke: #1c1917 !important;
      }

      /* Product Card Slider Overrides */
      .prev-img-btn, .next-img-btn, .dot-indicators-container {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease, transform 0.3s ease;
      }
      .product-card-hover:hover .prev-img-btn,
      .product-card-hover:hover .next-img-btn,
      .product-card-hover:hover .dot-indicators-container {
        opacity: 1;
        pointer-events: auto;
      }
      .prev-img-btn:hover, .next-img-btn:hover {
        transform: translateY(-50%) scale(1.05);
      }
    </style>
    <script is:inline set:html={`
      window.currentLang = "${lang}";
      window.productTranslations = {
        "generic shirt": "เสื้อเชิ้ตดีไซน์คลาสสิก",
        "generic watch": "นาฬิกาข้อมือมินิมอล",
        "generic pants": "กางเกงสแล็กทรงสลิม",
        "generic shoes": "รองเท้าผ้าใบสีขาวพรีเมียม",
        "generic t-shirt 1": "เสื้อยืดคอกลมมินิมอล 1",
        "generic t-shirt 2": "เสื้อโปโลผ้าทอลาย 2",
        "generic t-shirt 3": "กางเกงชิโน่ขาเต่อ 3",
        "generic t-shirt 4": "รองเท้าคลาสสิกสนีกเกอร์ 4",
        "generic set 1": "ชุดเซ็ตเสื้อผ้าเข้าชุด 1",
        "generic set 2": "ชุดเซ็ตเสื้อผ้าเข้าชุด 2",
        "generic set 3": "ชุดเซ็ตเสื้อผ้าเข้าชุด 3"
      };
      window.translateProductName = function(name, currentLang) {
        if (!name) return name;
        if (currentLang === 'th') {
          const key = name.toLowerCase().trim();
          return window.productTranslations[key] || name;
        }
        return name.replace(/\\b\\w/g, function(c) { return c.toUpperCase(); });
      };
    `} />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-brand-charcoal font-sans">
    <!-- Header -->
    <header 
      data-hero={showHeroHeader ? "true" : "false"}
