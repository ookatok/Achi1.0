---
import '../styles/global.css';
import { ArrowDown, Search, Cart, Globe, XIcon, User, Heart } from '../components/common/icons';
import { getSession } from 'auth-astro/server';

interface Props {
  title: string;
  description?: string;
  showHeroHeader?: boolean;
  isAdminPanel?: boolean;
}

const { title, description = 'ACHI | Cool Every Day', showHeroHeader = false, isAdminPanel = false } = Astro.props;
const session = await getSession(Astro.request);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Google Fonts for Figma Typography matching Outfit & Playfair -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <title>{title}</title>
    <style is:global>
      #shop-mega-menu a {
        color: #1c1917 !important; /* text-brand-charcoal (black) */
        transition: color 0.2s ease-in-out;
      }
      #shop-mega-menu a:hover {
        color: #a8a29e !important; /* text-stone-400 (grey) */
      }
      #shop-mega-menu a.active {
        color: #a8a29e !important; /* active link is grey */
      }
      
      /* Underline for active main nav links and buttons */
      header nav a,
      header nav button#shop-menu-btn {
        border-bottom: 2px solid transparent;
        padding-bottom: 4px;
        transition: border-color 0.3s ease-in-out, opacity 0.2s ease-in-out;
      }
      
      header nav a.active,
      header nav button.active {
        border-bottom-color: currentColor !important;
      }
      
      /* Typography reset to ensure buttons look exactly like neighboring links */
      #shop-menu-btn,
      header nav button {
        font-family: 'Outfit', sans-serif !important;
        font-weight: 300 !important; /* Outfit-light font weight */
        color: inherit;
      }

      /* Favorites active state styling */
      [data-favorite-btn].is-favorite {
        color: #1c1917 !important; /* brand-charcoal */
      }
      [data-favorite-btn].is-favorite svg {
        fill: #1c1917 !important;
        stroke: #1c1917 !important;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-brand-charcoal font-sans">
    <!-- Header -->
    <header 
      data-hero={showHeroHeader ? "true" : "false"}
      class={`w-full z-50 transition-all duration-300 ${showHeroHeader ? 'bg-transparent fixed top-0 text-white border-b border-transparent' : 'bg-white/95 text-brand-charcoal sticky top-0 border-b border-gray-200/50 backdrop-blur-md shadow-sm'}`}
    >
      <div class="max-w-[1440px] mx-auto px-6 h-24 flex items-center justify-between">
        <!-- Logo Section -->
        <div class="flex flex-col items-center">
          <a href="/" class="font-serif text-3xl tracking-[0.3em] font-light leading-none pl-[0.3em]">A C H I</a>
          <div class="w-36 border-t border-current opacity-30 my-1.5"></div>
          <span class="text-[9px] tracking-[0.4em] uppercase text-gray-400 font-light block leading-none pl-[0.4em]">Cool Every Day</span>
        </div>

        <!-- Center Navigation -->
        <nav class="hidden md:flex items-center gap-12 text-[13px] tracking-[0.15em] font-light uppercase h-full">
          {isAdminPanel ? (
            <>
              <button id="nav-tab-dashboard" class="border-b-2 border-brand-charcoal pb-1 text-xs font-semibold uppercase tracking-widest text-brand-charcoal cursor-pointer transition-all duration-300 bg-transparent border-none outline-none h-full flex items-center p-0 m-0">
                DASHBOARD
              </button>
              <button id="nav-tab-orders" class="border-b-2 border-transparent pb-1 text-xs font-semibold uppercase tracking-widest text-gray-400 hover:text-brand-charcoal cursor-pointer transition-all duration-300 bg-transparent border-none outline-none h-full flex items-center p-0 m-0">
                ORDERS
              </button>
              <button id="nav-tab-products" class="border-b-2 border-transparent pb-1 text-xs font-semibold uppercase tracking-widest text-gray-400 hover:text-brand-charcoal cursor-pointer transition-all duration-300 bg-transparent border-none outline-none h-full flex items-center p-0 m-0">
                PRODUCTS
              </button>
              <button id="nav-tab-blogs" class="border-b-2 border-transparent pb-1 text-xs font-semibold uppercase tracking-widest text-gray-400 hover:text-brand-charcoal cursor-pointer transition-all duration-300 bg-transparent border-none outline-none h-full flex items-center p-0 m-0">
                BLOGS
              </button>
              <button id="nav-tab-contacts" class="border-b-2 border-transparent pb-1 text-xs font-semibold uppercase tracking-widest text-gray-400 hover:text-brand-charcoal cursor-pointer transition-all duration-300 bg-transparent border-none outline-none h-full flex items-center p-0 m-0">
                CONTACTS
              </button>
            </>
          ) : (
            <>
              <a href="/" class="hover:opacity-70 transition-opacity">HOME</a>
              
              <!-- SHOP Mega Menu Container -->
              <div class="h-full flex items-center cursor-pointer">
                <button id="shop-menu-btn" class="hover:opacity-70 transition-opacity flex items-center uppercase bg-transparent border-none outline-none cursor-pointer tracking-[0.15em] font-light text-[13px] p-0 m-0 text-current">SHOP</button>
                
                <!-- Dropdown Mega Menu (Full Width) -->
                <div id="shop-mega-menu" class="absolute top-full left-0 w-full bg-white border-t border-b border-gray-200 py-12 shadow-sm hidden z-50 text-left normal-case tracking-normal animate-fade-in">
                  <div class="max-w-[1440px] mx-auto px-6 grid grid-cols-3 gap-8">
                    <!-- Column 1: Category -->
                    <div>
                      <h4 class="font-medium text-brand-charcoal text-[11px] uppercase tracking-wider mb-4 border-b border-gray-100 pb-2">Category</h4>
                      <ul class="space-y-3 text-[11px] tracking-widest text-gray-500 font-light uppercase">
                        <li>
                          <a href="/products?categorySlug=clothing" id="clothing-toggle-btn" class="hover:text-brand-gold font-medium text-brand-charcoal flex items-center gap-1.5 cursor-pointer">
                            Clothing
                            <ArrowDown id="clothing-arrow" />
                          </a>
                        </li>
                        <li class="clothing-sub-item hidden"><a href="/products/men" class="hover:text-brand-gold pl-3 block text-[10px]">MALE</a></li>
                        <li class="clothing-sub-item hidden"><a href="/products/women" class="hover:text-brand-gold pl-3 block text-[10px]">FEMALE</a></li>
                        <li><a href="/products/accessories" class="hover:text-brand-gold">Accessories</a></li>
                        <li><a href="/products/gifts" class="hover:text-brand-gold">Gifts</a></li>
                        <li><a href="/products" class="hover:text-brand-gold font-medium text-brand-charcoal">Shop All</a></li>
                      </ul>
                    </div>

                    <!-- Column 2: Featured -->
                    <div>
                      <h4 class="font-medium text-brand-charcoal text-[11px] uppercase tracking-wider mb-4 border-b border-gray-100 pb-2">Featured</h4>
                      <ul class="space-y-3 text-[11px] tracking-widest text-gray-500 font-light uppercase">
                        <li><a href="/products/new-arrivals" class="hover:text-brand-gold">New Arrivals</a></li>
                        <li><a href="/products/best-sellers" class="hover:text-brand-gold">Best Sellers</a></li>
                        <li><a href="/products/trending" class="hover:text-brand-gold">Trending Now</a></li>
                      </ul>
                    </div>

                    <!-- Column 3: Collections -->
                    <div>
                      <h4 class="font-medium text-brand-charcoal text-[11px] uppercase tracking-wider mb-4 border-b border-gray-100 pb-2">Collections</h4>
                      <ul class="space-y-3 text-[11px] tracking-widest text-gray-500 font-light uppercase">
                        <li class="text-gray-400 font-semibold mb-1 text-[10px]">Events</li>
                        <li><a href="/products/recommend" class="hover:text-brand-gold">Recommend</a></li>
                        <li><a href="/products/online-exclusives" class="hover:text-brand-gold">Online Exclusives</a></li>
                        <li><a href="/products/total-looks" class="hover:text-brand-gold">Total Looks</a></li>
                        <li><a href="/products/basics" class="hover:text-brand-gold">Basics</a></li>
                        <li><a href="/products/spring" class="hover:text-brand-gold">Spring</a></li>
                        <li><a href="/products/summer" class="hover:text-brand-gold">Summer</a></li>
                        <li><a href="/products/fall" class="hover:text-brand-gold">Fall</a></li>
                        <li><a href="/products/winter" class="hover:text-brand-gold">Winter</a></li>
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
              
              <a href="/products/new-arrivals" class="hover:opacity-70 transition-opacity">New Arrivals</a>
              <a href="/blog" class="hover:opacity-70 transition-opacity">BLOG</a>
            </>
          )}
        </nav>

        <!-- Right Side Icons -->
        <div class="flex items-center gap-6">
          <!-- Search Icon Button -->
          <button id="search-btn" class="hover:opacity-70 transition-opacity focus:outline-none cursor-pointer" aria-label="Search">
            <Search />
          </button>

          <!-- Favorite Icon Button -->
          <a href="/favorite" class="hover:opacity-70 transition-opacity cursor-pointer relative" aria-label="Favorites" id="header-favorite-btn">
            <Heart />
            <span id="favorite-badge" class="absolute -top-1.5 -right-1.5 bg-brand-charcoal text-white text-[9px] w-4 h-4 rounded-full flex items-center justify-center font-semibold scale-0 transition-transform duration-300">0</span>
          </a>

          <!-- Cart Icon Button -->
          <a href="/cart" class="hover:opacity-70 transition-opacity cursor-pointer relative" aria-label="Cart">
            <Cart />
          </a>

          <!-- Language Selector -->
          <button class="hover:opacity-70 transition-opacity cursor-pointer" aria-label="Language Selector">
            <Globe />
          </button>

          {session ? (
            <!-- Profile Icon Button -->
            <a href="/profile" class="hover:opacity-70 transition-opacity cursor-pointer" aria-label="Profile">
              <User />
            </a>
          ) : (
            <!-- Sign In Link -->
            <a href="/auth/signin" class="text-[11px] tracking-widest hover:opacity-70 transition-opacity uppercase font-light">Sign In</a>
          )}
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="w-full bg-white border-t border-gray-200 py-16 mt-20">
      <div class="max-w-[1440px] mx-auto px-6 flex flex-col items-center">
        <!-- Footer Logo -->
        <div class="flex flex-col items-center mb-12 text-center">
          <h4 class="font-serif text-3xl tracking-[0.3em] font-light leading-none pl-[0.3em]">A C H I</h4>
          <div class="w-36 border-t border-current opacity-30 my-1.5"></div>
          <span class="text-[9px] tracking-[0.4em] uppercase text-gray-400 font-light leading-none pl-[0.4em]">Cool Every Day</span>
        </div>

        <hr class="w-full border-gray-100 mb-12" />

        <!-- Footer Links Grid -->
        <div class="w-full grid grid-cols-2 md:grid-cols-4 gap-8 text-[11px] uppercase tracking-wider font-light mb-8">
          <!-- Col 1 -->
          <div>
            <h5 class="font-medium mb-4 text-brand-charcoal">THE COMPANY</h5>
            <ul class="space-y-2 text-gray-500">
              <li><a href="/about" class="hover:text-brand-gold transition-colors">ABOUT US</a></li>
            </ul>
          </div>

          <!-- Col 2 -->
          <div>
            <h5 class="font-medium mb-4 text-brand-charcoal">CUSTOMER SERVICE</h5>
            <ul class="space-y-2 text-gray-500">
              <li><a href="/contact" class="hover:text-brand-gold transition-colors">CONTACT US</a></li>
              <li><a href="/stores" class="hover:text-brand-gold transition-colors">STORE LOCATOR</a></li>
              <li><a href="/delivery" class="hover:text-brand-gold transition-colors">DELIVERY INFORMATION</a></li>
              <li><a href="/payments" class="hover:text-brand-gold transition-colors">PAYMENTS</a></li>
              <li><a href="/return" class="hover:text-brand-gold transition-colors">UNCONDITIONAL RETURN</a></li>
              <li><a href="/refunds" class="hover:text-brand-gold transition-colors">RETURN & REFUNDS</a></li>
              <li><a href="/product-care" class="hover:text-brand-gold transition-colors">PRODUCT CARE</a></li>
              <li><a href="/size-guide" class="hover:text-brand-gold transition-colors">SIZE GUIDE</a></li>
              <li><a href="/faq" class="hover:text-brand-gold transition-colors">FAQ</a></li>
              <li><a href="/fact-sheet" class="hover:text-brand-gold transition-colors">REQUEST A FACT SHEET</a></li>
            </ul>
          </div>

          <!-- Col 3 -->
          <div>
            <h5 class="font-medium mb-4 text-brand-charcoal">LEGAL</h5>
            <ul class="space-y-2 text-gray-500">
              <li><a href="/privacy" class="hover:text-brand-gold transition-colors">PRIVACY POLICY</a></li>
              <li><a href="/terms" class="hover:text-brand-gold transition-colors">TERMS & CONDITIONS</a></li>
              <li><a href="/cookies" class="hover:text-brand-gold transition-colors">COOKIE SETTINGS</a></li>
            </ul>
          </div>

          <!-- Col 4 -->
          <div>
            <h5 class="font-medium mb-4 text-brand-charcoal">FOLLOW US</h5>
            <ul class="space-y-2 text-gray-500">
              <li><a href="https://facebook.com" class="hover:text-brand-gold transition-colors">FACEBOOK</a></li>
              <li><a href="https://line.me" class="hover:text-brand-gold transition-colors">LINE OFFICIAL</a></li>
              <li><a href="https://instagram.com" class="hover:text-brand-gold transition-colors">INSTAGRAM</a></li>
              <li><a href="https://pinterest.com" class="hover:text-brand-gold transition-colors">PINTEREST</a></li>
              <li><a href="https://twitter.com" class="hover:text-brand-gold transition-colors">TWITTER</a></li>
              <li><a href="https://spotify.com" class="hover:text-brand-gold transition-colors">SPOTIFY</a></li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

    <!-- Search Overlay -->
    <div id="search-overlay" class="fixed inset-0 bg-white z-50 flex flex-col hidden">
      <!-- Search Overlay Header -->
      <div class="max-w-[1440px] w-full mx-auto px-6 h-24 flex items-center justify-between">
        <div class="flex flex-col items-center">
          <span class="font-serif text-3xl tracking-[0.3em] font-light pl-[0.3em]">A C H I</span>
          <div class="w-36 border-t border-current opacity-30 my-1.5"></div>
          <span class="text-[9px] tracking-[0.4em] uppercase text-gray-400 font-light pl-[0.4em]">Cool Every Day</span>
        </div>
        <button id="close-search-btn" class="hover:opacity-70 transition-opacity focus:outline-none cursor-pointer">
          <XIcon class="w-6 h-6" />
        </button>
      </div>

      <!-- Search Input Section -->
      <div class="flex-grow flex flex-col max-w-[800px] w-full mx-auto px-6 pt-16">
        <form action="/products" method="GET" class="relative border-b border-gray-400 flex items-center py-4">
          <Search class="w-6 h-6 text-gray-400 mr-4" />
          <input
            type="text"
            name="query"
            placeholder="Search"
            class="w-full bg-transparent text-xl font-light outline-none text-brand-charcoal placeholder-gray-400"
            autocomplete="off"
            id="search-input"
          />
          <button type="reset" id="clear-search-btn" class="text-gray-400 hover:text-brand-charcoal focus:outline-none hidden">
            <XIcon class="w-5 h-5" />
          </button>
        </form>
        
        <!-- Live Search Results Preview -->
        <div id="search-preview-container" class="mt-12 overflow-y-auto max-h-[55vh] hidden">
          <h4 class="text-[11px] uppercase tracking-widest text-gray-400 font-semibold mb-6 border-b border-gray-100 pb-2">Products</h4>
          <div id="search-preview-results" class="grid grid-cols-1 sm:grid-cols-2 gap-4 pb-12">
            <!-- Dynamically populated -->
          </div>
        </div>

        <div id="search-preview-empty" class="mt-12 text-center hidden">
          <p class="text-xs text-gray-400 font-light italic uppercase tracking-widest">No products found matching your search</p>
        </div>
        
        <!-- Suggestions -->
        <div id="search-suggestions" class="mt-8 text-xs uppercase tracking-widest text-gray-400 font-light">
          Suggestions: T-shirt, Denim, Jacket, Shades
        </div>
      </div>
    </div>

    <!-- Client-side script to toggle search overlay and handle live search -->
    <script>
      const searchBtn = document.getElementById('search-btn');
      const closeSearchBtn = document.getElementById('close-search-btn');
      const searchOverlay = document.getElementById('search-overlay');
      const searchInput = document.getElementById('search-input') as HTMLInputElement;
      const clearSearchBtn = document.getElementById('clear-search-btn');

      const searchPreviewContainer = document.getElementById('search-preview-container');
      const searchPreviewResults = document.getElementById('search-preview-results');
      const searchPreviewEmpty = document.getElementById('search-preview-empty');
      const searchSuggestions = document.getElementById('search-suggestions');

      const resolveImage = (url: string) => {
        if (!url) return '/assets/images/placeholder-product.png';
        if (url.startsWith('http') || url.startsWith('data:')) return url;
        if (url.startsWith('/assets/uploads/')) {
          return `http://localhost:3001${url}`;
        }
        return url.replace(/\.(png|jpg|jpeg)$/i, '.webp') + '?v=2';
      };

      let debounceTimer: number;

      const performSearch = async (query: string) => {
        if (!query.trim()) {
          if (searchPreviewContainer) searchPreviewContainer.classList.add('hidden');
          if (searchPreviewEmpty) searchPreviewEmpty.classList.add('hidden');
          if (searchSuggestions) searchSuggestions.classList.remove('hidden');
          if (searchPreviewResults) searchPreviewResults.innerHTML = '';
          return;
        }

        try {
          const res = await fetch(`http://localhost:3001/api/products?query=${encodeURIComponent(query)}`);
          if (res.ok) {
            const products = await res.json();
            
            if (products.length > 0) {
              if (searchPreviewEmpty) searchPreviewEmpty.classList.add('hidden');
              if (searchSuggestions) searchSuggestions.classList.add('hidden');
              if (searchPreviewContainer) searchPreviewContainer.classList.remove('hidden');
              
              if (searchPreviewResults) {
                searchPreviewResults.innerHTML = products.map((product: any) => {
                  const price = isNaN(Number(product.price)) ? product.price : Number(product.price).toLocaleString();
                  return `
                    <div class="flex items-center gap-4 p-3 bg-gray-50/50 border border-gray-100 rounded-sm hover:border-brand-charcoal transition-all relative group">
                      <div class="w-16 h-16 bg-white border border-gray-100 flex items-center justify-center overflow-hidden shrink-0 rounded-sm">
                        <img src="${resolveImage(product.imageUrl)}" alt="${product.name}" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
                      </div>
                      <div class="flex-grow">
                        <h5 class="text-xs font-semibold tracking-widest text-brand-charcoal uppercase leading-tight group-hover:text-brand-gold transition-colors">
                          ${product.name}
                        </h5>
                        <span class="text-xs text-brand-gold font-medium mt-1.5 block">
                          $${price}
                        </span>
                      </div>
                      <a href="/products/${product.id}" class="absolute inset-0 z-10" aria-label="View Details"></a>
                    </div>
                  `;
                }).join('');
              }
            } else {
              if (searchPreviewContainer) searchPreviewContainer.classList.add('hidden');
              if (searchSuggestions) searchSuggestions.classList.add('hidden');
              if (searchPreviewEmpty) searchPreviewEmpty.classList.remove('hidden');
              if (searchPreviewResults) searchPreviewResults.innerHTML = '';
            }
          }
        } catch (e) {
          console.error('Failed to perform live search', e);
        }
      };

      if (searchBtn && searchOverlay) {
        searchBtn.addEventListener('click', () => {
          searchOverlay.classList.remove('hidden');
          document.body.style.overflow = 'hidden'; // Lock background scroll
          if (searchInput) {
            searchInput.value = '';
            performSearch('');
            if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
            searchInput.focus();
          }
        });
      }

      if (closeSearchBtn && searchOverlay) {
        closeSearchBtn.addEventListener('click', () => {
          searchOverlay.classList.add('hidden');
          document.body.style.overflow = ''; // Unlock background scroll
          if (searchInput) {
            searchInput.value = '';
            performSearch('');
            if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
          }
        });
      }

      if (searchInput) {
        searchInput.addEventListener('input', () => {
          clearTimeout(debounceTimer);
          
          const val = searchInput.value;
          if (val.length > 0) {
            if (clearSearchBtn) clearSearchBtn.classList.remove('hidden');
          } else {
            if (clearSearchBtn) clearSearchBtn.classList.add('hidden');
          }

          debounceTimer = window.setTimeout(() => {
            performSearch(val);
          }, 250);
        });

        if (clearSearchBtn) {
          clearSearchBtn.addEventListener('click', () => {
            searchInput.value = '';
            clearSearchBtn.classList.add('hidden');
            performSearch('');
            searchInput.focus();
          });
        }
      }
    </script>

    <!-- Client-side script for sticky header and shop mega menu transitions -->
    <script is:inline>
      const stickyHeader = document.querySelector('header');
      const isHeroHeader = stickyHeader?.getAttribute('data-hero') === 'true';
      const shopMenuBtn = document.getElementById('shop-menu-btn');
      const shopMegaMenu = document.getElementById('shop-mega-menu');

      const handleStickyScroll = () => {
        if (!stickyHeader) return;
        const isMenuOpen = shopMegaMenu && (shopMegaMenu.classList.contains('block') || !shopMegaMenu.classList.contains('hidden'));
        
        if (window.scrollY > 20 || isMenuOpen) {
          stickyHeader.classList.add('scrolled');
          if (isHeroHeader) {
            stickyHeader.classList.remove('bg-transparent', 'text-white', 'border-transparent');
            stickyHeader.classList.add('bg-white/90', 'text-brand-charcoal', 'border-gray-200/50', 'shadow-sm', 'backdrop-blur-md');
          } else {
            stickyHeader.classList.add('shadow-md');
          }
        } else {
          stickyHeader.classList.remove('scrolled');
          if (isHeroHeader) {
            stickyHeader.classList.add('bg-transparent', 'text-white', 'border-transparent');
            stickyHeader.classList.remove('bg-white/90', 'text-brand-charcoal', 'border-gray-200/50', 'shadow-sm', 'backdrop-blur-md');
          } else {
            stickyHeader.classList.remove('shadow-md');
          }
        }
      };

      if (stickyHeader) {
        window.addEventListener('scroll', handleStickyScroll);
        // Initial check in case of page reload when already scrolled down
        handleStickyScroll();
      }

      if (shopMenuBtn && shopMegaMenu) {
        shopMenuBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isHidden = shopMegaMenu.classList.contains('hidden');
          if (isHidden) {
            shopMegaMenu.classList.remove('hidden');
            shopMegaMenu.classList.add('block');
          } else {
            shopMegaMenu.classList.remove('block');
            shopMegaMenu.classList.add('hidden');
          }
          handleStickyScroll();
        });

        // Close when clicking outside
        document.addEventListener('click', (e) => {
          if (shopMegaMenu && !shopMegaMenu.contains(e.target) && e.target !== shopMenuBtn) {
            shopMegaMenu.classList.remove('block');
            shopMegaMenu.classList.add('hidden');
            handleStickyScroll();
          }
        });
      }
    </script>
    <!-- Client-side script to highlight active links and toggle clothing menu -->
    <script is:inline>
      const currentPathName = window.location.pathname + window.location.search;
      
      // 1. Highlight active sub-links in the mega menu
      document.querySelectorAll('#shop-mega-menu a').forEach(link => {
        const href = link.getAttribute('href');
        if (href) {
          // Normalize paths for matching
          const normalizedHref = href.endsWith('/') ? href.slice(0, -1) : href;
          const normalizedCurrent = currentPathName.endsWith('/') ? currentPathName.slice(0, -1) : currentPathName;
          
          if (normalizedCurrent === normalizedHref || (normalizedHref !== '' && normalizedHref !== '/products' && normalizedCurrent.startsWith(normalizedHref))) {
            link.classList.add('active');
          }
        }
      });

      // 2. Highlight active main navigation items (HOME, SHOP, New Arrivals, BLOG)
      const mainLinks = document.querySelectorAll('header nav a, header nav button#shop-menu-btn');
      mainLinks.forEach(link => {
        const href = link.getAttribute('href');
        const id = link.getAttribute('id');
        const normalizedCurrent = currentPathName.endsWith('/') ? currentPathName.slice(0, -1) : currentPathName;

        if (id === 'shop-menu-btn') {
          // Active if pathname starts with /products but is not /products/new-arrivals
          if (window.location.pathname.startsWith('/products') && window.location.pathname !== '/products/new-arrivals') {
            link.classList.add('active');
          }
        } else if (href) {
          const normalizedHref = href.endsWith('/') ? href.slice(0, -1) : href;
          if (normalizedHref === '' && normalizedCurrent === '') {
            link.classList.add('active');
          } else if (normalizedHref !== '' && normalizedCurrent.startsWith(normalizedHref)) {
            link.classList.add('active');
          }
        }
      });

      // 3. Clothing subcategory toggle logic
      const clothingToggle = document.getElementById('clothing-toggle-btn');
      const clothingSubItems = document.querySelectorAll('.clothing-sub-item');
      const clothingArrow = document.getElementById('clothing-arrow');

      const toggleClothingMenu = (show) => {
        clothingSubItems.forEach(item => {
          if (show === undefined) {
            item.classList.toggle('hidden');
          } else if (show) {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });

        // Toggle arrow rotation
        if (clothingArrow) {
          const isCurrentlyHidden = clothingSubItems[0]?.classList.contains('hidden');
          if (isCurrentlyHidden) {
            clothingArrow.classList.remove('rotate-180');
          } else {
            clothingArrow.classList.add('rotate-180');
          }
        }
      };

      if (clothingToggle) {
        clothingToggle.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          toggleClothingMenu();
        });
      }

      // Auto-expand on page load if user is on /products/men or /products/women, or categorySlug is clothing
      const pathName = window.location.pathname;
      const searchParams = window.location.search;
      if (pathName === '/products/men' || pathName === '/products/women' || searchParams.includes('categorySlug=clothing')) {
        toggleClothingMenu(true);
      }
    </script>

    <!-- Client-side script for Favorites Wishlist sync and click tracking -->
    <script is:inline>
      (function() {
        const STORAGE_KEY = 'achi_favorites';

        const getFavorites = () => {
          try {
            const data = localStorage.getItem(STORAGE_KEY);
            return data ? JSON.parse(data) : [];
          } catch (e) {
            return [];
          }
        };

        const saveFavorites = (favs) => {
          try {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(favs));
          } catch (e) {
            console.error('Failed to save favorites', e);
          }
        };

        const updateFavoriteBadge = (count) => {
          const badge = document.getElementById('favorite-badge');
          if (!badge) return;
          badge.textContent = count;
          if (count > 0) {
            badge.classList.remove('scale-0');
            badge.classList.add('scale-100');
          } else {
            badge.classList.remove('scale-100');
            badge.classList.add('scale-0');
          }
        };

        const syncFavoriteButtons = () => {
          const favs = getFavorites();
          updateFavoriteBadge(favs.length);

          const favIds = new Set(favs.map(f => String(f.id)));
          
          document.querySelectorAll('[data-favorite-btn]').forEach(btn => {
            const id = btn.getAttribute('data-id');
            if (id && favIds.has(String(id))) {
              btn.classList.add('is-favorite');
            } else {
              btn.classList.remove('is-favorite');
            }
          });
        };

        const toggleFavorite = (product) => {
          let favs = getFavorites();
          const index = favs.findIndex(f => String(f.id) === String(product.id));

          if (index > -1) {
            favs.splice(index, 1);
          } else {
            favs.push(product);
          }

          saveFavorites(favs);
          syncFavoriteButtons();

          // Dispatch a custom event so the favorite page or other elements can react if they want
          window.dispatchEvent(new CustomEvent('achi-favorites-updated', { detail: favs }));
        };

        // Initialize and bind click handlers
        const initFavorites = () => {
          syncFavoriteButtons();

          // Global click event listener for event delegation
          document.addEventListener('click', (e) => {
            const btn = e.target.closest('[data-favorite-btn]');
            if (!btn) return;

            e.preventDefault();
            e.stopPropagation();

            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name') || '';
            const price = btn.getAttribute('data-price') || '';
            const imageUrl = btn.getAttribute('data-image') || '';

            if (id) {
              toggleFavorite({ id, name, price, imageUrl });
            }
          });
        };

        // Run on DOMContentLoaded or immediately if already loaded
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initFavorites);
        } else {
          initFavorites();
        }

        // Expose to window so other pages can easily check/manipulate if needed
        window.achiFavorites = {
          get: getFavorites,
          toggle: toggleFavorite,
          sync: syncFavoriteButtons
        };
      })();
    </script>
  </body>
