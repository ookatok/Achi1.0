---
import '../styles/global.css';
import { Search, Cart, Globe, XIcon, User, Heart } from '../components/common/icons';
import { getSession } from 'auth-astro/server';
import { useTranslations } from '../lib/translations';

interface Props {
  title: string;
  description?: string;
  showHeroHeader?: boolean;
  isAdminPanel?: boolean;
  pendingOrdersCount?: number;
}

const { title, description = 'ACHI | Cool Every Day', showHeroHeader = false, isAdminPanel = false, pendingOrdersCount = 0 } = Astro.props;
const session = await getSession(Astro.request);
const lang = (Astro.cookies.get('lang')?.value === 'en' ? 'en' : 'th') as 'th' | 'en';
const t = useTranslations(lang);

const l = (path: string) => {
  if (path.startsWith('http') || path.startsWith('mailto:') || path.startsWith('tel:')) {
    return path;
  }
  const cleanPath = path.startsWith('/') ? path : `/${path}`;
  return `/${lang}${cleanPath === '/' ? '' : cleanPath}`;
};

const token = (session as any)?.accessToken || '';
let cartCount = 0;

if (token) {
  try {
    const res = await fetch('http://localhost:3001/api/cart', {
      headers: {
        'Authorization': `Bearer ${token}`
      }
    });
    if (res.ok) {
      const cartData = await res.json();
      cartCount = cartData.items?.reduce((sum: number, item: any) => sum + item.quantity, 0) || 0;
    }
  } catch (err) {
    console.error('[NestJS API Error] Fetching cart in Layout failed.', err);
  }
}

let categoriesList = [] as any[];
let tagsList = [] as any[];

try {
  const catRes = await fetch(`${BACKEND_URL}/api/products/categories`);
  if (catRes.ok) {
    categoriesList = await catRes.json();
  }
  const tagRes = await fetch(`${BACKEND_URL}/api/products/tags`);
  if (tagRes.ok) {
    tagsList = await tagRes.json();
  }
} catch (err) {
  console.error('[NestJS API Error] Fetching categories/tags in Layout.astro failed.', err);
}

// Fallback lists
const fallbackCategories = [
  { id: 1, slug: 'men', name: 'men' },
  { id: 2, slug: 'women', name: 'women' },
  { id: 3, slug: 'accessories', name: 'accessories' },
];

const fallbackTags = [
  { id: 1, slug: 'new', name: 'new' },
  { id: 2, slug: 'basics', name: 'basics' },
  { id: 3, slug: 'summer', name: 'summer' },
];

const displayCategories = categoriesList.length > 0
  ? categoriesList.map(c => ({
      id: c.id,
      slug: c.slug,
      nameEn: c.name.charAt(0).toUpperCase() + c.name.slice(1),
      nameTh: c.name === 'men' ? 'ผู้ชาย' : c.name === 'women' ? 'ผู้หญิง' : c.name === 'accessories' ? 'เครื่องประดับ' : c.name
    }))
  : fallbackCategories.map(c => ({
      id: c.id,
      slug: c.slug,
      nameEn: c.name.charAt(0).toUpperCase() + c.name.slice(1),
      nameTh: c.name === 'men' ? 'ผู้ชาย' : c.name === 'women' ? 'ผู้หญิง' : c.name === 'accessories' ? 'เครื่องประดับ' : c.name
    }));

const displayTags = tagsList.length > 0
  ? tagsList.map(t => ({
      id: t.id,
      slug: t.slug,
      nameEn: t.name.charAt(0).toUpperCase() + t.name.slice(1),
      nameTh: t.name === 'summer' ? 'ฤดูร้อน' : t.name === 'basics' ? 'เบสิก' : t.name === 'new' ? 'ใหม่' : t.name
    }))
  : fallbackTags.map(t => ({
      id: t.id,
      slug: t.slug,
      nameEn: t.name.charAt(0).toUpperCase() + t.name.slice(1),
      nameTh: t.name === 'summer' ? 'ฤดูร้อน' : t.name === 'basics' ? 'เบสิก' : t.name === 'new' ? 'ใหม่' : t.name
    }));

const pathname = Astro.url.pathname;
const urlParams = Astro.url.searchParams;
const tabParam = urlParams.get('tab');

let resolvedActiveTab = 'dashboard';
if (pathname.includes('/admin/products') || pathname.includes('/admin/new-arrival-sets')) {
  resolvedActiveTab = 'products';
} else if (pathname.includes('/admin/collections')) {
  resolvedActiveTab = 'collections';
} else if (pathname.includes('/admin/blogs')) {
  resolvedActiveTab = 'blogs';
} else if (pathname.includes('/admin/orders')) {
  resolvedActiveTab = 'orders';
} else if (pathname.includes('/admin/faqs')) {
  resolvedActiveTab = 'faqs';
} else if (pathname.includes('/admin/contacts')) {
  resolvedActiveTab = 'contacts';
} else if (tabParam) {
  resolvedActiveTab = tabParam;
}
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Google Fonts for Figma Typography matching Outfit & Playfair -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <title>{title}</title>
    <style is:global>
      #shop-mega-menu a {
        color: #1c1917 !important; /* text-brand-charcoal (black) */
        transition: color 0.2s ease-in-out;
      }
      #shop-mega-menu a:hover {
        color: #a8a29e !important; /* text-stone-400 (grey) */
      }
      #shop-mega-menu a.active {
        color: #a8a29e !important; /* active link is grey */
      }
      
      /* Underline for active main nav links and buttons */
      header nav a,
      header nav button#shop-menu-btn {
        border-bottom: 2px solid transparent;
        padding-bottom: 4px;
        transition: border-color 0.3s ease-in-out, opacity 0.2s ease-in-out;
      }
      
      header nav a.active,
      header nav button.active {
        border-bottom-color: currentColor !important;
      }
      
      /* Typography reset to ensure buttons look exactly like neighboring links */
      #shop-menu-btn,
      header nav button {
        font-family: 'Outfit', sans-serif !important;
        font-weight: 300 !important; /* Outfit-light font weight */
        color: inherit;
      }

      /* Admin tab buttons active and hover state overrides */
      header nav button[id^="nav-tab-"],
      header nav a[id^="nav-tab-"] {
        border-bottom: 2px solid transparent;
        padding-bottom: 4px;
        transition: border-color 0.3s ease-in-out, color 0.3s ease-in-out;
      }
      header nav button[id^="nav-tab-"].active,
      header nav a[id^="nav-tab-"].active {
        border-bottom-color: #1c1917 !important; /* text-brand-charcoal */
        color: #1c1917 !important;
        font-weight: 600 !important;
      }
      header nav button[id^="nav-tab-"]:not(.active),
      header nav a[id^="nav-tab-"]:not(.active) {
        border-bottom-color: transparent !important;
        color: #a8a29e !important; /* text-stone-400 / text-gray-400 */
        font-weight: 300 !important;
      }
      header nav button[id^="nav-tab-"]:not(.active):hover,
      header nav a[id^="nav-tab-"]:not(.active):hover {
        color: #1c1917 !important;
      }

      /* Favorites active state styling */
      [data-favorite-btn].is-favorite {
        color: #1c1917 !important; /* brand-charcoal */
      }
      [data-favorite-btn].is-favorite svg {
        fill: #1c1917 !important;
        stroke: #1c1917 !important;
      }

      /* Product Card Slider Overrides */
      .prev-img-btn, .next-img-btn, .dot-indicators-container {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease, transform 0.3s ease;
      }
      .product-card-hover:hover .prev-img-btn,
      .product-card-hover:hover .next-img-btn,
      .product-card-hover:hover .dot-indicators-container {
        opacity: 1;
        pointer-events: auto;
      }
      .prev-img-btn:hover, .next-img-btn:hover {
        transform: translateY(-50%) scale(1.05);
      }
    </style>
    <script is:inline set:html={`
      window.currentLang = "${lang}";
      window.productTranslations = {
        "generic shirt": "เสื้อเชิ้ตดีไซน์คลาสสิก",
        "generic watch": "นาฬิกาข้อมือมินิมอล",
        "generic pants": "กางเกงสแล็กทรงสลิม",
        "generic shoes": "รองเท้าผ้าใบสีขาวพรีเมียม",
        "generic t-shirt 1": "เสื้อยืดคอกลมมินิมอล 1",
        "generic t-shirt 2": "เสื้อโปโลผ้าทอลาย 2",
        "generic t-shirt 3": "กางเกงชิโน่ขาเต่อ 3",
        "generic t-shirt 4": "รองเท้าคลาสสิกสนีกเกอร์ 4",
        "generic set 1": "ชุดเซ็ตเสื้อผ้าเข้าชุด 1",
        "generic set 2": "ชุดเซ็ตเสื้อผ้าเข้าชุด 2",
        "generic set 3": "ชุดเซ็ตเสื้อผ้าเข้าชุด 3"
      };
      window.translateProductName = function(name, currentLang) {
        if (!name) return name;
        if (currentLang === 'th') {
          const key = name.toLowerCase().trim();
          return window.productTranslations[key] || name;
        }
        return name.replace(/\\b\\w/g, function(c) { return c.toUpperCase(); });
      };
    `} />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-brand-charcoal font-sans">
    <!-- Header -->
    <header 
      data-hero={showHeroHeader ? "true" : "false"}
      class={`w-full z-50 transition-all duration-300 ${showHeroHeader ? 'bg-transparent fixed top-0 text-white border-b border-transparent' : 'bg-white/95 text-brand-charcoal sticky top-0 border-b border-gray-200/50 backdrop-blur-md shadow-sm'}`}
    >
      <div class="max-w-[1440px] mx-auto px-6 h-24 flex items-center justify-between">
        <!-- Logo Section -->
        <div class="flex flex-col items-center">
          <a href={l('/')} class="font-serif text-3xl tracking-[0.3em] font-light leading-none pl-[0.3em]">A C H I</a>
          <div class="w-36 border-t border-current opacity-30 my-1.5"></div>
          <span class="text-[9px] tracking-[0.4em] uppercase text-gray-400 font-light block leading-none pl-[0.4em]">Cool Every Day</span>
        </div>

        <!-- Center Navigation -->
        <nav class="hidden md:flex items-center gap-12 text-[13px] tracking-[0.15em] font-light uppercase h-full">
          {isAdminPanel ? (
            <>
              <a 
                href={l('/admin')} 
                id="nav-tab-dashboard" 
                class={`border-b-2 pb-1 text-xs font-semibold uppercase tracking-widest cursor-pointer transition-all duration-300 h-full flex items-center p-0 m-0 decoration-transparent ${
                  resolvedActiveTab === 'dashboard' 
                    ? 'border-brand-charcoal text-brand-charcoal active' 
                    : 'border-transparent text-gray-400 hover:text-brand-charcoal'
                }`}
              >
                {t('nav.dashboard')}
              </a>
              <a 
                href={l('/admin?tab=orders')} 
                id="nav-tab-orders" 
                class={`border-b-2 pb-1 text-xs font-semibold uppercase tracking-widest cursor-pointer transition-all duration-300 h-full flex items-center p-0 m-0 gap-1.5 decoration-transparent ${
                  resolvedActiveTab === 'orders' 
                    ? 'border-brand-charcoal text-brand-charcoal active' 
                    : 'border-transparent text-gray-400 hover:text-brand-charcoal'
                }`}
              >
                <span>{t('nav.orders')}</span>
                <span id="nav-orders-badge" class={`inline-flex items-center justify-center bg-red-500 text-white text-[9px] font-bold min-w-[18px] h-[18px] px-1 rounded-full ${pendingOrdersCount > 0 ? '' : 'hidden'}`}>
                  {pendingOrdersCount}
                </span>
              </a>
              <a 
                href={l('/admin?tab=products')} 
                id="nav-tab-products" 
                class={`border-b-2 pb-1 text-xs font-semibold uppercase tracking-widest cursor-pointer transition-all duration-300 h-full flex items-center p-0 m-0 decoration-transparent ${
                  resolvedActiveTab === 'products' 
                    ? 'border-brand-charcoal text-brand-charcoal active' 
                    : 'border-transparent text-gray-400 hover:text-brand-charcoal'
                }`}
              >
                {t('nav.products')}
              </a>
              <a 
                href={l('/admin?tab=collections')} 
                id="nav-tab-collections" 
                class={`border-b-2 pb-1 text-xs font-semibold uppercase tracking-widest cursor-pointer transition-all duration-300 h-full flex items-center p-0 m-0 decoration-transparent ${
                  resolvedActiveTab === 'collections' 
                    ? 'border-brand-charcoal text-brand-charcoal active' 
                    : 'border-transparent text-gray-400 hover:text-brand-charcoal'
                }`}
              >
                {t('nav.collections')}
              </a>
              <a 
                href={l('/admin?tab=blogs')} 
                id="nav-tab-blogs" 
                class={`border-b-2 pb-1 text-xs font-semibold uppercase tracking-widest cursor-pointer transition-all duration-300 h-full flex items-center p-0 m-0 decoration-transparent ${
                  resolvedActiveTab === 'blogs' 
                    ? 'border-brand-charcoal text-brand-charcoal active' 
                    : 'border-transparent text-gray-400 hover:text-brand-charcoal'
                }`}
              >
                {t('nav.blogs')}
              </a>
              <a 
                href={l('/admin?tab=contacts')} 
                id="nav-tab-contacts" 
                class={`border-b-2 pb-1 text-xs font-semibold uppercase tracking-widest cursor-pointer transition-all duration-300 h-full flex items-center p-0 m-0 decoration-transparent ${
                  resolvedActiveTab === 'contacts' 
                    ? 'border-brand-charcoal text-brand-charcoal active' 
                    : 'border-transparent text-gray-400 hover:text-brand-charcoal'
                }`}
              >
                {t('nav.contacts')}
              </a>
              <a 
                href={l('/admin?tab=faqs')} 
                id="nav-tab-faqs" 
                class={`border-b-2 pb-1 text-xs font-semibold uppercase tracking-widest cursor-pointer transition-all duration-300 h-full flex items-center p-0 m-0 decoration-transparent ${
                  resolvedActiveTab === 'faqs' 
                    ? 'border-brand-charcoal text-brand-charcoal active' 
                    : 'border-transparent text-gray-400 hover:text-brand-charcoal'
                }`}
              >
                {t('nav.faqs')}
              </a>
            </>
          ) : (
            <>
              <a href={l('/')} class="hover:opacity-70 transition-opacity">{t('nav.home')}</a>
              
              <!-- SHOP Mega Menu Container -->
              <div class="h-full flex items-center cursor-pointer">
                <button id="shop-menu-btn" class="hover:opacity-70 transition-opacity flex items-center uppercase bg-transparent border-none outline-none cursor-pointer tracking-[0.15em] font-light text-[13px] p-0 m-0 text-current">{t('nav.shop')}</button>
                
                <!-- Dropdown Mega Menu (5 Columns) -->
                <div id="shop-mega-menu" class="absolute top-full left-0 w-full bg-white border-t border-b border-gray-200 py-12 shadow-sm hidden z-50 text-left normal-case tracking-normal animate-fade-in">
                  <div class="max-w-[1440px] mx-auto px-6 grid grid-cols-5 gap-8">
                    <!-- Column 1: SHOP ALL -->
                    <div>
                      <h4 class="font-medium text-brand-charcoal text-[11px] uppercase tracking-wider mb-4 border-b border-gray-100 pb-2">
                        <a href={l('/products')} class="underline underline-offset-4 font-semibold hover:text-brand-gold">{t('menu.shop_all')}</a>
                      </h4>
                    </div>

                    <!-- Column 2: MEN -->
                    <div>
                      <h4 class="font-medium text-gray-400 text-[11px] uppercase tracking-wider mb-4 border-b border-gray-100 pb-2">{t('home.men')}</h4>
                      <ul class="space-y-3 text-[11px] tracking-widest text-gray-500 font-light uppercase">
                        <li><a href={l('/products?categorySlug=men&query=T-shirt')} class="hover:text-brand-gold">{t('menu.men_tshirt')}</a></li>
                        <li><a href={l('/products?categorySlug=men&query=Polo')} class="hover:text-brand-gold">{t('menu.men_polo')}</a></li>
                        <li><a href={l('/products?categorySlug=men&query=Hoodie')} class="hover:text-brand-gold">{t('menu.men_hoodie')}</a></li>
                        <li><a href={l('/products?categorySlug=men&query=Jeans')} class="hover:text-brand-gold">{t('menu.men_jeans')}</a></li>
                        <li><a href={l('/products?categorySlug=men&query=Pants')} class="hover:text-brand-gold">{t('menu.men_pants')}</a></li>
                        <li><a href={l('/products?categorySlug=men&query=Shorts')} class="hover:text-brand-gold">{t('menu.men_shorts')}</a></li>
                        <li><a href={l('/products?categorySlug=men&query=Bags')} class="hover:text-brand-gold">{t('menu.men_bags')}</a></li>
                      </ul>
                    </div>

                    <!-- Column 3: WOMEN -->
                    <div>
                      <h4 class="font-medium text-gray-400 text-[11px] uppercase tracking-wider mb-4 border-b border-gray-100 pb-2">{t('home.women')}</h4>
                      <ul class="space-y-3 text-[11px] tracking-widest text-gray-500 font-light uppercase">
                        <li><a href={l('/products?categorySlug=women&query=T-shirt')} class="hover:text-brand-gold">{t('menu.women_tshirt')}</a></li>
                        <li><a href={l('/products?categorySlug=women&query=Polo')} class="hover:text-brand-gold">{t('menu.women_polo')}</a></li>
                        <li><a href={l('/products?categorySlug=women&query=Hoodie')} class="hover:text-brand-gold">{t('menu.women_hoodie')}</a></li>
                        <li><a href={l('/products?categorySlug=women&query=Jeans')} class="hover:text-brand-gold">{t('menu.women_jeans')}</a></li>
                        <li><a href={l('/products?categorySlug=women&query=Pants')} class="hover:text-brand-gold">{t('menu.women_pants')}</a></li>
                        <li><a href={l('/products?categorySlug=women&query=Shorts')} class="hover:text-brand-gold">{t('menu.women_shorts')}</a></li>
                        <li><a href={l('/products?categorySlug=women&query=Skirts')} class="hover:text-brand-gold">{t('menu.skirts')}</a></li>
                        <li><a href={l('/products?categorySlug=women&query=Bags')} class="hover:text-brand-gold">{t('menu.women_bags')}</a></li>
                      </ul>
                    </div>

                    <!-- Column 4: Featured -->
                    <div>
                      <h4 class="font-medium text-gray-400 text-[11px] uppercase tracking-wider mb-4 border-b border-gray-100 pb-2">{t('menu.featured')}</h4>
                      <ul class="space-y-3 text-[11px] tracking-widest text-gray-500 font-light uppercase">
                        <li><a href={l('/products/new-arrivals')} class="hover:text-brand-gold">{t('nav.new_arrivals')}</a></li>
                        <li><a href={l('/products/best-sellers')} class="hover:text-brand-gold">{t('menu.best_sellers')}</a></li>
                        <li><a href={l('/discount')} class="hover:text-brand-gold">{t('nav.discount')}</a></li>
                      </ul>
                    </div>

                    <!-- Column 5: Collections -->
                    <div>
                      <h4 class="font-medium text-gray-400 text-[11px] uppercase tracking-wider mb-4 border-b border-gray-100 pb-2">{t('menu.collections')}</h4>
                      <ul class="space-y-3 text-[11px] tracking-widest text-gray-500 font-light uppercase">
                        <li><a href={l('/collections')} class="hover:text-brand-gold">{t('menu.events')}</a></li>
                        <li><a href={l('/products/total-looks')} class="hover:text-brand-gold">{t('menu.total_looks')}</a></li>
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
              
              <a href={l('/collections')} class="hover:opacity-70 transition-opacity">{t('nav.collections')}</a>
              <a href={l('/blog')} class="hover:opacity-70 transition-opacity">{t('nav.blog')}</a>
              <a href={l('/contact')} class="hover:opacity-70 transition-opacity">{t('nav.contact')}</a>
            </>
          )}
        </nav>

        <!-- Right Side Icons -->
        <div class="flex items-center gap-6">
          <!-- Search Icon Button -->
          <button id="search-btn" class="hover:opacity-70 transition-opacity focus:outline-none cursor-pointer" aria-label="Search">
            <Search />
          </button>

          <!-- Favorite Icon Button -->
          <a href={l('/favorite')} class="hover:opacity-70 transition-opacity cursor-pointer relative" aria-label="Favorites" id="header-favorite-btn">
            <Heart />
            <span id="favorite-badge" class="absolute -top-1.5 -right-1.5 bg-brand-charcoal text-white text-[9px] w-4 h-4 rounded-full flex items-center justify-center font-semibold scale-0 transition-transform duration-300">0</span>
          </a>

          <!-- Cart Icon Button -->
          <a href={l('/cart')} class="hover:opacity-70 transition-opacity cursor-pointer relative" aria-label="Cart">
            <Cart />
            <span id="cart-badge" class={`absolute -top-1.5 -right-1.5 bg-brand-charcoal text-white text-[9px] w-4 h-4 rounded-full flex items-center justify-center font-semibold transition-transform duration-300 ${cartCount > 0 ? 'scale-100' : 'scale-0'}`}>{cartCount}</span>
          </a>

          <!-- Language Selector -->
          <button id="language-selector-btn" class="language-selector-btn hover:opacity-70 transition-opacity cursor-pointer flex items-center gap-1.5" aria-label="Language Selector">
            <Globe />
            <span class="text-[10px] tracking-widest font-light uppercase">{lang === 'en' ? 'EN' : 'TH'}</span>
          </button>

          {session ? (
            <a href={l('/profile')} class="hover:opacity-70 transition-opacity cursor-pointer" aria-label="Profile">
              <User />
            </a>
          ) : (
            <a href={l('/auth/signin')} class="text-[11px] tracking-widest hover:opacity-70 transition-opacity uppercase font-light">{t('nav.signin')}</a>
          )}
        </div>
      </div>
    </header>

    <!-- Mega Menu Backdrop -->
    <div id="mega-menu-backdrop" class="fixed inset-0 bg-black/10 backdrop-blur-sm z-40 hidden transition-all duration-300"></div>

    <!-- Main Content Area -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="w-full bg-white border-t border-gray-200 py-16 mt-20">
      <div class="max-w-[1440px] mx-auto px-6 flex flex-col items-center">
        <!-- Footer Logo -->
        <div class="flex flex-col items-center mb-12 text-center">
          <h4 class="font-serif text-3xl tracking-[0.3em] font-light leading-none pl-[0.3em]">A C H I</h4>
          <div class="w-36 border-t border-current opacity-30 my-1.5"></div>
          <span class="text-[9px] tracking-[0.4em] uppercase text-gray-400 font-light leading-none pl-[0.4em]">Cool Every Day</span>
        </div>

        <hr class="w-full border-gray-100 mb-12" />

        <!-- Footer Links Grid -->
        <div class="w-full grid grid-cols-2 md:grid-cols-4 gap-8 text-[11px] uppercase tracking-wider font-light mb-8">
          <!-- Col 1 -->
          <div>
            <h5 class="font-medium mb-4 text-brand-charcoal">{t('footer.company')}</h5>
            <ul class="space-y-2 text-gray-500">
              <li><a href={l('/about')} class="hover:text-brand-gold transition-colors">{t('footer.about')}</a></li>
            </ul>
          </div>

          <!-- Col 2 -->
          <div>
