          <a href={l('/cart')} class="hover:opacity-70 transition-opacity cursor-pointer relative" aria-label="Cart">
            <Cart />
            <span id="search-cart-badge" class={`absolute -top-1.5 -right-1.5 bg-brand-charcoal text-white text-[9px] w-4 h-4 rounded-full flex items-center justify-center font-semibold transition-transform duration-300 ${cartCount > 0 ? 'scale-100' : 'scale-0'}`}>{cartCount}</span>
